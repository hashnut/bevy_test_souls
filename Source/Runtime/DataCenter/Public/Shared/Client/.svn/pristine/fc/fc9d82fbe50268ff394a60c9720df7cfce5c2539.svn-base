		case BuddyTabType::RecvInvitation: return TEXT("");
	}
	return FString();
}

////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
// Validators
////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////

inline bool IsValidBuddyTabType(BuddyTabType value) noexcept
{
	return (value >= BuddyTabType::Buddy && value < BuddyTabType::MAX);
