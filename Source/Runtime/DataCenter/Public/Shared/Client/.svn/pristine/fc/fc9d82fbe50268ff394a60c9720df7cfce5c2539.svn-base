UENUM(BlueprintType)
// 친구 탭 타입
enum class BuddyTabType : uint8
{

	// 친구 목록 탭
	Buddy = 0,

	// 친구 수락 탭
	RecvInvitation = 1,

	MAX = 2,
};


////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
// String -> Enum
////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////

inline BuddyTabType BuddyTabTypeStringToEnum(const FString& str)
{
	if (str.Compare(TEXT("Buddy"), ESearchCase::IgnoreCase) == 0)	return BuddyTabType::Buddy;
	if (str.Compare(TEXT("RecvInvitation"), ESearchCase::IgnoreCase) == 0)	return BuddyTabType::RecvInvitation;
	return BuddyTabType::MAX;
}

////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
// Enum -> String
////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////

inline FString BuddyTabTypeEnumToString(BuddyTabType value)
{
	switch (value)
	{
		case BuddyTabType::Buddy: return TEXT("Buddy");
		case BuddyTabType::RecvInvitation: return TEXT("RecvInvitation");
	}
	return FString();
}

////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
