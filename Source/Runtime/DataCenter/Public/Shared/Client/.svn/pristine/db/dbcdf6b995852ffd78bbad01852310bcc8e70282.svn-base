// 캐릭터, 스킬 등의 위치 정보를 디버깅하기 위한 DebugShapeType
enum class DebugShapeType : uint8
{

	// 전달 패킷 : S_DEBUG_SHAPE_CYLINDER_LIST
	CYLINDER = 0,

	// 전달 패킷 : S_DEBUG_SHAPE
	SPHERE = 1,

	// 전달 패킷 : S_DEBUG_SHAPE
	FAN = 2,

	// 전달 패킷 : S_DEBUG_SHAPE_LINE
	LINE = 3,

	MAX = 4,
};


////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
// String -> Enum
////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////

inline DebugShapeType DebugShapeTypeStringToEnum(const FString& str)
{
	if (str.Compare(TEXT("CYLINDER"), ESearchCase::IgnoreCase) == 0)	return DebugShapeType::CYLINDER;
	if (str.Compare(TEXT("SPHERE"), ESearchCase::IgnoreCase) == 0)	return DebugShapeType::SPHERE;
	if (str.Compare(TEXT("FAN"), ESearchCase::IgnoreCase) == 0)	return DebugShapeType::FAN;
	if (str.Compare(TEXT("LINE"), ESearchCase::IgnoreCase) == 0)	return DebugShapeType::LINE;
	return DebugShapeType::MAX;
}

////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
// Enum -> String
////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////

inline FString DebugShapeTypeEnumToString(DebugShapeType value)
{
	switch (value)
	{
		case DebugShapeType::CYLINDER: return TEXT("CYLINDER");
		case DebugShapeType::SPHERE: return TEXT("SPHERE");
		case DebugShapeType::FAN: return TEXT("FAN");
		case DebugShapeType::LINE: return TEXT("LINE");
	}
	return FString();
}

