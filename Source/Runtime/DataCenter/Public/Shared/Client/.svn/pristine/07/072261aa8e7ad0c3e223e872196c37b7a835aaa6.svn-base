////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
// Validators
////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////

inline bool IsValidMailBoxType(MailBoxType value) noexcept
{
	return (value >= MailBoxType::USER && value < MailBoxType::MAX);
}

inline bool IsValidMailAttachmentType(MailAttachmentType value) noexcept
{
	return (value >= MailAttachmentType::NONE && value < MailAttachmentType::MAX);
}

inline bool IsValidMailCategoryMain(MailCategoryMain value) noexcept
{
	return (value >= MailCategoryMain::Event && value < MailCategoryMain::MAX);
}

inline bool IsValidMailCategorySub(MailCategorySub value) noexcept
{
	return (value >= MailCategorySub::Event_Daily && value < MailCategorySub::MAX);
}

