inline MailBoxType MailBoxTypeStringToEnum(const FString& str)
{
	if (str.Compare(TEXT("USER"), ESearchCase::IgnoreCase) == 0)	return MailBoxType::USER;
	if (str.Compare(TEXT("GUILD"), ESearchCase::IgnoreCase) == 0)	return MailBoxType::GUILD;
	if (str.Compare(TEXT("ACCOUNT"), ESearchCase::IgnoreCase) == 0)	return MailBoxType::ACCOUNT;
	return MailBoxType::MAX;
}
