UENUM(BlueprintType)
// 앱가드 활성화 모드
enum class AppGuardActiveMode : uint8
{

	// 비활성화
	IN_ACTIVATE = 0,

	// 테스트 모드 활성화
	ACTIVATE_TEST = 1,

	// 라이브 모드 활성화
	ACTIVATE = 2,

	MAX = 3,
};


////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
// String -> Enum
////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////

inline AppGuardActiveMode AppGuardActiveModeStringToEnum(const FString& str)
{
	if (str.Compare(TEXT("IN_ACTIVATE"), ESearchCase::IgnoreCase) == 0)	return AppGuardActiveMode::IN_ACTIVATE;
	if (str.Compare(TEXT("ACTIVATE_TEST"), ESearchCase::IgnoreCase) == 0)	return AppGuardActiveMode::ACTIVATE_TEST;
	if (str.Compare(TEXT("ACTIVATE"), ESearchCase::IgnoreCase) == 0)	return AppGuardActiveMode::ACTIVATE;
	return AppGuardActiveMode::MAX;
}

////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
// Enum -> String
////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////

inline FString AppGuardActiveModeEnumToString(AppGuardActiveMode value)
{
	switch (value)
	{
		case AppGuardActiveMode::IN_ACTIVATE: return TEXT("IN_ACTIVATE");
		case AppGuardActiveMode::ACTIVATE_TEST: return TEXT("ACTIVATE_TEST");
		case AppGuardActiveMode::ACTIVATE: return TEXT("ACTIVATE");
	}
	return FString();
}

