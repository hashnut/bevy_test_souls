////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
// Enums
////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////

UENUM(BlueprintType)
// 공지 타입
enum class NoticeType : uint8
{

	// 긴급공지
	Urgent = 0,

	// 일반공지 - 일반적인 공지 및 정기적인 공지 발송
	General = 1,

	// 이벤트공지 - 이벤트 안내
	Event = 2,

	// 임시공지 - 임시 안내를 위해 활용
	Immediate = 3,

	// 특별공지 - 패치에 대한 안내 및 특별 상황에 대한 안내를 위해 활용
	Special = 4,

	MAX = 5,
};


////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
// String -> Enum
////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////

inline NoticeType NoticeTypeStringToEnum(const FString& str)
{
	if (str.Compare(TEXT("Urgent"), ESearchCase::IgnoreCase) == 0)	return NoticeType::Urgent;
	if (str.Compare(TEXT("General"), ESearchCase::IgnoreCase) == 0)	return NoticeType::General;
	if (str.Compare(TEXT("Event"), ESearchCase::IgnoreCase) == 0)	return NoticeType::Event;
	if (str.Compare(TEXT("Immediate"), ESearchCase::IgnoreCase) == 0)	return NoticeType::Immediate;
	if (str.Compare(TEXT("Special"), ESearchCase::IgnoreCase) == 0)	return NoticeType::Special;
	return NoticeType::MAX;
}

////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
// Enum -> String
////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////

inline FString NoticeTypeEnumToString(NoticeType value)
{
	switch (value)
	{
		case NoticeType::Urgent: return TEXT("Urgent");
		case NoticeType::General: return TEXT("General");
		case NoticeType::Event: return TEXT("Event");
		case NoticeType::Immediate: return TEXT("Immediate");
		case NoticeType::Special: return TEXT("Special");
	}
	return FString();
}

////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
// Enum -> DisplayKey (클라이언트 로컬라이징 번역 키를 처리하기 위해 활용)
////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////

inline FString NoticeTypeEnumToDisplayKey(NoticeType value)
{
	switch (value)
	{
		case NoticeType::Urgent: return TEXT("");
		case NoticeType::General: return TEXT("");
		case NoticeType::Event: return TEXT("");
		case NoticeType::Immediate: return TEXT("");
		case NoticeType::Special: return TEXT("");
	}
	return FString();
}

////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
// Validators
////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////

inline bool IsValidNoticeType(NoticeType value) noexcept
{
	return (value >= NoticeType::Urgent && value < NoticeType::MAX);
}

