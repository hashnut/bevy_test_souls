////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
// Enum -> String
////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////

inline FString EGsOptionItemEnumToString(EGsOptionItem value)
{
	switch (value)
	{
		case EGsOptionItem::None: return TEXT("None");
		case EGsOptionItem::Resolution: return TEXT("Resolution");
		case EGsOptionItem::FrameRate: return TEXT("FrameRate");
		case EGsOptionItem::AutoTuning: return TEXT("AutoTuning");
		case EGsOptionItem::ViewDistance: return TEXT("ViewDistance");
		case EGsOptionItem::PostProcess: return TEXT("PostProcess");
		case EGsOptionItem::Shadow: return TEXT("Shadow");
		case EGsOptionItem::Effect: return TEXT("Effect");
		case EGsOptionItem::Texture: return TEXT("Texture");
		case EGsOptionItem::Foliage: return TEXT("Foliage");
		case EGsOptionItem::SSAO: return TEXT("SSAO");
		case EGsOptionItem::Outline: return TEXT("Outline");
		case EGsOptionItem::MasterOn: return TEXT("MasterOn");
		case EGsOptionItem::MasterVolume: return TEXT("MasterVolume");
		case EGsOptionItem::BgmOn: return TEXT("BgmOn");
		case EGsOptionItem::BgmVolume: return TEXT("BgmVolume");
		case EGsOptionItem::EffectOn: return TEXT("EffectOn");
		case EGsOptionItem::EffectVolume: return TEXT("EffectVolume");
		case EGsOptionItem::HpPotionAotoRate: return TEXT("HpPotionAotoRate");
		case EGsOptionItem::MpPotionAotoRate: return TEXT("MpPotionAotoRate");
		case EGsOptionItem::PotionPriority: return TEXT("PotionPriority");
		case EGsOptionItem::AutoCombatGrade: return TEXT("AutoCombatGrade");
		case EGsOptionItem::MannerMode: return TEXT("MannerMode");
		case EGsOptionItem::ItemLootGrade: return TEXT("ItemLootGrade");
		case EGsOptionItem::HpRateAlertLevel: return TEXT("HpRateAlertLevel");
		case EGsOptionItem::PvpAttackedAlert: return TEXT("PvpAttackedAlert");
		case EGsOptionItem::AutoLogin: return TEXT("AutoLogin");
		case EGsOptionItem::DisableDistortion: return TEXT("DisableDistortion");
		case EGsOptionItem::TerrainNormalDistance: return TEXT("TerrainNormalDistance");
		case EGsOptionItem::AutoBattleRange: return TEXT("AutoBattleRange");
		case EGsOptionItem::AutoHPPortionUseRate: return TEXT("AutoHPPortionUseRate");
		case EGsOptionItem::AutoDropItemRootMinimalGrade: return TEXT("AutoDropItemRootMinimalGrade");
		case EGsOptionItem::EmptySpace: return TEXT("EmptySpace");
		case EGsOptionItem::DevideLine: return TEXT("DevideLine");
		case EGsOptionItem::AutoSearchMainDesc: return TEXT("AutoSearchMainDesc");
		case EGsOptionItem::AutoSearchSubDesc: return TEXT("AutoSearchSubDesc");
		case EGsOptionItem::AutoSearch: return TEXT("AutoSearch");
