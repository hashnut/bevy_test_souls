////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
// String -> Enum
////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////

inline EGsOptionItem EGsOptionItemStringToEnum(const FString& str)
{
	if (str.Compare(TEXT("None"), ESearchCase::IgnoreCase) == 0)	return EGsOptionItem::None;
	if (str.Compare(TEXT("Resolution"), ESearchCase::IgnoreCase) == 0)	return EGsOptionItem::Resolution;
	if (str.Compare(TEXT("FrameRate"), ESearchCase::IgnoreCase) == 0)	return EGsOptionItem::FrameRate;
	if (str.Compare(TEXT("AutoTuning"), ESearchCase::IgnoreCase) == 0)	return EGsOptionItem::AutoTuning;
	if (str.Compare(TEXT("ViewDistance"), ESearchCase::IgnoreCase) == 0)	return EGsOptionItem::ViewDistance;
	if (str.Compare(TEXT("PostProcess"), ESearchCase::IgnoreCase) == 0)	return EGsOptionItem::PostProcess;
	if (str.Compare(TEXT("Shadow"), ESearchCase::IgnoreCase) == 0)	return EGsOptionItem::Shadow;
	if (str.Compare(TEXT("Effect"), ESearchCase::IgnoreCase) == 0)	return EGsOptionItem::Effect;
	if (str.Compare(TEXT("Texture"), ESearchCase::IgnoreCase) == 0)	return EGsOptionItem::Texture;
	if (str.Compare(TEXT("Foliage"), ESearchCase::IgnoreCase) == 0)	return EGsOptionItem::Foliage;
	if (str.Compare(TEXT("SSAO"), ESearchCase::IgnoreCase) == 0)	return EGsOptionItem::SSAO;
	if (str.Compare(TEXT("Outline"), ESearchCase::IgnoreCase) == 0)	return EGsOptionItem::Outline;
	if (str.Compare(TEXT("MasterOn"), ESearchCase::IgnoreCase) == 0)	return EGsOptionItem::MasterOn;
	if (str.Compare(TEXT("MasterVolume"), ESearchCase::IgnoreCase) == 0)	return EGsOptionItem::MasterVolume;
	if (str.Compare(TEXT("BgmOn"), ESearchCase::IgnoreCase) == 0)	return EGsOptionItem::BgmOn;
	if (str.Compare(TEXT("BgmVolume"), ESearchCase::IgnoreCase) == 0)	return EGsOptionItem::BgmVolume;
	if (str.Compare(TEXT("EffectOn"), ESearchCase::IgnoreCase) == 0)	return EGsOptionItem::EffectOn;
	if (str.Compare(TEXT("EffectVolume"), ESearchCase::IgnoreCase) == 0)	return EGsOptionItem::EffectVolume;
	if (str.Compare(TEXT("HpPotionAotoRate"), ESearchCase::IgnoreCase) == 0)	return EGsOptionItem::HpPotionAotoRate;
	if (str.Compare(TEXT("MpPotionAotoRate"), ESearchCase::IgnoreCase) == 0)	return EGsOptionItem::MpPotionAotoRate;
	if (str.Compare(TEXT("PotionPriority"), ESearchCase::IgnoreCase) == 0)	return EGsOptionItem::PotionPriority;
