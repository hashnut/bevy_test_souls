		case EGsOptionItem::OptionAutoDecomposeSlateNormal: return TEXT("");
		case EGsOptionItem::OptionAutoDecomposeSlateMagic: return TEXT("");
		case EGsOptionItem::OptionAutoDecomposeSlateRare: return TEXT("");
		case EGsOptionItem::OptionAutoDecomposeEquip: return TEXT("");
		case EGsOptionItem::OptionAutoDecomposeSkillBook: return TEXT("");
		case EGsOptionItem::OptionAutoDecomposeSlate: return TEXT("");
		case EGsOptionItem::AutoDecomposeMainDesc: return TEXT("");
		case EGsOptionItem::ItemSlotExpansion: return TEXT("");
		case EGsOptionItem::OtherPCRendering: return TEXT("");
	}
	return FString();
}

////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
// Validators
////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////

inline bool IsValidEGsOptionItem(EGsOptionItem value) noexcept
{
	return (value >= EGsOptionItem::None && value < EGsOptionItem::MAX);
}

