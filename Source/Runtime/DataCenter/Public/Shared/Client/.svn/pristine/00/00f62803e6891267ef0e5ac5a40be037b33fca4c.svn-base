	// 침공 채팅
	INVADE = 7,

	// 귓속말
	WHISPER = 8,

	// 인터 서버 채팅
	INTER = 9,

	// 동맹 채팅
	ALLY = 10,

	// 그룹 채팅
	GROUP = 11,

	MAX = 12,
};

