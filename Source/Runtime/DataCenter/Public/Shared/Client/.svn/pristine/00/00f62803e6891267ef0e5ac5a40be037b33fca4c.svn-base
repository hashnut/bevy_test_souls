inline ChatType ChatTypeStringToEnum(const FString& str)
{
	if (str.Compare(TEXT("NONE"), ESearchCase::IgnoreCase) == 0)	return ChatType::NONE;
	if (str.Compare(TEXT("WORLD"), ESearchCase::IgnoreCase) == 0)	return ChatType::WORLD;
	if (str.Compare(TEXT("MAP"), ESearchCase::IgnoreCase) == 0)	return ChatType::MAP;
	if (str.Compare(TEXT("NORMAL"), ESearchCase::IgnoreCase) == 0)	return ChatType::NORMAL;
	if (str.Compare(TEXT("PARTY"), ESearchCase::IgnoreCase) == 0)	return ChatType::PARTY;
	if (str.Compare(TEXT("EMOTICON"), ESearchCase::IgnoreCase) == 0)	return ChatType::EMOTICON;
	if (str.Compare(TEXT("GUILD"), ESearchCase::IgnoreCase) == 0)	return ChatType::GUILD;
	if (str.Compare(TEXT("INVADE"), ESearchCase::IgnoreCase) == 0)	return ChatType::INVADE;
	if (str.Compare(TEXT("WHISPER"), ESearchCase::IgnoreCase) == 0)	return ChatType::WHISPER;
	if (str.Compare(TEXT("INTER"), ESearchCase::IgnoreCase) == 0)	return ChatType::INTER;
	if (str.Compare(TEXT("ALLY"), ESearchCase::IgnoreCase) == 0)	return ChatType::ALLY;
	if (str.Compare(TEXT("GROUP"), ESearchCase::IgnoreCase) == 0)	return ChatType::GROUP;
	return ChatType::MAX;
}
