////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
// Validators
////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////

inline bool IsValidChatType(ChatType value) noexcept
{
	return (value >= ChatType::NONE && value < ChatType::MAX);
}

inline bool IsValidGroupMessageType(GroupMessageType value) noexcept
{
	return (value >= GroupMessageType::NONE && value < GroupMessageType::MAX);
}

inline bool IsValidGuildGroupChatCommandType(GuildGroupChatCommandType value) noexcept
{
	return (value >= GuildGroupChatCommandType::NONE && value < GuildGroupChatCommandType::MAX);
}

