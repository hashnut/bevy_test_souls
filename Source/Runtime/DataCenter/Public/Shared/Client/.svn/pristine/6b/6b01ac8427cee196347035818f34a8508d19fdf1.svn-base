UENUM(BlueprintType)
// Prop의 Interaction type
enum class PropInteractionType : uint8
{

	// Default
	NONE = 0,

	// PROP 오브젝트 터치를 통한 인터렉션
	TOUCH = 1,

	MAX = 2,
};


////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
// String -> Enum
////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////

inline PropInteractionType PropInteractionTypeStringToEnum(const FString& str)
{
	if (str.Compare(TEXT("NONE"), ESearchCase::IgnoreCase) == 0)	return PropInteractionType::NONE;
	if (str.Compare(TEXT("TOUCH"), ESearchCase::IgnoreCase) == 0)	return PropInteractionType::TOUCH;
	return PropInteractionType::MAX;
}

////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
// Enum -> String
////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////

inline FString PropInteractionTypeEnumToString(PropInteractionType value)
{
	switch (value)
	{
		case PropInteractionType::NONE: return TEXT("NONE");
		case PropInteractionType::TOUCH: return TEXT("TOUCH");
	}
	return FString();
}

////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
// Enum -> DisplayKey (클라이언트 로컬라이징 번역 키를 처리하기 위해 활용)
////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////

inline FString PropInteractionTypeEnumToDisplayKey(PropInteractionType value)
{
	switch (value)
	{
		case PropInteractionType::NONE: return TEXT("");
		case PropInteractionType::TOUCH: return TEXT("");
	}
	return FString();
}

////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
// Validators
////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////

inline bool IsValidPropInteractionType(PropInteractionType value) noexcept
{
	return (value >= PropInteractionType::NONE && value < PropInteractionType::MAX);
}

