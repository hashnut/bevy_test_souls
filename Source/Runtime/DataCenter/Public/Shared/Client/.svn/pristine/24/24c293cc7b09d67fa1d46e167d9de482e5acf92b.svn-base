inline FString StatUpdateReasonEnumToDisplayKey(StatUpdateReason value)
{
	switch (value)
	{
		case StatUpdateReason::NONE: return TEXT("");
		case StatUpdateReason::ABNORMALITY: return TEXT("");
		case StatUpdateReason::PASSIVITY: return TEXT("");
		case StatUpdateReason::USER_LEVEL_UP: return TEXT("");
		case StatUpdateReason::USER_LEVEL_DOWN: return TEXT("");
		case StatUpdateReason::USER_BONUS_STAT_DISTRIBUTE: return TEXT("");
		case StatUpdateReason::USER_BONUS_STAT_RESET: return TEXT("");
		case StatUpdateReason::USER_TRANSFORM: return TEXT("");
		case StatUpdateReason::ITEM_EQUIP: return TEXT("");
		case StatUpdateReason::ITEM_COLLECTION: return TEXT("");
		case StatUpdateReason::ITEM_ENCHANT: return TEXT("");
		case StatUpdateReason::FAIRY_EQUIP: return TEXT("");
		case StatUpdateReason::FAIRY_COLLECTION: return TEXT("");
		case StatUpdateReason::COSTUME_EQUIP: return TEXT("");
		case StatUpdateReason::COSTUME_COLLECTION: return TEXT("");
		case StatUpdateReason::GUILD: return TEXT("");
		case StatUpdateReason::SEAL_UPDATE: return TEXT("");
		case StatUpdateReason::MONSTER_KNOWLEDGE_UPDATE: return TEXT("");
		case StatUpdateReason::TITLE_UPDATE: return TEXT("");
		case StatUpdateReason::MULTI_LEVEL_RANK_UPDATE: return TEXT("");
		case StatUpdateReason::SPIRIT_SHOT_ENCHANT: return TEXT("");
		case StatUpdateReason::PRESET_CHANGE: return TEXT("");
		case StatUpdateReason::SLATE_SPECIAL_NODE_ACTIVATE: return TEXT("");
		case StatUpdateReason::CODEX_CATEGORY_LEVEL_UP: return TEXT("");
		case StatUpdateReason::ITEM_MAGICAL_FORGE: return TEXT("");
		case StatUpdateReason::SANCTUM_NEXUS: return TEXT("");
	}
	return FString();
}

////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
// Validators
////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////

inline bool IsValidStatType(StatType value) noexcept
{
	return (value >= StatType::NONE && value < StatType::MAX);
}

inline bool IsValidStatUpdateReason(StatUpdateReason value) noexcept
{
	return (value >= StatUpdateReason::NONE && value < StatUpdateReason::MAX);
}

