inline FString StatUpdateReasonEnumToString(StatUpdateReason value)
{
	switch (value)
	{
		case StatUpdateReason::NONE: return TEXT("NONE");
		case StatUpdateReason::ABNORMALITY: return TEXT("ABNORMALITY");
		case StatUpdateReason::PASSIVITY: return TEXT("PASSIVITY");
		case StatUpdateReason::USER_LEVEL_UP: return TEXT("USER_LEVEL_UP");
		case StatUpdateReason::USER_LEVEL_DOWN: return TEXT("USER_LEVEL_DOWN");
		case StatUpdateReason::USER_BONUS_STAT_DISTRIBUTE: return TEXT("USER_BONUS_STAT_DISTRIBUTE");
		case StatUpdateReason::USER_BONUS_STAT_RESET: return TEXT("USER_BONUS_STAT_RESET");
		case StatUpdateReason::USER_TRANSFORM: return TEXT("USER_TRANSFORM");
		case StatUpdateReason::ITEM_EQUIP: return TEXT("ITEM_EQUIP");
		case StatUpdateReason::ITEM_COLLECTION: return TEXT("ITEM_COLLECTION");
		case StatUpdateReason::ITEM_ENCHANT: return TEXT("ITEM_ENCHANT");
		case StatUpdateReason::FAIRY_EQUIP: return TEXT("FAIRY_EQUIP");
		case StatUpdateReason::FAIRY_COLLECTION: return TEXT("FAIRY_COLLECTION");
		case StatUpdateReason::COSTUME_EQUIP: return TEXT("COSTUME_EQUIP");
		case StatUpdateReason::COSTUME_COLLECTION: return TEXT("COSTUME_COLLECTION");
		case StatUpdateReason::GUILD: return TEXT("GUILD");
		case StatUpdateReason::SEAL_UPDATE: return TEXT("SEAL_UPDATE");
		case StatUpdateReason::MONSTER_KNOWLEDGE_UPDATE: return TEXT("MONSTER_KNOWLEDGE_UPDATE");
		case StatUpdateReason::TITLE_UPDATE: return TEXT("TITLE_UPDATE");
		case StatUpdateReason::MULTI_LEVEL_RANK_UPDATE: return TEXT("MULTI_LEVEL_RANK_UPDATE");
		case StatUpdateReason::SPIRIT_SHOT_ENCHANT: return TEXT("SPIRIT_SHOT_ENCHANT");
		case StatUpdateReason::PRESET_CHANGE: return TEXT("PRESET_CHANGE");
		case StatUpdateReason::SLATE_SPECIAL_NODE_ACTIVATE: return TEXT("SLATE_SPECIAL_NODE_ACTIVATE");
		case StatUpdateReason::CODEX_CATEGORY_LEVEL_UP: return TEXT("CODEX_CATEGORY_LEVEL_UP");
