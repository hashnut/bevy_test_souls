////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
// String -> Enum
////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////

inline StatType StatTypeStringToEnum(const FString& str)
{
	if (str.Compare(TEXT("NONE"), ESearchCase::IgnoreCase) == 0)	return StatType::NONE;
	if (str.Compare(TEXT("HP"), ESearchCase::IgnoreCase) == 0)	return StatType::HP;
	if (str.Compare(TEXT("MP"), ESearchCase::IgnoreCase) == 0)	return StatType::MP;
	if (str.Compare(TEXT("WEIGHT"), ESearchCase::IgnoreCase) == 0)	return StatType::WEIGHT;
	if (str.Compare(TEXT("SENSITIVE"), ESearchCase::IgnoreCase) == 0)	return StatType::SENSITIVE;
	if (str.Compare(TEXT("COMBAT_POWER"), ESearchCase::IgnoreCase) == 0)	return StatType::COMBAT_POWER;
