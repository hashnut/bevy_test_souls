inline StatUpdateReason StatUpdateReasonStringToEnum(const FString& str)
{
	if (str.Compare(TEXT("NONE"), ESearchCase::IgnoreCase) == 0)	return StatUpdateReason::NONE;
	if (str.Compare(TEXT("ABNORMALITY"), ESearchCase::IgnoreCase) == 0)	return StatUpdateReason::ABNORMALITY;
	if (str.Compare(TEXT("PASSIVITY"), ESearchCase::IgnoreCase) == 0)	return StatUpdateReason::PASSIVITY;
	if (str.Compare(TEXT("USER_LEVEL_UP"), ESearchCase::IgnoreCase) == 0)	return StatUpdateReason::USER_LEVEL_UP;
	if (str.Compare(TEXT("USER_LEVEL_DOWN"), ESearchCase::IgnoreCase) == 0)	return StatUpdateReason::USER_LEVEL_DOWN;
	if (str.Compare(TEXT("USER_BONUS_STAT_DISTRIBUTE"), ESearchCase::IgnoreCase) == 0)	return StatUpdateReason::USER_BONUS_STAT_DISTRIBUTE;
	if (str.Compare(TEXT("USER_BONUS_STAT_RESET"), ESearchCase::IgnoreCase) == 0)	return StatUpdateReason::USER_BONUS_STAT_RESET;
	if (str.Compare(TEXT("USER_TRANSFORM"), ESearchCase::IgnoreCase) == 0)	return StatUpdateReason::USER_TRANSFORM;
	if (str.Compare(TEXT("ITEM_EQUIP"), ESearchCase::IgnoreCase) == 0)	return StatUpdateReason::ITEM_EQUIP;
	if (str.Compare(TEXT("ITEM_COLLECTION"), ESearchCase::IgnoreCase) == 0)	return StatUpdateReason::ITEM_COLLECTION;
	if (str.Compare(TEXT("ITEM_ENCHANT"), ESearchCase::IgnoreCase) == 0)	return StatUpdateReason::ITEM_ENCHANT;
	if (str.Compare(TEXT("FAIRY_EQUIP"), ESearchCase::IgnoreCase) == 0)	return StatUpdateReason::FAIRY_EQUIP;
	if (str.Compare(TEXT("FAIRY_COLLECTION"), ESearchCase::IgnoreCase) == 0)	return StatUpdateReason::FAIRY_COLLECTION;
	if (str.Compare(TEXT("COSTUME_EQUIP"), ESearchCase::IgnoreCase) == 0)	return StatUpdateReason::COSTUME_EQUIP;
	if (str.Compare(TEXT("COSTUME_COLLECTION"), ESearchCase::IgnoreCase) == 0)	return StatUpdateReason::COSTUME_COLLECTION;
	if (str.Compare(TEXT("GUILD"), ESearchCase::IgnoreCase) == 0)	return StatUpdateReason::GUILD;
	if (str.Compare(TEXT("SEAL_UPDATE"), ESearchCase::IgnoreCase) == 0)	return StatUpdateReason::SEAL_UPDATE;
	if (str.Compare(TEXT("MONSTER_KNOWLEDGE_UPDATE"), ESearchCase::IgnoreCase) == 0)	return StatUpdateReason::MONSTER_KNOWLEDGE_UPDATE;
	if (str.Compare(TEXT("TITLE_UPDATE"), ESearchCase::IgnoreCase) == 0)	return StatUpdateReason::TITLE_UPDATE;
	if (str.Compare(TEXT("MULTI_LEVEL_RANK_UPDATE"), ESearchCase::IgnoreCase) == 0)	return StatUpdateReason::MULTI_LEVEL_RANK_UPDATE;
	if (str.Compare(TEXT("SPIRIT_SHOT_ENCHANT"), ESearchCase::IgnoreCase) == 0)	return StatUpdateReason::SPIRIT_SHOT_ENCHANT;
	if (str.Compare(TEXT("PRESET_CHANGE"), ESearchCase::IgnoreCase) == 0)	return StatUpdateReason::PRESET_CHANGE;
	if (str.Compare(TEXT("SLATE_SPECIAL_NODE_ACTIVATE"), ESearchCase::IgnoreCase) == 0)	return StatUpdateReason::SLATE_SPECIAL_NODE_ACTIVATE;
	if (str.Compare(TEXT("CODEX_CATEGORY_LEVEL_UP"), ESearchCase::IgnoreCase) == 0)	return StatUpdateReason::CODEX_CATEGORY_LEVEL_UP;
	if (str.Compare(TEXT("ITEM_MAGICAL_FORGE"), ESearchCase::IgnoreCase) == 0)	return StatUpdateReason::ITEM_MAGICAL_FORGE;
	if (str.Compare(TEXT("SANCTUM_NEXUS"), ESearchCase::IgnoreCase) == 0)	return StatUpdateReason::SANCTUM_NEXUS;
	return StatUpdateReason::MAX;
}

