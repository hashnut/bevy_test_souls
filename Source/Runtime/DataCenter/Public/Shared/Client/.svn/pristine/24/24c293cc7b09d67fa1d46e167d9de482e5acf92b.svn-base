	if (str.Compare(TEXT("AGI"), ESearchCase::IgnoreCase) == 0)	return StatType::AGI;
	if (str.Compare(TEXT("WIS"), ESearchCase::IgnoreCase) == 0)	return StatType::WIS;
	if (str.Compare(TEXT("CON"), ESearchCase::IgnoreCase) == 0)	return StatType::CON;
