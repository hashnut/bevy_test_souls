		mNowBlockList = newBlockList;
		mPktWriter.Skip(sizeof(BlockList));
		mNowBlockList->SetMarketPIdOffset((uint16)mPktWriter.GetPktSize());
		mPktWriter.WriteString(marketPId);
		return BlockListHandle(mPktWriter, newBlockList);
