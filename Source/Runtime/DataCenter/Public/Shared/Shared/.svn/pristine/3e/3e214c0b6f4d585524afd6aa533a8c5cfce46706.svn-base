static constexpr int AFTER_CLEAR_GUILD_DUNGEON_TICK = 20;	// 20초 후 다 쫓는다

//영지 공략 던전 클리어 후 20초뒤 유저 쫓아낸다
static constexpr int AFTER_CLEAR_AGIT_DUNGEON_RAID_TICK = 20;	// 20초 후 다 쫓는다

//기사단 권한별 등급 값. 
//여러가지 권한을 가질 수 있으니 bitflag 로 합니다.
//GuildRightsLevel  == unint32//
static constexpr uint32 GUILD_RIGHTS_LEVEL_NONE					= 0b0000'0000'0000'0000;//없다
static constexpr uint32 GUILD_RIGHTS_LEVEL_DIPLOMACY			= 0b0000'0000'0000'0001;//기사단 외교 권한
static constexpr uint32 GUILD_RIGHTS_LEVEL_GUILD_STORE			= 0b0000'0000'0000'0010;//기사단 창고 권한
static constexpr uint32 GUILD_RIGHTS_LEVEL_GUILD_CAMP			= 0b0000'0000'0000'0100;//기사단 수호탑 권한
static constexpr uint32 GUILD_RIGHTS_LEVEL_MEMBER_MANAGEMENT	= 0b0000'0000'0000'1000;//기사단 단원관리
static constexpr uint32 GUILD_RIGHTS_LEVEL_POST_MANAGEMENT		= 0b0000'0000'0001'0000;//기사단 게시관리
static constexpr uint32 GUILD_RIGHTS_LEVEL_BUILDING_MANAGEMENT	= 0b0000'0000'0010'0000;//기사단 운영


//기사 단장은 모든권한
static constexpr uint32 GUILD_RIGHTS_LEVEL_MASTER = GUILD_RIGHTS_LEVEL_GUILD_STORE | GUILD_RIGHTS_LEVEL_DIPLOMACY
| GUILD_RIGHTS_LEVEL_GUILD_CAMP | GUILD_RIGHTS_LEVEL_MEMBER_MANAGEMENT
| GUILD_RIGHTS_LEVEL_POST_MANAGEMENT | GUILD_RIGHTS_LEVEL_BUILDING_MANAGEMENT;

inline constexpr bool IsRightsLevel(uint32 rightsLevel, uint32 rights )
{
	return(rights & rightsLevel);
}

