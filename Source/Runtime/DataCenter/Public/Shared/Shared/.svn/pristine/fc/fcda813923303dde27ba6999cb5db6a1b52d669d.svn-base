		case 13986: return L"SC_ACK_PERSONAL_TRADING_CANCEL";
		case 13987: return L"SC_NOTIFY_SHARED_BOOKMARK";
		case 13988: return L"SC_USER_LOOK_INFO_CHANGED";
		case 13990: return L"SC_ACK_QUEST_SUB_ACCEPT";
		case 13991: return L"SC_BATTLE_PASS_EXPOSE";
		case 13992: return L"SC_NOTIFY_PARTY_TARGET_CANCEL";
		case 13993: return L"SC_ACK_MARKET_TRANSACTION_CANCEL";
		case 13994: return L"SC_ITEM_USE_DELIVERY_BOX_COSTUME_COMPOSE";
		case 13995: return L"SC_INFORM_GUILD_STORE_ACQUIRED_ITEM";
		case 13997: return L"SC_INFORM_CHANGED_GUILD_EMBLEM";
	}
	return L"";
}

