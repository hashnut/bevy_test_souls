// String -> Enum
////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////

inline uint16 CGPacketIdStringToEnum(const wchar_t* str) noexcept
{
	if (_wcsicmp(L"CG_PING", str) == 0)	return CG_PING;
	if (_wcsicmp(L"CG_SERVER_PONG", str) == 0)	return CG_SERVER_PONG;
	if (_wcsicmp(L"CG_REQ_LOGIN", str) == 0)	return CG_REQ_LOGIN;
