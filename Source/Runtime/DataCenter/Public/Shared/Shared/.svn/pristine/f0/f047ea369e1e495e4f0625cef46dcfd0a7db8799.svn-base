	const wchar_t* GetPacketName() const { return L"CG_REQ_CHAT_WHISPER_V2"; }
	const wchar_t* GetRelatedPacketName() const { return L"GC_ACK_CHAT_WHISPER_V2"; }
#endif

	WorldId WorldId() { return mWorldId; }
#ifdef _SERVER
	const wchar_t* UserName() const
	{
		uchar* pktStart = (uchar*)this;
		uint16 pktSize = *((uint16*)pktStart);
		if (mUserNameOffset && pktSize > mUserNameOffset)
			return (const wchar_t*)(pktStart + mUserNameOffset);
		else
			return L"";
	}
#else // _SERVER
	const FString UserName()
	{
		const wchar_t* strWchar = L"";
		uchar* pktStart = (uchar*)this;
		uint16 pktSize = *((uint16*)pktStart);
		if (mUserNameOffset && pktSize > mUserNameOffset)
			strWchar = (const wchar_t*)(pktStart + mUserNameOffset);

		return PktWriter::ConvertToFString(strWchar);
	}
#endif // _SERVER
#ifdef _SERVER
	const wchar_t* Message() const
	{
		uchar* pktStart = (uchar*)this;
		uint16 pktSize = *((uint16*)pktStart);
		if (mMessageOffset && pktSize > mMessageOffset)
			return (const wchar_t*)(pktStart + mMessageOffset);
		else
			return L"";
	}
#else // _SERVER
