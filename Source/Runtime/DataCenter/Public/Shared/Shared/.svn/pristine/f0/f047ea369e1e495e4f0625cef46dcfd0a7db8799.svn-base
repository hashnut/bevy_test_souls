		mPktWriter << (uint16)CG_REQ_GUILDWAR_RANK_INFO;
		mReqRankIndexListOffset = (uint16*)mPktWriter.GetBuffer();
		*mReqRankIndexListOffset = 0;
		mPktWriter << (*mReqRankIndexListOffset);
		mReqRankIndexListSize = (uint16*)mPktWriter.GetBuffer();
		*mReqRankIndexListSize = 0;
		mPktWriter << (*mReqRankIndexListSize);
		mPktWriter << tierId;
		*mReqRankIndexListOffset = (uint16)mPktWriter.GetPktSize();
		if (reqRankIndexList && !reqRankIndexList->empty())
		{
			int tvalsize = (int)sizeof(*(reqRankIndexList->begin())); 
			auto _reqRankIndexList = const_cast<std::decay_t<T0>*>(reqRankIndexList);
			for (auto it = _reqRankIndexList->begin(); it != _reqRankIndexList->end(); ++it) 
			{
				mPktWriter.WriteBinary((uint16)tvalsize, (uchar*)&(*it)); 
			}
			*mReqRankIndexListSize = (uint16) (tvalsize * reqRankIndexList->size());
		}
	}
