// type = CG
// related packet = PKT_GC_ACK_GUILD_STORE_ITEM_AUCTION_REGISTER_WRITE
struct PKT_CG_REQ_GUILD_STORE_ITEM_AUCTION_REGISTER_READ
{
	struct ItemActionRegister
	{
		struct ReceiverDBIdList
		{
		protected:
			uint16 mThisOffset;
			uint16 mNextOffset;
			UserDBId mReceiverDBId;

		public:
			UserDBId ReceiverDBId() { return mReceiverDBId; }

			friend PktIterator<ItemActionRegister::ReceiverDBIdList>;
			friend ItemActionRegister;

			bool Validate(uint16 offset, uchar * pktStart, uint16 pktSize, uint16& dataSize)
			{
				if (static_cast<size_t>(pktSize) < static_cast<size_t>(offset) + sizeof(ItemActionRegister::ReceiverDBIdList))
					return false;

				ItemActionRegister::ReceiverDBIdList * node = (ItemActionRegister::ReceiverDBIdList*)(pktStart + offset);

				// ŔÚ±â ŔÚ˝ĹŔÇ Ć÷ŔÎĹÍ °ËÁő
				if (offset != node->mThisOffset)
					return false;

				// Value °ËÁő
				uchar* pktCurrentNodeStart = (uchar*)this - mThisOffset;
				uint16 pktCurrentNodeSize = *((uint16*)pktStart);
				dataSize += sizeof(ItemActionRegister::ReceiverDBIdList);	// skip
