#ifdef _SERVER
	template <typename Container>
	void MakeBookMarkListVector(Container & container)
	{
		//emplace() ČŁĂâÇŇ¶§¸¶´Ů ¸Ţ¸đ¸®¸¦ »ýĽş ÇĎ´Â şńżëŔĚ ąß»ýÇŃ´Ů şńżëŔ»ÁŮŔĚŔ§°ł reserve()»çżë
		container.reserve(mBookMarkListSize/sizeof(_T0));
		for (int offset = 0; offset < mBookMarkListSize; offset += sizeof(_T0))
		{
			const _T0* data = reinterpret_cast<const _T0*>(BookMarkList() + offset);
			container.emplace_back(*data);
		}
	}
#else // _SERVER
	template <typename Container, typename Data>
	void MakeBookMarkListVector(Container & container)
	{
		for (int offset = 0; offset < mBookMarkListSize; offset += sizeof(Data))
		{
			const Data* data = reinterpret_cast<const Data*>(BookMarkList() + offset);
			container.Add(*data);
		}
	}
#endif // _SERVER
#ifdef _SERVER
	template <typename TFunc>
	void ForEachBookMarkList(TFunc&& func) const
	{
		for (int offset = 0; offset < BookMarkListSize(); offset += sizeof(_T0))
		{
			const _T0* data = reinterpret_cast<const _T0*>(BookMarkList() + offset);
			func(data);
		}
	}
#endif


