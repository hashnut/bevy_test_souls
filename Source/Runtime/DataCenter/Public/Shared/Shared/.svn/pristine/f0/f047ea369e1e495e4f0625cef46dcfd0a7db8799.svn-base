// type = CG
// related packet = PKT_GC_ACK_COLLECTION_ITEM_WDMARKET_PRICE_LOWEST_WRITE
struct PKT_CG_REQ_COLLECTION_ITEM_WDMARKET_PRICE_LOWEST_READ
{
	struct ItemList
	{
	protected:
		uint16 mThisOffset;
		uint16 mNextOffset;
		ItemId mItemId;
		Level mLevel;
		int mTransactionCountRequired;

	public:
		ItemId ItemId() { return mItemId; }
		Level Level() { return mLevel; }
		int TransactionCountRequired() { return mTransactionCountRequired; }

		friend PktIterator<ItemList>;
		friend PKT_CG_REQ_COLLECTION_ITEM_WDMARKET_PRICE_LOWEST_READ;

		bool Validate(uint16 offset, uchar * pktStart, uint16 pktSize, uint16& dataSize)
		{
			if (static_cast<size_t>(pktSize) < static_cast<size_t>(offset) + sizeof(ItemList))
				return false;

			ItemList * node = (ItemList*)(pktStart + offset);

			// ŔÚ±â ŔÚ˝ĹŔÇ Ć÷ŔÎĹÍ °ËÁő
			if (offset != node->mThisOffset)
				return false;

			// Value °ËÁő
			uchar* pktCurrentNodeStart = (uchar*)this - mThisOffset;
			uint16 pktCurrentNodeSize = *((uint16*)pktStart);
			dataSize += sizeof(ItemList);	// skip
			if (false == ValidateValue(pktCurrentNodeStart, pktCurrentNodeSize, dataSize))
				return false;

			return true;
		}

		bool ValidateValue(const uchar* pktStart, uint16 pktSize, uint16& dataSize)
		{
			return (nullptr != pktStart && 0 < pktSize && 0 < dataSize) ? true : false;
		}

	}; // ItemList

public:
	uint16 mPktSize;
	uint16 mPktId;
	uint16 mItemListCount;
	uint16 mFirstItemListOffset;
	bool mIsSearchPricePerUnit;
	CollectionId mCollectionId;

public:
#ifdef _SERVER 
	bool GetServerTaskIdRealTime(OUT [[maybe_unused]] int& serverTaskId) const { return false; }
	const wchar_t* GetPacketName() const { return L"CG_REQ_COLLECTION_ITEM_WDMARKET_PRICE_LOWEST"; }
	const wchar_t* GetRelatedPacketName() const { return L"GC_ACK_COLLECTION_ITEM_WDMARKET_PRICE_LOWEST"; }
#endif

	bool IsSearchPricePerUnit() { return mIsSearchPricePerUnit; }
	CollectionId CollectionId() { return mCollectionId; }

	using ItemListIterator = PktIterator<ItemList>;
	const ItemListIterator GetLastItemListIterator() const
	{
		return ItemListIterator(0);
	}
	ItemListIterator GetFirstItemListIterator() const
	{
		if (mFirstItemListOffset && mPktSize >= mFirstItemListOffset + sizeof(ItemList))
		{
			ItemList* itemList = (ItemList*)((uchar*)this + mFirstItemListOffset);
			if (mFirstItemListOffset == itemList->mThisOffset)
				return ItemListIterator(itemList);
			else
				return ItemListIterator(0);
		}
		else
			return ItemListIterator(0);
	}
	const int GetItemListCount()
	{
		return mItemListCount;
	}
#ifdef _SERVER
	template<typename TFunc>
	void ForEachItemList(TFunc&& func)
	{
		for (auto it = GetFirstItemListIterator(); it != GetLastItemListIterator(); ++it)
			func(it);
	}
#endif


#ifdef _SERVER 
	std::xwstring FuncCreateItemListStr( [[maybe_unused]] ItemListIterator& iter) const
	{
		return Log::format(
			L"ItemId: {}, Level: {}, TransactionCountRequired: {}", 
			iter->ItemId(), iter->Level(), iter->TransactionCountRequired()
		).c_str();
	}

	std::xwstring GetLogWString() const
	{
		std::xwstring str1;
		str1.append(L"\n");
		for (ItemListIterator iter = this->GetFirstItemListIterator();
			iter != GetLastItemListIterator(); ++iter)
		{
			str1.append(L"[");
			str1.append(FuncCreateItemListStr(iter).c_str());

			str1.append(L"]\n");
		}

		return Log::format(
			L"[CG_REQ_COLLECTION_ITEM_WDMARKET_PRICE_LOWEST] IsSearchPricePerUnit: {}, CollectionId: {}, ItemList : {}"
			, mIsSearchPricePerUnit, mCollectionId, str1.c_str()
		).c_str();
	}
#endif

	bool Validate()
	{
		uchar* pktStart = (uchar*)this;
		uint16 pktSize = mPktSize;

		uint16 dataSize = sizeof(PKT_CG_REQ_COLLECTION_ITEM_WDMARKET_PRICE_LOWEST_READ);
		if (dataSize > mPktSize)
			return false;

		if (false == ValidateValue(pktStart, pktSize, dataSize))
			return false;

		if (false == ItemListValidateListNode(mFirstItemListOffset, pktStart, pktSize, dataSize))
			return false;

		if (dataSize != mPktSize)
			return false;

		return true;
	}

	bool ItemListValidateListNode(uint16 offset, uchar * pktStart, uint16 pktSize, uint16& dataSize)
	{		for (ItemListIterator iter = this->GetFirstItemListIterator();
			iter != GetLastItemListIterator(); ++iter)
		{
			if (false == (*iter).Validate(offset, pktStart, pktSize, dataSize))
			{
				return false;
			}
		}
		return true;
	}

	bool ValidateValue(const uchar* pktStart, uint16 pktSize, uint16& dataSize)
	{
		return (nullptr != pktStart && 0 < pktSize && 0 < dataSize) ? true : false;
	}

}; // PKT_CG_REQ_COLLECTION_ITEM_WDMARKET_PRICE_LOWEST_READ

