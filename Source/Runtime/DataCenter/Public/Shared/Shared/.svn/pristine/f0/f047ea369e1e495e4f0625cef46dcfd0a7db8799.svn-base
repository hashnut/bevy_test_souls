struct PKT_CG_REQ_CHANGE_GUILD_MEMBER_RIGHTS_BY_GRADE_READ
{
public:
	uint16 mPktSize;
	uint16 mPktId;
	uint16 mGuildMemberRightsbyGradeOffset;
	uint16 mGuildMemberRightsbyGradeSize;
	UserDBId mUserDBId;

public:
#ifdef _SERVER 
	using _T0 = GuildMemberRightsbyGrade;
	bool GetServerTaskIdRealTime(OUT [[maybe_unused]] int& serverTaskId) const { return false; }
	const wchar_t* GetPacketName() const { return L"CG_REQ_CHANGE_GUILD_MEMBER_RIGHTS_BY_GRADE"; }
	const wchar_t* GetRelatedPacketName() const { return L"GC_ACK_CHANGE_GUILD_MEMBER_RIGHTS_BY_GRADE"; }
#endif

	UserDBId UserDBId() { return mUserDBId; }
	const uchar* GuildMemberRightsbyGrade() const
	{
		uchar* pktStart = (uchar*)this;
		uint16 pktSize = *((uint16*)pktStart);
		if (mGuildMemberRightsbyGradeOffset && pktSize > mGuildMemberRightsbyGradeOffset)
			return (const uchar*)(pktStart + mGuildMemberRightsbyGradeOffset);
		else
			return 0;
	}
	int GuildMemberRightsbyGradeSize() const
	{
		return mGuildMemberRightsbyGradeSize;
	}
#ifdef _SERVER
	template <typename Container>
	void MakeGuildMemberRightsbyGradeVector(Container & container)
	{
		//emplace() ČŁĂâÇŇ¶§¸¶´Ů ¸Ţ¸đ¸®¸¦ »ýĽş ÇĎ´Â şńżëŔĚ ąß»ýÇŃ´Ů şńżëŔ»ÁŮŔĚŔ§°ł reserve()»çżë
		container.reserve(mGuildMemberRightsbyGradeSize/sizeof(_T0));
		for (int offset = 0; offset < mGuildMemberRightsbyGradeSize; offset += sizeof(_T0))
		{
			const _T0* data = reinterpret_cast<const _T0*>(GuildMemberRightsbyGrade() + offset);
			container.emplace_back(*data);
		}
	}
#else // _SERVER
	template <typename Container, typename Data>
	void MakeGuildMemberRightsbyGradeVector(Container & container)
	{
		for (int offset = 0; offset < mGuildMemberRightsbyGradeSize; offset += sizeof(Data))
		{
			const Data* data = reinterpret_cast<const Data*>(GuildMemberRightsbyGrade() + offset);
			container.Add(*data);
		}
	}
#endif // _SERVER
#ifdef _SERVER
	template <typename TFunc>
	void ForEachGuildMemberRightsbyGrade(TFunc&& func) const
	{
		for (int offset = 0; offset < GuildMemberRightsbyGradeSize(); offset += sizeof(_T0))
		{
			const _T0* data = reinterpret_cast<const _T0*>(GuildMemberRightsbyGrade() + offset);
			func(data);
		}
	}
#endif


#ifdef _SERVER 
	std::xwstring GetLogWString() const
	{
		auto GuildMemberRightsbyGradeListLogFunc = [this]() -> std::xwstring
		{
			std::xwstring result;
			result.append(L"\n");
			for (int offset = 0; offset < GuildMemberRightsbyGradeSize(); offset += sizeof(struct GuildMemberRightsbyGrade))
			{
				const struct GuildMemberRightsbyGrade* data = reinterpret_cast<const struct GuildMemberRightsbyGrade*>(GuildMemberRightsbyGrade() + offset);
				result.append(Log::format(L"{}", *data));
				result.append(L"\n");
			}
			return result;
		};


		return Log::format(
			L"[CG_REQ_CHANGE_GUILD_MEMBER_RIGHTS_BY_GRADE] UserDBId: {}, GuildMemberRightsbyGrade: {}"
			, mUserDBId, GuildMemberRightsbyGradeListLogFunc().c_str()
		).c_str();
	}
#endif

	bool Validate()
	{
		uchar* pktStart = (uchar*)this;
		uint16 pktSize = mPktSize;

		uint16 dataSize = sizeof(PKT_CG_REQ_CHANGE_GUILD_MEMBER_RIGHTS_BY_GRADE_READ);
		if (dataSize > mPktSize)
			return false;

		if (false == ValidateValue(pktStart, pktSize, dataSize))
			return false;

		if (dataSize != mPktSize)
			return false;

		return true;
	}

	bool ValidateValue(const uchar* pktStart, uint16 pktSize, uint16& dataSize)
	{
		if (false == ValidateBinary(mGuildMemberRightsbyGradeOffset, mGuildMemberRightsbyGradeSize, 0, pktSize, dataSize))
			return false;

		return (nullptr != pktStart && 0 < pktSize && 0 < dataSize) ? true : false;
	}

}; // PKT_CG_REQ_CHANGE_GUILD_MEMBER_RIGHTS_BY_GRADE_READ

