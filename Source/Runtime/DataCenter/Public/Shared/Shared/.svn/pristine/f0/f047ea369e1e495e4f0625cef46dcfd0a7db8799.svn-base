struct PKT_CG_REQ_WDMARKET_SALES_ITEM_LIST_READ
{
public:
	uint16 mPktSize;
	uint16 mPktId;
	uint16 mItemGradeListOffset;
	uint16 mItemGradeListSize;
	MarketCategory mMarketCategory;
	ItemId mItemId;

public:
#ifdef _SERVER 
	using _T0 = ItemGrade;
	bool GetServerTaskIdRealTime(OUT [[maybe_unused]] int& serverTaskId) const { return false; }
	const wchar_t* GetPacketName() const { return L"CG_REQ_WDMARKET_SALES_ITEM_LIST"; }
	const wchar_t* GetRelatedPacketName() const { return L"GC_ACK_WDMARKET_SALES_ITEM_LIST"; }
#endif

	MarketCategory MarketCategory() { return mMarketCategory; }
	ItemId ItemId() { return mItemId; }
	const uchar* ItemGradeList() const
	{
		uchar* pktStart = (uchar*)this;
		uint16 pktSize = *((uint16*)pktStart);
		if (mItemGradeListOffset && pktSize > mItemGradeListOffset)
			return (const uchar*)(pktStart + mItemGradeListOffset);
		else
			return 0;
	}
	int ItemGradeListSize() const
	{
		return mItemGradeListSize;
	}
#ifdef _SERVER
	template <typename Container>
	void MakeItemGradeListVector(Container & container)
	{
		//emplace() ČŁĂâÇŇ¶§¸¶´Ů ¸Ţ¸đ¸®¸¦ »ýĽş ÇĎ´Â şńżëŔĚ ąß»ýÇŃ´Ů şńżëŔ»ÁŮŔĚŔ§°ł reserve()»çżë
		container.reserve(mItemGradeListSize/sizeof(_T0));
		for (int offset = 0; offset < mItemGradeListSize; offset += sizeof(_T0))
		{
			const _T0* data = reinterpret_cast<const _T0*>(ItemGradeList() + offset);
			container.emplace_back(*data);
		}
	}
#else // _SERVER
	template <typename Container, typename Data>
	void MakeItemGradeListVector(Container & container)
	{
		for (int offset = 0; offset < mItemGradeListSize; offset += sizeof(Data))
		{
			const Data* data = reinterpret_cast<const Data*>(ItemGradeList() + offset);
			container.Add(*data);
		}
	}
#endif // _SERVER
#ifdef _SERVER
	template <typename TFunc>
	void ForEachItemGradeList(TFunc&& func) const
	{
		for (int offset = 0; offset < ItemGradeListSize(); offset += sizeof(_T0))
		{
			const _T0* data = reinterpret_cast<const _T0*>(ItemGradeList() + offset);
			func(data);
		}
	}
#endif


#ifdef _SERVER 
	std::xwstring GetLogWString() const
	{
		std::wstringstream ItemGradeListStream; 
		ItemGradeListStream << std::endl;
		ForEachItemGradeList(
			[&ItemGradeListStream](const ItemGrade* Id) {
				ItemGradeListStream << "[" << static_cast<size_t>(*Id) << "]" << std::endl;
				}
			);


		return Log::format(
			L"[CG_REQ_WDMARKET_SALES_ITEM_LIST] MarketCategory: {}, ItemGradeList: {}, ItemId: {}"
			, mMarketCategory, ItemGradeListStream.str().c_str(), mItemId
		).c_str();
	}
#endif

	bool Validate()
	{
		uchar* pktStart = (uchar*)this;
		uint16 pktSize = mPktSize;

		uint16 dataSize = sizeof(PKT_CG_REQ_WDMARKET_SALES_ITEM_LIST_READ);
		if (dataSize > mPktSize)
			return false;

		if (false == ValidateValue(pktStart, pktSize, dataSize))
			return false;

		if (dataSize != mPktSize)
			return false;

		return true;
	}

	bool ValidateValue(const uchar* pktStart, uint16 pktSize, uint16& dataSize)
	{
		if (false == ValidateBinary(mItemGradeListOffset, mItemGradeListSize, 0, pktSize, dataSize))
			return false;

		return (nullptr != pktStart && 0 < pktSize && 0 < dataSize) ? true : false;
	}

}; // PKT_CG_REQ_WDMARKET_SALES_ITEM_LIST_READ

// type = CG
// related packet = PKT_GC_ACK_WDMARKET_SALES_ITEM_LIST_READ
#ifdef _SERVER
struct PKT_CG_REQ_WDMARKET_SALES_ITEM_LIST_WRITE : public Disposable
#else
struct PKT_CG_REQ_WDMARKET_SALES_ITEM_LIST_WRITE
#endif
{
	PktWriter mPktWriter;
	uint16* mItemGradeListOffset;
	uint16* mItemGradeListSize;

#ifdef _SERVER 
	using _T0 = ItemGrade;
	bool GetServerTaskIdRealTime(OUT int& serverTaskId) const { return reinterpret_cast<PKT_CG_REQ_WDMARKET_SALES_ITEM_LIST_READ*>(mPktWriter.mBuf)->GetServerTaskIdRealTime(serverTaskId); }
	const wchar_t* GetPacketName() const { return L"CG_REQ_WDMARKET_SALES_ITEM_LIST"; }
	const wchar_t* GetRelatedPacketName() const { return L"GC_ACK_WDMARKET_SALES_ITEM_LIST"; }
#endif

#ifndef _SERVER
	template <typename T0>
	PKT_CG_REQ_WDMARKET_SALES_ITEM_LIST_WRITE(uchar* buf, int bufSize, MarketCategory marketCategory, const T0* itemGradeList, ItemId itemId)
		:
		mPktWriter(buf, bufSize)

	{
		mPktWriter << static_cast<uint16>(PD::CG::CGPacketId::CG_REQ_WDMARKET_SALES_ITEM_LIST);
		mItemGradeListOffset = (uint16*)mPktWriter.GetBuffer();
		*mItemGradeListOffset = 0;
		mPktWriter << (*mItemGradeListOffset);
		mItemGradeListSize = (uint16*)mPktWriter.GetBuffer();
		*mItemGradeListSize = 0;
		mPktWriter << (*mItemGradeListSize);
		mPktWriter << marketCategory;
		mPktWriter << itemId;
		*mItemGradeListOffset = (uint16)mPktWriter.GetPktSize();
		if (itemGradeList && 0 < itemGradeList->Num())
		{
			int tvalsize = (int)sizeof(*(itemGradeList->begin())); 
			auto _itemGradeList = (T0*)itemGradeList;
			for (auto it = _itemGradeList->begin(); it != _itemGradeList->end(); ++it) 
			{
				mPktWriter.WriteBinary((uint16)tvalsize, (uchar*)&(*it)); 
			}
			*mItemGradeListSize = (uint16)(tvalsize* itemGradeList->Num());
		}
	}

#endif // _SERVER
#ifdef _SERVER
	template <typename T0>
	PKT_CG_REQ_WDMARKET_SALES_ITEM_LIST_WRITE(SendBufferHelper& sendBuffer, MarketCategory marketCategory, const T0* itemGradeList, ItemId itemId)
		:
		mPktWriter(sendBuffer->GetCharBuffer(), (SEND_BUFFER_SIZE - 1))

	{
		static_assert(true == std::is_same_v<T0::value_type, _T0>, "itemGradeList type must be ItemGrade list type"); 
		mPktWriter << (uint16)CG_REQ_WDMARKET_SALES_ITEM_LIST;
		mItemGradeListOffset = (uint16*)mPktWriter.GetBuffer();
		*mItemGradeListOffset = 0;
		mPktWriter << (*mItemGradeListOffset);
		mItemGradeListSize = (uint16*)mPktWriter.GetBuffer();
		*mItemGradeListSize = 0;
		mPktWriter << (*mItemGradeListSize);
		mPktWriter << marketCategory;
		mPktWriter << itemId;
		*mItemGradeListOffset = (uint16)mPktWriter.GetPktSize();
		if (itemGradeList && !itemGradeList->empty())
		{
			int tvalsize = (int)sizeof(*(itemGradeList->begin())); 
			auto _itemGradeList = const_cast<std::decay_t<T0>*>(itemGradeList);
			for (auto it = _itemGradeList->begin(); it != _itemGradeList->end(); ++it) 
			{
				mPktWriter.WriteBinary((uint16)tvalsize, (uchar*)&(*it)); 
			}
			*mItemGradeListSize = (uint16) (tvalsize * itemGradeList->size());
		}
	}
#endif

#ifdef _SERVER 
	void send(IocpObjectSession* session, SendBufferRef sendBuffer, bool autoCloseSendBuffer)
	{
		if (session) 
			session->Send(sendBuffer, mPktWriter.GetPktSize(), autoCloseSendBuffer);
	}
#endif

#ifdef _SERVER 
	std::xwstring GetLogWString() const
	{
		auto readPacket = reinterpret_cast<PKT_CG_REQ_WDMARKET_SALES_ITEM_LIST_READ*>(mPktWriter.mBuf);
		return readPacket->GetLogWString();
	}
#endif

#ifndef _SERVER
#else
#endif
}; // PKT_CG_REQ_WDMARKET_SALES_ITEM_LIST_WRITE

