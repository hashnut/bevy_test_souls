// type = CG
// related packet = PKT_GC_ACK_MARKET_ITEM_SEARCH_WRITE
struct PKT_CG_REQ_MARKET_ITEM_SEARCH_READ
{
public:
	uint16 mPktSize;
	uint16 mPktId;
	uint16 mItemIdListOffset;
	uint16 mItemIdListSize;

public:
#ifdef _SERVER 
	using _T0 = ItemId;
	bool GetServerTaskIdRealTime(OUT [[maybe_unused]] int& serverTaskId) const { return false; }
	const wchar_t* GetPacketName() const { return L"CG_REQ_MARKET_ITEM_SEARCH"; }
	const wchar_t* GetRelatedPacketName() const { return L"GC_ACK_MARKET_ITEM_SEARCH"; }
#endif

	const uchar* ItemIdList() const
	{
		uchar* pktStart = (uchar*)this;
		uint16 pktSize = *((uint16*)pktStart);
		if (mItemIdListOffset && pktSize > mItemIdListOffset)
			return (const uchar*)(pktStart + mItemIdListOffset);
		else
			return 0;
	}
	int ItemIdListSize() const
	{
		return mItemIdListSize;
	}
#ifdef _SERVER
	template <typename Container>
	void MakeItemIdListVector(Container & container)
	{
		//emplace() ČŁĂâÇŇ¶§¸¶´Ů ¸Ţ¸đ¸®¸¦ »ýĽş ÇĎ´Â şńżëŔĚ ąß»ýÇŃ´Ů şńżëŔ»ÁŮŔĚŔ§°ł reserve()»çżë
		container.reserve(mItemIdListSize/sizeof(_T0));
		for (int offset = 0; offset < mItemIdListSize; offset += sizeof(_T0))
		{
			const _T0* data = reinterpret_cast<const _T0*>(ItemIdList() + offset);
			container.emplace_back(*data);
		}
	}
#else // _SERVER
	template <typename Container, typename Data>
	void MakeItemIdListVector(Container & container)
	{
		for (int offset = 0; offset < mItemIdListSize; offset += sizeof(Data))
		{
			const Data* data = reinterpret_cast<const Data*>(ItemIdList() + offset);
			container.Add(*data);
		}
	}
#endif // _SERVER
#ifdef _SERVER
	template <typename TFunc>
	void ForEachItemIdList(TFunc&& func) const
	{
		for (int offset = 0; offset < ItemIdListSize(); offset += sizeof(_T0))
		{
			const _T0* data = reinterpret_cast<const _T0*>(ItemIdList() + offset);
			func(data);
		}
	}
#endif


#ifdef _SERVER 
	std::xwstring GetLogWString() const
	{
		std::wstringstream ItemIdListStream; 
		ItemIdListStream << std::endl;
		ForEachItemIdList(
			[&ItemIdListStream](const ItemId* Id) {
				ItemIdListStream << "[" << static_cast<size_t>(*Id) << "]" << std::endl;
				}
			);


		return Log::format(
			L"[CG_REQ_MARKET_ITEM_SEARCH] ItemIdList: {}"
			, ItemIdListStream.str().c_str()
		).c_str();
	}
#endif

	bool Validate()
	{
		uchar* pktStart = (uchar*)this;
		uint16 pktSize = mPktSize;

		uint16 dataSize = sizeof(PKT_CG_REQ_MARKET_ITEM_SEARCH_READ);
		if (dataSize > mPktSize)
			return false;

		if (false == ValidateValue(pktStart, pktSize, dataSize))
			return false;

		if (dataSize != mPktSize)
			return false;

		return true;
	}

	bool ValidateValue(const uchar* pktStart, uint16 pktSize, uint16& dataSize)
	{
		if (false == ValidateBinary(mItemIdListOffset, mItemIdListSize, 0, pktSize, dataSize))
			return false;

		return (nullptr != pktStart && 0 < pktSize && 0 < dataSize) ? true : false;
	}

}; // PKT_CG_REQ_MARKET_ITEM_SEARCH_READ

// type = CG
// related packet = PKT_GC_ACK_MARKET_ITEM_SEARCH_READ
#ifdef _SERVER
struct PKT_CG_REQ_MARKET_ITEM_SEARCH_WRITE : public Disposable
#else
struct PKT_CG_REQ_MARKET_ITEM_SEARCH_WRITE
#endif
{
	PktWriter mPktWriter;
	uint16* mItemIdListOffset;
	uint16* mItemIdListSize;

#ifdef _SERVER 
	using _T0 = ItemId;
	bool GetServerTaskIdRealTime(OUT int& serverTaskId) const { return reinterpret_cast<PKT_CG_REQ_MARKET_ITEM_SEARCH_READ*>(mPktWriter.mBuf)->GetServerTaskIdRealTime(serverTaskId); }
	const wchar_t* GetPacketName() const { return L"CG_REQ_MARKET_ITEM_SEARCH"; }
	const wchar_t* GetRelatedPacketName() const { return L"GC_ACK_MARKET_ITEM_SEARCH"; }
#endif

#ifndef _SERVER
	template <typename T0>
	PKT_CG_REQ_MARKET_ITEM_SEARCH_WRITE(uchar* buf, int bufSize, const T0* itemIdList)
		:
		mPktWriter(buf, bufSize)

	{
		mPktWriter << static_cast<uint16>(PD::CG::CGPacketId::CG_REQ_MARKET_ITEM_SEARCH);
		mItemIdListOffset = (uint16*)mPktWriter.GetBuffer();
		*mItemIdListOffset = 0;
		mPktWriter << (*mItemIdListOffset);
		mItemIdListSize = (uint16*)mPktWriter.GetBuffer();
		*mItemIdListSize = 0;
		mPktWriter << (*mItemIdListSize);
		*mItemIdListOffset = (uint16)mPktWriter.GetPktSize();
		if (itemIdList && 0 < itemIdList->Num())
		{
			int tvalsize = (int)sizeof(*(itemIdList->begin())); 
			auto _itemIdList = (T0*)itemIdList;
			for (auto it = _itemIdList->begin(); it != _itemIdList->end(); ++it) 
			{
				mPktWriter.WriteBinary((uint16)tvalsize, (uchar*)&(*it)); 
			}
			*mItemIdListSize = (uint16)(tvalsize* itemIdList->Num());
		}
	}

#endif // _SERVER
#ifdef _SERVER
	template <typename T0>
	PKT_CG_REQ_MARKET_ITEM_SEARCH_WRITE(SendBufferHelper& sendBuffer, const T0* itemIdList)
		:
		mPktWriter(sendBuffer->GetCharBuffer(), (SEND_BUFFER_SIZE - 1))

	{
		static_assert(true == std::is_same_v<T0::value_type, _T0>, "itemIdList type must be ItemId list type"); 
		mPktWriter << (uint16)CG_REQ_MARKET_ITEM_SEARCH;
		mItemIdListOffset = (uint16*)mPktWriter.GetBuffer();
		*mItemIdListOffset = 0;
		mPktWriter << (*mItemIdListOffset);
		mItemIdListSize = (uint16*)mPktWriter.GetBuffer();
		*mItemIdListSize = 0;
		mPktWriter << (*mItemIdListSize);
		*mItemIdListOffset = (uint16)mPktWriter.GetPktSize();
		if (itemIdList && !itemIdList->empty())
		{
			int tvalsize = (int)sizeof(*(itemIdList->begin())); 
			auto _itemIdList = const_cast<std::decay_t<T0>*>(itemIdList);
			for (auto it = _itemIdList->begin(); it != _itemIdList->end(); ++it) 
			{
				mPktWriter.WriteBinary((uint16)tvalsize, (uchar*)&(*it)); 
			}
			*mItemIdListSize = (uint16) (tvalsize * itemIdList->size());
		}
	}
#endif

#ifdef _SERVER 
	void send(IocpObjectSession* session, SendBufferRef sendBuffer, bool autoCloseSendBuffer)
	{
		if (session) 
			session->Send(sendBuffer, mPktWriter.GetPktSize(), autoCloseSendBuffer);
	}
#endif

#ifdef _SERVER 
	std::xwstring GetLogWString() const
	{
		auto readPacket = reinterpret_cast<PKT_CG_REQ_MARKET_ITEM_SEARCH_READ*>(mPktWriter.mBuf);
		return readPacket->GetLogWString();
	}
#endif

#ifndef _SERVER
#else
#endif
}; // PKT_CG_REQ_MARKET_ITEM_SEARCH_WRITE

