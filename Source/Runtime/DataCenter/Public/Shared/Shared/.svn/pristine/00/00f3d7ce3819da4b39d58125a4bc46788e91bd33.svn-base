#endif

#ifndef _SERVER
	PKT_GW_GUILD_ASYNC_GUILDWAR_ENTRY_INFO_WRITE(uchar* buf, int bufSize, GuildDBId guildDBId, GuildWarMatchPointInfo matchPointInfo, uint64 eventId)
		:
		mPktWriter(buf, bufSize)
		, mNowEntrymemberList(0)
	{
		mPktWriter << static_cast<uint16>(PD::GW::GWPacketId::GW_GUILD_ASYNC_GUILDWAR_ENTRY_INFO);
		mEntrymemberListCount = (uint16*)mPktWriter.GetBuffer();
		*mEntrymemberListCount = 0;
		mPktWriter << (*mEntrymemberListCount);
		mFirstEntrymemberListOffset = (uint16*)mPktWriter.GetBuffer();
		*mFirstEntrymemberListOffset = 0;
		mPktWriter << (*mFirstEntrymemberListOffset);
		mPktWriter << guildDBId;
		mPktWriter << matchPointInfo;
		mPktWriter << eventId;
	}

#endif // _SERVER
#ifdef _SERVER
	PKT_GW_GUILD_ASYNC_GUILDWAR_ENTRY_INFO_WRITE(SendBufferHelper& sendBuffer, GuildDBId guildDBId, const GuildWarMatchPointInfo& matchPointInfo, uint64 eventId)
		:
		mPktWriter(sendBuffer->GetCharBuffer(), (SEND_BUFFER_SIZE - 1))
		, mNowEntrymemberList(0)
	{
		mPktWriter << (uint16)GW_GUILD_ASYNC_GUILDWAR_ENTRY_INFO;
		mEntrymemberListCount = (uint16*)mPktWriter.GetBuffer();
		*mEntrymemberListCount = 0;
		mPktWriter << (*mEntrymemberListCount);
		mFirstEntrymemberListOffset = (uint16*)mPktWriter.GetBuffer();
		*mFirstEntrymemberListOffset = 0;
		mPktWriter << (*mFirstEntrymemberListOffset);
		mPktWriter << guildDBId;
		mPktWriter << matchPointInfo;
		mPktWriter << eventId;
	}
#endif

#ifdef _SERVER 
	void send(IocpObjectSession* session, SendBufferRef sendBuffer, bool autoCloseSendBuffer)
	{
		if (session) 
			session->Send(sendBuffer, mPktWriter.GetPktSize(), autoCloseSendBuffer);
	}
#endif

#ifdef _SERVER 
	std::xwstring GetLogWString() const
	{
		auto readPacket = reinterpret_cast<PKT_GW_GUILD_ASYNC_GUILDWAR_ENTRY_INFO_READ*>(mPktWriter.mBuf);
		return readPacket->GetLogWString();
	}
#endif

#ifndef _SERVER
	EntrymemberListHandle CreateEntrymemberList(UserDBId member)
	{
		uchar* nowBuffer = mPktWriter.GetBuffer();
		uint16 nowWritten = (uint16)mPktWriter.GetPktSize();
		EntrymemberList* newEntrymemberList = new ((EntrymemberList*)nowBuffer) EntrymemberList(nowWritten, member);
		++(*mEntrymemberListCount);
		if (mNowEntrymemberList == 0)
			*mFirstEntrymemberListOffset = nowWritten;
		else
			mNowEntrymemberList->mNextOffset = nowWritten;
		mNowEntrymemberList = newEntrymemberList;
		mPktWriter.Skip(sizeof(EntrymemberList));
		return EntrymemberListHandle(mPktWriter, newEntrymemberList);
	}

#else
	EntrymemberListHandle CreateEntrymemberList(UserDBId member)
	{
		uchar* nowBuffer = mPktWriter.GetBuffer();
		uint16 nowWritten = (uint16)mPktWriter.GetPktSize();
		EntrymemberList* newEntrymemberList = new ((EntrymemberList*)nowBuffer) EntrymemberList(nowWritten, member);
		++(*mEntrymemberListCount);
		if (mNowEntrymemberList == 0)
			*mFirstEntrymemberListOffset = nowWritten;
		else
			mNowEntrymemberList->mNextOffset = nowWritten;
		mNowEntrymemberList = newEntrymemberList;
		mPktWriter.Skip(sizeof(EntrymemberList));
		return EntrymemberListHandle(mPktWriter, newEntrymemberList);
	}

#endif
}; // PKT_GW_GUILD_ASYNC_GUILDWAR_ENTRY_INFO_WRITE

