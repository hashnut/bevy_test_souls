struct PKT_GW_WORLD_GUILD_RANK_DATA_INFO_READ
{
public:
	uint16 mPktSize;
	uint16 mPktId;
	uint16 mGuildRankDataListOffset;
	uint16 mGuildRankDataListSize;
	uint16 mGuildRankRewardInfoListOffset;
	uint16 mGuildRankRewardInfoListSize;

public:
#ifdef _SERVER 
	using _T0 = GuildRankData;
	using _T1 = GuildRankRewardInfo;
	bool GetServerTaskIdRealTime(OUT [[maybe_unused]] int& serverTaskId) const { return false; }
	const wchar_t* GetPacketName() const { return L"GW_WORLD_GUILD_RANK_DATA_INFO"; }
	const wchar_t* GetRelatedPacketName() const { return L"WG_WORLD_GUILD_RANK_DATA_INFO"; }
#endif

	const uchar* GuildRankDataList() const
	{
		uchar* pktStart = (uchar*)this;
		uint16 pktSize = *((uint16*)pktStart);
		if (mGuildRankDataListOffset && pktSize > mGuildRankDataListOffset)
			return (const uchar*)(pktStart + mGuildRankDataListOffset);
		else
			return 0;
	}
	int GuildRankDataListSize() const
	{
		return mGuildRankDataListSize;
	}
#ifdef _SERVER
	template <typename Container>
	void MakeGuildRankDataListVector(Container & container)
	{
		//emplace() 호출할때마다 메모리를 생성 하는 비용이 발생한다 비용을줄이위개 reserve()사용
		container.reserve(mGuildRankDataListSize/sizeof(_T0));
		for (int offset = 0; offset < mGuildRankDataListSize; offset += sizeof(_T0))
		{
			const _T0* data = reinterpret_cast<const _T0*>(GuildRankDataList() + offset);
			container.emplace_back(*data);
		}
	}
#else // _SERVER
	template <typename Container, typename Data>
	void MakeGuildRankDataListVector(Container & container)
	{
		for (int offset = 0; offset < mGuildRankDataListSize; offset += sizeof(Data))
		{
			const Data* data = reinterpret_cast<const Data*>(GuildRankDataList() + offset);
			container.Add(*data);
		}
	}
#endif // _SERVER
#ifdef _SERVER
	template <typename TFunc>
	void ForEachGuildRankDataList(TFunc&& func) const
	{
		for (int offset = 0; offset < GuildRankDataListSize(); offset += sizeof(_T0))
		{
			const _T0* data = reinterpret_cast<const _T0*>(GuildRankDataList() + offset);
			func(data);
		}
	}
#endif
	const uchar* GuildRankRewardInfoList() const
	{
		uchar* pktStart = (uchar*)this;
		uint16 pktSize = *((uint16*)pktStart);
		if (mGuildRankRewardInfoListOffset && pktSize > mGuildRankRewardInfoListOffset)
			return (const uchar*)(pktStart + mGuildRankRewardInfoListOffset);
		else
			return 0;
	}
