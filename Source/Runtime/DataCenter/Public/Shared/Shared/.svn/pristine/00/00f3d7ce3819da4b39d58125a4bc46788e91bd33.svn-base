// type = GW
// related packet = PKT_WG_REQ_DB_USER_TUTORIAL_LOAD_WRITE
struct PKT_GW_ACK_DB_USER_TUTORIAL_LOAD_READ
{
	struct TutorialIdList
	{
	protected:
		uint16 mThisOffset;
		uint16 mNextOffset;
		TutorialId mTutorialId;

	public:
		TutorialId TutorialId() { return mTutorialId; }

		friend PktIterator<TutorialIdList>;
		friend PKT_GW_ACK_DB_USER_TUTORIAL_LOAD_READ;

		bool Validate(uint16 offset, uchar * pktStart, uint16 pktSize, uint16& dataSize)
		{
			if (static_cast<size_t>(pktSize) < static_cast<size_t>(offset) + sizeof(TutorialIdList))
				return false;

			TutorialIdList * node = (TutorialIdList*)(pktStart + offset);

			// 자기 자신의 포인터 검증
			if (offset != node->mThisOffset)
				return false;

			// Value 검증
			uchar* pktCurrentNodeStart = (uchar*)this - mThisOffset;
			uint16 pktCurrentNodeSize = *((uint16*)pktStart);
			dataSize += sizeof(TutorialIdList);	// skip
			if (false == ValidateValue(pktCurrentNodeStart, pktCurrentNodeSize, dataSize))
				return false;

			return true;
		}

		bool ValidateValue(const uchar* pktStart, uint16 pktSize, uint16& dataSize)
		{
			return (nullptr != pktStart && 0 < pktSize && 0 < dataSize) ? true : false;
		}

	}; // TutorialIdList

public:
	uint16 mPktSize;
	uint16 mPktId;
	uint16 mTutorialIdListCount;
	uint16 mFirstTutorialIdListOffset;
	ServerTaskId mTaskId;
	bool mSuccess;

public:
#ifdef _SERVER 
	bool GetServerTaskIdRealTime(OUT int& serverTaskId) const { serverTaskId = mTaskId; return true; }
	const wchar_t* GetPacketName() const { return L"GW_ACK_DB_USER_TUTORIAL_LOAD"; }
	const wchar_t* GetRelatedPacketName() const { return L"WG_REQ_DB_USER_TUTORIAL_LOAD"; }
#endif

	ServerTaskId TaskId() { return mTaskId; }
	bool Success() { return mSuccess; }

	using TutorialIdListIterator = PktIterator<TutorialIdList>;
	const TutorialIdListIterator GetLastTutorialIdListIterator() const
	{
		return TutorialIdListIterator(0);
	}
	TutorialIdListIterator GetFirstTutorialIdListIterator() const
	{
		if (mFirstTutorialIdListOffset && mPktSize >= mFirstTutorialIdListOffset + sizeof(TutorialIdList))
		{
			TutorialIdList* tutorialIdList = (TutorialIdList*)((uchar*)this + mFirstTutorialIdListOffset);
			if (mFirstTutorialIdListOffset == tutorialIdList->mThisOffset)
				return TutorialIdListIterator(tutorialIdList);
			else
				return TutorialIdListIterator(0);
		}
		else
			return TutorialIdListIterator(0);
	}
	const int GetTutorialIdListCount()
	{
		return mTutorialIdListCount;
	}
#ifdef _SERVER
	template<typename TFunc>
	void ForEachTutorialIdList(TFunc&& func)
	{
		for (auto it = GetFirstTutorialIdListIterator(); it != GetLastTutorialIdListIterator(); ++it)
			func(it);
	}
#endif


#ifdef _SERVER 
	std::xwstring FuncCreateTutorialIdListStr( [[maybe_unused]] TutorialIdListIterator& iter) const
	{
		return Log::format(
			L"TutorialId: {}", 
			iter->TutorialId()
		).c_str();
	}

	std::xwstring GetLogWString() const
	{
		std::xwstring str1;
		str1.append(L"\n");
		for (TutorialIdListIterator iter = this->GetFirstTutorialIdListIterator();
			iter != GetLastTutorialIdListIterator(); ++iter)
		{
			str1.append(L"[");
			str1.append(FuncCreateTutorialIdListStr(iter).c_str());

			str1.append(L"]\n");
		}

		return Log::format(
			L"[GW_ACK_DB_USER_TUTORIAL_LOAD] TaskId: {}, Success: {}, TutorialIdList : {}"
			, mTaskId, mSuccess, str1.c_str()
		).c_str();
	}
#endif

	bool Validate()
	{
		uchar* pktStart = (uchar*)this;
		uint16 pktSize = mPktSize;

		uint16 dataSize = sizeof(PKT_GW_ACK_DB_USER_TUTORIAL_LOAD_READ);
		if (dataSize > mPktSize)
			return false;

		if (false == ValidateValue(pktStart, pktSize, dataSize))
			return false;

		if (false == TutorialIdListValidateListNode(mFirstTutorialIdListOffset, pktStart, pktSize, dataSize))
			return false;

		if (dataSize != mPktSize)
			return false;

		return true;
	}

	bool TutorialIdListValidateListNode(uint16 offset, uchar * pktStart, uint16 pktSize, uint16& dataSize)
	{		for (TutorialIdListIterator iter = this->GetFirstTutorialIdListIterator();
			iter != GetLastTutorialIdListIterator(); ++iter)
		{
			if (false == (*iter).Validate(offset, pktStart, pktSize, dataSize))
			{
				return false;
			}
		}
		return true;
	}

	bool ValidateValue(const uchar* pktStart, uint16 pktSize, uint16& dataSize)
	{
		return (nullptr != pktStart && 0 < pktSize && 0 < dataSize) ? true : false;
	}

}; // PKT_GW_ACK_DB_USER_TUTORIAL_LOAD_READ

