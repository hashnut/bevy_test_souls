// type = GW
struct PKT_GW_WORLD_CHANNEL_CAMP_LIST_READ
{
	struct Camplist
	{
	protected:
		uint16 mThisOffset;
		uint16 mNextOffset;
		CampPosition mCampPosition;
		MapId mMapId;
		ChannelId mChannelId;

	public:
		const CampPosition& ConstRefCampPosition() { return mCampPosition; }
		CampPosition CampPosition() { return mCampPosition; }
		MapId MapId() { return mMapId; }
		ChannelId ChannelId() { return mChannelId; }

		friend PktIterator<Camplist>;
		friend PKT_GW_WORLD_CHANNEL_CAMP_LIST_READ;

		bool Validate(uint16 offset, uchar * pktStart, uint16 pktSize, uint16& dataSize)
		{
			if (static_cast<size_t>(pktSize) < static_cast<size_t>(offset) + sizeof(Camplist))
				return false;

			Camplist * node = (Camplist*)(pktStart + offset);

			// 자기 자신의 포인터 검증
			if (offset != node->mThisOffset)
				return false;

			// Value 검증
			uchar* pktCurrentNodeStart = (uchar*)this - mThisOffset;
			uint16 pktCurrentNodeSize = *((uint16*)pktStart);
			dataSize += sizeof(Camplist);	// skip
			if (false == ValidateValue(pktCurrentNodeStart, pktCurrentNodeSize, dataSize))
				return false;

			return true;
		}

		bool ValidateValue(const uchar* pktStart, uint16 pktSize, uint16& dataSize)
		{
			return (nullptr != pktStart && 0 < pktSize && 0 < dataSize) ? true : false;
		}

	}; // Camplist

public:
	uint16 mPktSize;
	uint16 mPktId;
	uint16 mCamplistCount;
	uint16 mFirstCamplistOffset;

public:
#ifdef _SERVER 
	bool GetServerTaskIdRealTime(OUT [[maybe_unused]] int& serverTaskId) const { return false; }
	const wchar_t* GetPacketName() const { return L"GW_WORLD_CHANNEL_CAMP_LIST"; }
	const wchar_t* GetRelatedPacketName() const { return L"WG_WORLD_CHANNEL_CAMP_LIST"; }
#endif


	using CamplistIterator = PktIterator<Camplist>;
	const CamplistIterator GetLastCamplistIterator() const
	{
		return CamplistIterator(0);
	}
	CamplistIterator GetFirstCamplistIterator() const
	{
		if (mFirstCamplistOffset && mPktSize >= mFirstCamplistOffset + sizeof(Camplist))
		{
			Camplist* camplist = (Camplist*)((uchar*)this + mFirstCamplistOffset);
			if (mFirstCamplistOffset == camplist->mThisOffset)
				return CamplistIterator(camplist);
			else
				return CamplistIterator(0);
		}
		else
			return CamplistIterator(0);
	}
	const int GetCamplistCount()
	{
		return mCamplistCount;
	}
#ifdef _SERVER
	template<typename TFunc>
	void ForEachCamplist(TFunc&& func)
	{
		for (auto it = GetFirstCamplistIterator(); it != GetLastCamplistIterator(); ++it)
			func(it);
	}
#endif


#ifdef _SERVER 
	std::xwstring FuncCreateCamplistStr( [[maybe_unused]] CamplistIterator& iter) const
	{
		return Log::format(
			L"CampPosition: {}, MapId: {}, ChannelId: {}", 
			iter->CampPosition(), iter->MapId(), iter->ChannelId()
		).c_str();
	}

	std::xwstring GetLogWString() const
	{
		std::xwstring str1;
		str1.append(L"\n");
		for (CamplistIterator iter = this->GetFirstCamplistIterator();
			iter != GetLastCamplistIterator(); ++iter)
		{
			str1.append(L"[");
			str1.append(FuncCreateCamplistStr(iter).c_str());

			str1.append(L"]\n");
		}

		return Log::format(
			L"[GW_WORLD_CHANNEL_CAMP_LIST] Camplist : {}"
			, str1.c_str()
		).c_str();
	}
#endif

	bool Validate()
	{
		uchar* pktStart = (uchar*)this;
		uint16 pktSize = mPktSize;

		uint16 dataSize = sizeof(PKT_GW_WORLD_CHANNEL_CAMP_LIST_READ);
		if (dataSize > mPktSize)
			return false;

		if (false == ValidateValue(pktStart, pktSize, dataSize))
			return false;

		if (false == CamplistValidateListNode(mFirstCamplistOffset, pktStart, pktSize, dataSize))
			return false;

		if (dataSize != mPktSize)
			return false;

		return true;
	}

	bool CamplistValidateListNode(uint16 offset, uchar * pktStart, uint16 pktSize, uint16& dataSize)
	{		for (CamplistIterator iter = this->GetFirstCamplistIterator();
			iter != GetLastCamplistIterator(); ++iter)
		{
			if (false == (*iter).Validate(offset, pktStart, pktSize, dataSize))
			{
				return false;
			}
		}
		return true;
	}

	bool ValidateValue(const uchar* pktStart, uint16 pktSize, uint16& dataSize)
	{
		return (nullptr != pktStart && 0 < pktSize && 0 < dataSize) ? true : false;
	}

}; // PKT_GW_WORLD_CHANNEL_CAMP_LIST_READ

