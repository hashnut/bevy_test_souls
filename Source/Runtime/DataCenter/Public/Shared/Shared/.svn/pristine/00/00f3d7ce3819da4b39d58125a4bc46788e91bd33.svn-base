// type = GW
struct PKT_GW_PARTY_CREATE_READ
{
	struct PartyMemberInfoList
	{
	protected:
		uint16 mThisOffset;
		uint16 mNextOffset;
		int mSlotIndex;
		int64 mGameId;
		MapId mMapId;
		ChannelId mChannelId;
		FVector mPos;

	public:
		int SlotIndex() { return mSlotIndex; }
		int64 GameId() { return mGameId; }
		MapId MapId() { return mMapId; }
		ChannelId ChannelId() { return mChannelId; }
		const FVector& ConstRefPos() { return mPos; }
		FVector Pos() { return mPos; }

		friend PktIterator<PartyMemberInfoList>;
		friend PKT_GW_PARTY_CREATE_READ;

		bool Validate(uint16 offset, uchar * pktStart, uint16 pktSize, uint16& dataSize)
		{
			if (static_cast<size_t>(pktSize) < static_cast<size_t>(offset) + sizeof(PartyMemberInfoList))
				return false;

			PartyMemberInfoList * node = (PartyMemberInfoList*)(pktStart + offset);

			// 자기 자신의 포인터 검증
			if (offset != node->mThisOffset)
				return false;

			// Value 검증
			uchar* pktCurrentNodeStart = (uchar*)this - mThisOffset;
			uint16 pktCurrentNodeSize = *((uint16*)pktStart);
			dataSize += sizeof(PartyMemberInfoList);	// skip
			if (false == ValidateValue(pktCurrentNodeStart, pktCurrentNodeSize, dataSize))
				return false;

			return true;
		}

		bool ValidateValue(const uchar* pktStart, uint16 pktSize, uint16& dataSize)
		{
			return (nullptr != pktStart && 0 < pktSize && 0 < dataSize) ? true : false;
		}

	}; // PartyMemberInfoList

public:
	uint16 mPktSize;
	uint16 mPktId;
	uint16 mPartyMemberInfoListCount;
	uint16 mFirstPartyMemberInfoListOffset;
	PartyId mPartyId;
	WorldId mGatewayWorldId;
	UserDBId mLeaderId;
	int mLeaderSlotIndex;
	PartyDropOwnershipType mDropOwnershipType;
	PartyType mPartyType;

public:
#ifdef _SERVER 
	bool GetServerTaskIdRealTime(OUT [[maybe_unused]] int& serverTaskId) const { return false; }
	const wchar_t* GetPacketName() const { return L"GW_PARTY_CREATE"; }
	const wchar_t* GetRelatedPacketName() const { return L"WG_PARTY_CREATE"; }
#endif

	PartyId PartyId() { return mPartyId; }
	WorldId GatewayWorldId() { return mGatewayWorldId; }
	UserDBId LeaderId() { return mLeaderId; }
	int LeaderSlotIndex() { return mLeaderSlotIndex; }
	PartyDropOwnershipType DropOwnershipType() { return mDropOwnershipType; }
	PartyType PartyType() { return mPartyType; }

	using PartyMemberInfoListIterator = PktIterator<PartyMemberInfoList>;
	const PartyMemberInfoListIterator GetLastPartyMemberInfoListIterator() const
	{
		return PartyMemberInfoListIterator(0);
	}
	PartyMemberInfoListIterator GetFirstPartyMemberInfoListIterator() const
	{
		if (mFirstPartyMemberInfoListOffset && mPktSize >= mFirstPartyMemberInfoListOffset + sizeof(PartyMemberInfoList))
		{
			PartyMemberInfoList* partyMemberInfoList = (PartyMemberInfoList*)((uchar*)this + mFirstPartyMemberInfoListOffset);
			if (mFirstPartyMemberInfoListOffset == partyMemberInfoList->mThisOffset)
				return PartyMemberInfoListIterator(partyMemberInfoList);
			else
				return PartyMemberInfoListIterator(0);
		}
		else
			return PartyMemberInfoListIterator(0);
	}
	const int GetPartyMemberInfoListCount()
	{
		return mPartyMemberInfoListCount;
	}
#ifdef _SERVER
	template<typename TFunc>
	void ForEachPartyMemberInfoList(TFunc&& func)
	{
		for (auto it = GetFirstPartyMemberInfoListIterator(); it != GetLastPartyMemberInfoListIterator(); ++it)
			func(it);
	}
#endif


#ifdef _SERVER 
	std::xwstring FuncCreatePartyMemberInfoListStr( [[maybe_unused]] PartyMemberInfoListIterator& iter) const
	{
		return Log::format(
			L"SlotIndex: {}, GameId: {}, MapId: {}, ChannelId: {}, Pos: {}", 
			iter->SlotIndex(), iter->GameId(), iter->MapId(), iter->ChannelId(), iter->Pos()
		).c_str();
	}

	std::xwstring GetLogWString() const
	{
		std::xwstring str1;
		str1.append(L"\n");
		for (PartyMemberInfoListIterator iter = this->GetFirstPartyMemberInfoListIterator();
			iter != GetLastPartyMemberInfoListIterator(); ++iter)
		{
			str1.append(L"[");
			str1.append(FuncCreatePartyMemberInfoListStr(iter).c_str());

			str1.append(L"]\n");
		}

		return Log::format(
			L"[GW_PARTY_CREATE] PartyId: {}, GatewayWorldId: {}, LeaderId: {}, LeaderSlotIndex: {}, DropOwnershipType: {}, PartyType: {}, PartyMemberInfoList : {}"
			, mPartyId, mGatewayWorldId, mLeaderId, mLeaderSlotIndex, mDropOwnershipType, mPartyType, str1.c_str()
		).c_str();
	}
#endif

	bool Validate()
	{
		uchar* pktStart = (uchar*)this;
		uint16 pktSize = mPktSize;

		uint16 dataSize = sizeof(PKT_GW_PARTY_CREATE_READ);
		if (dataSize > mPktSize)
			return false;

		if (false == ValidateValue(pktStart, pktSize, dataSize))
			return false;

		if (false == PartyMemberInfoListValidateListNode(mFirstPartyMemberInfoListOffset, pktStart, pktSize, dataSize))
			return false;

		if (dataSize != mPktSize)
			return false;

		return true;
	}

	bool PartyMemberInfoListValidateListNode(uint16 offset, uchar * pktStart, uint16 pktSize, uint16& dataSize)
	{		for (PartyMemberInfoListIterator iter = this->GetFirstPartyMemberInfoListIterator();
			iter != GetLastPartyMemberInfoListIterator(); ++iter)
		{
			if (false == (*iter).Validate(offset, pktStart, pktSize, dataSize))
			{
				return false;
			}
		}
		return true;
	}

	bool ValidateValue(const uchar* pktStart, uint16 pktSize, uint16& dataSize)
	{
		return (nullptr != pktStart && 0 < pktSize && 0 < dataSize) ? true : false;
	}

}; // PKT_GW_PARTY_CREATE_READ

