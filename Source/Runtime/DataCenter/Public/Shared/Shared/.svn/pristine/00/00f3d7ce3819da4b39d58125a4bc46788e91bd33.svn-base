	template <typename Container, typename Data>
	void MakeRewardItemsCreatedVector(Container & container)
	{
		for (int offset = 0; offset < mRewardItemsCreatedSize; offset += sizeof(Data))
		{
			const Data* data = reinterpret_cast<const Data*>(RewardItemsCreated() + offset);
			container.Add(*data);
		}
	}
#endif // _SERVER
#ifdef _SERVER
