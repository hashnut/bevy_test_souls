	{
		return mGuildRankRewardInfoListSize;
	}
#ifdef _SERVER
	template <typename Container>
	void MakeGuildRankRewardInfoListVector(Container & container)
	{
		//emplace() 호출할때마다 메모리를 생성 하는 비용이 발생한다 비용을줄이위개 reserve()사용
		container.reserve(mGuildRankRewardInfoListSize/sizeof(_T1));
		for (int offset = 0; offset < mGuildRankRewardInfoListSize; offset += sizeof(_T1))
		{
			const _T1* data = reinterpret_cast<const _T1*>(GuildRankRewardInfoList() + offset);
			container.emplace_back(*data);
		}
	}
