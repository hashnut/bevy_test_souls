			uchar* pktCurrentNodeStart = (uchar*)this - mThisOffset;
			uint16 pktCurrentNodeSize = *((uint16*)pktStart);
			dataSize += sizeof(GuildSimples);	// skip
			if (false == ValidateValue(pktCurrentNodeStart, pktCurrentNodeSize, dataSize))
				return false;

			if (false == GuildSimples::HostileListValidateListNode(mFirstHostileListOffset, pktStart, pktSize, dataSize))
				return false;

			if (false == GuildSimples::AllyListValidateListNode(mFirstAllyListOffset, pktStart, pktSize, dataSize))
				return false;

			return true;
		}

		bool HostileListValidateListNode(uint16 offset, uchar * pktStart, uint16 pktSize, uint16& dataSize)
		{
			for (HostileListIterator iter = this->GetFirstHostileListIterator();
				iter != GetLastHostileListIterator(); ++iter)
			{
				if (false == (*iter).Validate(offset, pktStart, pktSize, dataSize))
				{
					return false;
				}
