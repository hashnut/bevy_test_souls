	PKT_GW_ACK_DB_SKILL_LEARN_WRITE(uchar* buf, int bufSize, ServerTaskId taskId, bool success, const T0* skillSlotDataList)
		:
		mPktWriter(buf, bufSize)

	{
		mPktWriter << static_cast<uint16>(PD::GW::GWPacketId::GW_ACK_DB_SKILL_LEARN);
		mSkillSlotDataListOffset = (uint16*)mPktWriter.GetBuffer();
		*mSkillSlotDataListOffset = 0;
		mPktWriter << (*mSkillSlotDataListOffset);
		mSkillSlotDataListSize = (uint16*)mPktWriter.GetBuffer();
		*mSkillSlotDataListSize = 0;
		mPktWriter << (*mSkillSlotDataListSize);
		mPktWriter << taskId;
		mPktWriter << success;
		*mSkillSlotDataListOffset = (uint16)mPktWriter.GetPktSize();
		if (skillSlotDataList && 0 < skillSlotDataList->Num())
		{
			int tvalsize = (int)sizeof(*(skillSlotDataList->begin())); 
			auto _skillSlotDataList = (T0*)skillSlotDataList;
			for (auto it = _skillSlotDataList->begin(); it != _skillSlotDataList->end(); ++it) 
			{
				mPktWriter.WriteBinary((uint16)tvalsize, (uchar*)&(*it)); 
			}
			*mSkillSlotDataListSize = (uint16)(tvalsize* skillSlotDataList->Num());
		}
	}

#endif // _SERVER
#ifdef _SERVER
	template <typename T0>
	PKT_GW_ACK_DB_SKILL_LEARN_WRITE(SendBufferHelper& sendBuffer, ServerTaskId taskId, bool success, const T0* skillSlotDataList)
		:
