// type = GW
struct PKT_GW_GUILD_ASYNC_GUILDWAR_ENTRY_INFO_READ
{
	struct EntrymemberList
	{
	protected:
		uint16 mThisOffset;
		uint16 mNextOffset;
		UserDBId mMember;

	public:
		UserDBId Member() { return mMember; }

		friend PktIterator<EntrymemberList>;
		friend PKT_GW_GUILD_ASYNC_GUILDWAR_ENTRY_INFO_READ;

		bool Validate(uint16 offset, uchar * pktStart, uint16 pktSize, uint16& dataSize)
		{
			if (static_cast<size_t>(pktSize) < static_cast<size_t>(offset) + sizeof(EntrymemberList))
				return false;

			EntrymemberList * node = (EntrymemberList*)(pktStart + offset);

			// 자기 자신의 포인터 검증
			if (offset != node->mThisOffset)
				return false;

			// Value 검증
			uchar* pktCurrentNodeStart = (uchar*)this - mThisOffset;
			uint16 pktCurrentNodeSize = *((uint16*)pktStart);
			dataSize += sizeof(EntrymemberList);	// skip
			if (false == ValidateValue(pktCurrentNodeStart, pktCurrentNodeSize, dataSize))
				return false;

			return true;
		}

		bool ValidateValue(const uchar* pktStart, uint16 pktSize, uint16& dataSize)
		{
			return (nullptr != pktStart && 0 < pktSize && 0 < dataSize) ? true : false;
		}

	}; // EntrymemberList

public:
	uint16 mPktSize;
	uint16 mPktId;
	uint16 mEntrymemberListCount;
	uint16 mFirstEntrymemberListOffset;
	GuildDBId mGuildDBId;
	GuildWarMatchPointInfo mMatchPointInfo;
	uint64 mEventId;

public:
#ifdef _SERVER 
	bool GetServerTaskIdRealTime(OUT [[maybe_unused]] int& serverTaskId) const { return false; }
	const wchar_t* GetPacketName() const { return L"GW_GUILD_ASYNC_GUILDWAR_ENTRY_INFO"; }
	const wchar_t* GetRelatedPacketName() const { return L"WG_GUILD_ASYNC_GUILDWAR_ENTRY_INFO"; }
#endif

	GuildDBId GuildDBId() { return mGuildDBId; }
	const GuildWarMatchPointInfo& ConstRefMatchPointInfo() { return mMatchPointInfo; }
	GuildWarMatchPointInfo MatchPointInfo() { return mMatchPointInfo; }
	uint64 EventId() { return mEventId; }

	using EntrymemberListIterator = PktIterator<EntrymemberList>;
	const EntrymemberListIterator GetLastEntrymemberListIterator() const
	{
		return EntrymemberListIterator(0);
	}
	EntrymemberListIterator GetFirstEntrymemberListIterator() const
	{
		if (mFirstEntrymemberListOffset && mPktSize >= mFirstEntrymemberListOffset + sizeof(EntrymemberList))
		{
			EntrymemberList* entrymemberList = (EntrymemberList*)((uchar*)this + mFirstEntrymemberListOffset);
			if (mFirstEntrymemberListOffset == entrymemberList->mThisOffset)
				return EntrymemberListIterator(entrymemberList);
			else
				return EntrymemberListIterator(0);
		}
		else
			return EntrymemberListIterator(0);
	}
	const int GetEntrymemberListCount()
	{
		return mEntrymemberListCount;
	}
#ifdef _SERVER
	template<typename TFunc>
	void ForEachEntrymemberList(TFunc&& func)
	{
		for (auto it = GetFirstEntrymemberListIterator(); it != GetLastEntrymemberListIterator(); ++it)
			func(it);
	}
#endif


#ifdef _SERVER 
	std::xwstring FuncCreateEntrymemberListStr( [[maybe_unused]] EntrymemberListIterator& iter) const
	{
		return Log::format(
			L"Member: {}", 
			iter->Member()
		).c_str();
	}

	std::xwstring GetLogWString() const
	{
		std::xwstring str1;
		str1.append(L"\n");
		for (EntrymemberListIterator iter = this->GetFirstEntrymemberListIterator();
			iter != GetLastEntrymemberListIterator(); ++iter)
		{
			str1.append(L"[");
			str1.append(FuncCreateEntrymemberListStr(iter).c_str());

			str1.append(L"]\n");
		}

		return Log::format(
			L"[GW_GUILD_ASYNC_GUILDWAR_ENTRY_INFO] GuildDBId: {}, MatchPointInfo: {}, EventId: {}, EntrymemberList : {}"
			, mGuildDBId, mMatchPointInfo, mEventId, str1.c_str()
		).c_str();
	}
#endif

	bool Validate()
	{
		uchar* pktStart = (uchar*)this;
		uint16 pktSize = mPktSize;

		uint16 dataSize = sizeof(PKT_GW_GUILD_ASYNC_GUILDWAR_ENTRY_INFO_READ);
		if (dataSize > mPktSize)
			return false;

		if (false == ValidateValue(pktStart, pktSize, dataSize))
			return false;

		if (false == EntrymemberListValidateListNode(mFirstEntrymemberListOffset, pktStart, pktSize, dataSize))
			return false;

		if (dataSize != mPktSize)
			return false;

		return true;
	}

	bool EntrymemberListValidateListNode(uint16 offset, uchar * pktStart, uint16 pktSize, uint16& dataSize)
	{		for (EntrymemberListIterator iter = this->GetFirstEntrymemberListIterator();
			iter != GetLastEntrymemberListIterator(); ++iter)
		{
			if (false == (*iter).Validate(offset, pktStart, pktSize, dataSize))
			{
				return false;
			}
		}
		return true;
	}

	bool ValidateValue(const uchar* pktStart, uint16 pktSize, uint16& dataSize)
	{
		return (nullptr != pktStart && 0 < pktSize && 0 < dataSize) ? true : false;
	}

}; // PKT_GW_GUILD_ASYNC_GUILDWAR_ENTRY_INFO_READ

// type = GW
#ifdef _SERVER
