// type = GW
struct PKT_GW_NOTIFY_TITLE_UPDATE_LIST_READ
{
public:
	uint16 mPktSize;
	uint16 mPktId;
	uint16 mTitleListOffset;
	uint16 mTitleListSize;
	UserDBId mUserDBId;
	bool mIsChangedStatus;

public:
#ifdef _SERVER 
	using _T0 = TitleInfo;
	bool GetServerTaskIdRealTime(OUT [[maybe_unused]] int& serverTaskId) const { return false; }
	const wchar_t* GetPacketName() const { return L"GW_NOTIFY_TITLE_UPDATE_LIST"; }
	const wchar_t* GetRelatedPacketName() const { return L"WG_NOTIFY_TITLE_UPDATE_LIST"; }
#endif

	UserDBId UserDBId() { return mUserDBId; }
	bool IsChangedStatus() { return mIsChangedStatus; }
	const uchar* TitleList() const
	{
		uchar* pktStart = (uchar*)this;
		uint16 pktSize = *((uint16*)pktStart);
		if (mTitleListOffset && pktSize > mTitleListOffset)
			return (const uchar*)(pktStart + mTitleListOffset);
		else
			return 0;
	}
	int TitleListSize() const
	{
		return mTitleListSize;
	}
#ifdef _SERVER
	template <typename Container>
	void MakeTitleListVector(Container & container)
	{
		//emplace() 호출할때마다 메모리를 생성 하는 비용이 발생한다 비용을줄이위개 reserve()사용
		container.reserve(mTitleListSize/sizeof(_T0));
		for (int offset = 0; offset < mTitleListSize; offset += sizeof(_T0))
		{
			const _T0* data = reinterpret_cast<const _T0*>(TitleList() + offset);
			container.emplace_back(*data);
		}
	}
#else // _SERVER
	template <typename Container, typename Data>
	void MakeTitleListVector(Container & container)
	{
		for (int offset = 0; offset < mTitleListSize; offset += sizeof(Data))
		{
			const Data* data = reinterpret_cast<const Data*>(TitleList() + offset);
			container.Add(*data);
		}
	}
#endif // _SERVER
#ifdef _SERVER
	template <typename TFunc>
	void ForEachTitleList(TFunc&& func) const
	{
		for (int offset = 0; offset < TitleListSize(); offset += sizeof(_T0))
		{
			const _T0* data = reinterpret_cast<const _T0*>(TitleList() + offset);
			func(data);
		}
	}
#endif


#ifdef _SERVER 
	std::xwstring GetLogWString() const
	{

		return Log::format(
			L"[GW_NOTIFY_TITLE_UPDATE_LIST] UserDBId: {}, IsChangedStatus: {}"
			, mUserDBId, mIsChangedStatus
		).c_str();
	}
#endif

	bool Validate()
	{
		uchar* pktStart = (uchar*)this;
		uint16 pktSize = mPktSize;

		uint16 dataSize = sizeof(PKT_GW_NOTIFY_TITLE_UPDATE_LIST_READ);
		if (dataSize > mPktSize)
			return false;

		if (false == ValidateValue(pktStart, pktSize, dataSize))
			return false;

		if (dataSize != mPktSize)
			return false;

		return true;
	}

	bool ValidateValue(const uchar* pktStart, uint16 pktSize, uint16& dataSize)
	{
		if (false == ValidateBinary(mTitleListOffset, mTitleListSize, 0, pktSize, dataSize))
			return false;

		return (nullptr != pktStart && 0 < pktSize && 0 < dataSize) ? true : false;
	}

}; // PKT_GW_NOTIFY_TITLE_UPDATE_LIST_READ

// type = GW
#ifdef _SERVER
struct PKT_GW_NOTIFY_TITLE_UPDATE_LIST_WRITE : public Disposable
#else
struct PKT_GW_NOTIFY_TITLE_UPDATE_LIST_WRITE
#endif
{
	PktWriter mPktWriter;
	uint16* mTitleListOffset;
	uint16* mTitleListSize;

#ifdef _SERVER 
	using _T0 = TitleInfo;
	bool GetServerTaskIdRealTime(OUT int& serverTaskId) const { return reinterpret_cast<PKT_GW_NOTIFY_TITLE_UPDATE_LIST_READ*>(mPktWriter.mBuf)->GetServerTaskIdRealTime(serverTaskId); }
	const wchar_t* GetPacketName() const { return L"GW_NOTIFY_TITLE_UPDATE_LIST"; }
	const wchar_t* GetRelatedPacketName() const { return L"WG_NOTIFY_TITLE_UPDATE_LIST"; }
#endif

#ifndef _SERVER
	template <typename T0>
	PKT_GW_NOTIFY_TITLE_UPDATE_LIST_WRITE(uchar* buf, int bufSize, UserDBId userDBId, const T0* titleList, bool isChangedStatus)
		:
		mPktWriter(buf, bufSize)

	{
		mPktWriter << static_cast<uint16>(PD::GW::GWPacketId::GW_NOTIFY_TITLE_UPDATE_LIST);
		mTitleListOffset = (uint16*)mPktWriter.GetBuffer();
		*mTitleListOffset = 0;
		mPktWriter << (*mTitleListOffset);
		mTitleListSize = (uint16*)mPktWriter.GetBuffer();
		*mTitleListSize = 0;
		mPktWriter << (*mTitleListSize);
		mPktWriter << userDBId;
		mPktWriter << isChangedStatus;
		*mTitleListOffset = (uint16)mPktWriter.GetPktSize();
		if (titleList && 0 < titleList->Num())
		{
			int tvalsize = (int)sizeof(*(titleList->begin())); 
			auto _titleList = (T0*)titleList;
			for (auto it = _titleList->begin(); it != _titleList->end(); ++it) 
			{
				mPktWriter.WriteBinary((uint16)tvalsize, (uchar*)&(*it)); 
			}
			*mTitleListSize = (uint16)(tvalsize* titleList->Num());
		}
	}

#endif // _SERVER
#ifdef _SERVER
	template <typename T0>
	PKT_GW_NOTIFY_TITLE_UPDATE_LIST_WRITE(SendBufferHelper& sendBuffer, UserDBId userDBId, const T0* titleList, bool isChangedStatus)
		:
		mPktWriter(sendBuffer->GetCharBuffer(), (SEND_BUFFER_SIZE - 1))

	{
		static_assert(true == std::is_same_v<T0::value_type, _T0>, "titleList type must be TitleInfo list type"); 
		mPktWriter << (uint16)GW_NOTIFY_TITLE_UPDATE_LIST;
		mTitleListOffset = (uint16*)mPktWriter.GetBuffer();
		*mTitleListOffset = 0;
		mPktWriter << (*mTitleListOffset);
		mTitleListSize = (uint16*)mPktWriter.GetBuffer();
		*mTitleListSize = 0;
		mPktWriter << (*mTitleListSize);
		mPktWriter << userDBId;
		mPktWriter << isChangedStatus;
		*mTitleListOffset = (uint16)mPktWriter.GetPktSize();
		if (titleList && !titleList->empty())
		{
			int tvalsize = (int)sizeof(*(titleList->begin())); 
			auto _titleList = const_cast<std::decay_t<T0>*>(titleList);
			for (auto it = _titleList->begin(); it != _titleList->end(); ++it) 
			{
				mPktWriter.WriteBinary((uint16)tvalsize, (uchar*)&(*it)); 
			}
			*mTitleListSize = (uint16) (tvalsize * titleList->size());
		}
	}
#endif

#ifdef _SERVER 
	void send(IocpObjectSession* session, SendBufferRef sendBuffer, bool autoCloseSendBuffer)
	{
		if (session) 
			session->Send(sendBuffer, mPktWriter.GetPktSize(), autoCloseSendBuffer);
	}
#endif

#ifdef _SERVER 
	std::xwstring GetLogWString() const
	{
		auto readPacket = reinterpret_cast<PKT_GW_NOTIFY_TITLE_UPDATE_LIST_READ*>(mPktWriter.mBuf);
		return readPacket->GetLogWString();
	}
#endif

#ifndef _SERVER
#else
#endif
}; // PKT_GW_NOTIFY_TITLE_UPDATE_LIST_WRITE

