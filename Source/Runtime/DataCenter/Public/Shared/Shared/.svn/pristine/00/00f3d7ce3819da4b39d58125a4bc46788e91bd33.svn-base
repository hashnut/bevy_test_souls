#endif

	ServerTaskId TaskId() { return mTaskId; }
	bool Success() { return mSuccess; }
	const uchar* SkillSlotDataList() const
	{
		uchar* pktStart = (uchar*)this;
		uint16 pktSize = *((uint16*)pktStart);
		if (mSkillSlotDataListOffset && pktSize > mSkillSlotDataListOffset)
			return (const uchar*)(pktStart + mSkillSlotDataListOffset);
		else
			return 0;
	}
	int SkillSlotDataListSize() const
	{
		return mSkillSlotDataListSize;
	}
#ifdef _SERVER
	template <typename Container>
	void MakeSkillSlotDataListVector(Container & container)
	{
		//emplace() 호출할때마다 메모리를 생성 하는 비용이 발생한다 비용을줄이위개 reserve()사용
		container.reserve(mSkillSlotDataListSize/sizeof(_T0));
		for (int offset = 0; offset < mSkillSlotDataListSize; offset += sizeof(_T0))
		{
			const _T0* data = reinterpret_cast<const _T0*>(SkillSlotDataList() + offset);
			container.emplace_back(*data);
		}
	}
#else // _SERVER
	template <typename Container, typename Data>
	void MakeSkillSlotDataListVector(Container & container)
	{
		for (int offset = 0; offset < mSkillSlotDataListSize; offset += sizeof(Data))
		{
			const Data* data = reinterpret_cast<const Data*>(SkillSlotDataList() + offset);
			container.Add(*data);
		}
	}
#endif // _SERVER
#ifdef _SERVER
	template <typename TFunc>
	void ForEachSkillSlotDataList(TFunc&& func) const
	{
		for (int offset = 0; offset < SkillSlotDataListSize(); offset += sizeof(_T0))
		{
			const _T0* data = reinterpret_cast<const _T0*>(SkillSlotDataList() + offset);
			func(data);
		}
	}
#endif


