	template <typename T0>
	PKT_GW_ACK_DB_USER_QUICK_SLOT_LIST_WRITE(uchar* buf, int bufSize, ServerTaskId taskId, bool success, const T0* quickSlotDBInfoList)
		:
		mPktWriter(buf, bufSize)

	{
		mPktWriter << static_cast<uint16>(PD::GW::GWPacketId::GW_ACK_DB_USER_QUICK_SLOT_LIST);
		mQuickSlotDBInfoListOffset = (uint16*)mPktWriter.GetBuffer();
		*mQuickSlotDBInfoListOffset = 0;
		mPktWriter << (*mQuickSlotDBInfoListOffset);
		mQuickSlotDBInfoListSize = (uint16*)mPktWriter.GetBuffer();
		*mQuickSlotDBInfoListSize = 0;
		mPktWriter << (*mQuickSlotDBInfoListSize);
		mPktWriter << taskId;
		mPktWriter << success;
		*mQuickSlotDBInfoListOffset = (uint16)mPktWriter.GetPktSize();
		if (quickSlotDBInfoList && 0 < quickSlotDBInfoList->Num())
		{
