// type = GW
struct PKT_GW_PARTY_LIST_READ
{
	struct PartyList
	{
		struct PartyMemberInfoList
		{
		protected:
			uint16 mThisOffset;
			uint16 mNextOffset;
			int mSlotIndex;
			int64 mGameId;
			MapId mMapId;
			ChannelId mChannelId;
			FVector mPos;

		public:
			int SlotIndex() { return mSlotIndex; }
			int64 GameId() { return mGameId; }
			MapId MapId() { return mMapId; }
			ChannelId ChannelId() { return mChannelId; }
			const FVector& ConstRefPos() { return mPos; }
			FVector Pos() { return mPos; }

			friend PktIterator<PartyList::PartyMemberInfoList>;
			friend PartyList;

			bool Validate(uint16 offset, uchar * pktStart, uint16 pktSize, uint16& dataSize)
			{
				if (static_cast<size_t>(pktSize) < static_cast<size_t>(offset) + sizeof(PartyList::PartyMemberInfoList))
					return false;

				PartyList::PartyMemberInfoList * node = (PartyList::PartyMemberInfoList*)(pktStart + offset);

				// 자기 자신의 포인터 검증
				if (offset != node->mThisOffset)
					return false;

				// Value 검증
				uchar* pktCurrentNodeStart = (uchar*)this - mThisOffset;
				uint16 pktCurrentNodeSize = *((uint16*)pktStart);
				dataSize += sizeof(PartyList::PartyMemberInfoList);	// skip
				if (false == ValidateValue(pktCurrentNodeStart, pktCurrentNodeSize, dataSize))
					return false;

				return true;
			}

			bool ValidateValue(const uchar* pktStart, uint16 pktSize, uint16& dataSize)
			{
				return (nullptr != pktStart && 0 < pktSize && 0 < dataSize) ? true : false;
			}

		}; // PartyMemberInfoList

	protected:
		uint16 mThisOffset;
		uint16 mNextOffset;
		uint16 mPartyMemberInfoListCount;
		uint16 mFirstPartyMemberInfoListOffset;
		PartyId mPartyId;
		UserDBId mLeaderId;
		int mLeaderSlotIndex;
		PartyDropOwnershipType mDropOwnershipType;
		PartyType mPartyType;

	public:
		PartyId PartyId() { return mPartyId; }
		UserDBId LeaderId() { return mLeaderId; }
		int LeaderSlotIndex() { return mLeaderSlotIndex; }
		PartyDropOwnershipType DropOwnershipType() { return mDropOwnershipType; }
		PartyType PartyType() { return mPartyType; }

		using PartyMemberInfoListIterator = PktIterator<PartyMemberInfoList>;
		const PartyMemberInfoListIterator GetLastPartyMemberInfoListIterator() const
		{
			return PartyMemberInfoListIterator(0);
		}
		PartyMemberInfoListIterator GetFirstPartyMemberInfoListIterator() const
		{
			uchar* pktStart = (uchar*)this - mThisOffset;
			uint16 pktSize = *((uint16*)pktStart);
			if (mFirstPartyMemberInfoListOffset && pktSize >= mFirstPartyMemberInfoListOffset + sizeof(PartyMemberInfoList))
			{
				PartyMemberInfoList* partyMemberInfoList = (PartyMemberInfoList*)(pktStart + mFirstPartyMemberInfoListOffset);
				if (mFirstPartyMemberInfoListOffset == partyMemberInfoList->mThisOffset)
					return PartyMemberInfoListIterator(partyMemberInfoList);
				else
					return PartyMemberInfoListIterator(0);
			}
			else
				return PartyMemberInfoListIterator(0);
		}
		const int GetPartyMemberInfoListCount()
		{
			return mPartyMemberInfoListCount;
		}
#ifdef _SERVER
		template<typename TFunc>
		void ForEachPartyMemberInfoList(TFunc&& func)
		{
			for (auto it = GetFirstPartyMemberInfoListIterator(); it != GetLastPartyMemberInfoListIterator(); ++it)
				func(it);
		}
#endif

		friend PktIterator<PartyList>;
		friend PKT_GW_PARTY_LIST_READ;

		bool Validate(uint16 offset, uchar * pktStart, uint16 pktSize, uint16& dataSize)
		{
			if (static_cast<size_t>(pktSize) < static_cast<size_t>(offset) + sizeof(PartyList))
				return false;

			PartyList * node = (PartyList*)(pktStart + offset);

			// 자기 자신의 포인터 검증
			if (offset != node->mThisOffset)
				return false;

			// Value 검증
			uchar* pktCurrentNodeStart = (uchar*)this - mThisOffset;
			uint16 pktCurrentNodeSize = *((uint16*)pktStart);
			dataSize += sizeof(PartyList);	// skip
			if (false == ValidateValue(pktCurrentNodeStart, pktCurrentNodeSize, dataSize))
				return false;

			if (false == PartyList::PartyMemberInfoListValidateListNode(mFirstPartyMemberInfoListOffset, pktStart, pktSize, dataSize))
				return false;

			return true;
		}

		bool PartyMemberInfoListValidateListNode(uint16 offset, uchar * pktStart, uint16 pktSize, uint16& dataSize)
		{
			for (PartyMemberInfoListIterator iter = this->GetFirstPartyMemberInfoListIterator();
				iter != GetLastPartyMemberInfoListIterator(); ++iter)
			{
				if (false == (*iter).Validate(offset, pktStart, pktSize, dataSize))
				{
					return false;
				}
			}
			return true;
		}

		bool ValidateValue(const uchar* pktStart, uint16 pktSize, uint16& dataSize)
		{
			return (nullptr != pktStart && 0 < pktSize && 0 < dataSize) ? true : false;
		}

	}; // PartyList

public:
	uint16 mPktSize;
	uint16 mPktId;
	uint16 mPartyListCount;
	uint16 mFirstPartyListOffset;
	int mPacketIdx;
	int mTotalPacketCount;
	WorldId mGatewayWorldId;

public:
#ifdef _SERVER 
	bool GetServerTaskIdRealTime(OUT [[maybe_unused]] int& serverTaskId) const { return false; }
	const wchar_t* GetPacketName() const { return L"GW_PARTY_LIST"; }
	const wchar_t* GetRelatedPacketName() const { return L"WG_PARTY_LIST"; }
#endif

	int PacketIdx() { return mPacketIdx; }
	int TotalPacketCount() { return mTotalPacketCount; }
	WorldId GatewayWorldId() { return mGatewayWorldId; }

	using PartyListIterator = PktIterator<PartyList>;
	const PartyListIterator GetLastPartyListIterator() const
	{
		return PartyListIterator(0);
	}
	PartyListIterator GetFirstPartyListIterator() const
	{
		if (mFirstPartyListOffset && mPktSize >= mFirstPartyListOffset + sizeof(PartyList))
		{
			PartyList* partyList = (PartyList*)((uchar*)this + mFirstPartyListOffset);
			if (mFirstPartyListOffset == partyList->mThisOffset)
				return PartyListIterator(partyList);
			else
				return PartyListIterator(0);
		}
		else
			return PartyListIterator(0);
	}
	const int GetPartyListCount()
	{
		return mPartyListCount;
	}
#ifdef _SERVER
	template<typename TFunc>
	void ForEachPartyList(TFunc&& func)
	{
		for (auto it = GetFirstPartyListIterator(); it != GetLastPartyListIterator(); ++it)
			func(it);
	}
#endif


#ifdef _SERVER 
	std::xwstring FuncCreatePartyMemberInfoListStr( [[maybe_unused]] PartyList::PartyMemberInfoListIterator& iter) const
	{
		return Log::format(
			L"SlotIndex: {}, GameId: {}, MapId: {}, ChannelId: {}, Pos: {}", 
			iter->SlotIndex(), iter->GameId(), iter->MapId(), iter->ChannelId(), iter->Pos()
		).c_str();
	}

	std::xwstring FuncCreatePartyListStr( [[maybe_unused]] PartyListIterator& iter) const
	{
		return Log::format(
			L"PartyId: {}, LeaderId: {}, LeaderSlotIndex: {}, DropOwnershipType: {}, PartyType: {}", 
			iter->PartyId(), iter->LeaderId(), iter->LeaderSlotIndex(), iter->DropOwnershipType(), iter->PartyType()
		).c_str();
	}

	std::xwstring GetLogWString() const
	{
		std::xwstring str1;
		str1.append(L"\n");
		for (PartyListIterator iter = this->GetFirstPartyListIterator();
			iter != GetLastPartyListIterator(); ++iter)
		{
			str1.append(L"[");
			str1.append(FuncCreatePartyListStr(iter).c_str());

			for (PartyList::PartyMemberInfoListIterator PartyMemberInfoListIter = iter->GetFirstPartyMemberInfoListIterator();
				PartyMemberInfoListIter != iter->GetLastPartyMemberInfoListIterator(); ++PartyMemberInfoListIter)
			{
				str1.append(FuncCreatePartyMemberInfoListStr(PartyMemberInfoListIter).c_str());

			}

			str1.append(L"]\n");
		}

		return Log::format(
			L"[GW_PARTY_LIST] PacketIdx: {}, TotalPacketCount: {}, GatewayWorldId: {}, PartyList : {}"
			, mPacketIdx, mTotalPacketCount, mGatewayWorldId, str1.c_str()
		).c_str();
	}
#endif

	bool Validate()
	{
		uchar* pktStart = (uchar*)this;
		uint16 pktSize = mPktSize;

		uint16 dataSize = sizeof(PKT_GW_PARTY_LIST_READ);
		if (dataSize > mPktSize)
			return false;

		if (false == ValidateValue(pktStart, pktSize, dataSize))
			return false;

		if (false == PartyListValidateListNode(mFirstPartyListOffset, pktStart, pktSize, dataSize))
			return false;

		if (dataSize != mPktSize)
			return false;

		return true;
	}

	bool PartyListValidateListNode(uint16 offset, uchar * pktStart, uint16 pktSize, uint16& dataSize)
	{		for (PartyListIterator iter = this->GetFirstPartyListIterator();
			iter != GetLastPartyListIterator(); ++iter)
		{
			if (false == (*iter).Validate(offset, pktStart, pktSize, dataSize))
			{
				return false;
			}
		}
		return true;
	}

	bool ValidateValue(const uchar* pktStart, uint16 pktSize, uint16& dataSize)
	{
		return (nullptr != pktStart && 0 < pktSize && 0 < dataSize) ? true : false;
	}

}; // PKT_GW_PARTY_LIST_READ

