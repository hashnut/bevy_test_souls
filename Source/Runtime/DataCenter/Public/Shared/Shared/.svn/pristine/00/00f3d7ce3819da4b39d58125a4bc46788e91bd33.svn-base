struct PKT_GW_GM_UNLOCK_CONTENTS_ADD_READ
{
	struct AddUnlockContentsList
	{
	protected:
		uint16 mThisOffset;
		uint16 mNextOffset;
		UnlockContentsId mUnlockContentsId;
		int mResult;

	public:
		UnlockContentsId UnlockContentsId() { return mUnlockContentsId; }
		int Result() { return mResult; }

		friend PktIterator<AddUnlockContentsList>;
		friend PKT_GW_GM_UNLOCK_CONTENTS_ADD_READ;

		bool Validate(uint16 offset, uchar * pktStart, uint16 pktSize, uint16& dataSize)
		{
			if (static_cast<size_t>(pktSize) < static_cast<size_t>(offset) + sizeof(AddUnlockContentsList))
				return false;

			AddUnlockContentsList * node = (AddUnlockContentsList*)(pktStart + offset);

			// 자기 자신의 포인터 검증
			if (offset != node->mThisOffset)
				return false;

			// Value 검증
			uchar* pktCurrentNodeStart = (uchar*)this - mThisOffset;
			uint16 pktCurrentNodeSize = *((uint16*)pktStart);
			dataSize += sizeof(AddUnlockContentsList);	// skip
			if (false == ValidateValue(pktCurrentNodeStart, pktCurrentNodeSize, dataSize))
				return false;

			return true;
		}

		bool ValidateValue(const uchar* pktStart, uint16 pktSize, uint16& dataSize)
		{
			return (nullptr != pktStart && 0 < pktSize && 0 < dataSize) ? true : false;
		}

	}; // AddUnlockContentsList

public:
	uint16 mPktSize;
	uint16 mPktId;
	uint16 mAddUnlockContentsListCount;
	uint16 mFirstAddUnlockContentsListOffset;

public:
#ifdef _SERVER 
	bool GetServerTaskIdRealTime(OUT [[maybe_unused]] int& serverTaskId) const { return false; }
	const wchar_t* GetPacketName() const { return L"GW_GM_UNLOCK_CONTENTS_ADD"; }
	const wchar_t* GetRelatedPacketName() const { return L"WG_GM_UNLOCK_CONTENTS_ADD"; }
#endif


	using AddUnlockContentsListIterator = PktIterator<AddUnlockContentsList>;
	const AddUnlockContentsListIterator GetLastAddUnlockContentsListIterator() const
	{
		return AddUnlockContentsListIterator(0);
	}
	AddUnlockContentsListIterator GetFirstAddUnlockContentsListIterator() const
	{
		if (mFirstAddUnlockContentsListOffset && mPktSize >= mFirstAddUnlockContentsListOffset + sizeof(AddUnlockContentsList))
		{
			AddUnlockContentsList* addUnlockContentsList = (AddUnlockContentsList*)((uchar*)this + mFirstAddUnlockContentsListOffset);
			if (mFirstAddUnlockContentsListOffset == addUnlockContentsList->mThisOffset)
				return AddUnlockContentsListIterator(addUnlockContentsList);
			else
				return AddUnlockContentsListIterator(0);
		}
		else
			return AddUnlockContentsListIterator(0);
	}
	const int GetAddUnlockContentsListCount()
	{
		return mAddUnlockContentsListCount;
	}
#ifdef _SERVER
	template<typename TFunc>
