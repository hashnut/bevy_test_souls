	{
		static_assert(true == std::is_same_v<T0::value_type, _T0>, "quickSlotDBInfoList type must be QuickSlotDBInfo list type"); 
		mPktWriter << (uint16)GW_ACK_DB_USER_QUICK_SLOT_LIST;
