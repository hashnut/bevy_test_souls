#ifdef _SERVER

////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
// Enum -> String
////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////

inline const wchar_t* GWPacketIdEnumToString(uint16 value) noexcept
{
	switch (value)
	{
		case GW_PONG: return L"GW_PONG";
		case GW_ACK_REGISTER_MAIN_SESSION: return L"GW_ACK_REGISTER_MAIN_SESSION";
		case GW_ACK_REGISTER_BYPASS_SESSION: return L"GW_ACK_REGISTER_BYPASS_SESSION";
		case GW_ACK_WORLDTIME: return L"GW_ACK_WORLDTIME";
		case GW_WORLDTIME_UPDATE: return L"GW_WORLDTIME_UPDATE";
		case GW_ADMIN_COMMAND: return L"GW_ADMIN_COMMAND";
		case GW_BYPASS_FROM_CLIENT: return L"GW_BYPASS_FROM_CLIENT";
		case GW_REQ_ENTER_WORLD: return L"GW_REQ_ENTER_WORLD";
		case GW_ACK_WORLD_SERVER_USER_CACHE_LOAD_BEGIN: return L"GW_ACK_WORLD_SERVER_USER_CACHE_LOAD_BEGIN";
		case GW_ACK_WORLD_SERVER_USER_CACHE_LOAD_ABNORMALITY: return L"GW_ACK_WORLD_SERVER_USER_CACHE_LOAD_ABNORMALITY";
		case GW_ACK_WORLD_SERVER_USER_CACHE_LOAD_END: return L"GW_ACK_WORLD_SERVER_USER_CACHE_LOAD_END";
		case GW_ACK_DB_USER_DATA: return L"GW_ACK_DB_USER_DATA";
