		mRewardItemsCreatedOffset = (uint16*)mPktWriter.GetBuffer();
		*mRewardItemsCreatedOffset = 0;
		mPktWriter << (*mRewardItemsCreatedOffset);
		mRewardItemsCreatedSize = (uint16*)mPktWriter.GetBuffer();
