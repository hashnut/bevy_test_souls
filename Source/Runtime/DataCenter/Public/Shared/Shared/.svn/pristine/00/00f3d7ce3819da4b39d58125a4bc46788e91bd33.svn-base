		:
		mPktWriter(buf, bufSize)

	{
		mPktWriter << static_cast<uint16>(PD::GW::GWPacketId::GW_WORLD_GUILD_RANK_DATA_INFO);
		mGuildRankDataListOffset = (uint16*)mPktWriter.GetBuffer();
		*mGuildRankDataListOffset = 0;
		mPktWriter << (*mGuildRankDataListOffset);
		mGuildRankDataListSize = (uint16*)mPktWriter.GetBuffer();
		*mGuildRankDataListSize = 0;
		mPktWriter << (*mGuildRankDataListSize);
		mGuildRankRewardInfoListOffset = (uint16*)mPktWriter.GetBuffer();
		*mGuildRankRewardInfoListOffset = 0;
		mPktWriter << (*mGuildRankRewardInfoListOffset);
		mGuildRankRewardInfoListSize = (uint16*)mPktWriter.GetBuffer();
		*mGuildRankRewardInfoListSize = 0;
		mPktWriter << (*mGuildRankRewardInfoListSize);
		*mGuildRankDataListOffset = (uint16)mPktWriter.GetPktSize();
		if (GuildRankDataList && 0 < GuildRankDataList->Num())
		{
			int tvalsize = (int)sizeof(*(GuildRankDataList->begin())); 
			auto _GuildRankDataList = (T0*)GuildRankDataList;
			for (auto it = _GuildRankDataList->begin(); it != _GuildRankDataList->end(); ++it) 
			{
				mPktWriter.WriteBinary((uint16)tvalsize, (uchar*)&(*it)); 
			}
			*mGuildRankDataListSize = (uint16)(tvalsize* GuildRankDataList->Num());
		}
		*mGuildRankRewardInfoListOffset = (uint16)mPktWriter.GetPktSize();
		if (GuildRankRewardInfoList && 0 < GuildRankRewardInfoList->Num())
		{
			int tvalsize = (int)sizeof(*(GuildRankRewardInfoList->begin())); 
			auto _GuildRankRewardInfoList = (T1*)GuildRankRewardInfoList;
			for (auto it = _GuildRankRewardInfoList->begin(); it != _GuildRankRewardInfoList->end(); ++it) 
			{
				mPktWriter.WriteBinary((uint16)tvalsize, (uchar*)&(*it)); 
			}
			*mGuildRankRewardInfoListSize = (uint16)(tvalsize* GuildRankRewardInfoList->Num());
		}
	}

#endif // _SERVER
