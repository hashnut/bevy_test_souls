// type = GW
// related packet = PKT_WG_REQ_DB_GUILD_STORE_ACQUIRED_ITEM_WRITE
struct PKT_GW_ACK_DB_GUILD_STORE_ACQUIRED_ITEM_READ
{
public:
	uint16 mPktSize;
	uint16 mPktId;
	uint16 mItemDataCreatedOffset;
	uint16 mItemDataCreatedSize;
	ServerTaskId mTaskId;
	bool mSuccess;
	int mResult;

public:
#ifdef _SERVER 
	using _T0 = ItemDataCreated;
	bool GetServerTaskIdRealTime(OUT int& serverTaskId) const { serverTaskId = mTaskId; return true; }
	const wchar_t* GetPacketName() const { return L"GW_ACK_DB_GUILD_STORE_ACQUIRED_ITEM"; }
	const wchar_t* GetRelatedPacketName() const { return L"WG_REQ_DB_GUILD_STORE_ACQUIRED_ITEM"; }
#endif

	ServerTaskId TaskId() { return mTaskId; }
	bool Success() { return mSuccess; }
	int Result() { return mResult; }
	const uchar* ItemDataCreated() const
	{
		uchar* pktStart = (uchar*)this;
		uint16 pktSize = *((uint16*)pktStart);
		if (mItemDataCreatedOffset && pktSize > mItemDataCreatedOffset)
			return (const uchar*)(pktStart + mItemDataCreatedOffset);
		else
			return 0;
	}
	int ItemDataCreatedSize() const
	{
		return mItemDataCreatedSize;
	}
#ifdef _SERVER
	template <typename Container>
	void MakeItemDataCreatedVector(Container & container)
	{
		//emplace() 호출할때마다 메모리를 생성 하는 비용이 발생한다 비용을줄이위개 reserve()사용
		container.reserve(mItemDataCreatedSize/sizeof(_T0));
		for (int offset = 0; offset < mItemDataCreatedSize; offset += sizeof(_T0))
		{
			const _T0* data = reinterpret_cast<const _T0*>(ItemDataCreated() + offset);
			container.emplace_back(*data);
		}
	}
#else // _SERVER
	template <typename Container, typename Data>
	void MakeItemDataCreatedVector(Container & container)
	{
		for (int offset = 0; offset < mItemDataCreatedSize; offset += sizeof(Data))
		{
			const Data* data = reinterpret_cast<const Data*>(ItemDataCreated() + offset);
			container.Add(*data);
		}
	}
#endif // _SERVER
#ifdef _SERVER
	template <typename TFunc>
	void ForEachItemDataCreated(TFunc&& func) const
	{
		for (int offset = 0; offset < ItemDataCreatedSize(); offset += sizeof(_T0))
		{
			const _T0* data = reinterpret_cast<const _T0*>(ItemDataCreated() + offset);
			func(data);
		}
	}
#endif


#ifdef _SERVER 
	std::xwstring GetLogWString() const
	{

		return Log::format(
			L"[GW_ACK_DB_GUILD_STORE_ACQUIRED_ITEM] TaskId: {}, Success: {}, Result: {}"
			, mTaskId, mSuccess, mResult
		).c_str();
	}
#endif

	bool Validate()
	{
		uchar* pktStart = (uchar*)this;
		uint16 pktSize = mPktSize;

		uint16 dataSize = sizeof(PKT_GW_ACK_DB_GUILD_STORE_ACQUIRED_ITEM_READ);
		if (dataSize > mPktSize)
			return false;

		if (false == ValidateValue(pktStart, pktSize, dataSize))
			return false;

		if (dataSize != mPktSize)
			return false;

		return true;
	}

	bool ValidateValue(const uchar* pktStart, uint16 pktSize, uint16& dataSize)
	{
		if (false == ValidateBinary(mItemDataCreatedOffset, mItemDataCreatedSize, 0, pktSize, dataSize))
			return false;

		return (nullptr != pktStart && 0 < pktSize && 0 < dataSize) ? true : false;
	}

}; // PKT_GW_ACK_DB_GUILD_STORE_ACQUIRED_ITEM_READ

