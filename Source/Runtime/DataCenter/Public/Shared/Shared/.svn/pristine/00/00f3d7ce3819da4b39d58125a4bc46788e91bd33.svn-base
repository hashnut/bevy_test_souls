struct PKT_GW_ACK_DB_MONITORING_USER_LIST_READ
{
	struct MonitoringUserInfo
	{
	protected:
		uint16 mThisOffset;
		uint16 mNextOffset;
		uint16 mUserNameOffset;
		UserDBId mUserId;
		time_t mLastLogoutTime;
		WorldId mUserWorldId;

	public:
		UserDBId UserId() { return mUserId; }
		time_t LastLogoutTime() { return mLastLogoutTime; }
		WorldId UserWorldId() { return mUserWorldId; }

#ifdef _SERVER
		const wchar_t* UserName()
		{
			uchar* pktStart = (uchar*)this - mThisOffset;
			uint16 pktSize = *((uint16*)pktStart);
			if (mUserNameOffset && pktSize > mUserNameOffset)
				return (const wchar_t*)(pktStart + mUserNameOffset);
			else
				return L"";
		}
#else // _SERVER
		const FString UserName()
		{
			const wchar_t* strWchar = L"";
			uchar* pktStart = (uchar*)this - mThisOffset;
			uint16 pktSize = *((uint16*)pktStart);
			if (mUserNameOffset && pktSize > mUserNameOffset)
				strWchar = (const wchar_t*)(pktStart + mUserNameOffset);
			return PktWriter::ConvertToFString(strWchar);
		}
#endif // _SERVER
		friend PktIterator<MonitoringUserInfo>;
		friend PKT_GW_ACK_DB_MONITORING_USER_LIST_READ;

		bool Validate(uint16 offset, uchar * pktStart, uint16 pktSize, uint16& dataSize)
		{
			if (static_cast<size_t>(pktSize) < static_cast<size_t>(offset) + sizeof(MonitoringUserInfo))
				return false;

			MonitoringUserInfo * node = (MonitoringUserInfo*)(pktStart + offset);

			// 자기 자신의 포인터 검증
			if (offset != node->mThisOffset)
				return false;

			// Value 검증
			uchar* pktCurrentNodeStart = (uchar*)this - mThisOffset;
			uint16 pktCurrentNodeSize = *((uint16*)pktStart);
			dataSize += sizeof(MonitoringUserInfo);	// skip
			if (false == ValidateValue(pktCurrentNodeStart, pktCurrentNodeSize, dataSize))
				return false;

			return true;
		}

		bool ValidateValue(const uchar* pktStart, uint16 pktSize, uint16& dataSize)
		{
			if (false == ValidateString(mUserNameOffset, 0, pktStart, pktSize, dataSize))
				return false;

			return (nullptr != pktStart && 0 < pktSize && 0 < dataSize) ? true : false;
		}

	}; // MonitoringUserInfo

public:
	uint16 mPktSize;
	uint16 mPktId;
	uint16 mMonitoringUserInfoCount;
	uint16 mFirstMonitoringUserInfoOffset;
	ServerTaskId mTaskId;
	bool mSuccess;

public:
#ifdef _SERVER 
	bool GetServerTaskIdRealTime(OUT int& serverTaskId) const { serverTaskId = mTaskId; return true; }
	const wchar_t* GetPacketName() const { return L"GW_ACK_DB_MONITORING_USER_LIST"; }
	const wchar_t* GetRelatedPacketName() const { return L"WG_REQ_DB_MONITORING_USER_LIST"; }
#endif

	ServerTaskId TaskId() { return mTaskId; }
	bool Success() { return mSuccess; }

	using MonitoringUserInfoIterator = PktIterator<MonitoringUserInfo>;
	const MonitoringUserInfoIterator GetLastMonitoringUserInfoIterator() const
	{
		return MonitoringUserInfoIterator(0);
	}
	MonitoringUserInfoIterator GetFirstMonitoringUserInfoIterator() const
	{
		if (mFirstMonitoringUserInfoOffset && mPktSize >= mFirstMonitoringUserInfoOffset + sizeof(MonitoringUserInfo))
		{
			MonitoringUserInfo* monitoringUserInfo = (MonitoringUserInfo*)((uchar*)this + mFirstMonitoringUserInfoOffset);
			if (mFirstMonitoringUserInfoOffset == monitoringUserInfo->mThisOffset)
				return MonitoringUserInfoIterator(monitoringUserInfo);
			else
				return MonitoringUserInfoIterator(0);
		}
		else
			return MonitoringUserInfoIterator(0);
	}
	const int GetMonitoringUserInfoCount()
	{
		return mMonitoringUserInfoCount;
	}
#ifdef _SERVER
	template<typename TFunc>
	void ForEachMonitoringUserInfo(TFunc&& func)
	{
		for (auto it = GetFirstMonitoringUserInfoIterator(); it != GetLastMonitoringUserInfoIterator(); ++it)
			func(it);
	}
#endif


#ifdef _SERVER 
	std::xwstring FuncCreateMonitoringUserInfoStr( [[maybe_unused]] MonitoringUserInfoIterator& iter) const
	{
		return Log::format(
			L"UserId: {}, UserName: {}, LastLogoutTime: {}, UserWorldId: {}", 
			iter->UserId(), iter->UserName(), iter->LastLogoutTime(), iter->UserWorldId()
		).c_str();
	}

	std::xwstring GetLogWString() const
	{
		std::xwstring str1;
		str1.append(L"\n");
		for (MonitoringUserInfoIterator iter = this->GetFirstMonitoringUserInfoIterator();
			iter != GetLastMonitoringUserInfoIterator(); ++iter)
		{
			str1.append(L"[");
			str1.append(FuncCreateMonitoringUserInfoStr(iter).c_str());

			str1.append(L"]\n");
		}

		return Log::format(
			L"[GW_ACK_DB_MONITORING_USER_LIST] TaskId: {}, Success: {}, MonitoringUserInfo : {}"
			, mTaskId, mSuccess, str1.c_str()
		).c_str();
	}
#endif

	bool Validate()
	{
		uchar* pktStart = (uchar*)this;
		uint16 pktSize = mPktSize;

		uint16 dataSize = sizeof(PKT_GW_ACK_DB_MONITORING_USER_LIST_READ);
		if (dataSize > mPktSize)
			return false;

		if (false == ValidateValue(pktStart, pktSize, dataSize))
			return false;

		if (false == MonitoringUserInfoValidateListNode(mFirstMonitoringUserInfoOffset, pktStart, pktSize, dataSize))
			return false;

		if (dataSize != mPktSize)
			return false;

		return true;
	}

	bool MonitoringUserInfoValidateListNode(uint16 offset, uchar * pktStart, uint16 pktSize, uint16& dataSize)
	{		for (MonitoringUserInfoIterator iter = this->GetFirstMonitoringUserInfoIterator();
			iter != GetLastMonitoringUserInfoIterator(); ++iter)
		{
			if (false == (*iter).Validate(offset, pktStart, pktSize, dataSize))
			{
				return false;
			}
		}
		return true;
	}

	bool ValidateValue(const uchar* pktStart, uint16 pktSize, uint16& dataSize)
	{
		return (nullptr != pktStart && 0 < pktSize && 0 < dataSize) ? true : false;
	}

}; // PKT_GW_ACK_DB_MONITORING_USER_LIST_READ

