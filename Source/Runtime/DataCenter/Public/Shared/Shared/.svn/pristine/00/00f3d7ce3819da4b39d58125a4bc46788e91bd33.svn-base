	void MakeGuildRankRewardInfoListVector(Container & container)
	{
		for (int offset = 0; offset < mGuildRankRewardInfoListSize; offset += sizeof(Data))
		{
			const Data* data = reinterpret_cast<const Data*>(GuildRankRewardInfoList() + offset);
			container.Add(*data);
		}
	}
#endif // _SERVER
