struct PKT_GW_GUILD_ASYNC_GUILDWAR_ENTRY_INFO_WRITE
#endif
{
	struct EntrymemberList
	{
		EntrymemberList(uint16 offset, UserDBId member)
			:
			mThisOffset(offset)
			, mNextOffset(0)
			, mMember(member)
		{
		}

		uint16 mThisOffset;
		uint16 mNextOffset;
		UserDBId mMember;

	}; // EntrymemberList

	struct EntrymemberListHandle
	{
		EntrymemberListHandle(PktWriter& pktWriter, EntrymemberList* entrymemberList)
			:
			mPktWriter(pktWriter)
			, mEntrymemberList(entrymemberList)
		{
		}

		PktWriter& mPktWriter;
		EntrymemberList* mEntrymemberList;

	}; // EntrymemberListHandle

	PktWriter mPktWriter;
	uint16* mEntrymemberListCount;
	uint16* mFirstEntrymemberListOffset;
	EntrymemberList* mNowEntrymemberList;

#ifdef _SERVER 
	bool GetServerTaskIdRealTime(OUT int& serverTaskId) const { return reinterpret_cast<PKT_GW_GUILD_ASYNC_GUILDWAR_ENTRY_INFO_READ*>(mPktWriter.mBuf)->GetServerTaskIdRealTime(serverTaskId); }
	const wchar_t* GetPacketName() const { return L"GW_GUILD_ASYNC_GUILDWAR_ENTRY_INFO"; }
