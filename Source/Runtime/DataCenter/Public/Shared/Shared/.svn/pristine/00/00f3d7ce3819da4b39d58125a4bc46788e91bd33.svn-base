	{
		for (auto it = GetFirstAddUnlockContentsListIterator(); it != GetLastAddUnlockContentsListIterator(); ++it)
			func(it);
	}
#endif


#ifdef _SERVER 
	std::xwstring FuncCreateAddUnlockContentsListStr( [[maybe_unused]] AddUnlockContentsListIterator& iter) const
	{
		return Log::format(
			L"UnlockContentsId: {}, Result: {}", 
			iter->UnlockContentsId(), iter->Result()
		).c_str();
	}

	std::xwstring GetLogWString() const
	{
		std::xwstring str1;
		str1.append(L"\n");
		for (AddUnlockContentsListIterator iter = this->GetFirstAddUnlockContentsListIterator();
			iter != GetLastAddUnlockContentsListIterator(); ++iter)
		{
			str1.append(L"[");
			str1.append(FuncCreateAddUnlockContentsListStr(iter).c_str());

			str1.append(L"]\n");
		}

		return Log::format(
			L"[GW_GM_UNLOCK_CONTENTS_ADD] AddUnlockContentsList : {}"
			, str1.c_str()
		).c_str();
