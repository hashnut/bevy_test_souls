// type = GW
struct PKT_GW_INFORM_COMMON_OBJECTIVE_EVENT_LIST_READ
{
public:
	uint16 mPktSize;
	uint16 mPktId;
	uint16 mCommonObjectiveDataListOffset;
	uint16 mCommonObjectiveDataListSize;
	UserDBId mUserDBId;

public:
#ifdef _SERVER 
	using _T0 = CommonObjectiveInformData;
	bool GetServerTaskIdRealTime(OUT [[maybe_unused]] int& serverTaskId) const { return false; }
	const wchar_t* GetPacketName() const { return L"GW_INFORM_COMMON_OBJECTIVE_EVENT_LIST"; }
	const wchar_t* GetRelatedPacketName() const { return L"WG_INFORM_COMMON_OBJECTIVE_EVENT_LIST"; }
#endif

	UserDBId UserDBId() { return mUserDBId; }
	const uchar* CommonObjectiveDataList() const
	{
		uchar* pktStart = (uchar*)this;
		uint16 pktSize = *((uint16*)pktStart);
		if (mCommonObjectiveDataListOffset && pktSize > mCommonObjectiveDataListOffset)
			return (const uchar*)(pktStart + mCommonObjectiveDataListOffset);
		else
			return 0;
	}
	int CommonObjectiveDataListSize() const
	{
		return mCommonObjectiveDataListSize;
	}
#ifdef _SERVER
	template <typename Container>
	void MakeCommonObjectiveDataListVector(Container & container)
	{
		//emplace() 호출할때마다 메모리를 생성 하는 비용이 발생한다 비용을줄이위개 reserve()사용
		container.reserve(mCommonObjectiveDataListSize/sizeof(_T0));
		for (int offset = 0; offset < mCommonObjectiveDataListSize; offset += sizeof(_T0))
		{
			const _T0* data = reinterpret_cast<const _T0*>(CommonObjectiveDataList() + offset);
			container.emplace_back(*data);
		}
	}
#else // _SERVER
	template <typename Container, typename Data>
	void MakeCommonObjectiveDataListVector(Container & container)
	{
		for (int offset = 0; offset < mCommonObjectiveDataListSize; offset += sizeof(Data))
		{
			const Data* data = reinterpret_cast<const Data*>(CommonObjectiveDataList() + offset);
			container.Add(*data);
		}
	}
#endif // _SERVER
#ifdef _SERVER
	template <typename TFunc>
	void ForEachCommonObjectiveDataList(TFunc&& func) const
	{
		for (int offset = 0; offset < CommonObjectiveDataListSize(); offset += sizeof(_T0))
		{
			const _T0* data = reinterpret_cast<const _T0*>(CommonObjectiveDataList() + offset);
			func(data);
		}
	}
#endif


#ifdef _SERVER 
	std::xwstring GetLogWString() const
	{

		return Log::format(
			L"[GW_INFORM_COMMON_OBJECTIVE_EVENT_LIST] UserDBId: {}"
			, mUserDBId
		).c_str();
	}
#endif

	bool Validate()
	{
