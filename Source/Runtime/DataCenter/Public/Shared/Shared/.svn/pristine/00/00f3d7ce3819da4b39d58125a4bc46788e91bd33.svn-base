	{
		return mRewardItemsCreatedSize;
	}
#ifdef _SERVER
	template <typename Container>
	void MakeRewardItemsCreatedVector(Container & container)
	{
		//emplace() 호출할때마다 메모리를 생성 하는 비용이 발생한다 비용을줄이위개 reserve()사용
		container.reserve(mRewardItemsCreatedSize/sizeof(_T0));
		for (int offset = 0; offset < mRewardItemsCreatedSize; offset += sizeof(_T0))
		{
			const _T0* data = reinterpret_cast<const _T0*>(RewardItemsCreated() + offset);
			container.emplace_back(*data);
		}
	}
