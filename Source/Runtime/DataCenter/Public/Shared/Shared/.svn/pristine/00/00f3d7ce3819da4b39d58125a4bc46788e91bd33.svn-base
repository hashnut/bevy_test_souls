		*mQuickSlotDBInfoListSize = 0;
		mPktWriter << (*mQuickSlotDBInfoListSize);
		mPktWriter << taskId;
		mPktWriter << success;
		*mQuickSlotDBInfoListOffset = (uint16)mPktWriter.GetPktSize();
		if (quickSlotDBInfoList && !quickSlotDBInfoList->empty())
		{
			int tvalsize = (int)sizeof(*(quickSlotDBInfoList->begin())); 
			auto _quickSlotDBInfoList = const_cast<std::decay_t<T0>*>(quickSlotDBInfoList);
			for (auto it = _quickSlotDBInfoList->begin(); it != _quickSlotDBInfoList->end(); ++it) 
			{
				mPktWriter.WriteBinary((uint16)tvalsize, (uchar*)&(*it)); 
