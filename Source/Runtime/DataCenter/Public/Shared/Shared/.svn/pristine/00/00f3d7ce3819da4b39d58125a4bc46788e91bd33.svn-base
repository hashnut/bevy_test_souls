// type = GW
// related packet = PKT_WG_REQ_DB_USER_TIME_TICKET_LIST_WRITE
struct PKT_GW_ACK_DB_USER_TIME_TICKET_LIST_READ
{
public:
	uint16 mPktSize;
	uint16 mPktId;
	uint16 mTimeTicketTableOffset;
	uint16 mTimeTicketTableSize;
	ServerTaskId mTaskId;
	bool mSuccess;
	AccountWorldBossData mAccountWorldBossData;

public:
#ifdef _SERVER 
	using _T0 = TimeTicketTable;
	bool GetServerTaskIdRealTime(OUT int& serverTaskId) const { serverTaskId = mTaskId; return true; }
	const wchar_t* GetPacketName() const { return L"GW_ACK_DB_USER_TIME_TICKET_LIST"; }
	const wchar_t* GetRelatedPacketName() const { return L"WG_REQ_DB_USER_TIME_TICKET_LIST"; }
#endif

	ServerTaskId TaskId() { return mTaskId; }
	bool Success() { return mSuccess; }
	const AccountWorldBossData& ConstRefAccountWorldBossData() { return mAccountWorldBossData; }
	AccountWorldBossData AccountWorldBossData() { return mAccountWorldBossData; }
	const uchar* TimeTicketTable() const
	{
		uchar* pktStart = (uchar*)this;
		uint16 pktSize = *((uint16*)pktStart);
		if (mTimeTicketTableOffset && pktSize > mTimeTicketTableOffset)
			return (const uchar*)(pktStart + mTimeTicketTableOffset);
		else
			return 0;
	}
	int TimeTicketTableSize() const
	{
		return mTimeTicketTableSize;
	}
#ifdef _SERVER
	template <typename Container>
	void MakeTimeTicketTableVector(Container & container)
	{
		//emplace() 호출할때마다 메모리를 생성 하는 비용이 발생한다 비용을줄이위개 reserve()사용
		container.reserve(mTimeTicketTableSize/sizeof(_T0));
		for (int offset = 0; offset < mTimeTicketTableSize; offset += sizeof(_T0))
		{
			const _T0* data = reinterpret_cast<const _T0*>(TimeTicketTable() + offset);
			container.emplace_back(*data);
		}
	}
#else // _SERVER
	template <typename Container, typename Data>
	void MakeTimeTicketTableVector(Container & container)
	{
		for (int offset = 0; offset < mTimeTicketTableSize; offset += sizeof(Data))
		{
			const Data* data = reinterpret_cast<const Data*>(TimeTicketTable() + offset);
			container.Add(*data);
		}
	}
#endif // _SERVER
#ifdef _SERVER
	template <typename TFunc>
	void ForEachTimeTicketTable(TFunc&& func) const
	{
		for (int offset = 0; offset < TimeTicketTableSize(); offset += sizeof(_T0))
		{
			const _T0* data = reinterpret_cast<const _T0*>(TimeTicketTable() + offset);
			func(data);
		}
	}
#endif


#ifdef _SERVER 
	std::xwstring GetLogWString() const
	{

		return Log::format(
			L"[GW_ACK_DB_USER_TIME_TICKET_LIST] TaskId: {}, Success: {}, AccountWorldBossData: {}"
			, mTaskId, mSuccess, mAccountWorldBossData
		).c_str();
	}
#endif

	bool Validate()
	{
		uchar* pktStart = (uchar*)this;
		uint16 pktSize = mPktSize;

		uint16 dataSize = sizeof(PKT_GW_ACK_DB_USER_TIME_TICKET_LIST_READ);
		if (dataSize > mPktSize)
			return false;

		if (false == ValidateValue(pktStart, pktSize, dataSize))
			return false;

		if (dataSize != mPktSize)
			return false;

		return true;
	}

	bool ValidateValue(const uchar* pktStart, uint16 pktSize, uint16& dataSize)
	{
		if (false == ValidateBinary(mTimeTicketTableOffset, mTimeTicketTableSize, 0, pktSize, dataSize))
			return false;

		return (nullptr != pktStart && 0 < pktSize && 0 < dataSize) ? true : false;
	}

}; // PKT_GW_ACK_DB_USER_TIME_TICKET_LIST_READ

