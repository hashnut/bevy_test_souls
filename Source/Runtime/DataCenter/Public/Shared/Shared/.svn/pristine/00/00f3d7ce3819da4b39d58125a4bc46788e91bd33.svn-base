	{
		static_assert(true == std::is_same_v<T0::value_type, _T0>, "skillSlotDataList type must be SkillSlotData list type"); 
		mPktWriter << (uint16)GW_ACK_DB_SKILL_LEARN;
		mSkillSlotDataListOffset = (uint16*)mPktWriter.GetBuffer();
		*mSkillSlotDataListOffset = 0;
		mPktWriter << (*mSkillSlotDataListOffset);
		mSkillSlotDataListSize = (uint16*)mPktWriter.GetBuffer();
		*mSkillSlotDataListSize = 0;
		mPktWriter << (*mSkillSlotDataListSize);
		mPktWriter << taskId;
		mPktWriter << success;
		*mSkillSlotDataListOffset = (uint16)mPktWriter.GetPktSize();
		if (skillSlotDataList && !skillSlotDataList->empty())
		{
			int tvalsize = (int)sizeof(*(skillSlotDataList->begin())); 
			auto _skillSlotDataList = const_cast<std::decay_t<T0>*>(skillSlotDataList);
			for (auto it = _skillSlotDataList->begin(); it != _skillSlotDataList->end(); ++it) 
			{
				mPktWriter.WriteBinary((uint16)tvalsize, (uchar*)&(*it)); 
			}
			*mSkillSlotDataListSize = (uint16) (tvalsize * skillSlotDataList->size());
		}
	}
#endif

