// type = GW
struct PKT_GW_REQ_GUILDWAR_MAKE_CHANNEL_READ
{
public:
	uint16 mPktSize;
	uint16 mPktId;
	uint16 mMatchGuildListOffset;
	uint16 mMatchGuildListSize;
	MapId mMapId;

public:
#ifdef _SERVER 
	using _T0 = MatchGuildInfo;
	bool GetServerTaskIdRealTime(OUT [[maybe_unused]] int& serverTaskId) const { return false; }
	const wchar_t* GetPacketName() const { return L"GW_REQ_GUILDWAR_MAKE_CHANNEL"; }
	const wchar_t* GetRelatedPacketName() const { return L"WG_ACK_GUILDWAR_MAKE_CHANNEL"; }
#endif

	MapId MapId() { return mMapId; }
	const uchar* MatchGuildList() const
	{
		uchar* pktStart = (uchar*)this;
		uint16 pktSize = *((uint16*)pktStart);
		if (mMatchGuildListOffset && pktSize > mMatchGuildListOffset)
			return (const uchar*)(pktStart + mMatchGuildListOffset);
		else
			return 0;
	}
	int MatchGuildListSize() const
	{
		return mMatchGuildListSize;
	}
#ifdef _SERVER
	template <typename Container>
	void MakeMatchGuildListVector(Container & container)
	{
		//emplace() 호출할때마다 메모리를 생성 하는 비용이 발생한다 비용을줄이위개 reserve()사용
		container.reserve(mMatchGuildListSize/sizeof(_T0));
		for (int offset = 0; offset < mMatchGuildListSize; offset += sizeof(_T0))
		{
			const _T0* data = reinterpret_cast<const _T0*>(MatchGuildList() + offset);
			container.emplace_back(*data);
		}
	}
#else // _SERVER
	template <typename Container, typename Data>
	void MakeMatchGuildListVector(Container & container)
	{
		for (int offset = 0; offset < mMatchGuildListSize; offset += sizeof(Data))
		{
			const Data* data = reinterpret_cast<const Data*>(MatchGuildList() + offset);
			container.Add(*data);
		}
	}
#endif // _SERVER
#ifdef _SERVER
	template <typename TFunc>
	void ForEachMatchGuildList(TFunc&& func) const
	{
		for (int offset = 0; offset < MatchGuildListSize(); offset += sizeof(_T0))
		{
			const _T0* data = reinterpret_cast<const _T0*>(MatchGuildList() + offset);
			func(data);
		}
	}
#endif


#ifdef _SERVER 
	std::xwstring GetLogWString() const
	{

		return Log::format(
			L"[GW_REQ_GUILDWAR_MAKE_CHANNEL] MapId: {}"
			, mMapId
		).c_str();
	}
#endif

	bool Validate()
	{
		uchar* pktStart = (uchar*)this;
		uint16 pktSize = mPktSize;

		uint16 dataSize = sizeof(PKT_GW_REQ_GUILDWAR_MAKE_CHANNEL_READ);
		if (dataSize > mPktSize)
			return false;

		if (false == ValidateValue(pktStart, pktSize, dataSize))
			return false;

		if (dataSize != mPktSize)
			return false;

		return true;
	}

	bool ValidateValue(const uchar* pktStart, uint16 pktSize, uint16& dataSize)
	{
		if (false == ValidateBinary(mMatchGuildListOffset, mMatchGuildListSize, 0, pktSize, dataSize))
			return false;

		return (nullptr != pktStart && 0 < pktSize && 0 < dataSize) ? true : false;
	}

}; // PKT_GW_REQ_GUILDWAR_MAKE_CHANNEL_READ

// type = GW
#ifdef _SERVER
struct PKT_GW_REQ_GUILDWAR_MAKE_CHANNEL_WRITE : public Disposable
#else
struct PKT_GW_REQ_GUILDWAR_MAKE_CHANNEL_WRITE
#endif
{
	PktWriter mPktWriter;
	uint16* mMatchGuildListOffset;
	uint16* mMatchGuildListSize;

#ifdef _SERVER 
	using _T0 = MatchGuildInfo;
	bool GetServerTaskIdRealTime(OUT int& serverTaskId) const { return reinterpret_cast<PKT_GW_REQ_GUILDWAR_MAKE_CHANNEL_READ*>(mPktWriter.mBuf)->GetServerTaskIdRealTime(serverTaskId); }
	const wchar_t* GetPacketName() const { return L"GW_REQ_GUILDWAR_MAKE_CHANNEL"; }
	const wchar_t* GetRelatedPacketName() const { return L"WG_ACK_GUILDWAR_MAKE_CHANNEL"; }
#endif

#ifndef _SERVER
	template <typename T0>
	PKT_GW_REQ_GUILDWAR_MAKE_CHANNEL_WRITE(uchar* buf, int bufSize, MapId mapId, const T0* MatchGuildList)
		:
		mPktWriter(buf, bufSize)

	{
		mPktWriter << static_cast<uint16>(PD::GW::GWPacketId::GW_REQ_GUILDWAR_MAKE_CHANNEL);
		mMatchGuildListOffset = (uint16*)mPktWriter.GetBuffer();
		*mMatchGuildListOffset = 0;
		mPktWriter << (*mMatchGuildListOffset);
		mMatchGuildListSize = (uint16*)mPktWriter.GetBuffer();
		*mMatchGuildListSize = 0;
		mPktWriter << (*mMatchGuildListSize);
		mPktWriter << mapId;
		*mMatchGuildListOffset = (uint16)mPktWriter.GetPktSize();
		if (MatchGuildList && 0 < MatchGuildList->Num())
		{
			int tvalsize = (int)sizeof(*(MatchGuildList->begin())); 
			auto _MatchGuildList = (T0*)MatchGuildList;
			for (auto it = _MatchGuildList->begin(); it != _MatchGuildList->end(); ++it) 
			{
				mPktWriter.WriteBinary((uint16)tvalsize, (uchar*)&(*it)); 
			}
			*mMatchGuildListSize = (uint16)(tvalsize* MatchGuildList->Num());
		}
	}

#endif // _SERVER
#ifdef _SERVER
	template <typename T0>
	PKT_GW_REQ_GUILDWAR_MAKE_CHANNEL_WRITE(SendBufferHelper& sendBuffer, MapId mapId, const T0* MatchGuildList)
		:
		mPktWriter(sendBuffer->GetCharBuffer(), (SEND_BUFFER_SIZE - 1))

	{
		static_assert(true == std::is_same_v<T0::value_type, _T0>, "MatchGuildList type must be MatchGuildInfo list type"); 
		mPktWriter << (uint16)GW_REQ_GUILDWAR_MAKE_CHANNEL;
		mMatchGuildListOffset = (uint16*)mPktWriter.GetBuffer();
		*mMatchGuildListOffset = 0;
		mPktWriter << (*mMatchGuildListOffset);
		mMatchGuildListSize = (uint16*)mPktWriter.GetBuffer();
		*mMatchGuildListSize = 0;
		mPktWriter << (*mMatchGuildListSize);
		mPktWriter << mapId;
		*mMatchGuildListOffset = (uint16)mPktWriter.GetPktSize();
		if (MatchGuildList && !MatchGuildList->empty())
		{
			int tvalsize = (int)sizeof(*(MatchGuildList->begin())); 
			auto _MatchGuildList = const_cast<std::decay_t<T0>*>(MatchGuildList);
			for (auto it = _MatchGuildList->begin(); it != _MatchGuildList->end(); ++it) 
			{
				mPktWriter.WriteBinary((uint16)tvalsize, (uchar*)&(*it)); 
			}
			*mMatchGuildListSize = (uint16) (tvalsize * MatchGuildList->size());
		}
	}
#endif

#ifdef _SERVER 
	void send(IocpObjectSession* session, SendBufferRef sendBuffer, bool autoCloseSendBuffer)
	{
		if (session) 
			session->Send(sendBuffer, mPktWriter.GetPktSize(), autoCloseSendBuffer);
	}
#endif

#ifdef _SERVER 
	std::xwstring GetLogWString() const
	{
		auto readPacket = reinterpret_cast<PKT_GW_REQ_GUILDWAR_MAKE_CHANNEL_READ*>(mPktWriter.mBuf);
		return readPacket->GetLogWString();
	}
#endif

#ifndef _SERVER
#else
#endif
}; // PKT_GW_REQ_GUILDWAR_MAKE_CHANNEL_WRITE

