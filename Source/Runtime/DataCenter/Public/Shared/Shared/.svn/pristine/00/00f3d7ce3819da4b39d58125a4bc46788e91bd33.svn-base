	{
		uchar* pktStart = (uchar*)this;
		uint16 pktSize = *((uint16*)pktStart);
		if (mItemDataCreatedOffset && pktSize > mItemDataCreatedOffset)
			return (const uchar*)(pktStart + mItemDataCreatedOffset);
		else
			return 0;
	}
	int ItemDataCreatedSize() const
	{
		return mItemDataCreatedSize;
	}
#ifdef _SERVER
	template <typename Container>
	void MakeItemDataCreatedVector(Container & container)
	{
		//emplace() 호출할때마다 메모리를 생성 하는 비용이 발생한다 비용을줄이위개 reserve()사용
		container.reserve(mItemDataCreatedSize/sizeof(_T0));
		for (int offset = 0; offset < mItemDataCreatedSize; offset += sizeof(_T0))
		{
			const _T0* data = reinterpret_cast<const _T0*>(ItemDataCreated() + offset);
			container.emplace_back(*data);
		}
	}
#else // _SERVER
	template <typename Container, typename Data>
	void MakeItemDataCreatedVector(Container & container)
	{
		for (int offset = 0; offset < mItemDataCreatedSize; offset += sizeof(Data))
		{
			const Data* data = reinterpret_cast<const Data*>(ItemDataCreated() + offset);
			container.Add(*data);
		}
	}
#endif // _SERVER
#ifdef _SERVER
	template <typename TFunc>
	void ForEachItemDataCreated(TFunc&& func) const
	{
		for (int offset = 0; offset < ItemDataCreatedSize(); offset += sizeof(_T0))
		{
			const _T0* data = reinterpret_cast<const _T0*>(ItemDataCreated() + offset);
			func(data);
		}
	}
#endif


