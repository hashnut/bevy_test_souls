			for (auto it = _rewardItemsCreated->begin(); it != _rewardItemsCreated->end(); ++it) 
			{
				mPktWriter.WriteBinary((uint16)tvalsize, (uchar*)&(*it)); 
			}
			*mRewardItemsCreatedSize = (uint16) (tvalsize * rewardItemsCreated->size());
