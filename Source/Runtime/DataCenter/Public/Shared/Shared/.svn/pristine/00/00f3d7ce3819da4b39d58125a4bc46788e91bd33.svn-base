	{
		for (int offset = 0; offset < GuildRankRewardInfoListSize(); offset += sizeof(_T1))
		{
			const _T1* data = reinterpret_cast<const _T1*>(GuildRankRewardInfoList() + offset);
			func(data);
		}
	}
#endif


#ifdef _SERVER 
	std::xwstring GetLogWString() const
	{

		return Log::format(
			L"[GW_WORLD_GUILD_RANK_DATA_INFO] "
		).c_str();
	}
#endif

	bool Validate()
	{
		uchar* pktStart = (uchar*)this;
		uint16 pktSize = mPktSize;

		uint16 dataSize = sizeof(PKT_GW_WORLD_GUILD_RANK_DATA_INFO_READ);
		if (dataSize > mPktSize)
			return false;

		if (false == ValidateValue(pktStart, pktSize, dataSize))
			return false;

		if (dataSize != mPktSize)
			return false;

		return true;
	}

	bool ValidateValue(const uchar* pktStart, uint16 pktSize, uint16& dataSize)
	{
		if (false == ValidateBinary(mGuildRankDataListOffset, mGuildRankDataListSize, 0, pktSize, dataSize))
			return false;

		if (false == ValidateBinary(mGuildRankRewardInfoListOffset, mGuildRankRewardInfoListSize, 0, pktSize, dataSize))
			return false;

		return (nullptr != pktStart && 0 < pktSize && 0 < dataSize) ? true : false;
	}

