		:
		mPktWriter(sendBuffer->GetCharBuffer(), (SEND_BUFFER_SIZE - 1))

	{
		static_assert(true == std::is_same_v<T0::value_type, _T0>, "GuildRankDataList type must be GuildRankData list type"); 
		static_assert(true == std::is_same_v<T1::value_type, _T1>, "GuildRankRewardInfoList type must be GuildRankRewardInfo list type"); 
		mPktWriter << (uint16)GW_WORLD_GUILD_RANK_DATA_INFO;
		mGuildRankDataListOffset = (uint16*)mPktWriter.GetBuffer();
