			func(it);
	}
#endif


#ifdef _SERVER 
	std::xwstring FuncCreateHostileListStr( [[maybe_unused]] GuildSimples::HostileListIterator& iter) const
	{
		return Log::format(
			L"GuildId: {}", 
			iter->GuildId()
		).c_str();
	}

	std::xwstring FuncCreateAllyListStr( [[maybe_unused]] GuildSimples::AllyListIterator& iter) const
	{
		return Log::format(
			L"GuildId: {}", 
			iter->GuildId()
		).c_str();
	}

	std::xwstring FuncCreateGuildSimplesStr( [[maybe_unused]] GuildSimplesIterator& iter) const
	{
		return Log::format(
			L"GuildDetailInfo: {}, GuildName: {}, DungeonLevel: {}", 
			iter->GuildDetailInfo(), iter->GuildName(), iter->DungeonLevel()
		).c_str();
	}

	std::xwstring GetLogWString() const
	{
		std::xwstring str1;
		str1.append(L"\n");
		for (GuildSimplesIterator iter = this->GetFirstGuildSimplesIterator();
			iter != GetLastGuildSimplesIterator(); ++iter)
		{
			str1.append(L"[");
			str1.append(FuncCreateGuildSimplesStr(iter).c_str());

			for (GuildSimples::HostileListIterator HostileListIter = iter->GetFirstHostileListIterator();
				HostileListIter != iter->GetLastHostileListIterator(); ++HostileListIter)
			{
				str1.append(FuncCreateHostileListStr(HostileListIter).c_str());

			}

			for (GuildSimples::AllyListIterator AllyListIter = iter->GetFirstAllyListIterator();
				AllyListIter != iter->GetLastAllyListIterator(); ++AllyListIter)
			{
				str1.append(FuncCreateAllyListStr(AllyListIter).c_str());

			}

			str1.append(L"]\n");
		}

		return Log::format(
			L"[GW_WORLD_GUILD_LIST] GuildSimples : {}"
			, str1.c_str()
		).c_str();
	}
#endif

	bool Validate()
	{
		uchar* pktStart = (uchar*)this;
		uint16 pktSize = mPktSize;

		uint16 dataSize = sizeof(PKT_GW_WORLD_GUILD_LIST_READ);
		if (dataSize > mPktSize)
			return false;

		if (false == ValidateValue(pktStart, pktSize, dataSize))
			return false;

		if (false == GuildSimplesValidateListNode(mFirstGuildSimplesOffset, pktStart, pktSize, dataSize))
			return false;

		if (dataSize != mPktSize)
			return false;

		return true;
	}

	bool GuildSimplesValidateListNode(uint16 offset, uchar * pktStart, uint16 pktSize, uint16& dataSize)
	{		for (GuildSimplesIterator iter = this->GetFirstGuildSimplesIterator();
			iter != GetLastGuildSimplesIterator(); ++iter)
		{
			if (false == (*iter).Validate(offset, pktStart, pktSize, dataSize))
			{
				return false;
			}
		}
		return true;
	}

	bool ValidateValue(const uchar* pktStart, uint16 pktSize, uint16& dataSize)
	{
		return (nullptr != pktStart && 0 < pktSize && 0 < dataSize) ? true : false;
	}

}; // PKT_GW_WORLD_GUILD_LIST_READ

// type = GW
#ifdef _SERVER
struct PKT_GW_WORLD_GUILD_LIST_WRITE : public Disposable
#else
struct PKT_GW_WORLD_GUILD_LIST_WRITE
#endif
{
	struct GuildSimples
	{
		GuildSimples(uint16 offset, GuildDetail guildDetailInfo, GuildDunGeonLevel dungeonLevel)
			:
			mThisOffset(offset)
			, mNextOffset(0), mHostileListCount(0), mFirstHostileListOffset(0), mAllyListCount(0), mFirstAllyListOffset(0), mGuildNameOffset(0)
			, mGuildDetailInfo(guildDetailInfo)
			, mDungeonLevel(dungeonLevel)
		{
		}
		void SetGuildNameOffset(uint16 offset)
		{
			mGuildNameOffset = offset;
		}

		uint16 mThisOffset;
		uint16 mNextOffset;
		uint16 mHostileListCount;
		uint16 mFirstHostileListOffset;
		uint16 mAllyListCount;
		uint16 mFirstAllyListOffset;
		uint16 mGuildNameOffset;
		GuildDetail mGuildDetailInfo;
		GuildDunGeonLevel mDungeonLevel;

		struct HostileList
		{
			HostileList(uint16 offset, GuildDBId guildId)
			:
			mThisOffset(offset)
			, mNextOffset(0)
			, mGuildId(guildId)
			{
			}

			uint16 mThisOffset;
			uint16 mNextOffset;
			GuildDBId mGuildId;

		}; // HostileList

		struct AllyList
		{
			AllyList(uint16 offset, GuildDBId guildId)
			:
			mThisOffset(offset)
			, mNextOffset(0)
			, mGuildId(guildId)
			{
			}

			uint16 mThisOffset;
			uint16 mNextOffset;
			GuildDBId mGuildId;

		}; // AllyList

	}; // GuildSimples

	struct GuildSimplesHandle
	{
		struct HostileListHandle
		{
			HostileListHandle(PktWriter& pktWriter, GuildSimples::HostileList* hostileList)
			:
			mPktWriter(pktWriter)
			, mHostileList(hostileList)
			{
			}

			PktWriter& mPktWriter;
			GuildSimples::HostileList* mHostileList;

		}; // HostileListHandle

		struct AllyListHandle
		{
			AllyListHandle(PktWriter& pktWriter, GuildSimples::AllyList* allyList)
			:
			mPktWriter(pktWriter)
			, mAllyList(allyList)
			{
			}

			PktWriter& mPktWriter;
			GuildSimples::AllyList* mAllyList;

		}; // AllyListHandle

		GuildSimplesHandle(PktWriter& pktWriter, GuildSimples* guildSimples)
			:
			mPktWriter(pktWriter)
			, mGuildSimples(guildSimples), mNowHostileList(0), mNowAllyList(0)
		{
		}

		HostileListHandle CreateHostileList(GuildDBId guildId)
		{
			uchar* nowBuffer = mPktWriter.GetBuffer();
			uint16 nowWritten = (uint16)mPktWriter.GetPktSize();
			GuildSimples::HostileList* newHostileList = new ((GuildSimples::HostileList*)nowBuffer) GuildSimples::HostileList(nowWritten, guildId);
			mGuildSimples->mHostileListCount++;
			if (mNowHostileList == 0)
				mGuildSimples->mFirstHostileListOffset = nowWritten;
			else
				mNowHostileList->mNextOffset = nowWritten;
			mNowHostileList = newHostileList;
			mPktWriter.Skip(sizeof(GuildSimples::HostileList));
			return HostileListHandle(mPktWriter, newHostileList);
		}

		AllyListHandle CreateAllyList(GuildDBId guildId)
		{
			uchar* nowBuffer = mPktWriter.GetBuffer();
			uint16 nowWritten = (uint16)mPktWriter.GetPktSize();
			GuildSimples::AllyList* newAllyList = new ((GuildSimples::AllyList*)nowBuffer) GuildSimples::AllyList(nowWritten, guildId);
			mGuildSimples->mAllyListCount++;
			if (mNowAllyList == 0)
				mGuildSimples->mFirstAllyListOffset = nowWritten;
			else
				mNowAllyList->mNextOffset = nowWritten;
			mNowAllyList = newAllyList;
			mPktWriter.Skip(sizeof(GuildSimples::AllyList));
			return AllyListHandle(mPktWriter, newAllyList);
		}

		PktWriter& mPktWriter;
		GuildSimples* mGuildSimples;
		GuildSimples::HostileList* mNowHostileList;
		GuildSimples::AllyList* mNowAllyList;

	}; // GuildSimplesHandle

	PktWriter mPktWriter;
	uint16* mGuildSimplesCount;
	uint16* mFirstGuildSimplesOffset;
	GuildSimples* mNowGuildSimples;

#ifdef _SERVER 
	bool GetServerTaskIdRealTime(OUT int& serverTaskId) const { return reinterpret_cast<PKT_GW_WORLD_GUILD_LIST_READ*>(mPktWriter.mBuf)->GetServerTaskIdRealTime(serverTaskId); }
	const wchar_t* GetPacketName() const { return L"GW_WORLD_GUILD_LIST"; }
	const wchar_t* GetRelatedPacketName() const { return L"WG_WORLD_GUILD_LIST"; }
#endif

#ifndef _SERVER
	PKT_GW_WORLD_GUILD_LIST_WRITE(uchar* buf, int bufSize)
		:
		mPktWriter(buf, bufSize)
		, mNowGuildSimples(0)
	{
		mPktWriter << static_cast<uint16>(PD::GW::GWPacketId::GW_WORLD_GUILD_LIST);
		mGuildSimplesCount = (uint16*)mPktWriter.GetBuffer();
		*mGuildSimplesCount = 0;
		mPktWriter << (*mGuildSimplesCount);
		mFirstGuildSimplesOffset = (uint16*)mPktWriter.GetBuffer();
		*mFirstGuildSimplesOffset = 0;
		mPktWriter << (*mFirstGuildSimplesOffset);
	}

#endif // _SERVER
#ifdef _SERVER
	PKT_GW_WORLD_GUILD_LIST_WRITE(SendBufferHelper& sendBuffer)
		:
		mPktWriter(sendBuffer->GetCharBuffer(), (SEND_BUFFER_SIZE - 1))
		, mNowGuildSimples(0)
	{
		mPktWriter << (uint16)GW_WORLD_GUILD_LIST;
		mGuildSimplesCount = (uint16*)mPktWriter.GetBuffer();
		*mGuildSimplesCount = 0;
		mPktWriter << (*mGuildSimplesCount);
		mFirstGuildSimplesOffset = (uint16*)mPktWriter.GetBuffer();
		*mFirstGuildSimplesOffset = 0;
		mPktWriter << (*mFirstGuildSimplesOffset);
	}
#endif

#ifdef _SERVER 
	void send(IocpObjectSession* session, SendBufferRef sendBuffer, bool autoCloseSendBuffer)
	{
		if (session) 
			session->Send(sendBuffer, mPktWriter.GetPktSize(), autoCloseSendBuffer);
	}
#endif

#ifdef _SERVER 
	std::xwstring GetLogWString() const
	{
		auto readPacket = reinterpret_cast<PKT_GW_WORLD_GUILD_LIST_READ*>(mPktWriter.mBuf);
		return readPacket->GetLogWString();
	}
#endif

#ifndef _SERVER
	GuildSimplesHandle CreateGuildSimples(const GuildDetail& guildDetailInfo, const FString& guildName, GuildDunGeonLevel dungeonLevel)
	{
		uchar* nowBuffer = mPktWriter.GetBuffer();
		uint16 nowWritten = (uint16)mPktWriter.GetPktSize();
		GuildSimples* newGuildSimples = new ((GuildSimples*)nowBuffer) GuildSimples(nowWritten, guildDetailInfo, dungeonLevel);
		++(*mGuildSimplesCount);
		if (mNowGuildSimples == 0)
			*mFirstGuildSimplesOffset = nowWritten;
		else
			mNowGuildSimples->mNextOffset = nowWritten;
		mNowGuildSimples = newGuildSimples;
		mPktWriter.Skip(sizeof(GuildSimples));
		mNowGuildSimples->SetGuildNameOffset((uint16)mPktWriter.GetPktSize());
		mPktWriter.WriteString(guildName);
		return GuildSimplesHandle(mPktWriter, newGuildSimples);
	}

#else
	GuildSimplesHandle CreateGuildSimples(const GuildDetail& guildDetailInfo, const wchar* guildName, GuildDunGeonLevel dungeonLevel)
	{
