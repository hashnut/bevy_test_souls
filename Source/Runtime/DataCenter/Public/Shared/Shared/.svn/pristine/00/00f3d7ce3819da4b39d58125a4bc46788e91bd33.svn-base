	const wchar_t* GetRelatedPacketName() const { return L"WG_REQ_DB_GUILD_STORE_ACQUIRED_ITEM"; }
#endif

#ifndef _SERVER
	template <typename T0>
	PKT_GW_ACK_DB_GUILD_STORE_ACQUIRED_ITEM_WRITE(uchar* buf, int bufSize, ServerTaskId taskId, bool success, int result, const T0* itemDataCreated)
		:
		mPktWriter(buf, bufSize)

	{
		mPktWriter << static_cast<uint16>(PD::GW::GWPacketId::GW_ACK_DB_GUILD_STORE_ACQUIRED_ITEM);
		mItemDataCreatedOffset = (uint16*)mPktWriter.GetBuffer();
		*mItemDataCreatedOffset = 0;
		mPktWriter << (*mItemDataCreatedOffset);
		mItemDataCreatedSize = (uint16*)mPktWriter.GetBuffer();
		*mItemDataCreatedSize = 0;
		mPktWriter << (*mItemDataCreatedSize);
		mPktWriter << taskId;
		mPktWriter << success;
		mPktWriter << result;
		*mItemDataCreatedOffset = (uint16)mPktWriter.GetPktSize();
		if (itemDataCreated && 0 < itemDataCreated->Num())
		{
			int tvalsize = (int)sizeof(*(itemDataCreated->begin())); 
			auto _itemDataCreated = (T0*)itemDataCreated;
			for (auto it = _itemDataCreated->begin(); it != _itemDataCreated->end(); ++it) 
			{
				mPktWriter.WriteBinary((uint16)tvalsize, (uchar*)&(*it)); 
			}
			*mItemDataCreatedSize = (uint16)(tvalsize* itemDataCreated->Num());
		}
	}

#endif // _SERVER
#ifdef _SERVER
	template <typename T0>
	PKT_GW_ACK_DB_GUILD_STORE_ACQUIRED_ITEM_WRITE(SendBufferHelper& sendBuffer, ServerTaskId taskId, bool success, int result, const T0* itemDataCreated)
		:
		mPktWriter(sendBuffer->GetCharBuffer(), (SEND_BUFFER_SIZE - 1))

	{
		static_assert(true == std::is_same_v<T0::value_type, _T0>, "itemDataCreated type must be ItemDataCreated list type"); 
		mPktWriter << (uint16)GW_ACK_DB_GUILD_STORE_ACQUIRED_ITEM;
		mItemDataCreatedOffset = (uint16*)mPktWriter.GetBuffer();
		*mItemDataCreatedOffset = 0;
		mPktWriter << (*mItemDataCreatedOffset);
		mItemDataCreatedSize = (uint16*)mPktWriter.GetBuffer();
		*mItemDataCreatedSize = 0;
		mPktWriter << (*mItemDataCreatedSize);
		mPktWriter << taskId;
		mPktWriter << success;
		mPktWriter << result;
		*mItemDataCreatedOffset = (uint16)mPktWriter.GetPktSize();
		if (itemDataCreated && !itemDataCreated->empty())
		{
			int tvalsize = (int)sizeof(*(itemDataCreated->begin())); 
			auto _itemDataCreated = const_cast<std::decay_t<T0>*>(itemDataCreated);
			for (auto it = _itemDataCreated->begin(); it != _itemDataCreated->end(); ++it) 
			{
				mPktWriter.WriteBinary((uint16)tvalsize, (uchar*)&(*it)); 
			}
			*mItemDataCreatedSize = (uint16) (tvalsize * itemDataCreated->size());
		}
	}
#endif

#ifdef _SERVER 
	void send(IocpObjectSession* session, SendBufferRef sendBuffer, bool autoCloseSendBuffer)
	{
		if (session) 
