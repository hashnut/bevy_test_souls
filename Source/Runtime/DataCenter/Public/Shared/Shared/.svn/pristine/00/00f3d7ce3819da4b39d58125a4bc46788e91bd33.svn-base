		mPktWriter << (*mBookmarkListSize);
		mPktWriter << taskId;
		mPktWriter << success;
		*mBookmarkListOffset = (uint16)mPktWriter.GetPktSize();
		if (bookmarkList && !bookmarkList->empty())
		{
			int tvalsize = (int)sizeof(*(bookmarkList->begin())); 
			auto _bookmarkList = const_cast<std::decay_t<T0>*>(bookmarkList);
			for (auto it = _bookmarkList->begin(); it != _bookmarkList->end(); ++it) 
			{
				mPktWriter.WriteBinary((uint16)tvalsize, (uchar*)&(*it)); 
