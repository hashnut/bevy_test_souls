{
	struct QuestList
	{
	protected:
		uint16 mThisOffset;
		uint16 mNextOffset;
		QuestId mQuestId;

	public:
		QuestId QuestId() { return mQuestId; }

		friend PktIterator<QuestList>;
		friend PKT_WG_REQ_DB_QUEST_MULTI_LEVEL_RANK_ACCEPT_READ;

		bool Validate(uint16 offset, uchar * pktStart, uint16 pktSize, uint16& dataSize)
		{
			if (static_cast<size_t>(pktSize) < static_cast<size_t>(offset) + sizeof(QuestList))
				return false;

			QuestList * node = (QuestList*)(pktStart + offset);

			// ŔÚ±â ŔÚ˝ĹŔÇ Ć÷ŔÎĹÍ °ËÁő
			if (offset != node->mThisOffset)
				return false;

			// Value °ËÁő
			uchar* pktCurrentNodeStart = (uchar*)this - mThisOffset;
			uint16 pktCurrentNodeSize = *((uint16*)pktStart);
			dataSize += sizeof(QuestList);	// skip
			if (false == ValidateValue(pktCurrentNodeStart, pktCurrentNodeSize, dataSize))
				return false;

			return true;
		}

		bool ValidateValue(const uchar* pktStart, uint16 pktSize, uint16& dataSize)
		{
			return (nullptr != pktStart && 0 < pktSize && 0 < dataSize) ? true : false;
		}

	}; // QuestList

public:
	uint16 mPktSize;
	uint16 mPktId;
	uint16 mQuestListCount;
	uint16 mFirstQuestListOffset;
	ServerTaskId mTaskId;
	UserDBId mUserDBId;
	StoryId mCurStoryId;
	StoryId mAcceptStoryId;
	MultiLevelRankId mClearMultiLevelRankId;
	MultiLevelRankSlotInfo mAcceptMultiLevelRankInfo;

