	{
		auto readPacket = reinterpret_cast<PKT_WG_REQ_REGISTER_ADMIN_COMMAND_READ*>(mPktWriter.mBuf);
		return readPacket->GetLogWString();
	}
#endif

#ifndef _SERVER
	CommandListHandle CreateCommandList(CommandHandlerType type, const FString& command)
	{
		uchar* nowBuffer = mPktWriter.GetBuffer();
		uint16 nowWritten = (uint16)mPktWriter.GetPktSize();
		CommandList* newCommandList = new ((CommandList*)nowBuffer) CommandList(nowWritten, type);
		++(*mCommandListCount);
		if (mNowCommandList == 0)
			*mFirstCommandListOffset = nowWritten;
		else
			mNowCommandList->mNextOffset = nowWritten;
		mNowCommandList = newCommandList;
		mPktWriter.Skip(sizeof(CommandList));
		mNowCommandList->SetCommandOffset((uint16)mPktWriter.GetPktSize());
		mPktWriter.WriteString(command);
		return CommandListHandle(mPktWriter, newCommandList);
	}

#else
	CommandListHandle CreateCommandList(CommandHandlerType type, const wchar* command)
	{
		uchar* nowBuffer = mPktWriter.GetBuffer();
		uint16 nowWritten = (uint16)mPktWriter.GetPktSize();
		CommandList* newCommandList = new ((CommandList*)nowBuffer) CommandList(nowWritten, type);
