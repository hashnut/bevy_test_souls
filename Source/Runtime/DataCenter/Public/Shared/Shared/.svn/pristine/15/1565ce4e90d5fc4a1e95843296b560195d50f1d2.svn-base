			auto _sealSlotLockDataList = const_cast<std::decay_t<T0>*>(sealSlotLockDataList);
			for (auto it = _sealSlotLockDataList->begin(); it != _sealSlotLockDataList->end(); ++it) 
			{
				mPktWriter.WriteBinary((uint16)tvalsize, (uchar*)&(*it)); 
			}
			*mSealSlotLockDataListSize = (uint16) (tvalsize * sealSlotLockDataList->size());
		}
	}
#endif

#ifdef _SERVER 
	void send(IocpObjectSession* session, SendBufferRef sendBuffer, bool autoCloseSendBuffer)
	{
		if (session) 
			session->Send(sendBuffer, mPktWriter.GetPktSize(), autoCloseSendBuffer);
	}
#endif

#ifdef _SERVER 
	std::xwstring GetLogWString() const
	{
		auto readPacket = reinterpret_cast<PKT_WG_REQ_DB_SEAL_SLOT_LOCK_DATA_SAVE_READ*>(mPktWriter.mBuf);
		return readPacket->GetLogWString();
	}
#endif

#ifndef _SERVER
#else
