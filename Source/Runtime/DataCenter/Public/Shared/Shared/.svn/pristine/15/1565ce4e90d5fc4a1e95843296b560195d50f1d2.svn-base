// type = WG
struct PKT_WG_BYPASS_TO_CLIENT_READ
{
public:
	uint16 mPktSize;
	uint16 mPktId;
	uint16 mUserBypassIdListOffset;
	uint16 mUserBypassIdListSize;
	uint16 mBypassBufOffset;
	uint16 mBypassBufSize;
	uint16 mBypassPacketId;

public:
#ifdef _SERVER 
	using _T0 = BypassTicketSequence;
	bool GetServerTaskIdRealTime(OUT [[maybe_unused]] int& serverTaskId) const { return false; }
	const wchar_t* GetPacketName() const { return L"WG_BYPASS_TO_CLIENT"; }
	const wchar_t* GetRelatedPacketName() const { return L"GW_BYPASS_TO_CLIENT"; }
#endif

	uint16 BypassPacketId() { return mBypassPacketId; }
	const uchar* UserBypassIdList() const
	{
		uchar* pktStart = (uchar*)this;
		uint16 pktSize = *((uint16*)pktStart);
		if (mUserBypassIdListOffset && pktSize > mUserBypassIdListOffset)
			return (const uchar*)(pktStart + mUserBypassIdListOffset);
		else
			return 0;
	}
	int UserBypassIdListSize() const
	{
		return mUserBypassIdListSize;
	}
#ifdef _SERVER
	template <typename Container>
	void MakeUserBypassIdListVector(Container & container)
	{
		//emplace() ČŁĂâÇŇ¶§¸¶´Ů ¸Ţ¸đ¸®¸¦ »ýĽş ÇĎ´Â şńżëŔĚ ąß»ýÇŃ´Ů şńżëŔ»ÁŮŔĚŔ§°ł reserve()»çżë
		container.reserve(mUserBypassIdListSize/sizeof(_T0));
		for (int offset = 0; offset < mUserBypassIdListSize; offset += sizeof(_T0))
		{
			const _T0* data = reinterpret_cast<const _T0*>(UserBypassIdList() + offset);
			container.emplace_back(*data);
		}
	}
#else // _SERVER
	template <typename Container, typename Data>
	void MakeUserBypassIdListVector(Container & container)
	{
		for (int offset = 0; offset < mUserBypassIdListSize; offset += sizeof(Data))
		{
			const Data* data = reinterpret_cast<const Data*>(UserBypassIdList() + offset);
			container.Add(*data);
		}
	}
#endif // _SERVER
#ifdef _SERVER
	template <typename TFunc>
	void ForEachUserBypassIdList(TFunc&& func) const
	{
		for (int offset = 0; offset < UserBypassIdListSize(); offset += sizeof(_T0))
		{
			const _T0* data = reinterpret_cast<const _T0*>(UserBypassIdList() + offset);
			func(data);
		}
	}
#endif
	const uchar* BypassBuf() const
	{
		uchar* pktStart = (uchar*)this;
		uint16 pktSize = *((uint16*)pktStart);
		if (mBypassBufOffset && pktSize > mBypassBufOffset)
			return (const uchar*)(pktStart + mBypassBufOffset);
		else
			return 0;
	}
	int BypassBufSize() const
	{
		return mBypassBufSize;
	}


#ifdef _SERVER 
	std::xwstring GetLogWString() const
	{

		return Log::format(
			L"[WG_BYPASS_TO_CLIENT] BypassPacketId: {}"
			, mBypassPacketId
		).c_str();
	}
#endif

	bool Validate()
	{
		uchar* pktStart = (uchar*)this;
		uint16 pktSize = mPktSize;

		uint16 dataSize = sizeof(PKT_WG_BYPASS_TO_CLIENT_READ);
		if (dataSize > mPktSize)
			return false;

		if (false == ValidateValue(pktStart, pktSize, dataSize))
			return false;

		if (dataSize != mPktSize)
			return false;

		return true;
	}

	bool ValidateValue(const uchar* pktStart, uint16 pktSize, uint16& dataSize)
	{
		if (false == ValidateBinary(mUserBypassIdListOffset, mUserBypassIdListSize, 0, pktSize, dataSize))
			return false;

		if (false == ValidateBinary(mBypassBufOffset, mBypassBufSize, 0, pktSize, dataSize))
			return false;

		return (nullptr != pktStart && 0 < pktSize && 0 < dataSize) ? true : false;
	}

}; // PKT_WG_BYPASS_TO_CLIENT_READ

// type = WG
#ifdef _SERVER
struct PKT_WG_BYPASS_TO_CLIENT_WRITE : public Disposable
#else
struct PKT_WG_BYPASS_TO_CLIENT_WRITE
#endif
{
	PktWriter mPktWriter;
	uint16* mUserBypassIdListOffset;
	uint16* mUserBypassIdListSize;
	uint16* mBypassBufOffset;
	uint16* mBypassBufSize;

#ifdef _SERVER 
	using _T0 = BypassTicketSequence;
	bool GetServerTaskIdRealTime(OUT int& serverTaskId) const { return reinterpret_cast<PKT_WG_BYPASS_TO_CLIENT_READ*>(mPktWriter.mBuf)->GetServerTaskIdRealTime(serverTaskId); }
	const wchar_t* GetPacketName() const { return L"WG_BYPASS_TO_CLIENT"; }
	const wchar_t* GetRelatedPacketName() const { return L"GW_BYPASS_TO_CLIENT"; }
#endif

#ifndef _SERVER
	template <typename T0>
	PKT_WG_BYPASS_TO_CLIENT_WRITE(uchar* buf, int bufSize, const T0* userBypassIdList, uint16 bypassPacketId, int sizeBypassBuf, uchar* bypassBuf)
		:
		mPktWriter(buf, bufSize)

	{
		mPktWriter << static_cast<uint16>(PD::WG::WGPacketId::WG_BYPASS_TO_CLIENT);
		mUserBypassIdListOffset = (uint16*)mPktWriter.GetBuffer();
		*mUserBypassIdListOffset = 0;
		mPktWriter << (*mUserBypassIdListOffset);
		mUserBypassIdListSize = (uint16*)mPktWriter.GetBuffer();
		*mUserBypassIdListSize = 0;
		mPktWriter << (*mUserBypassIdListSize);
		mBypassBufOffset = (uint16*)mPktWriter.GetBuffer();
		*mBypassBufOffset = 0;
		mPktWriter << (*mBypassBufOffset);
		mBypassBufSize = (uint16*)mPktWriter.GetBuffer();
		*mBypassBufSize = 0;
		mPktWriter << (*mBypassBufSize);
		mPktWriter << bypassPacketId;
		*mUserBypassIdListOffset = (uint16)mPktWriter.GetPktSize();
		if (userBypassIdList && 0 < userBypassIdList->Num())
		{
			int tvalsize = (int)sizeof(*(userBypassIdList->begin())); 
			auto _userBypassIdList = (T0*)userBypassIdList;
			for (auto it = _userBypassIdList->begin(); it != _userBypassIdList->end(); ++it) 
			{
				mPktWriter.WriteBinary((uint16)tvalsize, (uchar*)&(*it)); 
			}
			*mUserBypassIdListSize = (uint16)(tvalsize* userBypassIdList->Num());
		}
		*mBypassBufOffset = (uint16)mPktWriter.GetPktSize();
		*mBypassBufSize = (uint16) sizeBypassBuf;
		mPktWriter.WriteBinary((uint16)sizeBypassBuf, bypassBuf);
	}

#endif // _SERVER
#ifdef _SERVER
	template <typename T0>
	PKT_WG_BYPASS_TO_CLIENT_WRITE(SendBufferHelper& sendBuffer, const T0* userBypassIdList, uint16 bypassPacketId, int sizeBypassBuf, uchar* bypassBuf)
		:
		mPktWriter(sendBuffer->GetCharBuffer(), (SEND_BUFFER_SIZE - 1))

	{
		static_assert(true == std::is_same_v<T0::value_type, _T0>, "userBypassIdList type must be BypassTicketSequence list type"); 
		mPktWriter << (uint16)WG_BYPASS_TO_CLIENT;
		mUserBypassIdListOffset = (uint16*)mPktWriter.GetBuffer();
		*mUserBypassIdListOffset = 0;
		mPktWriter << (*mUserBypassIdListOffset);
		mUserBypassIdListSize = (uint16*)mPktWriter.GetBuffer();
		*mUserBypassIdListSize = 0;
		mPktWriter << (*mUserBypassIdListSize);
		mBypassBufOffset = (uint16*)mPktWriter.GetBuffer();
		*mBypassBufOffset = 0;
		mPktWriter << (*mBypassBufOffset);
		mBypassBufSize = (uint16*)mPktWriter.GetBuffer();
		*mBypassBufSize = 0;
		mPktWriter << (*mBypassBufSize);
		mPktWriter << bypassPacketId;
		*mUserBypassIdListOffset = (uint16)mPktWriter.GetPktSize();
		if (userBypassIdList && !userBypassIdList->empty())
		{
			int tvalsize = (int)sizeof(*(userBypassIdList->begin())); 
			auto _userBypassIdList = const_cast<std::decay_t<T0>*>(userBypassIdList);
			for (auto it = _userBypassIdList->begin(); it != _userBypassIdList->end(); ++it) 
			{
				mPktWriter.WriteBinary((uint16)tvalsize, (uchar*)&(*it)); 
			}
			*mUserBypassIdListSize = (uint16) (tvalsize * userBypassIdList->size());
		}
		*mBypassBufOffset = (uint16)mPktWriter.GetPktSize();
		*mBypassBufSize = (uint16) sizeBypassBuf;
		mPktWriter.WriteBinary((uint16)sizeBypassBuf, bypassBuf);
	}
#endif

#ifdef _SERVER 
	void send(IocpObjectSession* session, SendBufferRef sendBuffer, bool autoCloseSendBuffer)
	{
		if (session) 
			session->Send(sendBuffer, mPktWriter.GetPktSize(), autoCloseSendBuffer);
	}
#endif

#ifdef _SERVER 
	std::xwstring GetLogWString() const
	{
		auto readPacket = reinterpret_cast<PKT_WG_BYPASS_TO_CLIENT_READ*>(mPktWriter.mBuf);
		return readPacket->GetLogWString();
	}
#endif

#ifndef _SERVER
#else
#endif
}; // PKT_WG_BYPASS_TO_CLIENT_WRITE

