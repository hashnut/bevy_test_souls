	bool Validate()
	{
		uchar* pktStart = (uchar*)this;
		uint16 pktSize = mPktSize;

		uint16 dataSize = sizeof(PKT_WG_REQ_DB_CRAFT_POST_PROCESS_READ);
		if (dataSize > mPktSize)
			return false;

		if (false == ValidateValue(pktStart, pktSize, dataSize))
			return false;

		if (dataSize != mPktSize)
			return false;

		return true;
	}

	bool ValidateValue(const uchar* pktStart, uint16 pktSize, uint16& dataSize)
	{
		if (false == ValidateBinary(mItemsCreateOffset, mItemsCreateSize, 0, pktSize, dataSize))
			return false;

		if (false == ValidateBinary(mItemsFinalStacksOffset, mItemsFinalStacksSize, 0, pktSize, dataSize))
			return false;

		if (false == ValidateBinary(mItemsDeletedOffset, mItemsDeletedSize, 0, pktSize, dataSize))
			return false;

		if (false == ValidateBinary(mUpdateCurrencyDecreaseOffset, mUpdateCurrencyDecreaseSize, 0, pktSize, dataSize))
			return false;

		if (false == ValidateBinary(mUpdateCurrencyOffset, mUpdateCurrencySize, 0, pktSize, dataSize))
			return false;

		if (false == ValidateBinary(mCraftRestrictPairListOffset, mCraftRestrictPairListSize, 0, pktSize, dataSize))
			return false;

		return (nullptr != pktStart && 0 < pktSize && 0 < dataSize) ? true : false;
	}

