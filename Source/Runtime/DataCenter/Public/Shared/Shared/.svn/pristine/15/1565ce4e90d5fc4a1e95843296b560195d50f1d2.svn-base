#ifdef _SERVER
	template <typename Container>
	void MakeItemsCreateVector(Container & container)
	{
		//emplace() ČŁĂâÇŇ¶§¸¶´Ů ¸Ţ¸đ¸®¸¦ »ýĽş ÇĎ´Â şńżëŔĚ ąß»ýÇŃ´Ů şńżëŔ»ÁŮŔĚŔ§°ł reserve()»çżë
		container.reserve(mItemsCreateSize/sizeof(_T0));
		for (int offset = 0; offset < mItemsCreateSize; offset += sizeof(_T0))
		{
			const _T0* data = reinterpret_cast<const _T0*>(ItemsCreate() + offset);
			container.emplace_back(*data);
		}
	}
#else // _SERVER
	template <typename Container, typename Data>
	void MakeItemsCreateVector(Container & container)
	{
		for (int offset = 0; offset < mItemsCreateSize; offset += sizeof(Data))
		{
			const Data* data = reinterpret_cast<const Data*>(ItemsCreate() + offset);
			container.Add(*data);
		}
	}
#endif // _SERVER
#ifdef _SERVER
	template <typename TFunc>
	void ForEachItemsCreate(TFunc&& func) const
	{
		for (int offset = 0; offset < ItemsCreateSize(); offset += sizeof(_T0))
		{
			const _T0* data = reinterpret_cast<const _T0*>(ItemsCreate() + offset);
			func(data);
		}
	}
#endif
