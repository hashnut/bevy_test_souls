// type = WG
struct PKT_WG_REQ_REGISTER_ADMIN_COMMAND_READ
{
	struct CommandList
	{
	protected:
		uint16 mThisOffset;
		uint16 mNextOffset;
		uint16 mCommandOffset;
		CommandHandlerType mType;

	public:
		CommandHandlerType Type() { return mType; }

#ifdef _SERVER
		const wchar_t* Command()
		{
			uchar* pktStart = (uchar*)this - mThisOffset;
			uint16 pktSize = *((uint16*)pktStart);
			if (mCommandOffset && pktSize > mCommandOffset)
				return (const wchar_t*)(pktStart + mCommandOffset);
			else
				return L"";
		}
#else // _SERVER
		const FString Command()
		{
			const wchar_t* strWchar = L"";
			uchar* pktStart = (uchar*)this - mThisOffset;
			uint16 pktSize = *((uint16*)pktStart);
			if (mCommandOffset && pktSize > mCommandOffset)
				strWchar = (const wchar_t*)(pktStart + mCommandOffset);
			return PktWriter::ConvertToFString(strWchar);
		}
#endif // _SERVER
		friend PktIterator<CommandList>;
		friend PKT_WG_REQ_REGISTER_ADMIN_COMMAND_READ;

		bool Validate(uint16 offset, uchar * pktStart, uint16 pktSize, uint16& dataSize)
		{
			if (static_cast<size_t>(pktSize) < static_cast<size_t>(offset) + sizeof(CommandList))
				return false;

			CommandList * node = (CommandList*)(pktStart + offset);

			// ŔÚ±â ŔÚ˝ĹŔÇ Ć÷ŔÎĹÍ °ËÁő
			if (offset != node->mThisOffset)
				return false;

			// Value °ËÁő
			uchar* pktCurrentNodeStart = (uchar*)this - mThisOffset;
			uint16 pktCurrentNodeSize = *((uint16*)pktStart);
			dataSize += sizeof(CommandList);	// skip
			if (false == ValidateValue(pktCurrentNodeStart, pktCurrentNodeSize, dataSize))
				return false;

			return true;
		}

		bool ValidateValue(const uchar* pktStart, uint16 pktSize, uint16& dataSize)
		{
			if (false == ValidateString(mCommandOffset, 0, pktStart, pktSize, dataSize))
				return false;

			return (nullptr != pktStart && 0 < pktSize && 0 < dataSize) ? true : false;
		}

	}; // CommandList

public:
	uint16 mPktSize;
	uint16 mPktId;
	uint16 mCommandListCount;
	uint16 mFirstCommandListOffset;

public:
#ifdef _SERVER 
	bool GetServerTaskIdRealTime(OUT [[maybe_unused]] int& serverTaskId) const { return false; }
	const wchar_t* GetPacketName() const { return L"WG_REQ_REGISTER_ADMIN_COMMAND"; }
	const wchar_t* GetRelatedPacketName() const { return L"GW_ACK_REGISTER_ADMIN_COMMAND"; }
#endif


	using CommandListIterator = PktIterator<CommandList>;
	const CommandListIterator GetLastCommandListIterator() const
	{
		return CommandListIterator(0);
	}
	CommandListIterator GetFirstCommandListIterator() const
	{
		if (mFirstCommandListOffset && mPktSize >= mFirstCommandListOffset + sizeof(CommandList))
		{
			CommandList* commandList = (CommandList*)((uchar*)this + mFirstCommandListOffset);
			if (mFirstCommandListOffset == commandList->mThisOffset)
				return CommandListIterator(commandList);
			else
				return CommandListIterator(0);
		}
		else
			return CommandListIterator(0);
	}
	const int GetCommandListCount()
	{
		return mCommandListCount;
	}
#ifdef _SERVER
	template<typename TFunc>
	void ForEachCommandList(TFunc&& func)
	{
		for (auto it = GetFirstCommandListIterator(); it != GetLastCommandListIterator(); ++it)
			func(it);
	}
#endif


#ifdef _SERVER 
	std::xwstring FuncCreateCommandListStr( [[maybe_unused]] CommandListIterator& iter) const
	{
		return Log::format(
			L"Type: {}, Command: {}", 
			iter->Type(), iter->Command()
		).c_str();
	}

	std::xwstring GetLogWString() const
	{
		std::xwstring str1;
		str1.append(L"\n");
		for (CommandListIterator iter = this->GetFirstCommandListIterator();
			iter != GetLastCommandListIterator(); ++iter)
		{
			str1.append(L"[");
			str1.append(FuncCreateCommandListStr(iter).c_str());

			str1.append(L"]\n");
		}

		return Log::format(
			L"[WG_REQ_REGISTER_ADMIN_COMMAND] CommandList : {}"
			, str1.c_str()
		).c_str();
	}
#endif

	bool Validate()
	{
		uchar* pktStart = (uchar*)this;
		uint16 pktSize = mPktSize;

		uint16 dataSize = sizeof(PKT_WG_REQ_REGISTER_ADMIN_COMMAND_READ);
		if (dataSize > mPktSize)
			return false;

		if (false == ValidateValue(pktStart, pktSize, dataSize))
			return false;

		if (false == CommandListValidateListNode(mFirstCommandListOffset, pktStart, pktSize, dataSize))
			return false;

		if (dataSize != mPktSize)
			return false;

		return true;
	}

	bool CommandListValidateListNode(uint16 offset, uchar * pktStart, uint16 pktSize, uint16& dataSize)
	{		for (CommandListIterator iter = this->GetFirstCommandListIterator();
			iter != GetLastCommandListIterator(); ++iter)
		{
			if (false == (*iter).Validate(offset, pktStart, pktSize, dataSize))
			{
				return false;
			}
		}
		return true;
	}

	bool ValidateValue(const uchar* pktStart, uint16 pktSize, uint16& dataSize)
	{
		return (nullptr != pktStart && 0 < pktSize && 0 < dataSize) ? true : false;
	}

}; // PKT_WG_REQ_REGISTER_ADMIN_COMMAND_READ

