	UserDBId mUserDBId;

public:
#ifdef _SERVER 
	using _T0 = AchievementInfo;
	using _T1 = AchievementInfo;
	bool GetServerTaskIdRealTime(OUT int& serverTaskId) const { serverTaskId = mTaskId; return true; }
	const wchar_t* GetPacketName() const { return L"WG_REQ_DB_ACHIEVEMENT_UPDATE"; }
