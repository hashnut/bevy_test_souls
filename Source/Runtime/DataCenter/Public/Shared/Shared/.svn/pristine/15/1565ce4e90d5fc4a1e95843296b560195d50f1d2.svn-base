// related packet = PKT_GW_REQ_INVADE_PORTAL_INFO_WRITE
struct PKT_WG_ACK_INVADE_PORTAL_INFO_READ
{
	struct InvadePortalInfoList
	{
		struct SpawnSpotIdList
		{
		protected:
			uint16 mThisOffset;
			uint16 mNextOffset;
			SpotId mSpotId;
			bool mIsActive;

		public:
			SpotId SpotId() { return mSpotId; }
			bool IsActive() { return mIsActive; }

			friend PktIterator<InvadePortalInfoList::SpawnSpotIdList>;
			friend InvadePortalInfoList;

			bool Validate(uint16 offset, uchar * pktStart, uint16 pktSize, uint16& dataSize)
			{
				if (static_cast<size_t>(pktSize) < static_cast<size_t>(offset) + sizeof(InvadePortalInfoList::SpawnSpotIdList))
					return false;

				InvadePortalInfoList::SpawnSpotIdList * node = (InvadePortalInfoList::SpawnSpotIdList*)(pktStart + offset);

				// ŔÚ±â ŔÚ˝ĹŔÇ Ć÷ŔÎĹÍ °ËÁő
				if (offset != node->mThisOffset)
					return false;

				// Value °ËÁő
				uchar* pktCurrentNodeStart = (uchar*)this - mThisOffset;
				uint16 pktCurrentNodeSize = *((uint16*)pktStart);
				dataSize += sizeof(InvadePortalInfoList::SpawnSpotIdList);	// skip
				if (false == ValidateValue(pktCurrentNodeStart, pktCurrentNodeSize, dataSize))
					return false;

				return true;
			}

			bool ValidateValue(const uchar* pktStart, uint16 pktSize, uint16& dataSize)
			{
				return (nullptr != pktStart && 0 < pktSize && 0 < dataSize) ? true : false;
			}

		}; // SpawnSpotIdList

	protected:
		uint16 mThisOffset;
		uint16 mNextOffset;
		uint16 mSpawnSpotIdListCount;
		uint16 mFirstSpawnSpotIdListOffset;
		MapId mMapId;

	public:
		MapId MapId() { return mMapId; }

		using SpawnSpotIdListIterator = PktIterator<SpawnSpotIdList>;
		const SpawnSpotIdListIterator GetLastSpawnSpotIdListIterator() const
		{
			return SpawnSpotIdListIterator(0);
		}
		SpawnSpotIdListIterator GetFirstSpawnSpotIdListIterator() const
		{
			uchar* pktStart = (uchar*)this - mThisOffset;
			uint16 pktSize = *((uint16*)pktStart);
