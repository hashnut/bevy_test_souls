		if (false == ValidateBinary(mItemMoveToOwnerOffset, mItemMoveToOwnerSize, 0, pktSize, dataSize))
			return false;

		if (false == ValidateBinary(mOwnerItemsCreateOffset, mOwnerItemsCreateSize, 0, pktSize, dataSize))
