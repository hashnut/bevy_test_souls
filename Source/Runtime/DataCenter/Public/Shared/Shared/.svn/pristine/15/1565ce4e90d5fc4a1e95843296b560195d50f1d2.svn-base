	const uchar* CurrencyPairList() const
	{
		uchar* pktStart = (uchar*)this;
		uint16 pktSize = *((uint16*)pktStart);
		if (mCurrencyPairListOffset && pktSize > mCurrencyPairListOffset)
			return (const uchar*)(pktStart + mCurrencyPairListOffset);
		else
			return 0;
	}
	int CurrencyPairListSize() const
	{
		return mCurrencyPairListSize;
	}
#ifdef _SERVER
	template <typename Container>
	void MakeCurrencyPairListVector(Container & container)
	{
		//emplace() ČŁĂâÇŇ¶§¸¶´Ů ¸Ţ¸đ¸®¸¦ »ýĽş ÇĎ´Â şńżëŔĚ ąß»ýÇŃ´Ů şńżëŔ»ÁŮŔĚŔ§°ł reserve()»çżë
		container.reserve(mCurrencyPairListSize/sizeof(_T0));
		for (int offset = 0; offset < mCurrencyPairListSize; offset += sizeof(_T0))
		{
			const _T0* data = reinterpret_cast<const _T0*>(CurrencyPairList() + offset);
			container.emplace_back(*data);
		}
	}
#else // _SERVER
	template <typename Container, typename Data>
	void MakeCurrencyPairListVector(Container & container)
	{
		for (int offset = 0; offset < mCurrencyPairListSize; offset += sizeof(Data))
		{
			const Data* data = reinterpret_cast<const Data*>(CurrencyPairList() + offset);
			container.Add(*data);
		}
	}
#endif // _SERVER
#ifdef _SERVER
	template <typename TFunc>
	void ForEachCurrencyPairList(TFunc&& func) const
	{
		for (int offset = 0; offset < CurrencyPairListSize(); offset += sizeof(_T0))
		{
			const _T0* data = reinterpret_cast<const _T0*>(CurrencyPairList() + offset);
			func(data);
		}
	}
#endif


#ifdef _SERVER 
	std::xwstring GetLogWString() const
	{

		return Log::format(
			L"[WG_REQ_DB_DEPOT_EXTEND_SLOT] TaskId: {}, UserId: {}, ExtendedNumber: {}"
			, mTaskId, mUserId, mExtendedNumber
		).c_str();
	}
#endif

	bool Validate()
	{
		uchar* pktStart = (uchar*)this;
		uint16 pktSize = mPktSize;

		uint16 dataSize = sizeof(PKT_WG_REQ_DB_DEPOT_EXTEND_SLOT_READ);
		if (dataSize > mPktSize)
			return false;

		if (false == ValidateValue(pktStart, pktSize, dataSize))
