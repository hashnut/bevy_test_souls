	const wchar_t* GetRelatedPacketName() const { return L"GW_ACK_DB_QUEST_MULTI_LEVEL_RANK_ACCEPT"; }
#endif

	ServerTaskId TaskId() { return mTaskId; }
	UserDBId UserDBId() { return mUserDBId; }
	StoryId CurStoryId() { return mCurStoryId; }
	StoryId AcceptStoryId() { return mAcceptStoryId; }
	MultiLevelRankId ClearMultiLevelRankId() { return mClearMultiLevelRankId; }
	const MultiLevelRankSlotInfo& ConstRefAcceptMultiLevelRankInfo() { return mAcceptMultiLevelRankInfo; }
	MultiLevelRankSlotInfo AcceptMultiLevelRankInfo() { return mAcceptMultiLevelRankInfo; }

	using QuestListIterator = PktIterator<QuestList>;
	const QuestListIterator GetLastQuestListIterator() const
	{
		return QuestListIterator(0);
	}
	QuestListIterator GetFirstQuestListIterator() const
	{
		if (mFirstQuestListOffset && mPktSize >= mFirstQuestListOffset + sizeof(QuestList))
		{
			QuestList* questList = (QuestList*)((uchar*)this + mFirstQuestListOffset);
			if (mFirstQuestListOffset == questList->mThisOffset)
				return QuestListIterator(questList);
			else
				return QuestListIterator(0);
		}
		else
			return QuestListIterator(0);
	}
	const int GetQuestListCount()
	{
		return mQuestListCount;
	}
