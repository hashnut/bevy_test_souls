#ifdef _SERVER
	template <typename Container>
	void MakeStatInfoListVector(Container & container)
	{
		//emplace() ČŁĂâÇŇ¶§¸¶´Ů ¸Ţ¸đ¸®¸¦ »ýĽş ÇĎ´Â şńżëŔĚ ąß»ýÇŃ´Ů şńżëŔ»ÁŮŔĚŔ§°ł reserve()»çżë
		container.reserve(mStatInfoListSize/sizeof(_T0));
		for (int offset = 0; offset < mStatInfoListSize; offset += sizeof(_T0))
		{
