	CreatureId BossId() { return mBossId; }
	const uchar* ItemsCreateList() const
	{
		uchar* pktStart = (uchar*)this;
		uint16 pktSize = *((uint16*)pktStart);
		if (mItemsCreateListOffset && pktSize > mItemsCreateListOffset)
			return (const uchar*)(pktStart + mItemsCreateListOffset);
		else
			return 0;
	}
	int ItemsCreateListSize() const
	{
		return mItemsCreateListSize;
	}
#ifdef _SERVER
	template <typename Container>
	void MakeItemsCreateListVector(Container & container)
	{
		//emplace() ČŁĂâÇŇ¶§¸¶´Ů ¸Ţ¸đ¸®¸¦ »ýĽş ÇĎ´Â şńżëŔĚ ąß»ýÇŃ´Ů şńżëŔ»ÁŮŔĚŔ§°ł reserve()»çżë
		container.reserve(mItemsCreateListSize/sizeof(_T0));
		for (int offset = 0; offset < mItemsCreateListSize; offset += sizeof(_T0))
		{
			const _T0* data = reinterpret_cast<const _T0*>(ItemsCreateList() + offset);
			container.emplace_back(*data);
		}
	}
#else // _SERVER
	template <typename Container, typename Data>
	void MakeItemsCreateListVector(Container & container)
	{
		for (int offset = 0; offset < mItemsCreateListSize; offset += sizeof(Data))
		{
			const Data* data = reinterpret_cast<const Data*>(ItemsCreateList() + offset);
			container.Add(*data);
		}
	}
#endif // _SERVER
#ifdef _SERVER
	template <typename TFunc>
	void ForEachItemsCreateList(TFunc&& func) const
	{
		for (int offset = 0; offset < ItemsCreateListSize(); offset += sizeof(_T0))
		{
			const _T0* data = reinterpret_cast<const _T0*>(ItemsCreateList() + offset);
			func(data);
		}
	}
#endif

	using ContributorMemberIterator = PktIterator<ContributorMember>;
	const ContributorMemberIterator GetLastContributorMemberIterator() const
	{
		return ContributorMemberIterator(0);
	}
	ContributorMemberIterator GetFirstContributorMemberIterator() const
	{
		if (mFirstContributorMemberOffset && mPktSize >= mFirstContributorMemberOffset + sizeof(ContributorMember))
		{
			ContributorMember* contributorMember = (ContributorMember*)((uchar*)this + mFirstContributorMemberOffset);
			if (mFirstContributorMemberOffset == contributorMember->mThisOffset)
				return ContributorMemberIterator(contributorMember);
			else
				return ContributorMemberIterator(0);
		}
		else
			return ContributorMemberIterator(0);
	}
	const int GetContributorMemberCount()
	{
		return mContributorMemberCount;
	}
#ifdef _SERVER
	template<typename TFunc>
	void ForEachContributorMember(TFunc&& func)
	{
		for (auto it = GetFirstContributorMemberIterator(); it != GetLastContributorMemberIterator(); ++it)
			func(it);
	}
#endif


#ifdef _SERVER 
	std::xwstring FuncCreateContributorMemberStr( [[maybe_unused]] ContributorMemberIterator& iter) const
	{
		return Log::format(
			L"UserName: {}, UserDBId: {}", 
			iter->UserName(), iter->UserDBId()
		).c_str();
	}

	std::xwstring GetLogWString() const
	{
		std::xwstring str1;
		str1.append(L"\n");
		for (ContributorMemberIterator iter = this->GetFirstContributorMemberIterator();
			iter != GetLastContributorMemberIterator(); ++iter)
		{
			str1.append(L"[");
			str1.append(FuncCreateContributorMemberStr(iter).c_str());

			str1.append(L"]\n");
		}

		return Log::format(
			L"[WG_REQ_DB_GUILD_STORE_ACQUIRED_ITEM] TaskId: {}, GuildDBId: {}, ItemAcquiredType: {}, MapId: {}, BossId: {}, ContributorMember : {}"
			, mTaskId, mGuildDBId, mItemAcquiredType, mMapId, mBossId, str1.c_str()
		).c_str();
	}
#endif

	bool Validate()
	{
		uchar* pktStart = (uchar*)this;
		uint16 pktSize = mPktSize;

		uint16 dataSize = sizeof(PKT_WG_REQ_DB_GUILD_STORE_ACQUIRED_ITEM_READ);
		if (dataSize > mPktSize)
			return false;

		if (false == ValidateValue(pktStart, pktSize, dataSize))
			return false;

		if (false == ContributorMemberValidateListNode(mFirstContributorMemberOffset, pktStart, pktSize, dataSize))
			return false;

		if (dataSize != mPktSize)
			return false;

		return true;
	}

	bool ContributorMemberValidateListNode(uint16 offset, uchar * pktStart, uint16 pktSize, uint16& dataSize)
	{		for (ContributorMemberIterator iter = this->GetFirstContributorMemberIterator();
			iter != GetLastContributorMemberIterator(); ++iter)
		{
			if (false == (*iter).Validate(offset, pktStart, pktSize, dataSize))
			{
				return false;
			}
		}
		return true;
	}

	bool ValidateValue(const uchar* pktStart, uint16 pktSize, uint16& dataSize)
	{
		if (false == ValidateBinary(mItemsCreateListOffset, mItemsCreateListSize, 0, pktSize, dataSize))
			return false;

		return (nullptr != pktStart && 0 < pktSize && 0 < dataSize) ? true : false;
	}

}; // PKT_WG_REQ_DB_GUILD_STORE_ACQUIRED_ITEM_READ

