struct PKT_WG_INTER_FIELDBOSS_CLEAR_TIME_UPDATE_READ
{
	struct FieldBossList
	{
	protected:
		uint16 mThisOffset;
		uint16 mNextOffset;
		FieldBossId mFieldBossId;
		bool mSpawn;
		time_t mStartTime;
		time_t mLastclearTime;

	public:
		FieldBossId FieldBossId() { return mFieldBossId; }
		bool Spawn() { return mSpawn; }
		time_t StartTime() { return mStartTime; }
		time_t LastclearTime() { return mLastclearTime; }

		friend PktIterator<FieldBossList>;
		friend PKT_WG_INTER_FIELDBOSS_CLEAR_TIME_UPDATE_READ;

		bool Validate(uint16 offset, uchar * pktStart, uint16 pktSize, uint16& dataSize)
		{
			if (static_cast<size_t>(pktSize) < static_cast<size_t>(offset) + sizeof(FieldBossList))
				return false;

			FieldBossList * node = (FieldBossList*)(pktStart + offset);

			// ŔÚ±â ŔÚ˝ĹŔÇ Ć÷ŔÎĹÍ °ËÁő
			if (offset != node->mThisOffset)
				return false;

			// Value °ËÁő
			uchar* pktCurrentNodeStart = (uchar*)this - mThisOffset;
			uint16 pktCurrentNodeSize = *((uint16*)pktStart);
			dataSize += sizeof(FieldBossList);	// skip
			if (false == ValidateValue(pktCurrentNodeStart, pktCurrentNodeSize, dataSize))
				return false;

			return true;
		}

		bool ValidateValue(const uchar* pktStart, uint16 pktSize, uint16& dataSize)
		{
			return (nullptr != pktStart && 0 < pktSize && 0 < dataSize) ? true : false;
		}

	}; // FieldBossList

public:
	uint16 mPktSize;
	uint16 mPktId;
	uint16 mFieldBossListCount;
	uint16 mFirstFieldBossListOffset;
	bool mDbUpdate;

public:
#ifdef _SERVER 
	bool GetServerTaskIdRealTime(OUT [[maybe_unused]] int& serverTaskId) const { return false; }
	const wchar_t* GetPacketName() const { return L"WG_INTER_FIELDBOSS_CLEAR_TIME_UPDATE"; }
	const wchar_t* GetRelatedPacketName() const { return L"GW_INTER_FIELDBOSS_CLEAR_TIME_UPDATE"; }
#endif

	bool DbUpdate() { return mDbUpdate; }

	using FieldBossListIterator = PktIterator<FieldBossList>;
	const FieldBossListIterator GetLastFieldBossListIterator() const
	{
		return FieldBossListIterator(0);
	}
	FieldBossListIterator GetFirstFieldBossListIterator() const
	{
		if (mFirstFieldBossListOffset && mPktSize >= mFirstFieldBossListOffset + sizeof(FieldBossList))
		{
			FieldBossList* fieldBossList = (FieldBossList*)((uchar*)this + mFirstFieldBossListOffset);
			if (mFirstFieldBossListOffset == fieldBossList->mThisOffset)
				return FieldBossListIterator(fieldBossList);
			else
				return FieldBossListIterator(0);
		}
		else
			return FieldBossListIterator(0);
	}
	const int GetFieldBossListCount()
	{
		return mFieldBossListCount;
	}
#ifdef _SERVER
	template<typename TFunc>
	void ForEachFieldBossList(TFunc&& func)
	{
		for (auto it = GetFirstFieldBossListIterator(); it != GetLastFieldBossListIterator(); ++it)
			func(it);
	}
#endif


#ifdef _SERVER 
	std::xwstring FuncCreateFieldBossListStr( [[maybe_unused]] FieldBossListIterator& iter) const
	{
		return Log::format(
			L"FieldBossId: {}, Spawn: {}, StartTime: {}, LastclearTime: {}", 
			iter->FieldBossId(), iter->Spawn(), iter->StartTime(), iter->LastclearTime()
		).c_str();
	}

	std::xwstring GetLogWString() const
	{
		std::xwstring str1;
		str1.append(L"\n");
		for (FieldBossListIterator iter = this->GetFirstFieldBossListIterator();
			iter != GetLastFieldBossListIterator(); ++iter)
		{
			str1.append(L"[");
			str1.append(FuncCreateFieldBossListStr(iter).c_str());

			str1.append(L"]\n");
		}

		return Log::format(
			L"[WG_INTER_FIELDBOSS_CLEAR_TIME_UPDATE] DbUpdate: {}, FieldBossList : {}"
			, mDbUpdate, str1.c_str()
		).c_str();
	}
#endif

	bool Validate()
	{
		uchar* pktStart = (uchar*)this;
		uint16 pktSize = mPktSize;

		uint16 dataSize = sizeof(PKT_WG_INTER_FIELDBOSS_CLEAR_TIME_UPDATE_READ);
		if (dataSize > mPktSize)
			return false;

		if (false == ValidateValue(pktStart, pktSize, dataSize))
			return false;

		if (false == FieldBossListValidateListNode(mFirstFieldBossListOffset, pktStart, pktSize, dataSize))
			return false;

		if (dataSize != mPktSize)
			return false;

		return true;
	}

	bool FieldBossListValidateListNode(uint16 offset, uchar * pktStart, uint16 pktSize, uint16& dataSize)
	{		for (FieldBossListIterator iter = this->GetFirstFieldBossListIterator();
			iter != GetLastFieldBossListIterator(); ++iter)
		{
			if (false == (*iter).Validate(offset, pktStart, pktSize, dataSize))
			{
				return false;
			}
		}
		return true;
	}

	bool ValidateValue(const uchar* pktStart, uint16 pktSize, uint16& dataSize)
	{
		return (nullptr != pktStart && 0 < pktSize && 0 < dataSize) ? true : false;
	}

}; // PKT_WG_INTER_FIELDBOSS_CLEAR_TIME_UPDATE_READ

