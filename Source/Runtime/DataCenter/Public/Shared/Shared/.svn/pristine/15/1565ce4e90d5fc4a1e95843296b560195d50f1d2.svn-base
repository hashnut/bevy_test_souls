// type = WG
struct PKT_WG_INTER_GUILDWAR_ASYNC_STATE_FROM_CHANNEL_READ
{
public:
	uint16 mPktSize;
	uint16 mPktId;
	uint16 mUserDBIdListOffset;
	uint16 mUserDBIdListSize;
	GuildDBId mGuildId;
	MapId mMapId;
	WorldId mWorldId;
	ChannelId mChannelId;
	GuildWarState mState;
	SpotId mTeamHomeSpotId;
	time_t mStateEndTime;

public:
#ifdef _SERVER 
	using _T0 = UserDBId;
	bool GetServerTaskIdRealTime(OUT [[maybe_unused]] int& serverTaskId) const { return false; }
	const wchar_t* GetPacketName() const { return L"WG_INTER_GUILDWAR_ASYNC_STATE_FROM_CHANNEL"; }
	const wchar_t* GetRelatedPacketName() const { return L"GW_INTER_GUILDWAR_ASYNC_STATE_FROM_CHANNEL"; }
#endif

	GuildDBId GuildId() { return mGuildId; }
	MapId MapId() { return mMapId; }
	WorldId WorldId() { return mWorldId; }
	ChannelId ChannelId() { return mChannelId; }
	const GuildWarState& ConstRefState() { return mState; }
	GuildWarState State() { return mState; }
	SpotId TeamHomeSpotId() { return mTeamHomeSpotId; }
	time_t StateEndTime() { return mStateEndTime; }
	const uchar* UserDBIdList() const
	{
		uchar* pktStart = (uchar*)this;
		uint16 pktSize = *((uint16*)pktStart);
		if (mUserDBIdListOffset && pktSize > mUserDBIdListOffset)
			return (const uchar*)(pktStart + mUserDBIdListOffset);
		else
			return 0;
	}
	int UserDBIdListSize() const
	{
		return mUserDBIdListSize;
	}
#ifdef _SERVER
	template <typename Container>
	void MakeUserDBIdListVector(Container & container)
	{
		//emplace() ČŁĂâÇŇ¶§¸¶´Ů ¸Ţ¸đ¸®¸¦ »ýĽş ÇĎ´Â şńżëŔĚ ąß»ýÇŃ´Ů şńżëŔ»ÁŮŔĚŔ§°ł reserve()»çżë
		container.reserve(mUserDBIdListSize/sizeof(_T0));
		for (int offset = 0; offset < mUserDBIdListSize; offset += sizeof(_T0))
		{
			const _T0* data = reinterpret_cast<const _T0*>(UserDBIdList() + offset);
			container.emplace_back(*data);
		}
	}
#else // _SERVER
	template <typename Container, typename Data>
	void MakeUserDBIdListVector(Container & container)
	{
		for (int offset = 0; offset < mUserDBIdListSize; offset += sizeof(Data))
		{
			const Data* data = reinterpret_cast<const Data*>(UserDBIdList() + offset);
			container.Add(*data);
		}
	}
#endif // _SERVER
#ifdef _SERVER
	template <typename TFunc>
	void ForEachUserDBIdList(TFunc&& func) const
	{
		for (int offset = 0; offset < UserDBIdListSize(); offset += sizeof(_T0))
		{
			const _T0* data = reinterpret_cast<const _T0*>(UserDBIdList() + offset);
			func(data);
		}
	}
#endif


#ifdef _SERVER 
	std::xwstring GetLogWString() const
	{

		return Log::format(
			L"[WG_INTER_GUILDWAR_ASYNC_STATE_FROM_CHANNEL] GuildId: {}, MapId: {}, WorldId: {}, ChannelId: {}, State: {}, TeamHomeSpotId: {}, StateEndTime: {}"
			, mGuildId, mMapId, mWorldId, mChannelId, mState, mTeamHomeSpotId, mStateEndTime
		).c_str();
