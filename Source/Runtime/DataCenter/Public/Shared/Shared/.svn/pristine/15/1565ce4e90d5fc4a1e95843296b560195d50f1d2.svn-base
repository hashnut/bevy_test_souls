	{
		auto StatInfoListLogFunc = [this]() -> std::xwstring
		{
			std::xwstring result;
			result.append(L"\n");
			for (int offset = 0; offset < StatInfoSize(); offset += sizeof(struct StatInfo))
			{
				const struct StatInfo* data = reinterpret_cast<const struct StatInfo*>(StatInfo() + offset);
				result.append(Log::format(L"{}", *data));
				result.append(L"\n");
			}
			return result;
		};


		return Log::format(
			L"[WG_MQ_BALANCE_SIMULATOR] UserDBId: {}, BalanceSimulatorInfo: {}, StatInfo: {}"
			, mUserDBId, mBalanceSimulatorInfo, StatInfoListLogFunc().c_str()
		).c_str();
	}
#endif

	bool Validate()
	{
