// type = WG
// related packet = PKT_GW_ACK_DB_QUICK_SLOT_SET_WRITE
struct PKT_WG_REQ_DB_QUICK_SLOT_SET_READ
{
	struct QuickSlotList
	{
	protected:
		uint16 mThisOffset;
		uint16 mNextOffset;
		QuickSlotId mQuickSlotId;
		ItemDBId mItemDBId;
		ItemId mItemId;
		bool mAutoUse;

	public:
		QuickSlotId QuickSlotId() { return mQuickSlotId; }
		ItemDBId ItemDBId() { return mItemDBId; }
		ItemId ItemId() { return mItemId; }
		bool AutoUse() { return mAutoUse; }

		friend PktIterator<QuickSlotList>;
		friend PKT_WG_REQ_DB_QUICK_SLOT_SET_READ;

		bool Validate(uint16 offset, uchar * pktStart, uint16 pktSize, uint16& dataSize)
		{
			if (static_cast<size_t>(pktSize) < static_cast<size_t>(offset) + sizeof(QuickSlotList))
				return false;

			QuickSlotList * node = (QuickSlotList*)(pktStart + offset);

			// ŔÚ±â ŔÚ˝ĹŔÇ Ć÷ŔÎĹÍ °ËÁő
			if (offset != node->mThisOffset)
				return false;

			// Value °ËÁő
			uchar* pktCurrentNodeStart = (uchar*)this - mThisOffset;
			uint16 pktCurrentNodeSize = *((uint16*)pktStart);
			dataSize += sizeof(QuickSlotList);	// skip
			if (false == ValidateValue(pktCurrentNodeStart, pktCurrentNodeSize, dataSize))
				return false;

			return true;
		}

		bool ValidateValue(const uchar* pktStart, uint16 pktSize, uint16& dataSize)
		{
			return (nullptr != pktStart && 0 < pktSize && 0 < dataSize) ? true : false;
		}

	}; // QuickSlotList

public:
	uint16 mPktSize;
	uint16 mPktId;
	uint16 mQuickSlotListCount;
	uint16 mFirstQuickSlotListOffset;
	ServerTaskId mTaskId;
	UserDBId mUserDBId;

public:
#ifdef _SERVER 
	bool GetServerTaskIdRealTime(OUT int& serverTaskId) const { serverTaskId = mTaskId; return true; }
	const wchar_t* GetPacketName() const { return L"WG_REQ_DB_QUICK_SLOT_SET"; }
	const wchar_t* GetRelatedPacketName() const { return L"GW_ACK_DB_QUICK_SLOT_SET"; }
#endif

	ServerTaskId TaskId() { return mTaskId; }
	UserDBId UserDBId() { return mUserDBId; }

	using QuickSlotListIterator = PktIterator<QuickSlotList>;
	const QuickSlotListIterator GetLastQuickSlotListIterator() const
	{
		return QuickSlotListIterator(0);
	}
	QuickSlotListIterator GetFirstQuickSlotListIterator() const
	{
		if (mFirstQuickSlotListOffset && mPktSize >= mFirstQuickSlotListOffset + sizeof(QuickSlotList))
		{
			QuickSlotList* quickSlotList = (QuickSlotList*)((uchar*)this + mFirstQuickSlotListOffset);
			if (mFirstQuickSlotListOffset == quickSlotList->mThisOffset)
				return QuickSlotListIterator(quickSlotList);
			else
				return QuickSlotListIterator(0);
		}
		else
			return QuickSlotListIterator(0);
	}
	const int GetQuickSlotListCount()
	{
		return mQuickSlotListCount;
	}
#ifdef _SERVER
	template<typename TFunc>
	void ForEachQuickSlotList(TFunc&& func)
	{
		for (auto it = GetFirstQuickSlotListIterator(); it != GetLastQuickSlotListIterator(); ++it)
			func(it);
	}
#endif


#ifdef _SERVER 
	std::xwstring FuncCreateQuickSlotListStr( [[maybe_unused]] QuickSlotListIterator& iter) const
	{
		return Log::format(
			L"QuickSlotId: {}, ItemDBId: {}, ItemId: {}, AutoUse: {}", 
			iter->QuickSlotId(), iter->ItemDBId(), iter->ItemId(), iter->AutoUse()
		).c_str();
	}

	std::xwstring GetLogWString() const
	{
		std::xwstring str1;
		str1.append(L"\n");
		for (QuickSlotListIterator iter = this->GetFirstQuickSlotListIterator();
			iter != GetLastQuickSlotListIterator(); ++iter)
		{
			str1.append(L"[");
			str1.append(FuncCreateQuickSlotListStr(iter).c_str());

			str1.append(L"]\n");
		}

		return Log::format(
			L"[WG_REQ_DB_QUICK_SLOT_SET] TaskId: {}, UserDBId: {}, QuickSlotList : {}"
			, mTaskId, mUserDBId, str1.c_str()
		).c_str();
	}
#endif

	bool Validate()
	{
		uchar* pktStart = (uchar*)this;
		uint16 pktSize = mPktSize;

		uint16 dataSize = sizeof(PKT_WG_REQ_DB_QUICK_SLOT_SET_READ);
		if (dataSize > mPktSize)
			return false;

		if (false == ValidateValue(pktStart, pktSize, dataSize))
			return false;

		if (false == QuickSlotListValidateListNode(mFirstQuickSlotListOffset, pktStart, pktSize, dataSize))
			return false;

		if (dataSize != mPktSize)
			return false;

		return true;
	}

	bool QuickSlotListValidateListNode(uint16 offset, uchar * pktStart, uint16 pktSize, uint16& dataSize)
	{		for (QuickSlotListIterator iter = this->GetFirstQuickSlotListIterator();
			iter != GetLastQuickSlotListIterator(); ++iter)
		{
			if (false == (*iter).Validate(offset, pktStart, pktSize, dataSize))
			{
				return false;
			}
		}
		return true;
	}

