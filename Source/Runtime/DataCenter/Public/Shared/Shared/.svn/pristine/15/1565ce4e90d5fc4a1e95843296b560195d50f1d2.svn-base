			return false;

		if (false == ValidateBinary(mOwnerUpdateCurrencyOffset, mOwnerUpdateCurrencySize, 0, pktSize, dataSize))
			return false;

		if (false == ValidateBinary(mItemMoveToTargetOffset, mItemMoveToTargetSize, 0, pktSize, dataSize))
			return false;

		if (false == ValidateBinary(mTargetItemsCreateOffset, mTargetItemsCreateSize, 0, pktSize, dataSize))
			return false;

		if (false == ValidateBinary(mTargetItemsUpdateOffset, mTargetItemsUpdateSize, 0, pktSize, dataSize))
			return false;

		if (false == ValidateBinary(mTargetItemsDeletedOffset, mTargetItemsDeletedSize, 0, pktSize, dataSize))
			return false;

		if (false == ValidateBinary(mTargetUpdateCurrencyOffset, mTargetUpdateCurrencySize, 0, pktSize, dataSize))
			return false;

		return (nullptr != pktStart && 0 < pktSize && 0 < dataSize) ? true : false;
