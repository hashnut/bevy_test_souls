			, mNextOffset(0), mGuildNameOffset(0), mCaptainNameOffset(0)
			, mGuildDBId(guildDBId)
			, mCurrenctHomePlanetWorldId(currenctHomePlanetWorldId)
			, mGuildEmblemId(guildEmblemId)
