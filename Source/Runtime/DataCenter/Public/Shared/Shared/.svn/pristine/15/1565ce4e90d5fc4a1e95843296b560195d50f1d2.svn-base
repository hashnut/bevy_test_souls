#ifdef _SERVER

////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
// Enum -> String
////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////

inline const wchar_t* WGPacketIdEnumToString(uint16 value) noexcept
{
	switch (value)
	{
		case WG_BYPASS_TO_CLIENT: return L"WG_BYPASS_TO_CLIENT";
		case WG_BROADCAST_TO_CLIENT_ALL: return L"WG_BROADCAST_TO_CLIENT_ALL";
		case WG_BROADCAST_TO_CLIENT_MAP_USER: return L"WG_BROADCAST_TO_CLIENT_MAP_USER";
