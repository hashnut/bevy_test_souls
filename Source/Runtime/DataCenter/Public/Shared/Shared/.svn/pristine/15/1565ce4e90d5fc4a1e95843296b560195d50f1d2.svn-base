	PkContributorIterator GetFirstPkContributorIterator() const
	{
		if (mFirstPkContributorOffset && mPktSize >= mFirstPkContributorOffset + sizeof(PkContributor))
		{
			PkContributor* pkContributor = (PkContributor*)((uchar*)this + mFirstPkContributorOffset);
			if (mFirstPkContributorOffset == pkContributor->mThisOffset)
				return PkContributorIterator(pkContributor);
