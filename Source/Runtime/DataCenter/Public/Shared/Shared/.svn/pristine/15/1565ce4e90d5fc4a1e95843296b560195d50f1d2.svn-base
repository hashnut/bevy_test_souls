#endif

	ServerTaskId TaskId() { return mTaskId; }
	UserDBId UserDBId() { return mUserDBId; }
	const uchar* InsertList() const
	{
		uchar* pktStart = (uchar*)this;
		uint16 pktSize = *((uint16*)pktStart);
		if (mInsertListOffset && pktSize > mInsertListOffset)
			return (const uchar*)(pktStart + mInsertListOffset);
		else
			return 0;
	}
	int InsertListSize() const
	{
		return mInsertListSize;
	}
#ifdef _SERVER
	template <typename Container>
	void MakeInsertListVector(Container & container)
	{
		//emplace() ČŁĂâÇŇ¶§¸¶´Ů ¸Ţ¸đ¸®¸¦ »ýĽş ÇĎ´Â şńżëŔĚ ąß»ýÇŃ´Ů şńżëŔ»ÁŮŔĚŔ§°ł reserve()»çżë
		container.reserve(mInsertListSize/sizeof(_T0));
		for (int offset = 0; offset < mInsertListSize; offset += sizeof(_T0))
		{
			const _T0* data = reinterpret_cast<const _T0*>(InsertList() + offset);
			container.emplace_back(*data);
		}
	}
#else // _SERVER
	template <typename Container, typename Data>
	void MakeInsertListVector(Container & container)
	{
		for (int offset = 0; offset < mInsertListSize; offset += sizeof(Data))
		{
			const Data* data = reinterpret_cast<const Data*>(InsertList() + offset);
			container.Add(*data);
		}
	}
#endif // _SERVER
#ifdef _SERVER
	template <typename TFunc>
	void ForEachInsertList(TFunc&& func) const
	{
		for (int offset = 0; offset < InsertListSize(); offset += sizeof(_T0))
		{
			const _T0* data = reinterpret_cast<const _T0*>(InsertList() + offset);
			func(data);
		}
	}
#endif
	const uchar* UpdateList() const
	{
		uchar* pktStart = (uchar*)this;
		uint16 pktSize = *((uint16*)pktStart);
		if (mUpdateListOffset && pktSize > mUpdateListOffset)
			return (const uchar*)(pktStart + mUpdateListOffset);
		else
			return 0;
	}
	int UpdateListSize() const
	{
		return mUpdateListSize;
	}
#ifdef _SERVER
	template <typename Container>
	void MakeUpdateListVector(Container & container)
	{
		//emplace() ČŁĂâÇŇ¶§¸¶´Ů ¸Ţ¸đ¸®¸¦ »ýĽş ÇĎ´Â şńżëŔĚ ąß»ýÇŃ´Ů şńżëŔ»ÁŮŔĚŔ§°ł reserve()»çżë
		container.reserve(mUpdateListSize/sizeof(_T1));
		for (int offset = 0; offset < mUpdateListSize; offset += sizeof(_T1))
		{
			const _T1* data = reinterpret_cast<const _T1*>(UpdateList() + offset);
