// type = WG
// related packet = PKT_GW_ACK_DB_DEPOT_EXTEND_SLOT_READ
#ifdef _SERVER
struct PKT_WG_REQ_DB_DEPOT_EXTEND_SLOT_WRITE : public Disposable
#else
struct PKT_WG_REQ_DB_DEPOT_EXTEND_SLOT_WRITE
#endif
{
	PktWriter mPktWriter;
	uint16* mCurrencyPairListOffset;
	uint16* mCurrencyPairListSize;

#ifdef _SERVER 
	using _T0 = CurrencyPair;
	bool GetServerTaskIdRealTime(OUT int& serverTaskId) const { return reinterpret_cast<PKT_WG_REQ_DB_DEPOT_EXTEND_SLOT_READ*>(mPktWriter.mBuf)->GetServerTaskIdRealTime(serverTaskId); }
	const wchar_t* GetPacketName() const { return L"WG_REQ_DB_DEPOT_EXTEND_SLOT"; }
	const wchar_t* GetRelatedPacketName() const { return L"GW_ACK_DB_DEPOT_EXTEND_SLOT"; }
#endif

#ifndef _SERVER
	template <typename T0>
	PKT_WG_REQ_DB_DEPOT_EXTEND_SLOT_WRITE(uchar* buf, int bufSize, ServerTaskId taskId, UserDBId userId, SlotExtendNumber extendedNumber, const T0* currencyPairList)
		:
		mPktWriter(buf, bufSize)

	{
		mPktWriter << static_cast<uint16>(PD::WG::WGPacketId::WG_REQ_DB_DEPOT_EXTEND_SLOT);
		mCurrencyPairListOffset = (uint16*)mPktWriter.GetBuffer();
		*mCurrencyPairListOffset = 0;
		mPktWriter << (*mCurrencyPairListOffset);
		mCurrencyPairListSize = (uint16*)mPktWriter.GetBuffer();
		*mCurrencyPairListSize = 0;
		mPktWriter << (*mCurrencyPairListSize);
		mPktWriter << taskId;
		mPktWriter << userId;
		mPktWriter << extendedNumber;
		*mCurrencyPairListOffset = (uint16)mPktWriter.GetPktSize();
		if (currencyPairList && 0 < currencyPairList->Num())
		{
			int tvalsize = (int)sizeof(*(currencyPairList->begin())); 
			auto _currencyPairList = (T0*)currencyPairList;
			for (auto it = _currencyPairList->begin(); it != _currencyPairList->end(); ++it) 
			{
				mPktWriter.WriteBinary((uint16)tvalsize, (uchar*)&(*it)); 
			}
			*mCurrencyPairListSize = (uint16)(tvalsize* currencyPairList->Num());
		}
	}

#endif // _SERVER
#ifdef _SERVER
	template <typename T0>
	PKT_WG_REQ_DB_DEPOT_EXTEND_SLOT_WRITE(SendBufferHelper& sendBuffer, ServerTaskId taskId, UserDBId userId, SlotExtendNumber extendedNumber, const T0* currencyPairList)
		:
		mPktWriter(sendBuffer->GetCharBuffer(), (SEND_BUFFER_SIZE - 1))

	{
		static_assert(true == std::is_same_v<T0::value_type, _T0>, "currencyPairList type must be CurrencyPair list type"); 
		mPktWriter << (uint16)WG_REQ_DB_DEPOT_EXTEND_SLOT;
		mCurrencyPairListOffset = (uint16*)mPktWriter.GetBuffer();
		*mCurrencyPairListOffset = 0;
		mPktWriter << (*mCurrencyPairListOffset);
		mCurrencyPairListSize = (uint16*)mPktWriter.GetBuffer();
		*mCurrencyPairListSize = 0;
		mPktWriter << (*mCurrencyPairListSize);
		mPktWriter << taskId;
		mPktWriter << userId;
		mPktWriter << extendedNumber;
		*mCurrencyPairListOffset = (uint16)mPktWriter.GetPktSize();
		if (currencyPairList && !currencyPairList->empty())
		{
			int tvalsize = (int)sizeof(*(currencyPairList->begin())); 
			auto _currencyPairList = const_cast<std::decay_t<T0>*>(currencyPairList);
			for (auto it = _currencyPairList->begin(); it != _currencyPairList->end(); ++it) 
			{
				mPktWriter.WriteBinary((uint16)tvalsize, (uchar*)&(*it)); 
			}
			*mCurrencyPairListSize = (uint16) (tvalsize * currencyPairList->size());
		}
	}
#endif

#ifdef _SERVER 
	void send(IocpObjectSession* session, SendBufferRef sendBuffer, bool autoCloseSendBuffer)
	{
		if (session) 
			session->Send(sendBuffer, mPktWriter.GetPktSize(), autoCloseSendBuffer);
	}
#endif

#ifdef _SERVER 
	std::xwstring GetLogWString() const
	{
		auto readPacket = reinterpret_cast<PKT_WG_REQ_DB_DEPOT_EXTEND_SLOT_READ*>(mPktWriter.mBuf);
		return readPacket->GetLogWString();
	}
#endif

#ifndef _SERVER
#else
#endif
}; // PKT_WG_REQ_DB_DEPOT_EXTEND_SLOT_WRITE

