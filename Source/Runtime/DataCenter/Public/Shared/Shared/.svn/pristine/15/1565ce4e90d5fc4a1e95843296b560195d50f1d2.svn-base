// type = WG
// related packet = PKT_GW_ACK_DB_GUILD_STORE_ACQUIRED_ITEM_WRITE
struct PKT_WG_REQ_DB_GUILD_STORE_ACQUIRED_ITEM_READ
{
	struct ContributorMember
	{
	protected:
		uint16 mThisOffset;
		uint16 mNextOffset;
		uint16 mUserNameOffset;
		UserDBId mUserDBId;

	public:
		UserDBId UserDBId() { return mUserDBId; }

#ifdef _SERVER
		const wchar_t* UserName()
		{
			uchar* pktStart = (uchar*)this - mThisOffset;
			uint16 pktSize = *((uint16*)pktStart);
			if (mUserNameOffset && pktSize > mUserNameOffset)
				return (const wchar_t*)(pktStart + mUserNameOffset);
			else
				return L"";
		}
#else // _SERVER
		const FString UserName()
		{
			const wchar_t* strWchar = L"";
			uchar* pktStart = (uchar*)this - mThisOffset;
			uint16 pktSize = *((uint16*)pktStart);
			if (mUserNameOffset && pktSize > mUserNameOffset)
				strWchar = (const wchar_t*)(pktStart + mUserNameOffset);
			return PktWriter::ConvertToFString(strWchar);
		}
#endif // _SERVER
		friend PktIterator<ContributorMember>;
		friend PKT_WG_REQ_DB_GUILD_STORE_ACQUIRED_ITEM_READ;

		bool Validate(uint16 offset, uchar * pktStart, uint16 pktSize, uint16& dataSize)
		{
			if (static_cast<size_t>(pktSize) < static_cast<size_t>(offset) + sizeof(ContributorMember))
				return false;

			ContributorMember * node = (ContributorMember*)(pktStart + offset);

			// ŔÚ±â ŔÚ˝ĹŔÇ Ć÷ŔÎĹÍ °ËÁő
			if (offset != node->mThisOffset)
				return false;

			// Value °ËÁő
			uchar* pktCurrentNodeStart = (uchar*)this - mThisOffset;
			uint16 pktCurrentNodeSize = *((uint16*)pktStart);
			dataSize += sizeof(ContributorMember);	// skip
			if (false == ValidateValue(pktCurrentNodeStart, pktCurrentNodeSize, dataSize))
				return false;

			return true;
		}

		bool ValidateValue(const uchar* pktStart, uint16 pktSize, uint16& dataSize)
		{
			if (false == ValidateString(mUserNameOffset, 0, pktStart, pktSize, dataSize))
				return false;

			return (nullptr != pktStart && 0 < pktSize && 0 < dataSize) ? true : false;
		}

	}; // ContributorMember

public:
	uint16 mPktSize;
	uint16 mPktId;
	uint16 mContributorMemberCount;
	uint16 mFirstContributorMemberOffset;
	uint16 mItemsCreateListOffset;
	uint16 mItemsCreateListSize;
	ServerTaskId mTaskId;
	GuildDBId mGuildDBId;
	GuildItemAcquireType mItemAcquiredType;
	MapId mMapId;
	CreatureId mBossId;

public:
#ifdef _SERVER 
	using _T0 = ItemToCreate;
	bool GetServerTaskIdRealTime(OUT int& serverTaskId) const { serverTaskId = mTaskId; return true; }
	const wchar_t* GetPacketName() const { return L"WG_REQ_DB_GUILD_STORE_ACQUIRED_ITEM"; }
	const wchar_t* GetRelatedPacketName() const { return L"GW_ACK_DB_GUILD_STORE_ACQUIRED_ITEM"; }
#endif

	ServerTaskId TaskId() { return mTaskId; }
	GuildDBId GuildDBId() { return mGuildDBId; }
	GuildItemAcquireType ItemAcquiredType() { return mItemAcquiredType; }
