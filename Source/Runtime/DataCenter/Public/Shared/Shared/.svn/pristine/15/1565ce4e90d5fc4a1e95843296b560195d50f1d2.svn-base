// type = WG
struct PKT_WG_INTER_GUILD_LIST_READ
{
	struct Guild
	{
	protected:
		uint16 mThisOffset;
		uint16 mNextOffset;
		uint16 mGuildNameOffset;
		uint16 mCaptainNameOffset;
		GuildDBId mGuildDBId;
		PlanetWorldId mCurrenctHomePlanetWorldId;
		GuildEmblemId mGuildEmblemId;

	public:
		GuildDBId GuildDBId() { return mGuildDBId; }
		const PlanetWorldId& ConstRefCurrenctHomePlanetWorldId() { return mCurrenctHomePlanetWorldId; }
		PlanetWorldId CurrenctHomePlanetWorldId() { return mCurrenctHomePlanetWorldId; }
		GuildEmblemId GuildEmblemId() { return mGuildEmblemId; }

#ifdef _SERVER
		const wchar_t* GuildName()
		{
			uchar* pktStart = (uchar*)this - mThisOffset;
			uint16 pktSize = *((uint16*)pktStart);
			if (mGuildNameOffset && pktSize > mGuildNameOffset)
				return (const wchar_t*)(pktStart + mGuildNameOffset);
			else
				return L"";
		}
#else // _SERVER
		const FString GuildName()
		{
			const wchar_t* strWchar = L"";
			uchar* pktStart = (uchar*)this - mThisOffset;
			uint16 pktSize = *((uint16*)pktStart);
			if (mGuildNameOffset && pktSize > mGuildNameOffset)
				strWchar = (const wchar_t*)(pktStart + mGuildNameOffset);
			return PktWriter::ConvertToFString(strWchar);
		}
#endif // _SERVER
#ifdef _SERVER
		const wchar_t* CaptainName()
		{
			uchar* pktStart = (uchar*)this - mThisOffset;
			uint16 pktSize = *((uint16*)pktStart);
			if (mCaptainNameOffset && pktSize > mCaptainNameOffset)
				return (const wchar_t*)(pktStart + mCaptainNameOffset);
			else
				return L"";
		}
#else // _SERVER
		const FString CaptainName()
		{
			const wchar_t* strWchar = L"";
			uchar* pktStart = (uchar*)this - mThisOffset;
			uint16 pktSize = *((uint16*)pktStart);
			if (mCaptainNameOffset && pktSize > mCaptainNameOffset)
				strWchar = (const wchar_t*)(pktStart + mCaptainNameOffset);
			return PktWriter::ConvertToFString(strWchar);
		}
#endif // _SERVER
		friend PktIterator<Guild>;
		friend PKT_WG_INTER_GUILD_LIST_READ;

		bool Validate(uint16 offset, uchar * pktStart, uint16 pktSize, uint16& dataSize)
		{
			if (static_cast<size_t>(pktSize) < static_cast<size_t>(offset) + sizeof(Guild))
				return false;

			Guild * node = (Guild*)(pktStart + offset);

			// ŔÚ±â ŔÚ˝ĹŔÇ Ć÷ŔÎĹÍ °ËÁő
			if (offset != node->mThisOffset)
				return false;

			// Value °ËÁő
			uchar* pktCurrentNodeStart = (uchar*)this - mThisOffset;
			uint16 pktCurrentNodeSize = *((uint16*)pktStart);
			dataSize += sizeof(Guild);	// skip
			if (false == ValidateValue(pktCurrentNodeStart, pktCurrentNodeSize, dataSize))
				return false;

			return true;
		}

		bool ValidateValue(const uchar* pktStart, uint16 pktSize, uint16& dataSize)
		{
			if (false == ValidateString(mGuildNameOffset, 0, pktStart, pktSize, dataSize))
				return false;

			if (false == ValidateString(mCaptainNameOffset, 0, pktStart, pktSize, dataSize))
				return false;

			return (nullptr != pktStart && 0 < pktSize && 0 < dataSize) ? true : false;
		}

	}; // Guild

public:
	uint16 mPktSize;
	uint16 mPktId;
	uint16 mGuildCount;
	uint16 mFirstGuildOffset;

public:
#ifdef _SERVER 
	bool GetServerTaskIdRealTime(OUT [[maybe_unused]] int& serverTaskId) const { return false; }
	const wchar_t* GetPacketName() const { return L"WG_INTER_GUILD_LIST"; }
	const wchar_t* GetRelatedPacketName() const { return L"GW_INTER_GUILD_LIST"; }
#endif


	using GuildIterator = PktIterator<Guild>;
	const GuildIterator GetLastGuildIterator() const
	{
		return GuildIterator(0);
	}
	GuildIterator GetFirstGuildIterator() const
	{
		if (mFirstGuildOffset && mPktSize >= mFirstGuildOffset + sizeof(Guild))
		{
			Guild* guild = (Guild*)((uchar*)this + mFirstGuildOffset);
			if (mFirstGuildOffset == guild->mThisOffset)
				return GuildIterator(guild);
			else
				return GuildIterator(0);
		}
		else
			return GuildIterator(0);
	}
	const int GetGuildCount()
	{
		return mGuildCount;
	}
#ifdef _SERVER
	template<typename TFunc>
	void ForEachGuild(TFunc&& func)
	{
		for (auto it = GetFirstGuildIterator(); it != GetLastGuildIterator(); ++it)
			func(it);
	}
#endif


#ifdef _SERVER 
	std::xwstring FuncCreateGuildStr( [[maybe_unused]] GuildIterator& iter) const
	{
		return Log::format(
			L"GuildDBId: {}, CurrenctHomePlanetWorldId: {}, GuildEmblemId: {}, GuildName: {}, CaptainName: {}", 
			iter->GuildDBId(), iter->CurrenctHomePlanetWorldId(), iter->GuildEmblemId(), iter->GuildName(), iter->CaptainName()
		).c_str();
	}

	std::xwstring GetLogWString() const
	{
		std::xwstring str1;
		str1.append(L"\n");
		for (GuildIterator iter = this->GetFirstGuildIterator();
			iter != GetLastGuildIterator(); ++iter)
		{
			str1.append(L"[");
			str1.append(FuncCreateGuildStr(iter).c_str());

			str1.append(L"]\n");
		}

		return Log::format(
			L"[WG_INTER_GUILD_LIST] Guild : {}"
			, str1.c_str()
		).c_str();
	}
#endif

	bool Validate()
	{
		uchar* pktStart = (uchar*)this;
		uint16 pktSize = mPktSize;

		uint16 dataSize = sizeof(PKT_WG_INTER_GUILD_LIST_READ);
		if (dataSize > mPktSize)
			return false;

		if (false == ValidateValue(pktStart, pktSize, dataSize))
			return false;

		if (false == GuildValidateListNode(mFirstGuildOffset, pktStart, pktSize, dataSize))
			return false;

		if (dataSize != mPktSize)
			return false;

		return true;
	}

	bool GuildValidateListNode(uint16 offset, uchar * pktStart, uint16 pktSize, uint16& dataSize)
	{		for (GuildIterator iter = this->GetFirstGuildIterator();
			iter != GetLastGuildIterator(); ++iter)
		{
			if (false == (*iter).Validate(offset, pktStart, pktSize, dataSize))
			{
				return false;
			}
		}
		return true;
	}

	bool ValidateValue(const uchar* pktStart, uint16 pktSize, uint16& dataSize)
	{
		return (nullptr != pktStart && 0 < pktSize && 0 < dataSize) ? true : false;
	}

}; // PKT_WG_INTER_GUILD_LIST_READ

