// type = WG
struct PKT_WG_WORLD_SERVER_USER_CACHE_SAVE_ABNORMALITY_READ
{
	struct AbnormalityList
	{
	protected:
		uint16 mThisOffset;
		uint16 mNextOffset;
		AbnormalityData mAbnormalityData;

	public:
		const AbnormalityData& ConstRefAbnormalityData() { return mAbnormalityData; }
		AbnormalityData AbnormalityData() { return mAbnormalityData; }

		friend PktIterator<AbnormalityList>;
		friend PKT_WG_WORLD_SERVER_USER_CACHE_SAVE_ABNORMALITY_READ;

		bool Validate(uint16 offset, uchar * pktStart, uint16 pktSize, uint16& dataSize)
		{
			if (static_cast<size_t>(pktSize) < static_cast<size_t>(offset) + sizeof(AbnormalityList))
				return false;

			AbnormalityList * node = (AbnormalityList*)(pktStart + offset);

			// ŔÚ±â ŔÚ˝ĹŔÇ Ć÷ŔÎĹÍ °ËÁő
			if (offset != node->mThisOffset)
				return false;

			// Value °ËÁő
			uchar* pktCurrentNodeStart = (uchar*)this - mThisOffset;
			uint16 pktCurrentNodeSize = *((uint16*)pktStart);
			dataSize += sizeof(AbnormalityList);	// skip
			if (false == ValidateValue(pktCurrentNodeStart, pktCurrentNodeSize, dataSize))
				return false;

			return true;
		}

		bool ValidateValue(const uchar* pktStart, uint16 pktSize, uint16& dataSize)
		{
			return (nullptr != pktStart && 0 < pktSize && 0 < dataSize) ? true : false;
		}

	}; // AbnormalityList

public:
	uint16 mPktSize;
	uint16 mPktId;
	uint16 mAbnormalityListCount;
	uint16 mFirstAbnormalityListOffset;
	uint64 mGatewayUserObject;

public:
#ifdef _SERVER 
	bool GetServerTaskIdRealTime(OUT [[maybe_unused]] int& serverTaskId) const { return false; }
	const wchar_t* GetPacketName() const { return L"WG_WORLD_SERVER_USER_CACHE_SAVE_ABNORMALITY"; }
	const wchar_t* GetRelatedPacketName() const { return L"GW_WORLD_SERVER_USER_CACHE_SAVE_ABNORMALITY"; }
#endif

	uint64 GatewayUserObject() { return mGatewayUserObject; }

	using AbnormalityListIterator = PktIterator<AbnormalityList>;
	const AbnormalityListIterator GetLastAbnormalityListIterator() const
	{
		return AbnormalityListIterator(0);
	}
	AbnormalityListIterator GetFirstAbnormalityListIterator() const
	{
		if (mFirstAbnormalityListOffset && mPktSize >= mFirstAbnormalityListOffset + sizeof(AbnormalityList))
		{
			AbnormalityList* abnormalityList = (AbnormalityList*)((uchar*)this + mFirstAbnormalityListOffset);
			if (mFirstAbnormalityListOffset == abnormalityList->mThisOffset)
				return AbnormalityListIterator(abnormalityList);
			else
				return AbnormalityListIterator(0);
		}
		else
			return AbnormalityListIterator(0);
	}
	const int GetAbnormalityListCount()
	{
		return mAbnormalityListCount;
	}
#ifdef _SERVER
	template<typename TFunc>
	void ForEachAbnormalityList(TFunc&& func)
	{
		for (auto it = GetFirstAbnormalityListIterator(); it != GetLastAbnormalityListIterator(); ++it)
			func(it);
	}
#endif


#ifdef _SERVER 
	std::xwstring FuncCreateAbnormalityListStr( [[maybe_unused]] AbnormalityListIterator& iter) const
	{
		return Log::format(
			L"AbnormalityData: {}", 
			iter->AbnormalityData()
		).c_str();
	}

	std::xwstring GetLogWString() const
	{
		std::xwstring str1;
		str1.append(L"\n");
		for (AbnormalityListIterator iter = this->GetFirstAbnormalityListIterator();
			iter != GetLastAbnormalityListIterator(); ++iter)
		{
			str1.append(L"[");
			str1.append(FuncCreateAbnormalityListStr(iter).c_str());

			str1.append(L"]\n");
		}

		return Log::format(
			L"[WG_WORLD_SERVER_USER_CACHE_SAVE_ABNORMALITY] GatewayUserObject: {}, AbnormalityList : {}"
			, mGatewayUserObject, str1.c_str()
		).c_str();
	}
#endif

	bool Validate()
	{
		uchar* pktStart = (uchar*)this;
		uint16 pktSize = mPktSize;

		uint16 dataSize = sizeof(PKT_WG_WORLD_SERVER_USER_CACHE_SAVE_ABNORMALITY_READ);
		if (dataSize > mPktSize)
			return false;

		if (false == ValidateValue(pktStart, pktSize, dataSize))
			return false;

		if (false == AbnormalityListValidateListNode(mFirstAbnormalityListOffset, pktStart, pktSize, dataSize))
			return false;

		if (dataSize != mPktSize)
			return false;

		return true;
	}

	bool AbnormalityListValidateListNode(uint16 offset, uchar * pktStart, uint16 pktSize, uint16& dataSize)
	{		for (AbnormalityListIterator iter = this->GetFirstAbnormalityListIterator();
			iter != GetLastAbnormalityListIterator(); ++iter)
		{
			if (false == (*iter).Validate(offset, pktStart, pktSize, dataSize))
			{
				return false;
			}
		}
		return true;
	}

	bool ValidateValue(const uchar* pktStart, uint16 pktSize, uint16& dataSize)
	{
		return (nullptr != pktStart && 0 < pktSize && 0 < dataSize) ? true : false;
	}

}; // PKT_WG_WORLD_SERVER_USER_CACHE_SAVE_ABNORMALITY_READ

