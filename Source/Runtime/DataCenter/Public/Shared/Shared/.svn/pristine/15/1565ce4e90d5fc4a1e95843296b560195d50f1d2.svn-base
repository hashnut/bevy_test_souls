// type = WG
struct PKT_WG_GUILD_DUNGEON_CLEAR_READ
{
	struct RewardJoinMailDataList
	{
	protected:
		uint16 mThisOffset;
		uint16 mNextOffset;
		uint16 mVarParameterOffset;
		MailData mMailData;

	public:
		const MailData& ConstRefMailData() { return mMailData; }
		MailData MailData() { return mMailData; }

#ifdef _SERVER
		const wchar_t* VarParameter()
		{
			uchar* pktStart = (uchar*)this - mThisOffset;
			uint16 pktSize = *((uint16*)pktStart);
			if (mVarParameterOffset && pktSize > mVarParameterOffset)
				return (const wchar_t*)(pktStart + mVarParameterOffset);
			else
				return L"";
		}
#else // _SERVER
		const FString VarParameter()
		{
			const wchar_t* strWchar = L"";
			uchar* pktStart = (uchar*)this - mThisOffset;
			uint16 pktSize = *((uint16*)pktStart);
			if (mVarParameterOffset && pktSize > mVarParameterOffset)
				strWchar = (const wchar_t*)(pktStart + mVarParameterOffset);
			return PktWriter::ConvertToFString(strWchar);
		}
#endif // _SERVER
		friend PktIterator<RewardJoinMailDataList>;
		friend PKT_WG_GUILD_DUNGEON_CLEAR_READ;

		bool Validate(uint16 offset, uchar * pktStart, uint16 pktSize, uint16& dataSize)
		{
			if (static_cast<size_t>(pktSize) < static_cast<size_t>(offset) + sizeof(RewardJoinMailDataList))
				return false;

			RewardJoinMailDataList * node = (RewardJoinMailDataList*)(pktStart + offset);

			// ŔÚ±â ŔÚ˝ĹŔÇ Ć÷ŔÎĹÍ °ËÁő
			if (offset != node->mThisOffset)
				return false;

			// Value °ËÁő
			uchar* pktCurrentNodeStart = (uchar*)this - mThisOffset;
			uint16 pktCurrentNodeSize = *((uint16*)pktStart);
			dataSize += sizeof(RewardJoinMailDataList);	// skip
			if (false == ValidateValue(pktCurrentNodeStart, pktCurrentNodeSize, dataSize))
				return false;

			return true;
		}

		bool ValidateValue(const uchar* pktStart, uint16 pktSize, uint16& dataSize)
		{
			if (false == ValidateString(mVarParameterOffset, 0, pktStart, pktSize, dataSize))
				return false;

			return (nullptr != pktStart && 0 < pktSize && 0 < dataSize) ? true : false;
		}

	}; // RewardJoinMailDataList

public:
	uint16 mPktSize;
	uint16 mPktId;
	uint16 mRewardJoinMailDataListCount;
	uint16 mFirstRewardJoinMailDataListOffset;
	GuildDBId mGuildDBId;
	GuildDunGeonLevel mLevel;
	int mDungeonCleartimeSec;

public:
#ifdef _SERVER 
	bool GetServerTaskIdRealTime(OUT [[maybe_unused]] int& serverTaskId) const { return false; }
	const wchar_t* GetPacketName() const { return L"WG_GUILD_DUNGEON_CLEAR"; }
	const wchar_t* GetRelatedPacketName() const { return L"GW_GUILD_DUNGEON_CLEAR"; }
#endif

	GuildDBId GuildDBId() { return mGuildDBId; }
	GuildDunGeonLevel Level() { return mLevel; }
	int DungeonCleartimeSec() { return mDungeonCleartimeSec; }

	using RewardJoinMailDataListIterator = PktIterator<RewardJoinMailDataList>;
	const RewardJoinMailDataListIterator GetLastRewardJoinMailDataListIterator() const
	{
		return RewardJoinMailDataListIterator(0);
	}
	RewardJoinMailDataListIterator GetFirstRewardJoinMailDataListIterator() const
	{
		if (mFirstRewardJoinMailDataListOffset && mPktSize >= mFirstRewardJoinMailDataListOffset + sizeof(RewardJoinMailDataList))
		{
			RewardJoinMailDataList* rewardJoinMailDataList = (RewardJoinMailDataList*)((uchar*)this + mFirstRewardJoinMailDataListOffset);
			if (mFirstRewardJoinMailDataListOffset == rewardJoinMailDataList->mThisOffset)
				return RewardJoinMailDataListIterator(rewardJoinMailDataList);
			else
				return RewardJoinMailDataListIterator(0);
		}
		else
			return RewardJoinMailDataListIterator(0);
	}
	const int GetRewardJoinMailDataListCount()
	{
		return mRewardJoinMailDataListCount;
	}
#ifdef _SERVER
	template<typename TFunc>
	void ForEachRewardJoinMailDataList(TFunc&& func)
	{
		for (auto it = GetFirstRewardJoinMailDataListIterator(); it != GetLastRewardJoinMailDataListIterator(); ++it)
			func(it);
	}
#endif


#ifdef _SERVER 
	std::xwstring FuncCreateRewardJoinMailDataListStr( [[maybe_unused]] RewardJoinMailDataListIterator& iter) const
	{
		return Log::format(
			L"MailData: {}, VarParameter: {}", 
			iter->MailData(), iter->VarParameter()
		).c_str();
	}

	std::xwstring GetLogWString() const
	{
		std::xwstring str1;
		str1.append(L"\n");
		for (RewardJoinMailDataListIterator iter = this->GetFirstRewardJoinMailDataListIterator();
			iter != GetLastRewardJoinMailDataListIterator(); ++iter)
		{
			str1.append(L"[");
			str1.append(FuncCreateRewardJoinMailDataListStr(iter).c_str());

			str1.append(L"]\n");
		}

		return Log::format(
			L"[WG_GUILD_DUNGEON_CLEAR] GuildDBId: {}, Level: {}, DungeonCleartimeSec: {}, RewardJoinMailDataList : {}"
			, mGuildDBId, mLevel, mDungeonCleartimeSec, str1.c_str()
		).c_str();
