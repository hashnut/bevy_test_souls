			iter->Result(), iter->WeaponType(), iter->PkContributorType(), iter->ContributorId(), iter->UserName(), iter->GuildEmblemId(), iter->GuildName(), iter->Damage(), iter->WorldId()
		).c_str();
	}

	std::xwstring GetLogWString() const
	{
		std::xwstring str1;
		str1.append(L"\n");
		for (PkContributorIterator iter = this->GetFirstPkContributorIterator();
			iter != GetLastPkContributorIterator(); ++iter)
		{
			str1.append(L"[");
			str1.append(FuncCreatePkContributorStr(iter).c_str());

			str1.append(L"]\n");
		}

		return Log::format(
			L"[WG_REQ_DB_ADD_PK_BOOK_INFO] TaskId: {}, UserDBId: {}, RecordId: {}, PkResult: {}, IsInsert: {}, CreatedTime: {}, MapId: {}, LostExp: {}, CurrentMaxExp: {}, RemainActionCount: {}, PkContributor : {}"
			, mTaskId, mUserDBId, mRecordId, mPkResult, mIsInsert, mCreatedTime, mMapId, mLostExp, mCurrentMaxExp, mRemainActionCount, str1.c_str()
		).c_str();
	}
