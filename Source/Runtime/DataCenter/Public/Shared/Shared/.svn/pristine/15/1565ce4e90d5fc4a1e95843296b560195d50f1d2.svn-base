		uint16 mNextOffset;
		uint16 mGuildNameOffset;
		uint16 mCaptainNameOffset;
		GuildDBId mGuildDBId;
		PlanetWorldId mCurrenctHomePlanetWorldId;
		GuildEmblemId mGuildEmblemId;

	}; // Guild

	struct GuildHandle
	{
		GuildHandle(PktWriter& pktWriter, Guild* guild)
			:
			mPktWriter(pktWriter)
			, mGuild(guild)
		{
		}

		PktWriter& mPktWriter;
		Guild* mGuild;

	}; // GuildHandle

	PktWriter mPktWriter;
	uint16* mGuildCount;
	uint16* mFirstGuildOffset;
	Guild* mNowGuild;

#ifdef _SERVER 
	bool GetServerTaskIdRealTime(OUT int& serverTaskId) const { return reinterpret_cast<PKT_WG_INTER_GUILD_LIST_READ*>(mPktWriter.mBuf)->GetServerTaskIdRealTime(serverTaskId); }
	const wchar_t* GetPacketName() const { return L"WG_INTER_GUILD_LIST"; }
	const wchar_t* GetRelatedPacketName() const { return L"GW_INTER_GUILD_LIST"; }
#endif

#ifndef _SERVER
	PKT_WG_INTER_GUILD_LIST_WRITE(uchar* buf, int bufSize)
		:
		mPktWriter(buf, bufSize)
		, mNowGuild(0)
	{
		mPktWriter << static_cast<uint16>(PD::WG::WGPacketId::WG_INTER_GUILD_LIST);
		mGuildCount = (uint16*)mPktWriter.GetBuffer();
		*mGuildCount = 0;
		mPktWriter << (*mGuildCount);
		mFirstGuildOffset = (uint16*)mPktWriter.GetBuffer();
		*mFirstGuildOffset = 0;
		mPktWriter << (*mFirstGuildOffset);
	}

#endif // _SERVER
#ifdef _SERVER
	PKT_WG_INTER_GUILD_LIST_WRITE(SendBufferHelper& sendBuffer)
		:
		mPktWriter(sendBuffer->GetCharBuffer(), (SEND_BUFFER_SIZE - 1))
		, mNowGuild(0)
	{
		mPktWriter << (uint16)WG_INTER_GUILD_LIST;
		mGuildCount = (uint16*)mPktWriter.GetBuffer();
		*mGuildCount = 0;
		mPktWriter << (*mGuildCount);
		mFirstGuildOffset = (uint16*)mPktWriter.GetBuffer();
		*mFirstGuildOffset = 0;
		mPktWriter << (*mFirstGuildOffset);
	}
#endif

#ifdef _SERVER 
	void send(IocpObjectSession* session, SendBufferRef sendBuffer, bool autoCloseSendBuffer)
	{
		if (session) 
			session->Send(sendBuffer, mPktWriter.GetPktSize(), autoCloseSendBuffer);
	}
#endif

#ifdef _SERVER 
	std::xwstring GetLogWString() const
	{
		auto readPacket = reinterpret_cast<PKT_WG_INTER_GUILD_LIST_READ*>(mPktWriter.mBuf);
		return readPacket->GetLogWString();
	}
#endif

#ifndef _SERVER
	GuildHandle CreateGuild(GuildDBId guildDBId, const PlanetWorldId& currenctHomePlanetWorldId, GuildEmblemId guildEmblemId, const FString& guildName, const FString& captainName)
	{
		uchar* nowBuffer = mPktWriter.GetBuffer();
		uint16 nowWritten = (uint16)mPktWriter.GetPktSize();
		Guild* newGuild = new ((Guild*)nowBuffer) Guild(nowWritten, guildDBId, currenctHomePlanetWorldId, guildEmblemId);
		++(*mGuildCount);
		if (mNowGuild == 0)
			*mFirstGuildOffset = nowWritten;
		else
			mNowGuild->mNextOffset = nowWritten;
		mNowGuild = newGuild;
		mPktWriter.Skip(sizeof(Guild));
		mNowGuild->SetGuildNameOffset((uint16)mPktWriter.GetPktSize());
		mPktWriter.WriteString(guildName);
		mNowGuild->SetCaptainNameOffset((uint16)mPktWriter.GetPktSize());
		mPktWriter.WriteString(captainName);
		return GuildHandle(mPktWriter, newGuild);
	}

#else
	GuildHandle CreateGuild(GuildDBId guildDBId, const PlanetWorldId& currenctHomePlanetWorldId, GuildEmblemId guildEmblemId, const wchar* guildName, const wchar* captainName)
	{
		uchar* nowBuffer = mPktWriter.GetBuffer();
		uint16 nowWritten = (uint16)mPktWriter.GetPktSize();
		Guild* newGuild = new ((Guild*)nowBuffer) Guild(nowWritten, guildDBId, currenctHomePlanetWorldId, guildEmblemId);
		++(*mGuildCount);
		if (mNowGuild == 0)
			*mFirstGuildOffset = nowWritten;
		else
			mNowGuild->mNextOffset = nowWritten;
		mNowGuild = newGuild;
		mPktWriter.Skip(sizeof(Guild));
		mNowGuild->SetGuildNameOffset((uint16)mPktWriter.GetPktSize());
		mPktWriter.WriteString(guildName);
		mNowGuild->SetCaptainNameOffset((uint16)mPktWriter.GetPktSize());
		mPktWriter.WriteString(captainName);
		return GuildHandle(mPktWriter, newGuild);
	}

#endif
}; // PKT_WG_INTER_GUILD_LIST_WRITE

