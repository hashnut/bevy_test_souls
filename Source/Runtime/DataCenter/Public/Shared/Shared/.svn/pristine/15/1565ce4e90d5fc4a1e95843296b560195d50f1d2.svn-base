// type = WG
// related packet = PKT_GW_REQ_WORLD_BUDDY_LOGIN_STATE_WRITE
struct PKT_WG_ACK_WORLD_BUDDY_LOGIN_STATE_READ
{
	struct BuddyUserLoginStateList
	{
	protected:
		uint16 mThisOffset;
		uint16 mNextOffset;
		UserDBId mBuddyUserDBId;
		int mLoginState;

	public:
		UserDBId BuddyUserDBId() { return mBuddyUserDBId; }
		int LoginState() { return mLoginState; }

		friend PktIterator<BuddyUserLoginStateList>;
		friend PKT_WG_ACK_WORLD_BUDDY_LOGIN_STATE_READ;

		bool Validate(uint16 offset, uchar * pktStart, uint16 pktSize, uint16& dataSize)
		{
			if (static_cast<size_t>(pktSize) < static_cast<size_t>(offset) + sizeof(BuddyUserLoginStateList))
				return false;

			BuddyUserLoginStateList * node = (BuddyUserLoginStateList*)(pktStart + offset);

			// ŔÚ±â ŔÚ˝ĹŔÇ Ć÷ŔÎĹÍ °ËÁő
			if (offset != node->mThisOffset)
				return false;

			// Value °ËÁő
			uchar* pktCurrentNodeStart = (uchar*)this - mThisOffset;
			uint16 pktCurrentNodeSize = *((uint16*)pktStart);
			dataSize += sizeof(BuddyUserLoginStateList);	// skip
			if (false == ValidateValue(pktCurrentNodeStart, pktCurrentNodeSize, dataSize))
				return false;

			return true;
		}

		bool ValidateValue(const uchar* pktStart, uint16 pktSize, uint16& dataSize)
		{
			return (nullptr != pktStart && 0 < pktSize && 0 < dataSize) ? true : false;
		}

	}; // BuddyUserLoginStateList

public:
	uint16 mPktSize;
	uint16 mPktId;
	uint16 mBuddyUserLoginStateListCount;
	uint16 mFirstBuddyUserLoginStateListOffset;
	UserDBId mReqUserDBId;

public:
#ifdef _SERVER 
	bool GetServerTaskIdRealTime(OUT [[maybe_unused]] int& serverTaskId) const { return false; }
	const wchar_t* GetPacketName() const { return L"WG_ACK_WORLD_BUDDY_LOGIN_STATE"; }
	const wchar_t* GetRelatedPacketName() const { return L"GW_REQ_WORLD_BUDDY_LOGIN_STATE"; }
#endif

	UserDBId ReqUserDBId() { return mReqUserDBId; }

	using BuddyUserLoginStateListIterator = PktIterator<BuddyUserLoginStateList>;
	const BuddyUserLoginStateListIterator GetLastBuddyUserLoginStateListIterator() const
	{
		return BuddyUserLoginStateListIterator(0);
	}
	BuddyUserLoginStateListIterator GetFirstBuddyUserLoginStateListIterator() const
	{
		if (mFirstBuddyUserLoginStateListOffset && mPktSize >= mFirstBuddyUserLoginStateListOffset + sizeof(BuddyUserLoginStateList))
		{
			BuddyUserLoginStateList* buddyUserLoginStateList = (BuddyUserLoginStateList*)((uchar*)this + mFirstBuddyUserLoginStateListOffset);
			if (mFirstBuddyUserLoginStateListOffset == buddyUserLoginStateList->mThisOffset)
				return BuddyUserLoginStateListIterator(buddyUserLoginStateList);
			else
				return BuddyUserLoginStateListIterator(0);
		}
		else
			return BuddyUserLoginStateListIterator(0);
	}
	const int GetBuddyUserLoginStateListCount()
	{
		return mBuddyUserLoginStateListCount;
	}
#ifdef _SERVER
	template<typename TFunc>
	void ForEachBuddyUserLoginStateList(TFunc&& func)
	{
		for (auto it = GetFirstBuddyUserLoginStateListIterator(); it != GetLastBuddyUserLoginStateListIterator(); ++it)
			func(it);
	}
#endif


#ifdef _SERVER 
	std::xwstring FuncCreateBuddyUserLoginStateListStr( [[maybe_unused]] BuddyUserLoginStateListIterator& iter) const
	{
		return Log::format(
			L"BuddyUserDBId: {}, LoginState: {}", 
			iter->BuddyUserDBId(), iter->LoginState()
		).c_str();
	}

	std::xwstring GetLogWString() const
	{
		std::xwstring str1;
		str1.append(L"\n");
		for (BuddyUserLoginStateListIterator iter = this->GetFirstBuddyUserLoginStateListIterator();
			iter != GetLastBuddyUserLoginStateListIterator(); ++iter)
		{
			str1.append(L"[");
			str1.append(FuncCreateBuddyUserLoginStateListStr(iter).c_str());

			str1.append(L"]\n");
		}

		return Log::format(
			L"[WG_ACK_WORLD_BUDDY_LOGIN_STATE] ReqUserDBId: {}, BuddyUserLoginStateList : {}"
			, mReqUserDBId, str1.c_str()
		).c_str();
	}
#endif

	bool Validate()
	{
		uchar* pktStart = (uchar*)this;
		uint16 pktSize = mPktSize;

		uint16 dataSize = sizeof(PKT_WG_ACK_WORLD_BUDDY_LOGIN_STATE_READ);
		if (dataSize > mPktSize)
			return false;

		if (false == ValidateValue(pktStart, pktSize, dataSize))
			return false;

		if (false == BuddyUserLoginStateListValidateListNode(mFirstBuddyUserLoginStateListOffset, pktStart, pktSize, dataSize))
			return false;

		if (dataSize != mPktSize)
			return false;

		return true;
	}

	bool BuddyUserLoginStateListValidateListNode(uint16 offset, uchar * pktStart, uint16 pktSize, uint16& dataSize)
	{		for (BuddyUserLoginStateListIterator iter = this->GetFirstBuddyUserLoginStateListIterator();
			iter != GetLastBuddyUserLoginStateListIterator(); ++iter)
		{
			if (false == (*iter).Validate(offset, pktStart, pktSize, dataSize))
			{
				return false;
			}
		}
		return true;
	}

	bool ValidateValue(const uchar* pktStart, uint16 pktSize, uint16& dataSize)
	{
		return (nullptr != pktStart && 0 < pktSize && 0 < dataSize) ? true : false;
	}

}; // PKT_WG_ACK_WORLD_BUDDY_LOGIN_STATE_READ

