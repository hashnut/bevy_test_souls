		for (PartyListIterator iter = this->GetFirstPartyListIterator();
			iter != GetLastPartyListIterator(); ++iter)
		{
			str1.append(L"[");
			str1.append(FuncCreatePartyListStr(iter).c_str());

			for (PartyList::PartyMemberInfoListIterator PartyMemberInfoListIter = iter->GetFirstPartyMemberInfoListIterator();
				PartyMemberInfoListIter != iter->GetLastPartyMemberInfoListIterator(); ++PartyMemberInfoListIter)
			{
				str1.append(FuncCreatePartyMemberInfoListStr(PartyMemberInfoListIter).c_str());

			}

			str1.append(L"]\n");
