	{
		return Log::format(
			L"QuestId: {}", 
			iter->QuestId()
		).c_str();
	}

	std::xwstring GetLogWString() const
	{
		std::xwstring str1;
		str1.append(L"\n");
		for (QuestListIterator iter = this->GetFirstQuestListIterator();
			iter != GetLastQuestListIterator(); ++iter)
		{
			str1.append(L"[");
			str1.append(FuncCreateQuestListStr(iter).c_str());

			str1.append(L"]\n");
		}

		return Log::format(
			L"[WG_REQ_DB_QUEST_MULTI_LEVEL_RANK_ACCEPT] TaskId: {}, UserDBId: {}, CurStoryId: {}, AcceptStoryId: {}, ClearMultiLevelRankId: {}, AcceptMultiLevelRankInfo: {}, QuestList : {}"
			, mTaskId, mUserDBId, mCurStoryId, mAcceptStoryId, mClearMultiLevelRankId, mAcceptMultiLevelRankInfo, str1.c_str()
		).c_str();
	}
#endif

	bool Validate()
	{
		uchar* pktStart = (uchar*)this;
		uint16 pktSize = mPktSize;

		uint16 dataSize = sizeof(PKT_WG_REQ_DB_QUEST_MULTI_LEVEL_RANK_ACCEPT_READ);
		if (dataSize > mPktSize)
			return false;

		if (false == ValidateValue(pktStart, pktSize, dataSize))
			return false;

		if (false == QuestListValidateListNode(mFirstQuestListOffset, pktStart, pktSize, dataSize))
			return false;

		if (dataSize != mPktSize)
			return false;

		return true;
	}

	bool QuestListValidateListNode(uint16 offset, uchar * pktStart, uint16 pktSize, uint16& dataSize)
	{		for (QuestListIterator iter = this->GetFirstQuestListIterator();
			iter != GetLastQuestListIterator(); ++iter)
		{
			if (false == (*iter).Validate(offset, pktStart, pktSize, dataSize))
			{
				return false;
			}
		}
		return true;
	}

	bool ValidateValue(const uchar* pktStart, uint16 pktSize, uint16& dataSize)
	{
		return (nullptr != pktStart && 0 < pktSize && 0 < dataSize) ? true : false;
	}

