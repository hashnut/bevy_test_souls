	const uchar* ItemsCreate() const
	{
		uchar* pktStart = (uchar*)this;
		uint16 pktSize = *((uint16*)pktStart);
		if (mItemsCreateOffset && pktSize > mItemsCreateOffset)
			return (const uchar*)(pktStart + mItemsCreateOffset);
		else
			return 0;
