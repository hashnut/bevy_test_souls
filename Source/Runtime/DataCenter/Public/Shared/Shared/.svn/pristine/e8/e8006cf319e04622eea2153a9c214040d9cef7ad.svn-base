// type = CS
// related packet = PKT_SC_ACK_NPC_EVENT_SHOP_PURCHASE_WRITE
struct PKT_CS_REQ_NPC_EVENT_SHOP_PURCHASE_READ
{
public:
	uint16 mPktSize;
	uint16 mPktId;
	uint16 mItemsOffset;
	uint16 mItemsSize;
	int64 mInteractNpcGameId;
	FVector mCurrPos;
	int16 mCurrDir;

public:
#ifdef _SERVER 
	using _T0 = NpcEventShopItemBuyPair;
	bool GetServerTaskIdRealTime(OUT [[maybe_unused]] int& serverTaskId) const { return false; }
	const wchar_t* GetPacketName() const { return L"CS_REQ_NPC_EVENT_SHOP_PURCHASE"; }
	const wchar_t* GetRelatedPacketName() const { return L"SC_ACK_NPC_EVENT_SHOP_PURCHASE"; }
#endif

	int64 InteractNpcGameId() { return mInteractNpcGameId; }
	const FVector& ConstRefCurrPos() { return mCurrPos; }
	FVector CurrPos() { return mCurrPos; }
	int16 CurrDir() { return mCurrDir; }
	const uchar* Items() const
	{
		uchar* pktStart = (uchar*)this;
		uint16 pktSize = *((uint16*)pktStart);
		if (mItemsOffset && pktSize > mItemsOffset)
			return (const uchar*)(pktStart + mItemsOffset);
		else
			return 0;
	}
	int ItemsSize() const
	{
		return mItemsSize;
	}
#ifdef _SERVER
	template <typename Container>
	void MakeItemsVector(Container & container)
	{
		//emplace() ČŁĂâÇŇ¶§¸¶´Ů ¸Ţ¸đ¸®¸¦ »ýĽş ÇĎ´Â şńżëŔĚ ąß»ýÇŃ´Ů şńżëŔ»ÁŮŔĚŔ§°ł reserve()»çżë
		container.reserve(mItemsSize/sizeof(_T0));
		for (int offset = 0; offset < mItemsSize; offset += sizeof(_T0))
		{
			const _T0* data = reinterpret_cast<const _T0*>(Items() + offset);
			container.emplace_back(*data);
		}
	}
#else // _SERVER
	template <typename Container, typename Data>
	void MakeItemsVector(Container & container)
	{
		for (int offset = 0; offset < mItemsSize; offset += sizeof(Data))
		{
			const Data* data = reinterpret_cast<const Data*>(Items() + offset);
			container.Add(*data);
		}
	}
#endif // _SERVER
#ifdef _SERVER
	template <typename TFunc>
	void ForEachItems(TFunc&& func) const
	{
		for (int offset = 0; offset < ItemsSize(); offset += sizeof(_T0))
		{
			const _T0* data = reinterpret_cast<const _T0*>(Items() + offset);
			func(data);
		}
	}
#endif


#ifdef _SERVER 
	std::xwstring GetLogWString() const
	{

		return Log::format(
			L"[CS_REQ_NPC_EVENT_SHOP_PURCHASE] InteractNpcGameId: {}, CurrPos: {}, CurrDir: {}"
			, mInteractNpcGameId, mCurrPos, mCurrDir
		).c_str();
	}
#endif

	bool Validate()
	{
		uchar* pktStart = (uchar*)this;
		uint16 pktSize = mPktSize;

		uint16 dataSize = sizeof(PKT_CS_REQ_NPC_EVENT_SHOP_PURCHASE_READ);
		if (dataSize > mPktSize)
			return false;

		if (false == ValidateValue(pktStart, pktSize, dataSize))
			return false;

		if (dataSize != mPktSize)
			return false;

		return true;
	}

	bool ValidateValue(const uchar* pktStart, uint16 pktSize, uint16& dataSize)
	{
		if (false == ValidateBinary(mItemsOffset, mItemsSize, 0, pktSize, dataSize))
			return false;

		return (nullptr != pktStart && 0 < pktSize && 0 < dataSize) ? true : false;
	}

}; // PKT_CS_REQ_NPC_EVENT_SHOP_PURCHASE_READ

// type = CS
// related packet = PKT_SC_ACK_NPC_EVENT_SHOP_PURCHASE_READ
#ifdef _SERVER
struct PKT_CS_REQ_NPC_EVENT_SHOP_PURCHASE_WRITE : public Disposable
#else
struct PKT_CS_REQ_NPC_EVENT_SHOP_PURCHASE_WRITE
#endif
{
	PktWriter mPktWriter;
	uint16* mItemsOffset;
	uint16* mItemsSize;

#ifdef _SERVER 
	using _T0 = NpcEventShopItemBuyPair;
	bool GetServerTaskIdRealTime(OUT int& serverTaskId) const { return reinterpret_cast<PKT_CS_REQ_NPC_EVENT_SHOP_PURCHASE_READ*>(mPktWriter.mBuf)->GetServerTaskIdRealTime(serverTaskId); }
	const wchar_t* GetPacketName() const { return L"CS_REQ_NPC_EVENT_SHOP_PURCHASE"; }
	const wchar_t* GetRelatedPacketName() const { return L"SC_ACK_NPC_EVENT_SHOP_PURCHASE"; }
#endif

#ifndef _SERVER
	template <typename T0>
	PKT_CS_REQ_NPC_EVENT_SHOP_PURCHASE_WRITE(uchar* buf, int bufSize, int64 interactNpcGameId, const T0* items, FVector currPos, int16 currDir)
		:
		mPktWriter(buf, bufSize)

	{
		mPktWriter << static_cast<uint16>(PD::CS::CSPacketId::CS_REQ_NPC_EVENT_SHOP_PURCHASE);
		mItemsOffset = (uint16*)mPktWriter.GetBuffer();
		*mItemsOffset = 0;
		mPktWriter << (*mItemsOffset);
		mItemsSize = (uint16*)mPktWriter.GetBuffer();
		*mItemsSize = 0;
		mPktWriter << (*mItemsSize);
		mPktWriter << interactNpcGameId;
		mPktWriter << currPos;
		mPktWriter << currDir;
		*mItemsOffset = (uint16)mPktWriter.GetPktSize();
		if (items && 0 < items->Num())
		{
			int tvalsize = (int)sizeof(*(items->begin())); 
			auto _items = (T0*)items;
			for (auto it = _items->begin(); it != _items->end(); ++it) 
			{
				mPktWriter.WriteBinary((uint16)tvalsize, (uchar*)&(*it)); 
			}
			*mItemsSize = (uint16)(tvalsize* items->Num());
		}
	}

#endif // _SERVER
#ifdef _SERVER
	template <typename T0>
	PKT_CS_REQ_NPC_EVENT_SHOP_PURCHASE_WRITE(SendBufferHelper& sendBuffer, int64 interactNpcGameId, const T0* items, const FVector& currPos, int16 currDir)
		:
		mPktWriter(sendBuffer->GetCharBuffer(), (SEND_BUFFER_SIZE - 1))

	{
		static_assert(true == std::is_same_v<T0::value_type, _T0>, "items type must be NpcEventShopItemBuyPair list type"); 
		mPktWriter << (uint16)CS_REQ_NPC_EVENT_SHOP_PURCHASE;
		mItemsOffset = (uint16*)mPktWriter.GetBuffer();
		*mItemsOffset = 0;
		mPktWriter << (*mItemsOffset);
		mItemsSize = (uint16*)mPktWriter.GetBuffer();
		*mItemsSize = 0;
		mPktWriter << (*mItemsSize);
		mPktWriter << interactNpcGameId;
		mPktWriter << currPos;
		mPktWriter << currDir;
		*mItemsOffset = (uint16)mPktWriter.GetPktSize();
		if (items && !items->empty())
		{
			int tvalsize = (int)sizeof(*(items->begin())); 
			auto _items = const_cast<std::decay_t<T0>*>(items);
			for (auto it = _items->begin(); it != _items->end(); ++it) 
			{
				mPktWriter.WriteBinary((uint16)tvalsize, (uchar*)&(*it)); 
			}
			*mItemsSize = (uint16) (tvalsize * items->size());
		}
	}
#endif

#ifdef _SERVER 
	void send(IocpObjectSession* session, SendBufferRef sendBuffer, bool autoCloseSendBuffer)
	{
		if (session) 
			session->Send(sendBuffer, mPktWriter.GetPktSize(), autoCloseSendBuffer);
	}
#endif

#ifdef _SERVER 
	std::xwstring GetLogWString() const
	{
		auto readPacket = reinterpret_cast<PKT_CS_REQ_NPC_EVENT_SHOP_PURCHASE_READ*>(mPktWriter.mBuf);
		return readPacket->GetLogWString();
	}
#endif

#ifndef _SERVER
#else
