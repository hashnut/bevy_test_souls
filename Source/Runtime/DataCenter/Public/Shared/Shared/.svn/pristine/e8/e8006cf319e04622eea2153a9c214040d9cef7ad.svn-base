	uint16 mPktId;
	uint16 mMoveItemsOffset;
	uint16 mMoveItemsSize;
	CreatureId mNpcId;
	FVector mCurrPos;
	int16 mCurrDir;

public:
#ifdef _SERVER 
	using _T0 = ItemDBIdAmountPair;
	bool GetServerTaskIdRealTime(OUT [[maybe_unused]] int& serverTaskId) const { return false; }
	const wchar_t* GetPacketName() const { return L"CS_REQ_MOVE_DEPOT_ITEM_TO_INVENTORY"; }
	const wchar_t* GetRelatedPacketName() const { return L"SC_ACK_MOVE_DEPOT_ITEM_TO_INVENTORY"; }
#endif

	CreatureId NpcId() { return mNpcId; }
	const FVector& ConstRefCurrPos() { return mCurrPos; }
	FVector CurrPos() { return mCurrPos; }
	int16 CurrDir() { return mCurrDir; }
	const uchar* MoveItems() const
	{
		uchar* pktStart = (uchar*)this;
		uint16 pktSize = *((uint16*)pktStart);
		if (mMoveItemsOffset && pktSize > mMoveItemsOffset)
			return (const uchar*)(pktStart + mMoveItemsOffset);
		else
			return 0;
	}
	int MoveItemsSize() const
	{
		return mMoveItemsSize;
	}
#ifdef _SERVER
	template <typename Container>
	void MakeMoveItemsVector(Container & container)
	{
		//emplace() ČŁĂâÇŇ¶§¸¶´Ů ¸Ţ¸đ¸®¸¦ »ýĽş ÇĎ´Â şńżëŔĚ ąß»ýÇŃ´Ů şńżëŔ»ÁŮŔĚŔ§°ł reserve()»çżë
		container.reserve(mMoveItemsSize/sizeof(_T0));
		for (int offset = 0; offset < mMoveItemsSize; offset += sizeof(_T0))
		{
			const _T0* data = reinterpret_cast<const _T0*>(MoveItems() + offset);
			container.emplace_back(*data);
		}
	}
#else // _SERVER
	template <typename Container, typename Data>
	void MakeMoveItemsVector(Container & container)
	{
		for (int offset = 0; offset < mMoveItemsSize; offset += sizeof(Data))
		{
			const Data* data = reinterpret_cast<const Data*>(MoveItems() + offset);
			container.Add(*data);
		}
	}
#endif // _SERVER
#ifdef _SERVER
	template <typename TFunc>
	void ForEachMoveItems(TFunc&& func) const
	{
		for (int offset = 0; offset < MoveItemsSize(); offset += sizeof(_T0))
		{
			const _T0* data = reinterpret_cast<const _T0*>(MoveItems() + offset);
			func(data);
		}
	}
#endif


#ifdef _SERVER 
	std::xwstring GetLogWString() const
	{

		return Log::format(
			L"[CS_REQ_MOVE_DEPOT_ITEM_TO_INVENTORY] NpcId: {}, CurrPos: {}, CurrDir: {}"
			, mNpcId, mCurrPos, mCurrDir
		).c_str();
	}
#endif

	bool Validate()
	{
		uchar* pktStart = (uchar*)this;
		uint16 pktSize = mPktSize;

		uint16 dataSize = sizeof(PKT_CS_REQ_MOVE_DEPOT_ITEM_TO_INVENTORY_READ);
		if (dataSize > mPktSize)
			return false;

		if (false == ValidateValue(pktStart, pktSize, dataSize))
			return false;

		if (dataSize != mPktSize)
			return false;

		return true;
	}

	bool ValidateValue(const uchar* pktStart, uint16 pktSize, uint16& dataSize)
	{
		if (false == ValidateBinary(mMoveItemsOffset, mMoveItemsSize, 0, pktSize, dataSize))
			return false;

		return (nullptr != pktStart && 0 < pktSize && 0 < dataSize) ? true : false;
	}

}; // PKT_CS_REQ_MOVE_DEPOT_ITEM_TO_INVENTORY_READ

// type = CS
// related packet = PKT_SC_ACK_MOVE_DEPOT_ITEM_TO_INVENTORY_READ
#ifdef _SERVER
struct PKT_CS_REQ_MOVE_DEPOT_ITEM_TO_INVENTORY_WRITE : public Disposable
#else
struct PKT_CS_REQ_MOVE_DEPOT_ITEM_TO_INVENTORY_WRITE
#endif
{
	PktWriter mPktWriter;
	uint16* mMoveItemsOffset;
	uint16* mMoveItemsSize;

#ifdef _SERVER 
	using _T0 = ItemDBIdAmountPair;
	bool GetServerTaskIdRealTime(OUT int& serverTaskId) const { return reinterpret_cast<PKT_CS_REQ_MOVE_DEPOT_ITEM_TO_INVENTORY_READ*>(mPktWriter.mBuf)->GetServerTaskIdRealTime(serverTaskId); }
	const wchar_t* GetPacketName() const { return L"CS_REQ_MOVE_DEPOT_ITEM_TO_INVENTORY"; }
	const wchar_t* GetRelatedPacketName() const { return L"SC_ACK_MOVE_DEPOT_ITEM_TO_INVENTORY"; }
#endif

#ifndef _SERVER
	template <typename T0>
	PKT_CS_REQ_MOVE_DEPOT_ITEM_TO_INVENTORY_WRITE(uchar* buf, int bufSize, CreatureId npcId, const T0* moveItems, FVector currPos, int16 currDir)
		:
		mPktWriter(buf, bufSize)

	{
		mPktWriter << static_cast<uint16>(PD::CS::CSPacketId::CS_REQ_MOVE_DEPOT_ITEM_TO_INVENTORY);
		mMoveItemsOffset = (uint16*)mPktWriter.GetBuffer();
		*mMoveItemsOffset = 0;
		mPktWriter << (*mMoveItemsOffset);
		mMoveItemsSize = (uint16*)mPktWriter.GetBuffer();
		*mMoveItemsSize = 0;
		mPktWriter << (*mMoveItemsSize);
		mPktWriter << npcId;
		mPktWriter << currPos;
		mPktWriter << currDir;
		*mMoveItemsOffset = (uint16)mPktWriter.GetPktSize();
		if (moveItems && 0 < moveItems->Num())
		{
			int tvalsize = (int)sizeof(*(moveItems->begin())); 
			auto _moveItems = (T0*)moveItems;
			for (auto it = _moveItems->begin(); it != _moveItems->end(); ++it) 
			{
				mPktWriter.WriteBinary((uint16)tvalsize, (uchar*)&(*it)); 
			}
			*mMoveItemsSize = (uint16)(tvalsize* moveItems->Num());
		}
	}

#endif // _SERVER
#ifdef _SERVER
	template <typename T0>
	PKT_CS_REQ_MOVE_DEPOT_ITEM_TO_INVENTORY_WRITE(SendBufferHelper& sendBuffer, CreatureId npcId, const T0* moveItems, const FVector& currPos, int16 currDir)
		:
		mPktWriter(sendBuffer->GetCharBuffer(), (SEND_BUFFER_SIZE - 1))

	{
		static_assert(true == std::is_same_v<T0::value_type, _T0>, "moveItems type must be ItemDBIdAmountPair list type"); 
		mPktWriter << (uint16)CS_REQ_MOVE_DEPOT_ITEM_TO_INVENTORY;
		mMoveItemsOffset = (uint16*)mPktWriter.GetBuffer();
		*mMoveItemsOffset = 0;
		mPktWriter << (*mMoveItemsOffset);
		mMoveItemsSize = (uint16*)mPktWriter.GetBuffer();
		*mMoveItemsSize = 0;
		mPktWriter << (*mMoveItemsSize);
		mPktWriter << npcId;
		mPktWriter << currPos;
		mPktWriter << currDir;
		*mMoveItemsOffset = (uint16)mPktWriter.GetPktSize();
		if (moveItems && !moveItems->empty())
		{
			int tvalsize = (int)sizeof(*(moveItems->begin())); 
			auto _moveItems = const_cast<std::decay_t<T0>*>(moveItems);
			for (auto it = _moveItems->begin(); it != _moveItems->end(); ++it) 
			{
				mPktWriter.WriteBinary((uint16)tvalsize, (uchar*)&(*it)); 
			}
			*mMoveItemsSize = (uint16) (tvalsize * moveItems->size());
		}
	}
#endif

#ifdef _SERVER 
	void send(IocpObjectSession* session, SendBufferRef sendBuffer, bool autoCloseSendBuffer)
	{
		if (session) 
			session->Send(sendBuffer, mPktWriter.GetPktSize(), autoCloseSendBuffer);
	}
#endif

#ifdef _SERVER 
	std::xwstring GetLogWString() const
	{
		auto readPacket = reinterpret_cast<PKT_CS_REQ_MOVE_DEPOT_ITEM_TO_INVENTORY_READ*>(mPktWriter.mBuf);
		return readPacket->GetLogWString();
	}
#endif

#ifndef _SERVER
#else
#endif
}; // PKT_CS_REQ_MOVE_DEPOT_ITEM_TO_INVENTORY_WRITE

