	{
		//emplace() ČŁĂâÇŇ¶§¸¶´Ů ¸Ţ¸đ¸®¸¦ »ýĽş ÇĎ´Â şńżëŔĚ ąß»ýÇŃ´Ů şńżëŔ»ÁŮŔĚŔ§°ł reserve()»çżë
		container.reserve(mMaterialCostumeIdAmountListSize/sizeof(_T0));
		for (int offset = 0; offset < mMaterialCostumeIdAmountListSize; offset += sizeof(_T0))
		{
