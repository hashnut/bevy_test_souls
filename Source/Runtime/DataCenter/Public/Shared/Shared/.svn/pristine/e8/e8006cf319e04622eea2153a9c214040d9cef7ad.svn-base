	ItemDBId CouponItemDBId() { return mCouponItemDBId; }
#ifdef _SERVER
	const wchar_t* MarketPId() const
	{
		uchar* pktStart = (uchar*)this;
		uint16 pktSize = *((uint16*)pktStart);
		if (mMarketPIdOffset && pktSize > mMarketPIdOffset)
			return (const wchar_t*)(pktStart + mMarketPIdOffset);
		else
			return L"";
	}
#else // _SERVER
	const FString MarketPId()
	{
		const wchar_t* strWchar = L"";
		uchar* pktStart = (uchar*)this;
		uint16 pktSize = *((uint16*)pktStart);
		if (mMarketPIdOffset && pktSize > mMarketPIdOffset)
			strWchar = (const wchar_t*)(pktStart + mMarketPIdOffset);

		return PktWriter::ConvertToFString(strWchar);
	}
#endif // _SERVER
	const uchar* Purchase_bypass_info() const
	{
		uchar* pktStart = (uchar*)this;
		uint16 pktSize = *((uint16*)pktStart);
		if (mPurchase_bypass_infoOffset && pktSize > mPurchase_bypass_infoOffset)
			return (const uchar*)(pktStart + mPurchase_bypass_infoOffset);
		else
			return 0;
	}
	int Purchase_bypass_infoSize() const
	{
		return mPurchase_bypass_infoSize;
	}
	const uchar* PurchaseList() const
	{
		uchar* pktStart = (uchar*)this;
		uint16 pktSize = *((uint16*)pktStart);
		if (mPurchaseListOffset && pktSize > mPurchaseListOffset)
			return (const uchar*)(pktStart + mPurchaseListOffset);
		else
			return 0;
	}
	int PurchaseListSize() const
	{
		return mPurchaseListSize;
	}
#ifdef _SERVER
	template <typename Container>
	void MakePurchaseListVector(Container & container)
	{
		//emplace() ČŁĂâÇŇ¶§¸¶´Ů ¸Ţ¸đ¸®¸¦ »ýĽş ÇĎ´Â şńżëŔĚ ąß»ýÇŃ´Ů şńżëŔ»ÁŮŔĚŔ§°ł reserve()»çżë
		container.reserve(mPurchaseListSize/sizeof(_T0));
		for (int offset = 0; offset < mPurchaseListSize; offset += sizeof(_T0))
		{
			const _T0* data = reinterpret_cast<const _T0*>(PurchaseList() + offset);
			container.emplace_back(*data);
		}
	}
#else // _SERVER
	template <typename Container, typename Data>
	void MakePurchaseListVector(Container & container)
	{
		for (int offset = 0; offset < mPurchaseListSize; offset += sizeof(Data))
		{
			const Data* data = reinterpret_cast<const Data*>(PurchaseList() + offset);
			container.Add(*data);
		}
	}
#endif // _SERVER
#ifdef _SERVER
	template <typename TFunc>
	void ForEachPurchaseList(TFunc&& func) const
	{
		for (int offset = 0; offset < PurchaseListSize(); offset += sizeof(_T0))
		{
			const _T0* data = reinterpret_cast<const _T0*>(PurchaseList() + offset);
			func(data);
		}
	}
#endif


#ifdef _SERVER 
	std::xwstring GetLogWString() const
	{

		return Log::format(
			L"[CS_REQ_BM_SHOP_PURCHASE_ITEM] BmHiveIdentifier: {}, IsBulkSale: {}, MarketPId: {}, CouponItemDBId: {}"
			, mBmHiveIdentifier, mIsBulkSale, MarketPId(), mCouponItemDBId
		).c_str();
	}
#endif

	bool Validate()
	{
		uchar* pktStart = (uchar*)this;
		uint16 pktSize = mPktSize;

		uint16 dataSize = sizeof(PKT_CS_REQ_BM_SHOP_PURCHASE_ITEM_READ);
		if (dataSize > mPktSize)
			return false;

		if (false == ValidateValue(pktStart, pktSize, dataSize))
			return false;

		if (dataSize != mPktSize)
			return false;

		return true;
	}

	bool ValidateValue(const uchar* pktStart, uint16 pktSize, uint16& dataSize)
	{
		if (false == ValidateString(mMarketPIdOffset, 0, pktStart, pktSize, dataSize))
			return false;

		if (false == ValidateBinary(mPurchase_bypass_infoOffset, mPurchase_bypass_infoSize, 0, pktSize, dataSize))
			return false;

		if (false == ValidateBinary(mPurchaseListOffset, mPurchaseListSize, 0, pktSize, dataSize))
			return false;

		return (nullptr != pktStart && 0 < pktSize && 0 < dataSize) ? true : false;
	}

}; // PKT_CS_REQ_BM_SHOP_PURCHASE_ITEM_READ

