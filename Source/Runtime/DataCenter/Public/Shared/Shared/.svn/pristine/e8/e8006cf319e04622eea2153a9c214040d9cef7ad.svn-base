// type = CS
// related packet = PKT_SC_ACK_WDMARKET_TRANSACTION_PURCHASE_WRITE
struct PKT_CS_REQ_WDMARKET_TRANSACTION_PURCHASE_READ
{
public:
	uint16 mPktSize;
	uint16 mPktId;
	uint16 mMarketTransactionIdListOffset;
	uint16 mMarketTransactionIdListSize;

public:
#ifdef _SERVER 
	using _T0 = MarketTransactionId;
	bool GetServerTaskIdRealTime(OUT [[maybe_unused]] int& serverTaskId) const { return false; }
	const wchar_t* GetPacketName() const { return L"CS_REQ_WDMARKET_TRANSACTION_PURCHASE"; }
	const wchar_t* GetRelatedPacketName() const { return L"SC_ACK_WDMARKET_TRANSACTION_PURCHASE"; }
#endif

	const uchar* MarketTransactionIdList() const
	{
		uchar* pktStart = (uchar*)this;
		uint16 pktSize = *((uint16*)pktStart);
		if (mMarketTransactionIdListOffset && pktSize > mMarketTransactionIdListOffset)
			return (const uchar*)(pktStart + mMarketTransactionIdListOffset);
		else
			return 0;
	}
	int MarketTransactionIdListSize() const
	{
		return mMarketTransactionIdListSize;
	}
#ifdef _SERVER
	template <typename Container>
	void MakeMarketTransactionIdListVector(Container & container)
	{
		//emplace() ČŁĂâÇŇ¶§¸¶´Ů ¸Ţ¸đ¸®¸¦ »ýĽş ÇĎ´Â şńżëŔĚ ąß»ýÇŃ´Ů şńżëŔ»ÁŮŔĚŔ§°ł reserve()»çżë
		container.reserve(mMarketTransactionIdListSize/sizeof(_T0));
		for (int offset = 0; offset < mMarketTransactionIdListSize; offset += sizeof(_T0))
		{
			const _T0* data = reinterpret_cast<const _T0*>(MarketTransactionIdList() + offset);
			container.emplace_back(*data);
		}
	}
#else // _SERVER
	template <typename Container, typename Data>
	void MakeMarketTransactionIdListVector(Container & container)
	{
		for (int offset = 0; offset < mMarketTransactionIdListSize; offset += sizeof(Data))
		{
			const Data* data = reinterpret_cast<const Data*>(MarketTransactionIdList() + offset);
			container.Add(*data);
		}
	}
#endif // _SERVER
#ifdef _SERVER
	template <typename TFunc>
	void ForEachMarketTransactionIdList(TFunc&& func) const
	{
		for (int offset = 0; offset < MarketTransactionIdListSize(); offset += sizeof(_T0))
		{
			const _T0* data = reinterpret_cast<const _T0*>(MarketTransactionIdList() + offset);
			func(data);
		}
	}
#endif


#ifdef _SERVER 
	std::xwstring GetLogWString() const
	{
		std::wstringstream MarketTransactionIdListStream; 
		MarketTransactionIdListStream << std::endl;
		ForEachMarketTransactionIdList(
			[&MarketTransactionIdListStream](const MarketTransactionId* Id) {
				MarketTransactionIdListStream << "[" << static_cast<size_t>(*Id) << "]" << std::endl;
				}
			);


		return Log::format(
			L"[CS_REQ_WDMARKET_TRANSACTION_PURCHASE] MarketTransactionIdList: {}"
			, MarketTransactionIdListStream.str().c_str()
		).c_str();
	}
#endif

	bool Validate()
	{
		uchar* pktStart = (uchar*)this;
		uint16 pktSize = mPktSize;

		uint16 dataSize = sizeof(PKT_CS_REQ_WDMARKET_TRANSACTION_PURCHASE_READ);
		if (dataSize > mPktSize)
			return false;

		if (false == ValidateValue(pktStart, pktSize, dataSize))
			return false;

		if (dataSize != mPktSize)
			return false;

		return true;
	}

	bool ValidateValue(const uchar* pktStart, uint16 pktSize, uint16& dataSize)
	{
		if (false == ValidateBinary(mMarketTransactionIdListOffset, mMarketTransactionIdListSize, 0, pktSize, dataSize))
			return false;

		return (nullptr != pktStart && 0 < pktSize && 0 < dataSize) ? true : false;
	}

}; // PKT_CS_REQ_WDMARKET_TRANSACTION_PURCHASE_READ

// type = CS
// related packet = PKT_SC_ACK_WDMARKET_TRANSACTION_PURCHASE_READ
#ifdef _SERVER
struct PKT_CS_REQ_WDMARKET_TRANSACTION_PURCHASE_WRITE : public Disposable
#else
struct PKT_CS_REQ_WDMARKET_TRANSACTION_PURCHASE_WRITE
#endif
{
	PktWriter mPktWriter;
	uint16* mMarketTransactionIdListOffset;
	uint16* mMarketTransactionIdListSize;

#ifdef _SERVER 
	using _T0 = MarketTransactionId;
	bool GetServerTaskIdRealTime(OUT int& serverTaskId) const { return reinterpret_cast<PKT_CS_REQ_WDMARKET_TRANSACTION_PURCHASE_READ*>(mPktWriter.mBuf)->GetServerTaskIdRealTime(serverTaskId); }
	const wchar_t* GetPacketName() const { return L"CS_REQ_WDMARKET_TRANSACTION_PURCHASE"; }
	const wchar_t* GetRelatedPacketName() const { return L"SC_ACK_WDMARKET_TRANSACTION_PURCHASE"; }
#endif

#ifndef _SERVER
	template <typename T0>
	PKT_CS_REQ_WDMARKET_TRANSACTION_PURCHASE_WRITE(uchar* buf, int bufSize, const T0* marketTransactionIdList)
		:
		mPktWriter(buf, bufSize)

	{
		mPktWriter << static_cast<uint16>(PD::CS::CSPacketId::CS_REQ_WDMARKET_TRANSACTION_PURCHASE);
		mMarketTransactionIdListOffset = (uint16*)mPktWriter.GetBuffer();
		*mMarketTransactionIdListOffset = 0;
		mPktWriter << (*mMarketTransactionIdListOffset);
		mMarketTransactionIdListSize = (uint16*)mPktWriter.GetBuffer();
		*mMarketTransactionIdListSize = 0;
		mPktWriter << (*mMarketTransactionIdListSize);
		*mMarketTransactionIdListOffset = (uint16)mPktWriter.GetPktSize();
		if (marketTransactionIdList && 0 < marketTransactionIdList->Num())
		{
			int tvalsize = (int)sizeof(*(marketTransactionIdList->begin())); 
			auto _marketTransactionIdList = (T0*)marketTransactionIdList;
			for (auto it = _marketTransactionIdList->begin(); it != _marketTransactionIdList->end(); ++it) 
			{
				mPktWriter.WriteBinary((uint16)tvalsize, (uchar*)&(*it)); 
			}
			*mMarketTransactionIdListSize = (uint16)(tvalsize* marketTransactionIdList->Num());
		}
	}

#endif // _SERVER
#ifdef _SERVER
	template <typename T0>
	PKT_CS_REQ_WDMARKET_TRANSACTION_PURCHASE_WRITE(SendBufferHelper& sendBuffer, const T0* marketTransactionIdList)
		:
		mPktWriter(sendBuffer->GetCharBuffer(), (SEND_BUFFER_SIZE - 1))

	{
		static_assert(true == std::is_same_v<T0::value_type, _T0>, "marketTransactionIdList type must be MarketTransactionId list type"); 
		mPktWriter << (uint16)CS_REQ_WDMARKET_TRANSACTION_PURCHASE;
		mMarketTransactionIdListOffset = (uint16*)mPktWriter.GetBuffer();
		*mMarketTransactionIdListOffset = 0;
		mPktWriter << (*mMarketTransactionIdListOffset);
		mMarketTransactionIdListSize = (uint16*)mPktWriter.GetBuffer();
		*mMarketTransactionIdListSize = 0;
		mPktWriter << (*mMarketTransactionIdListSize);
		*mMarketTransactionIdListOffset = (uint16)mPktWriter.GetPktSize();
		if (marketTransactionIdList && !marketTransactionIdList->empty())
		{
			int tvalsize = (int)sizeof(*(marketTransactionIdList->begin())); 
			auto _marketTransactionIdList = const_cast<std::decay_t<T0>*>(marketTransactionIdList);
			for (auto it = _marketTransactionIdList->begin(); it != _marketTransactionIdList->end(); ++it) 
			{
				mPktWriter.WriteBinary((uint16)tvalsize, (uchar*)&(*it)); 
			}
			*mMarketTransactionIdListSize = (uint16) (tvalsize * marketTransactionIdList->size());
		}
	}
#endif

#ifdef _SERVER 
	void send(IocpObjectSession* session, SendBufferRef sendBuffer, bool autoCloseSendBuffer)
	{
		if (session) 
			session->Send(sendBuffer, mPktWriter.GetPktSize(), autoCloseSendBuffer);
	}
#endif

#ifdef _SERVER 
	std::xwstring GetLogWString() const
	{
		auto readPacket = reinterpret_cast<PKT_CS_REQ_WDMARKET_TRANSACTION_PURCHASE_READ*>(mPktWriter.mBuf);
		return readPacket->GetLogWString();
	}
#endif

#ifndef _SERVER
#else
#endif
}; // PKT_CS_REQ_WDMARKET_TRANSACTION_PURCHASE_WRITE

