	{
		auto readPacket = reinterpret_cast<PKT_CS_TITLE_CONFIRM_READ*>(mPktWriter.mBuf);
		return readPacket->GetLogWString();
	}
#endif

#ifndef _SERVER
#else
#endif
}; // PKT_CS_TITLE_CONFIRM_WRITE

