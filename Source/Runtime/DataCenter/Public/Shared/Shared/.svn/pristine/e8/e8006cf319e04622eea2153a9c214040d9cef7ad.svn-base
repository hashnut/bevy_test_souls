public:
#ifdef _SERVER 
	using _T0 = BMProductIdAmountPair;
	bool GetServerTaskIdRealTime(OUT [[maybe_unused]] int& serverTaskId) const { return false; }
	const wchar_t* GetPacketName() const { return L"CS_REQ_BM_SHOP_PURCHASE_ITEM"; }
