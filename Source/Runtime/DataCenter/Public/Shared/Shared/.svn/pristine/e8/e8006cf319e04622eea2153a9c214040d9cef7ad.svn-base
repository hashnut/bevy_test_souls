#ifdef _SERVER 
	std::xwstring GetLogWString() const
	{
		auto MaterialCostumeIdAmountListListLogFunc = [this]() -> std::xwstring
		{
			std::xwstring result;
			result.append(L"\n");
			for (int offset = 0; offset < MaterialCostumeIdAmountListSize(); offset += sizeof(struct CostumeIdAmountPair))
			{
				const struct CostumeIdAmountPair* data = reinterpret_cast<const struct CostumeIdAmountPair*>(MaterialCostumeIdAmountList() + offset);
				result.append(Log::format(L"{}", *data));
