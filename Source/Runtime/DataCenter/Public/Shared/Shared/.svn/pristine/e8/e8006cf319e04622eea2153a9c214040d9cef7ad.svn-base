	{
		uchar* pktStart = (uchar*)this;
		uint16 pktSize = *((uint16*)pktStart);
		if (mMaterialFairyIdAmountListOffset && pktSize > mMaterialFairyIdAmountListOffset)
			return (const uchar*)(pktStart + mMaterialFairyIdAmountListOffset);
		else
			return 0;
	}
	int MaterialFairyIdAmountListSize() const
	{
		return mMaterialFairyIdAmountListSize;
	}
#ifdef _SERVER
	template <typename Container>
	void MakeMaterialFairyIdAmountListVector(Container & container)
	{
		//emplace() ČŁĂâÇŇ¶§¸¶´Ů ¸Ţ¸đ¸®¸¦ »ýĽş ÇĎ´Â şńżëŔĚ ąß»ýÇŃ´Ů şńżëŔ»ÁŮŔĚŔ§°ł reserve()»çżë
		container.reserve(mMaterialFairyIdAmountListSize/sizeof(_T0));
		for (int offset = 0; offset < mMaterialFairyIdAmountListSize; offset += sizeof(_T0))
		{
			const _T0* data = reinterpret_cast<const _T0*>(MaterialFairyIdAmountList() + offset);
			container.emplace_back(*data);
		}
	}
#else // _SERVER
	template <typename Container, typename Data>
	void MakeMaterialFairyIdAmountListVector(Container & container)
	{
		for (int offset = 0; offset < mMaterialFairyIdAmountListSize; offset += sizeof(Data))
		{
			const Data* data = reinterpret_cast<const Data*>(MaterialFairyIdAmountList() + offset);
			container.Add(*data);
		}
	}
#endif // _SERVER
#ifdef _SERVER
	template <typename TFunc>
	void ForEachMaterialFairyIdAmountList(TFunc&& func) const
	{
		for (int offset = 0; offset < MaterialFairyIdAmountListSize(); offset += sizeof(_T0))
		{
			const _T0* data = reinterpret_cast<const _T0*>(MaterialFairyIdAmountList() + offset);
			func(data);
		}
	}
#endif
