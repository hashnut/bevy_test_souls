// type = CS
// related packet = PKT_SC_ACK_ITEM_ENCHANT_MULTI_WRITE
struct PKT_CS_REQ_ITEM_ENCHANT_MULTI_READ
{
public:
	uint16 mPktSize;
	uint16 mPktId;
	uint16 mItemsUseOffset;
	uint16 mItemsUseSize;
	uint16 mTargetItemDBIdListOffset;
	uint16 mTargetItemDBIdListSize;
	Level mTargetLevel;

public:
#ifdef _SERVER 
	using _T0 = ItemDBIdAmountPair;
	using _T1 = ItemDBId;
	bool GetServerTaskIdRealTime(OUT [[maybe_unused]] int& serverTaskId) const { return false; }
	const wchar_t* GetPacketName() const { return L"CS_REQ_ITEM_ENCHANT_MULTI"; }
	const wchar_t* GetRelatedPacketName() const { return L"SC_ACK_ITEM_ENCHANT_MULTI"; }
#endif

	Level TargetLevel() { return mTargetLevel; }
	const uchar* ItemsUse() const
	{
		uchar* pktStart = (uchar*)this;
		uint16 pktSize = *((uint16*)pktStart);
		if (mItemsUseOffset && pktSize > mItemsUseOffset)
			return (const uchar*)(pktStart + mItemsUseOffset);
		else
			return 0;
	}
	int ItemsUseSize() const
	{
		return mItemsUseSize;
	}
#ifdef _SERVER
	template <typename Container>
	void MakeItemsUseVector(Container & container)
	{
		//emplace() ČŁĂâÇŇ¶§¸¶´Ů ¸Ţ¸đ¸®¸¦ »ýĽş ÇĎ´Â şńżëŔĚ ąß»ýÇŃ´Ů şńżëŔ»ÁŮŔĚŔ§°ł reserve()»çżë
		container.reserve(mItemsUseSize/sizeof(_T0));
		for (int offset = 0; offset < mItemsUseSize; offset += sizeof(_T0))
		{
			const _T0* data = reinterpret_cast<const _T0*>(ItemsUse() + offset);
			container.emplace_back(*data);
		}
	}
#else // _SERVER
	template <typename Container, typename Data>
	void MakeItemsUseVector(Container & container)
	{
		for (int offset = 0; offset < mItemsUseSize; offset += sizeof(Data))
		{
			const Data* data = reinterpret_cast<const Data*>(ItemsUse() + offset);
			container.Add(*data);
		}
	}
#endif // _SERVER
#ifdef _SERVER
	template <typename TFunc>
	void ForEachItemsUse(TFunc&& func) const
	{
		for (int offset = 0; offset < ItemsUseSize(); offset += sizeof(_T0))
		{
			const _T0* data = reinterpret_cast<const _T0*>(ItemsUse() + offset);
			func(data);
		}
	}
#endif
	const uchar* TargetItemDBIdList() const
	{
		uchar* pktStart = (uchar*)this;
		uint16 pktSize = *((uint16*)pktStart);
		if (mTargetItemDBIdListOffset && pktSize > mTargetItemDBIdListOffset)
			return (const uchar*)(pktStart + mTargetItemDBIdListOffset);
		else
			return 0;
	}
	int TargetItemDBIdListSize() const
	{
		return mTargetItemDBIdListSize;
	}
#ifdef _SERVER
	template <typename Container>
	void MakeTargetItemDBIdListVector(Container & container)
	{
		//emplace() ČŁĂâÇŇ¶§¸¶´Ů ¸Ţ¸đ¸®¸¦ »ýĽş ÇĎ´Â şńżëŔĚ ąß»ýÇŃ´Ů şńżëŔ»ÁŮŔĚŔ§°ł reserve()»çżë
		container.reserve(mTargetItemDBIdListSize/sizeof(_T1));
		for (int offset = 0; offset < mTargetItemDBIdListSize; offset += sizeof(_T1))
		{
			const _T1* data = reinterpret_cast<const _T1*>(TargetItemDBIdList() + offset);
			container.emplace_back(*data);
		}
	}
#else // _SERVER
	template <typename Container, typename Data>
	void MakeTargetItemDBIdListVector(Container & container)
	{
		for (int offset = 0; offset < mTargetItemDBIdListSize; offset += sizeof(Data))
		{
			const Data* data = reinterpret_cast<const Data*>(TargetItemDBIdList() + offset);
			container.Add(*data);
		}
	}
#endif // _SERVER
#ifdef _SERVER
	template <typename TFunc>
	void ForEachTargetItemDBIdList(TFunc&& func) const
	{
		for (int offset = 0; offset < TargetItemDBIdListSize(); offset += sizeof(_T1))
		{
			const _T1* data = reinterpret_cast<const _T1*>(TargetItemDBIdList() + offset);
			func(data);
		}
	}
#endif


#ifdef _SERVER 
	std::xwstring GetLogWString() const
	{
		auto ItemsUseListLogFunc = [this]() -> std::xwstring
		{
			std::xwstring result;
			result.append(L"\n");
			for (int offset = 0; offset < ItemsUseSize(); offset += sizeof(struct ItemDBIdAmountPair))
			{
				const struct ItemDBIdAmountPair* data = reinterpret_cast<const struct ItemDBIdAmountPair*>(ItemsUse() + offset);
				result.append(Log::format(L"{}", *data));
				result.append(L"\n");
			}
			return result;
		};

		std::wstringstream TargetItemDBIdListStream; 
		TargetItemDBIdListStream << std::endl;
		ForEachTargetItemDBIdList(
			[&TargetItemDBIdListStream](const ItemDBId* Id) {
				TargetItemDBIdListStream << "[" << static_cast<size_t>(*Id) << "]" << std::endl;
				}
			);


		return Log::format(
			L"[CS_REQ_ITEM_ENCHANT_MULTI] ItemsUse: {}, TargetItemDBIdList: {}, TargetLevel: {}"
			, ItemsUseListLogFunc().c_str(), TargetItemDBIdListStream.str().c_str(), mTargetLevel
		).c_str();
	}
#endif

	bool Validate()
	{
		uchar* pktStart = (uchar*)this;
		uint16 pktSize = mPktSize;

		uint16 dataSize = sizeof(PKT_CS_REQ_ITEM_ENCHANT_MULTI_READ);
		if (dataSize > mPktSize)
			return false;

		if (false == ValidateValue(pktStart, pktSize, dataSize))
			return false;

		if (dataSize != mPktSize)
			return false;

		return true;
	}

	bool ValidateValue(const uchar* pktStart, uint16 pktSize, uint16& dataSize)
	{
		if (false == ValidateBinary(mItemsUseOffset, mItemsUseSize, 0, pktSize, dataSize))
			return false;

		if (false == ValidateBinary(mTargetItemDBIdListOffset, mTargetItemDBIdListSize, 0, pktSize, dataSize))
			return false;

		return (nullptr != pktStart && 0 < pktSize && 0 < dataSize) ? true : false;
	}

}; // PKT_CS_REQ_ITEM_ENCHANT_MULTI_READ

