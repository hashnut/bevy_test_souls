// type = CS
// related packet = PKT_SC_ACK_MAIL_RECV_WRITE
struct PKT_CS_REQ_MAIL_RECV_READ
{
public:
	uint16 mPktSize;
	uint16 mPktId;
	uint16 mMailDBIdsOffset;
	uint16 mMailDBIdsSize;
	MailBoxType mBoxType;

public:
#ifdef _SERVER 
	using _T0 = MailDBId;
	bool GetServerTaskIdRealTime(OUT [[maybe_unused]] int& serverTaskId) const { return false; }
	const wchar_t* GetPacketName() const { return L"CS_REQ_MAIL_RECV"; }
	const wchar_t* GetRelatedPacketName() const { return L"SC_ACK_MAIL_RECV"; }
#endif

	MailBoxType BoxType() { return mBoxType; }
	const uchar* MailDBIds() const
	{
		uchar* pktStart = (uchar*)this;
		uint16 pktSize = *((uint16*)pktStart);
		if (mMailDBIdsOffset && pktSize > mMailDBIdsOffset)
			return (const uchar*)(pktStart + mMailDBIdsOffset);
		else
			return 0;
	}
	int MailDBIdsSize() const
	{
		return mMailDBIdsSize;
	}
#ifdef _SERVER
	template <typename Container>
	void MakeMailDBIdsVector(Container & container)
	{
		//emplace() ČŁĂâÇŇ¶§¸¶´Ů ¸Ţ¸đ¸®¸¦ »ýĽş ÇĎ´Â şńżëŔĚ ąß»ýÇŃ´Ů şńżëŔ»ÁŮŔĚŔ§°ł reserve()»çżë
		container.reserve(mMailDBIdsSize/sizeof(_T0));
		for (int offset = 0; offset < mMailDBIdsSize; offset += sizeof(_T0))
		{
			const _T0* data = reinterpret_cast<const _T0*>(MailDBIds() + offset);
			container.emplace_back(*data);
		}
	}
#else // _SERVER
	template <typename Container, typename Data>
	void MakeMailDBIdsVector(Container & container)
	{
		for (int offset = 0; offset < mMailDBIdsSize; offset += sizeof(Data))
		{
			const Data* data = reinterpret_cast<const Data*>(MailDBIds() + offset);
			container.Add(*data);
		}
	}
#endif // _SERVER
#ifdef _SERVER
	template <typename TFunc>
	void ForEachMailDBIds(TFunc&& func) const
	{
		for (int offset = 0; offset < MailDBIdsSize(); offset += sizeof(_T0))
		{
			const _T0* data = reinterpret_cast<const _T0*>(MailDBIds() + offset);
			func(data);
		}
	}
#endif


#ifdef _SERVER 
	std::xwstring GetLogWString() const
	{

		return Log::format(
			L"[CS_REQ_MAIL_RECV] BoxType: {}"
			, mBoxType
		).c_str();
	}
#endif

	bool Validate()
	{
		uchar* pktStart = (uchar*)this;
		uint16 pktSize = mPktSize;

		uint16 dataSize = sizeof(PKT_CS_REQ_MAIL_RECV_READ);
		if (dataSize > mPktSize)
			return false;

		if (false == ValidateValue(pktStart, pktSize, dataSize))
			return false;

		if (dataSize != mPktSize)
			return false;

		return true;
	}

	bool ValidateValue(const uchar* pktStart, uint16 pktSize, uint16& dataSize)
	{
		if (false == ValidateBinary(mMailDBIdsOffset, mMailDBIdsSize, 0, pktSize, dataSize))
			return false;

		return (nullptr != pktStart && 0 < pktSize && 0 < dataSize) ? true : false;
	}

}; // PKT_CS_REQ_MAIL_RECV_READ

// type = CS
// related packet = PKT_SC_ACK_MAIL_RECV_READ
#ifdef _SERVER
struct PKT_CS_REQ_MAIL_RECV_WRITE : public Disposable
#else
struct PKT_CS_REQ_MAIL_RECV_WRITE
#endif
{
	PktWriter mPktWriter;
	uint16* mMailDBIdsOffset;
	uint16* mMailDBIdsSize;

#ifdef _SERVER 
	using _T0 = MailDBId;
	bool GetServerTaskIdRealTime(OUT int& serverTaskId) const { return reinterpret_cast<PKT_CS_REQ_MAIL_RECV_READ*>(mPktWriter.mBuf)->GetServerTaskIdRealTime(serverTaskId); }
	const wchar_t* GetPacketName() const { return L"CS_REQ_MAIL_RECV"; }
	const wchar_t* GetRelatedPacketName() const { return L"SC_ACK_MAIL_RECV"; }
#endif

#ifndef _SERVER
	template <typename T0>
	PKT_CS_REQ_MAIL_RECV_WRITE(uchar* buf, int bufSize, MailBoxType boxType, const T0* mailDBIds)
		:
		mPktWriter(buf, bufSize)

	{
		mPktWriter << static_cast<uint16>(PD::CS::CSPacketId::CS_REQ_MAIL_RECV);
		mMailDBIdsOffset = (uint16*)mPktWriter.GetBuffer();
		*mMailDBIdsOffset = 0;
		mPktWriter << (*mMailDBIdsOffset);
		mMailDBIdsSize = (uint16*)mPktWriter.GetBuffer();
		*mMailDBIdsSize = 0;
		mPktWriter << (*mMailDBIdsSize);
		mPktWriter << boxType;
		*mMailDBIdsOffset = (uint16)mPktWriter.GetPktSize();
		if (mailDBIds && 0 < mailDBIds->Num())
		{
			int tvalsize = (int)sizeof(*(mailDBIds->begin())); 
			auto _mailDBIds = (T0*)mailDBIds;
			for (auto it = _mailDBIds->begin(); it != _mailDBIds->end(); ++it) 
			{
				mPktWriter.WriteBinary((uint16)tvalsize, (uchar*)&(*it)); 
			}
			*mMailDBIdsSize = (uint16)(tvalsize* mailDBIds->Num());
		}
	}

#endif // _SERVER
#ifdef _SERVER
	template <typename T0>
	PKT_CS_REQ_MAIL_RECV_WRITE(SendBufferHelper& sendBuffer, MailBoxType boxType, const T0* mailDBIds)
		:
		mPktWriter(sendBuffer->GetCharBuffer(), (SEND_BUFFER_SIZE - 1))

	{
		static_assert(true == std::is_same_v<T0::value_type, _T0>, "mailDBIds type must be MailDBId list type"); 
		mPktWriter << (uint16)CS_REQ_MAIL_RECV;
		mMailDBIdsOffset = (uint16*)mPktWriter.GetBuffer();
		*mMailDBIdsOffset = 0;
		mPktWriter << (*mMailDBIdsOffset);
		mMailDBIdsSize = (uint16*)mPktWriter.GetBuffer();
		*mMailDBIdsSize = 0;
		mPktWriter << (*mMailDBIdsSize);
		mPktWriter << boxType;
		*mMailDBIdsOffset = (uint16)mPktWriter.GetPktSize();
		if (mailDBIds && !mailDBIds->empty())
		{
			int tvalsize = (int)sizeof(*(mailDBIds->begin())); 
			auto _mailDBIds = const_cast<std::decay_t<T0>*>(mailDBIds);
			for (auto it = _mailDBIds->begin(); it != _mailDBIds->end(); ++it) 
			{
				mPktWriter.WriteBinary((uint16)tvalsize, (uchar*)&(*it)); 
			}
			*mMailDBIdsSize = (uint16) (tvalsize * mailDBIds->size());
		}
	}
#endif

#ifdef _SERVER 
	void send(IocpObjectSession* session, SendBufferRef sendBuffer, bool autoCloseSendBuffer)
	{
		if (session) 
			session->Send(sendBuffer, mPktWriter.GetPktSize(), autoCloseSendBuffer);
	}
#endif

#ifdef _SERVER 
	std::xwstring GetLogWString() const
	{
		auto readPacket = reinterpret_cast<PKT_CS_REQ_MAIL_RECV_READ*>(mPktWriter.mBuf);
		return readPacket->GetLogWString();
	}
#endif

#ifndef _SERVER
#else
#endif
