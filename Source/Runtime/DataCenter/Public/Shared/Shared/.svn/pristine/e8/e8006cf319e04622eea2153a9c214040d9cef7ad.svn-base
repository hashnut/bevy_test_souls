struct PKT_CS_REQ_SPIRIT_SHOT_ENCHNT_READ
{
public:
	uint16 mPktSize;
	uint16 mPktId;
	uint16 mItemsUseOffset;
	uint16 mItemsUseSize;
	SpiritShotCategoryId mSpiritShotCategoryId;
	SpiritShotLevelId mSpiritShotLevelId;
	int mModifyEnchantRateCount;

public:
#ifdef _SERVER 
	using _T0 = ItemDBIdAmountPair;
	bool GetServerTaskIdRealTime(OUT [[maybe_unused]] int& serverTaskId) const { return false; }
	const wchar_t* GetPacketName() const { return L"CS_REQ_SPIRIT_SHOT_ENCHNT"; }
	const wchar_t* GetRelatedPacketName() const { return L"SC_ACK_SPIRIT_SHOT_ENCHNT"; }
#endif

	const SpiritShotCategoryId& ConstRefSpiritShotCategoryId() { return mSpiritShotCategoryId; }
	SpiritShotCategoryId SpiritShotCategoryId() { return mSpiritShotCategoryId; }
	const SpiritShotLevelId& ConstRefSpiritShotLevelId() { return mSpiritShotLevelId; }
	SpiritShotLevelId SpiritShotLevelId() { return mSpiritShotLevelId; }
	int ModifyEnchantRateCount() { return mModifyEnchantRateCount; }
	const uchar* ItemsUse() const
	{
		uchar* pktStart = (uchar*)this;
		uint16 pktSize = *((uint16*)pktStart);
		if (mItemsUseOffset && pktSize > mItemsUseOffset)
			return (const uchar*)(pktStart + mItemsUseOffset);
		else
			return 0;
	}
	int ItemsUseSize() const
	{
		return mItemsUseSize;
	}
#ifdef _SERVER
	template <typename Container>
	void MakeItemsUseVector(Container & container)
	{
		//emplace() ČŁĂâÇŇ¶§¸¶´Ů ¸Ţ¸đ¸®¸¦ »ýĽş ÇĎ´Â şńżëŔĚ ąß»ýÇŃ´Ů şńżëŔ»ÁŮŔĚŔ§°ł reserve()»çżë
		container.reserve(mItemsUseSize/sizeof(_T0));
		for (int offset = 0; offset < mItemsUseSize; offset += sizeof(_T0))
		{
			const _T0* data = reinterpret_cast<const _T0*>(ItemsUse() + offset);
			container.emplace_back(*data);
		}
	}
#else // _SERVER
	template <typename Container, typename Data>
	void MakeItemsUseVector(Container & container)
	{
		for (int offset = 0; offset < mItemsUseSize; offset += sizeof(Data))
		{
			const Data* data = reinterpret_cast<const Data*>(ItemsUse() + offset);
			container.Add(*data);
		}
	}
#endif // _SERVER
#ifdef _SERVER
	template <typename TFunc>
	void ForEachItemsUse(TFunc&& func) const
	{
		for (int offset = 0; offset < ItemsUseSize(); offset += sizeof(_T0))
		{
			const _T0* data = reinterpret_cast<const _T0*>(ItemsUse() + offset);
			func(data);
		}
	}
#endif


#ifdef _SERVER 
	std::xwstring GetLogWString() const
	{
		auto ItemsUseListLogFunc = [this]() -> std::xwstring
		{
			std::xwstring result;
			result.append(L"\n");
			for (int offset = 0; offset < ItemsUseSize(); offset += sizeof(struct ItemDBIdAmountPair))
			{
				const struct ItemDBIdAmountPair* data = reinterpret_cast<const struct ItemDBIdAmountPair*>(ItemsUse() + offset);
				result.append(Log::format(L"{}", *data));
				result.append(L"\n");
			}
			return result;
		};


		return Log::format(
			L"[CS_REQ_SPIRIT_SHOT_ENCHNT] SpiritShotCategoryId: {}, SpiritShotLevelId: {}, ModifyEnchantRateCount: {}, ItemsUse: {}"
			, mSpiritShotCategoryId, mSpiritShotLevelId, mModifyEnchantRateCount, ItemsUseListLogFunc().c_str()
		).c_str();
	}
#endif

	bool Validate()
	{
		uchar* pktStart = (uchar*)this;
		uint16 pktSize = mPktSize;

		uint16 dataSize = sizeof(PKT_CS_REQ_SPIRIT_SHOT_ENCHNT_READ);
		if (dataSize > mPktSize)
			return false;

		if (false == ValidateValue(pktStart, pktSize, dataSize))
			return false;

		if (dataSize != mPktSize)
			return false;

		return true;
	}

	bool ValidateValue(const uchar* pktStart, uint16 pktSize, uint16& dataSize)
	{
		if (false == ValidateBinary(mItemsUseOffset, mItemsUseSize, 0, pktSize, dataSize))
			return false;

		return (nullptr != pktStart && 0 < pktSize && 0 < dataSize) ? true : false;
	}

}; // PKT_CS_REQ_SPIRIT_SHOT_ENCHNT_READ

