#endif

#ifndef _SERVER
	template <typename T0>
	PKT_CS_REQ_SPIRIT_SHOT_ENCHNT_WRITE(uchar* buf, int bufSize, SpiritShotCategoryId spiritShotCategoryId, SpiritShotLevelId spiritShotLevelId, int modifyEnchantRateCount, const T0* itemsUse)
		:
		mPktWriter(buf, bufSize)

	{
		mPktWriter << static_cast<uint16>(PD::CS::CSPacketId::CS_REQ_SPIRIT_SHOT_ENCHNT);
		mItemsUseOffset = (uint16*)mPktWriter.GetBuffer();
		*mItemsUseOffset = 0;
		mPktWriter << (*mItemsUseOffset);
		mItemsUseSize = (uint16*)mPktWriter.GetBuffer();
		*mItemsUseSize = 0;
		mPktWriter << (*mItemsUseSize);
		mPktWriter << spiritShotCategoryId;
		mPktWriter << spiritShotLevelId;
		mPktWriter << modifyEnchantRateCount;
		*mItemsUseOffset = (uint16)mPktWriter.GetPktSize();
		if (itemsUse && 0 < itemsUse->Num())
		{
			int tvalsize = (int)sizeof(*(itemsUse->begin())); 
			auto _itemsUse = (T0*)itemsUse;
			for (auto it = _itemsUse->begin(); it != _itemsUse->end(); ++it) 
			{
				mPktWriter.WriteBinary((uint16)tvalsize, (uchar*)&(*it)); 
			}
			*mItemsUseSize = (uint16)(tvalsize* itemsUse->Num());
		}
	}

#endif // _SERVER
#ifdef _SERVER
	template <typename T0>
	PKT_CS_REQ_SPIRIT_SHOT_ENCHNT_WRITE(SendBufferHelper& sendBuffer, const SpiritShotCategoryId& spiritShotCategoryId, const SpiritShotLevelId& spiritShotLevelId, int modifyEnchantRateCount, const T0* itemsUse)
		:
		mPktWriter(sendBuffer->GetCharBuffer(), (SEND_BUFFER_SIZE - 1))

	{
		static_assert(true == std::is_same_v<T0::value_type, _T0>, "itemsUse type must be ItemDBIdAmountPair list type"); 
		mPktWriter << (uint16)CS_REQ_SPIRIT_SHOT_ENCHNT;
		mItemsUseOffset = (uint16*)mPktWriter.GetBuffer();
		*mItemsUseOffset = 0;
		mPktWriter << (*mItemsUseOffset);
		mItemsUseSize = (uint16*)mPktWriter.GetBuffer();
		*mItemsUseSize = 0;
		mPktWriter << (*mItemsUseSize);
		mPktWriter << spiritShotCategoryId;
		mPktWriter << spiritShotLevelId;
		mPktWriter << modifyEnchantRateCount;
		*mItemsUseOffset = (uint16)mPktWriter.GetPktSize();
		if (itemsUse && !itemsUse->empty())
		{
			int tvalsize = (int)sizeof(*(itemsUse->begin())); 
			auto _itemsUse = const_cast<std::decay_t<T0>*>(itemsUse);
			for (auto it = _itemsUse->begin(); it != _itemsUse->end(); ++it) 
			{
				mPktWriter.WriteBinary((uint16)tvalsize, (uchar*)&(*it)); 
			}
			*mItemsUseSize = (uint16) (tvalsize * itemsUse->size());
		}
	}
#endif

