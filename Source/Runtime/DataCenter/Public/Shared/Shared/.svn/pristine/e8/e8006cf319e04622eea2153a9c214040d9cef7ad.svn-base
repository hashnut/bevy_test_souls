#endif

#ifndef _SERVER
	template <typename T0, typename T1>
	PKT_CS_REQ_FAIRY_COMPOSE_WRITE(uchar* buf, int bufSize, const T0* materialFairyIdAmountList, const T1* materialCountList)
		:
		mPktWriter(buf, bufSize)

	{
		mPktWriter << static_cast<uint16>(PD::CS::CSPacketId::CS_REQ_FAIRY_COMPOSE);
		mMaterialFairyIdAmountListOffset = (uint16*)mPktWriter.GetBuffer();
		*mMaterialFairyIdAmountListOffset = 0;
		mPktWriter << (*mMaterialFairyIdAmountListOffset);
		mMaterialFairyIdAmountListSize = (uint16*)mPktWriter.GetBuffer();
		*mMaterialFairyIdAmountListSize = 0;
		mPktWriter << (*mMaterialFairyIdAmountListSize);
		mMaterialCountListOffset = (uint16*)mPktWriter.GetBuffer();
