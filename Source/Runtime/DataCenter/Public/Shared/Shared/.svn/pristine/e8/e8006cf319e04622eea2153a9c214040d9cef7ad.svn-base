// type = CS
struct PKT_CS_USER_MOVE_READ
{
public:
	uint16 mPktSize;
	uint16 mPktId;
	FVector mCurPos;
	int16 mCurDir;
	FVector mDestPos;
	float mFallingSpeed;
	uchar mMotionType;
	uint64 mClientTick;
	uint64 mPosValidateSeq;

public:
#ifdef _SERVER 
	bool GetServerTaskIdRealTime(OUT [[maybe_unused]] int& serverTaskId) const { return false; }
	const wchar_t* GetPacketName() const { return L"CS_USER_MOVE"; }
	const wchar_t* GetRelatedPacketName() const { return L"SC_USER_MOVE"; }
#endif

	const FVector& ConstRefCurPos() { return mCurPos; }
	FVector CurPos() { return mCurPos; }
	int16 CurDir() { return mCurDir; }
	const FVector& ConstRefDestPos() { return mDestPos; }
	FVector DestPos() { return mDestPos; }
	float FallingSpeed() { return mFallingSpeed; }
	uchar MotionType() { return mMotionType; }
	uint64 ClientTick() { return mClientTick; }
	uint64 PosValidateSeq() { return mPosValidateSeq; }


#ifdef _SERVER 
	std::xwstring GetLogWString() const
	{

		return Log::format(
			L"[CS_USER_MOVE] CurPos: {}, CurDir: {}, DestPos: {}, FallingSpeed: {}, MotionType: {}, ClientTick: {}, PosValidateSeq: {}"
			, mCurPos, mCurDir, mDestPos, mFallingSpeed, mMotionType, mClientTick, mPosValidateSeq
		).c_str();
	}
#endif

	bool Validate()
	{
		uchar* pktStart = (uchar*)this;
		uint16 pktSize = mPktSize;

		uint16 dataSize = sizeof(PKT_CS_USER_MOVE_READ);
		if (dataSize > mPktSize)
			return false;

		if (false == ValidateValue(pktStart, pktSize, dataSize))
			return false;

		if (dataSize != mPktSize)
			return false;

		return true;
	}

	bool ValidateValue(const uchar* pktStart, uint16 pktSize, uint16& dataSize)
	{
		return (nullptr != pktStart && 0 < pktSize && 0 < dataSize) ? true : false;
	}

}; // PKT_CS_USER_MOVE_READ

