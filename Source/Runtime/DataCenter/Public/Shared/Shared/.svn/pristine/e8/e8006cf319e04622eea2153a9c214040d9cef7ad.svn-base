// type = CS
struct PKT_CS_REQ_MAIL_SEND_READ
{
public:
	uint16 mPktSize;
	uint16 mPktId;
	uint16 mMailDataListOffset;
	uint16 mMailDataListSize;

public:
#ifdef _SERVER 
	using _T0 = MailData;
	bool GetServerTaskIdRealTime(OUT [[maybe_unused]] int& serverTaskId) const { return false; }
	const wchar_t* GetPacketName() const { return L"CS_REQ_MAIL_SEND"; }
	const wchar_t* GetRelatedPacketName() const { return L"SC_ACK_MAIL_SEND"; }
#endif

	const uchar* MailDataList() const
	{
		uchar* pktStart = (uchar*)this;
		uint16 pktSize = *((uint16*)pktStart);
		if (mMailDataListOffset && pktSize > mMailDataListOffset)
			return (const uchar*)(pktStart + mMailDataListOffset);
		else
			return 0;
	}
	int MailDataListSize() const
	{
		return mMailDataListSize;
	}
#ifdef _SERVER
	template <typename Container>
	void MakeMailDataListVector(Container & container)
	{
		//emplace() ČŁĂâÇŇ¶§¸¶´Ů ¸Ţ¸đ¸®¸¦ »ýĽş ÇĎ´Â şńżëŔĚ ąß»ýÇŃ´Ů şńżëŔ»ÁŮŔĚŔ§°ł reserve()»çżë
		container.reserve(mMailDataListSize/sizeof(_T0));
		for (int offset = 0; offset < mMailDataListSize; offset += sizeof(_T0))
		{
			const _T0* data = reinterpret_cast<const _T0*>(MailDataList() + offset);
			container.emplace_back(*data);
		}
	}
#else // _SERVER
	template <typename Container, typename Data>
	void MakeMailDataListVector(Container & container)
	{
		for (int offset = 0; offset < mMailDataListSize; offset += sizeof(Data))
		{
			const Data* data = reinterpret_cast<const Data*>(MailDataList() + offset);
			container.Add(*data);
		}
	}
#endif // _SERVER
#ifdef _SERVER
	template <typename TFunc>
	void ForEachMailDataList(TFunc&& func) const
	{
		for (int offset = 0; offset < MailDataListSize(); offset += sizeof(_T0))
		{
			const _T0* data = reinterpret_cast<const _T0*>(MailDataList() + offset);
			func(data);
		}
	}
#endif


#ifdef _SERVER 
	std::xwstring GetLogWString() const
	{
		auto MailDataListListLogFunc = [this]() -> std::xwstring
		{
			std::xwstring result;
			result.append(L"\n");
			for (int offset = 0; offset < MailDataListSize(); offset += sizeof(struct MailData))
			{
				const struct MailData* data = reinterpret_cast<const struct MailData*>(MailDataList() + offset);
				result.append(Log::format(L"{}", *data));
				result.append(L"\n");
			}
			return result;
		};


		return Log::format(
			L"[CS_REQ_MAIL_SEND] MailDataList: {}"
			, MailDataListListLogFunc().c_str()
		).c_str();
	}
#endif

	bool Validate()
	{
		uchar* pktStart = (uchar*)this;
		uint16 pktSize = mPktSize;

		uint16 dataSize = sizeof(PKT_CS_REQ_MAIL_SEND_READ);
		if (dataSize > mPktSize)
			return false;

		if (false == ValidateValue(pktStart, pktSize, dataSize))
			return false;

		if (dataSize != mPktSize)
			return false;

		return true;
	}

	bool ValidateValue(const uchar* pktStart, uint16 pktSize, uint16& dataSize)
	{
		if (false == ValidateBinary(mMailDataListOffset, mMailDataListSize, 0, pktSize, dataSize))
			return false;

		return (nullptr != pktStart && 0 < pktSize && 0 < dataSize) ? true : false;
	}

}; // PKT_CS_REQ_MAIL_SEND_READ

// type = CS
#ifdef _SERVER
struct PKT_CS_REQ_MAIL_SEND_WRITE : public Disposable
#else
struct PKT_CS_REQ_MAIL_SEND_WRITE
#endif
{
	PktWriter mPktWriter;
	uint16* mMailDataListOffset;
	uint16* mMailDataListSize;

#ifdef _SERVER 
	using _T0 = MailData;
	bool GetServerTaskIdRealTime(OUT int& serverTaskId) const { return reinterpret_cast<PKT_CS_REQ_MAIL_SEND_READ*>(mPktWriter.mBuf)->GetServerTaskIdRealTime(serverTaskId); }
	const wchar_t* GetPacketName() const { return L"CS_REQ_MAIL_SEND"; }
	const wchar_t* GetRelatedPacketName() const { return L"SC_ACK_MAIL_SEND"; }
#endif

#ifndef _SERVER
	template <typename T0>
	PKT_CS_REQ_MAIL_SEND_WRITE(uchar* buf, int bufSize, const T0* mailDataList)
		:
		mPktWriter(buf, bufSize)

	{
		mPktWriter << static_cast<uint16>(PD::CS::CSPacketId::CS_REQ_MAIL_SEND);
		mMailDataListOffset = (uint16*)mPktWriter.GetBuffer();
		*mMailDataListOffset = 0;
		mPktWriter << (*mMailDataListOffset);
		mMailDataListSize = (uint16*)mPktWriter.GetBuffer();
		*mMailDataListSize = 0;
		mPktWriter << (*mMailDataListSize);
		*mMailDataListOffset = (uint16)mPktWriter.GetPktSize();
		if (mailDataList && 0 < mailDataList->Num())
		{
			int tvalsize = (int)sizeof(*(mailDataList->begin())); 
			auto _mailDataList = (T0*)mailDataList;
			for (auto it = _mailDataList->begin(); it != _mailDataList->end(); ++it) 
			{
				mPktWriter.WriteBinary((uint16)tvalsize, (uchar*)&(*it)); 
			}
			*mMailDataListSize = (uint16)(tvalsize* mailDataList->Num());
		}
	}

#endif // _SERVER
#ifdef _SERVER
	template <typename T0>
	PKT_CS_REQ_MAIL_SEND_WRITE(SendBufferHelper& sendBuffer, const T0* mailDataList)
		:
		mPktWriter(sendBuffer->GetCharBuffer(), (SEND_BUFFER_SIZE - 1))

	{
		static_assert(true == std::is_same_v<T0::value_type, _T0>, "mailDataList type must be MailData list type"); 
		mPktWriter << (uint16)CS_REQ_MAIL_SEND;
		mMailDataListOffset = (uint16*)mPktWriter.GetBuffer();
		*mMailDataListOffset = 0;
		mPktWriter << (*mMailDataListOffset);
		mMailDataListSize = (uint16*)mPktWriter.GetBuffer();
		*mMailDataListSize = 0;
		mPktWriter << (*mMailDataListSize);
		*mMailDataListOffset = (uint16)mPktWriter.GetPktSize();
		if (mailDataList && !mailDataList->empty())
		{
			int tvalsize = (int)sizeof(*(mailDataList->begin())); 
			auto _mailDataList = const_cast<std::decay_t<T0>*>(mailDataList);
			for (auto it = _mailDataList->begin(); it != _mailDataList->end(); ++it) 
			{
				mPktWriter.WriteBinary((uint16)tvalsize, (uchar*)&(*it)); 
			}
			*mMailDataListSize = (uint16) (tvalsize * mailDataList->size());
		}
	}
#endif

#ifdef _SERVER 
	void send(IocpObjectSession* session, SendBufferRef sendBuffer, bool autoCloseSendBuffer)
	{
		if (session) 
			session->Send(sendBuffer, mPktWriter.GetPktSize(), autoCloseSendBuffer);
	}
#endif

#ifdef _SERVER 
	std::xwstring GetLogWString() const
	{
		auto readPacket = reinterpret_cast<PKT_CS_REQ_MAIL_SEND_READ*>(mPktWriter.mBuf);
		return readPacket->GetLogWString();
	}
#endif

#ifndef _SERVER
#else
#endif
}; // PKT_CS_REQ_MAIL_SEND_WRITE

