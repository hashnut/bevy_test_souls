// type = CS
// related packet = PKT_SC_ACK_CRAFT_WRITE
struct PKT_CS_REQ_CRAFT_READ
{
public:
	uint16 mPktSize;
	uint16 mPktId;
	uint16 mMaterialItemListOffset;
	uint16 mMaterialItemListSize;
	CraftId mCraftId;
	ItemAmount mCraftCount;

public:
#ifdef _SERVER 
	using _T0 = ItemDBIdAmountPair;
	bool GetServerTaskIdRealTime(OUT [[maybe_unused]] int& serverTaskId) const { return false; }
	const wchar_t* GetPacketName() const { return L"CS_REQ_CRAFT"; }
	const wchar_t* GetRelatedPacketName() const { return L"SC_ACK_CRAFT"; }
#endif

	CraftId CraftId() { return mCraftId; }
	ItemAmount CraftCount() { return mCraftCount; }
	const uchar* MaterialItemList() const
	{
		uchar* pktStart = (uchar*)this;
		uint16 pktSize = *((uint16*)pktStart);
		if (mMaterialItemListOffset && pktSize > mMaterialItemListOffset)
			return (const uchar*)(pktStart + mMaterialItemListOffset);
		else
			return 0;
	}
	int MaterialItemListSize() const
	{
		return mMaterialItemListSize;
	}
#ifdef _SERVER
	template <typename Container>
	void MakeMaterialItemListVector(Container & container)
	{
		//emplace() ČŁĂâÇŇ¶§¸¶´Ů ¸Ţ¸đ¸®¸¦ »ýĽş ÇĎ´Â şńżëŔĚ ąß»ýÇŃ´Ů şńżëŔ»ÁŮŔĚŔ§°ł reserve()»çżë
		container.reserve(mMaterialItemListSize/sizeof(_T0));
		for (int offset = 0; offset < mMaterialItemListSize; offset += sizeof(_T0))
		{
			const _T0* data = reinterpret_cast<const _T0*>(MaterialItemList() + offset);
			container.emplace_back(*data);
		}
	}
#else // _SERVER
	template <typename Container, typename Data>
	void MakeMaterialItemListVector(Container & container)
	{
		for (int offset = 0; offset < mMaterialItemListSize; offset += sizeof(Data))
		{
			const Data* data = reinterpret_cast<const Data*>(MaterialItemList() + offset);
			container.Add(*data);
		}
	}
#endif // _SERVER
#ifdef _SERVER
	template <typename TFunc>
	void ForEachMaterialItemList(TFunc&& func) const
	{
		for (int offset = 0; offset < MaterialItemListSize(); offset += sizeof(_T0))
		{
			const _T0* data = reinterpret_cast<const _T0*>(MaterialItemList() + offset);
			func(data);
		}
	}
#endif


#ifdef _SERVER 
	std::xwstring GetLogWString() const
	{

		return Log::format(
			L"[CS_REQ_CRAFT] CraftId: {}, CraftCount: {}"
			, mCraftId, mCraftCount
		).c_str();
	}
#endif

	bool Validate()
	{
		uchar* pktStart = (uchar*)this;
		uint16 pktSize = mPktSize;

		uint16 dataSize = sizeof(PKT_CS_REQ_CRAFT_READ);
		if (dataSize > mPktSize)
			return false;

		if (false == ValidateValue(pktStart, pktSize, dataSize))
			return false;

		if (dataSize != mPktSize)
			return false;

		return true;
	}

	bool ValidateValue(const uchar* pktStart, uint16 pktSize, uint16& dataSize)
	{
		if (false == ValidateBinary(mMaterialItemListOffset, mMaterialItemListSize, 0, pktSize, dataSize))
			return false;

		return (nullptr != pktStart && 0 < pktSize && 0 < dataSize) ? true : false;
	}

}; // PKT_CS_REQ_CRAFT_READ

// type = CS
// related packet = PKT_SC_ACK_CRAFT_READ
#ifdef _SERVER
struct PKT_CS_REQ_CRAFT_WRITE : public Disposable
#else
struct PKT_CS_REQ_CRAFT_WRITE
#endif
{
	PktWriter mPktWriter;
	uint16* mMaterialItemListOffset;
	uint16* mMaterialItemListSize;

#ifdef _SERVER 
	using _T0 = ItemDBIdAmountPair;
	bool GetServerTaskIdRealTime(OUT int& serverTaskId) const { return reinterpret_cast<PKT_CS_REQ_CRAFT_READ*>(mPktWriter.mBuf)->GetServerTaskIdRealTime(serverTaskId); }
	const wchar_t* GetPacketName() const { return L"CS_REQ_CRAFT"; }
	const wchar_t* GetRelatedPacketName() const { return L"SC_ACK_CRAFT"; }
#endif

#ifndef _SERVER
	template <typename T0>
	PKT_CS_REQ_CRAFT_WRITE(uchar* buf, int bufSize, CraftId craftId, ItemAmount craftCount, const T0* materialItemList)
		:
		mPktWriter(buf, bufSize)

	{
		mPktWriter << static_cast<uint16>(PD::CS::CSPacketId::CS_REQ_CRAFT);
		mMaterialItemListOffset = (uint16*)mPktWriter.GetBuffer();
		*mMaterialItemListOffset = 0;
		mPktWriter << (*mMaterialItemListOffset);
		mMaterialItemListSize = (uint16*)mPktWriter.GetBuffer();
		*mMaterialItemListSize = 0;
		mPktWriter << (*mMaterialItemListSize);
		mPktWriter << craftId;
		mPktWriter << craftCount;
		*mMaterialItemListOffset = (uint16)mPktWriter.GetPktSize();
		if (materialItemList && 0 < materialItemList->Num())
		{
			int tvalsize = (int)sizeof(*(materialItemList->begin())); 
			auto _materialItemList = (T0*)materialItemList;
			for (auto it = _materialItemList->begin(); it != _materialItemList->end(); ++it) 
			{
				mPktWriter.WriteBinary((uint16)tvalsize, (uchar*)&(*it)); 
			}
			*mMaterialItemListSize = (uint16)(tvalsize* materialItemList->Num());
		}
	}

#endif // _SERVER
#ifdef _SERVER
	template <typename T0>
	PKT_CS_REQ_CRAFT_WRITE(SendBufferHelper& sendBuffer, CraftId craftId, ItemAmount craftCount, const T0* materialItemList)
		:
		mPktWriter(sendBuffer->GetCharBuffer(), (SEND_BUFFER_SIZE - 1))

	{
		static_assert(true == std::is_same_v<T0::value_type, _T0>, "materialItemList type must be ItemDBIdAmountPair list type"); 
		mPktWriter << (uint16)CS_REQ_CRAFT;
		mMaterialItemListOffset = (uint16*)mPktWriter.GetBuffer();
		*mMaterialItemListOffset = 0;
		mPktWriter << (*mMaterialItemListOffset);
		mMaterialItemListSize = (uint16*)mPktWriter.GetBuffer();
		*mMaterialItemListSize = 0;
		mPktWriter << (*mMaterialItemListSize);
		mPktWriter << craftId;
		mPktWriter << craftCount;
		*mMaterialItemListOffset = (uint16)mPktWriter.GetPktSize();
		if (materialItemList && !materialItemList->empty())
		{
			int tvalsize = (int)sizeof(*(materialItemList->begin())); 
			auto _materialItemList = const_cast<std::decay_t<T0>*>(materialItemList);
			for (auto it = _materialItemList->begin(); it != _materialItemList->end(); ++it) 
			{
				mPktWriter.WriteBinary((uint16)tvalsize, (uchar*)&(*it)); 
			}
			*mMaterialItemListSize = (uint16) (tvalsize * materialItemList->size());
		}
	}
#endif

#ifdef _SERVER 
	void send(IocpObjectSession* session, SendBufferRef sendBuffer, bool autoCloseSendBuffer)
	{
		if (session) 
			session->Send(sendBuffer, mPktWriter.GetPktSize(), autoCloseSendBuffer);
	}
#endif

#ifdef _SERVER 
	std::xwstring GetLogWString() const
	{
		auto readPacket = reinterpret_cast<PKT_CS_REQ_CRAFT_READ*>(mPktWriter.mBuf);
		return readPacket->GetLogWString();
	}
#endif

#ifndef _SERVER
#else
#endif
}; // PKT_CS_REQ_CRAFT_WRITE

