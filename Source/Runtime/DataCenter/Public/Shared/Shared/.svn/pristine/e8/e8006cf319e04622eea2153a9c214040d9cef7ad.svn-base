// type = CS
struct PKT_CS_REQ_BONUS_STAT_INCREASE_READ
{
public:
	uint16 mPktSize;
	uint16 mPktId;
	uint16 mBonusStatListDeltaOffset;
	uint16 mBonusStatListDeltaSize;

public:
#ifdef _SERVER 
	using _T0 = StatInfo;
	bool GetServerTaskIdRealTime(OUT [[maybe_unused]] int& serverTaskId) const { return false; }
	const wchar_t* GetPacketName() const { return L"CS_REQ_BONUS_STAT_INCREASE"; }
	const wchar_t* GetRelatedPacketName() const { return L"SC_ACK_BONUS_STAT_INCREASE"; }
#endif

	const uchar* BonusStatListDelta() const
	{
		uchar* pktStart = (uchar*)this;
		uint16 pktSize = *((uint16*)pktStart);
		if (mBonusStatListDeltaOffset && pktSize > mBonusStatListDeltaOffset)
			return (const uchar*)(pktStart + mBonusStatListDeltaOffset);
		else
			return 0;
	}
	int BonusStatListDeltaSize() const
	{
		return mBonusStatListDeltaSize;
	}
#ifdef _SERVER
	template <typename Container>
	void MakeBonusStatListDeltaVector(Container & container)
	{
		//emplace() ČŁĂâÇŇ¶§¸¶´Ů ¸Ţ¸đ¸®¸¦ »ýĽş ÇĎ´Â şńżëŔĚ ąß»ýÇŃ´Ů şńżëŔ»ÁŮŔĚŔ§°ł reserve()»çżë
		container.reserve(mBonusStatListDeltaSize/sizeof(_T0));
		for (int offset = 0; offset < mBonusStatListDeltaSize; offset += sizeof(_T0))
		{
			const _T0* data = reinterpret_cast<const _T0*>(BonusStatListDelta() + offset);
			container.emplace_back(*data);
		}
	}
