			auto _materialFairyIdAmountList = (T0*)materialFairyIdAmountList;
			for (auto it = _materialFairyIdAmountList->begin(); it != _materialFairyIdAmountList->end(); ++it) 
			{
				mPktWriter.WriteBinary((uint16)tvalsize, (uchar*)&(*it)); 
			}
			*mMaterialFairyIdAmountListSize = (uint16)(tvalsize* materialFairyIdAmountList->Num());
