#ifdef _SERVER
struct PKT_CS_REQ_MOVE_INVENTORY_ITEM_TO_DEPOT_WRITE : public Disposable
#else
struct PKT_CS_REQ_MOVE_INVENTORY_ITEM_TO_DEPOT_WRITE
#endif
{
	PktWriter mPktWriter;
	uint16* mMoveItemsOffset;
	uint16* mMoveItemsSize;

#ifdef _SERVER 
	using _T0 = ItemDBIdAmountPair;
	bool GetServerTaskIdRealTime(OUT int& serverTaskId) const { return reinterpret_cast<PKT_CS_REQ_MOVE_INVENTORY_ITEM_TO_DEPOT_READ*>(mPktWriter.mBuf)->GetServerTaskIdRealTime(serverTaskId); }
	const wchar_t* GetPacketName() const { return L"CS_REQ_MOVE_INVENTORY_ITEM_TO_DEPOT"; }
	const wchar_t* GetRelatedPacketName() const { return L"SC_ACK_MOVE_INVENTORY_ITEM_TO_DEPOT"; }
#endif

#ifndef _SERVER
	template <typename T0>
	PKT_CS_REQ_MOVE_INVENTORY_ITEM_TO_DEPOT_WRITE(uchar* buf, int bufSize, CreatureId npcId, const T0* moveItems, FVector currPos, int16 currDir)
		:
		mPktWriter(buf, bufSize)

	{
		mPktWriter << static_cast<uint16>(PD::CS::CSPacketId::CS_REQ_MOVE_INVENTORY_ITEM_TO_DEPOT);
		mMoveItemsOffset = (uint16*)mPktWriter.GetBuffer();
		*mMoveItemsOffset = 0;
		mPktWriter << (*mMoveItemsOffset);
		mMoveItemsSize = (uint16*)mPktWriter.GetBuffer();
		*mMoveItemsSize = 0;
		mPktWriter << (*mMoveItemsSize);
		mPktWriter << npcId;
		mPktWriter << currPos;
		mPktWriter << currDir;
		*mMoveItemsOffset = (uint16)mPktWriter.GetPktSize();
		if (moveItems && 0 < moveItems->Num())
		{
			int tvalsize = (int)sizeof(*(moveItems->begin())); 
			auto _moveItems = (T0*)moveItems;
			for (auto it = _moveItems->begin(); it != _moveItems->end(); ++it) 
			{
				mPktWriter.WriteBinary((uint16)tvalsize, (uchar*)&(*it)); 
			}
			*mMoveItemsSize = (uint16)(tvalsize* moveItems->Num());
		}
	}

#endif // _SERVER
#ifdef _SERVER
	template <typename T0>
	PKT_CS_REQ_MOVE_INVENTORY_ITEM_TO_DEPOT_WRITE(SendBufferHelper& sendBuffer, CreatureId npcId, const T0* moveItems, const FVector& currPos, int16 currDir)
		:
		mPktWriter(sendBuffer->GetCharBuffer(), (SEND_BUFFER_SIZE - 1))

	{
		static_assert(true == std::is_same_v<T0::value_type, _T0>, "moveItems type must be ItemDBIdAmountPair list type"); 
		mPktWriter << (uint16)CS_REQ_MOVE_INVENTORY_ITEM_TO_DEPOT;
		mMoveItemsOffset = (uint16*)mPktWriter.GetBuffer();
		*mMoveItemsOffset = 0;
		mPktWriter << (*mMoveItemsOffset);
		mMoveItemsSize = (uint16*)mPktWriter.GetBuffer();
		*mMoveItemsSize = 0;
		mPktWriter << (*mMoveItemsSize);
		mPktWriter << npcId;
		mPktWriter << currPos;
		mPktWriter << currDir;
		*mMoveItemsOffset = (uint16)mPktWriter.GetPktSize();
		if (moveItems && !moveItems->empty())
		{
			int tvalsize = (int)sizeof(*(moveItems->begin())); 
			auto _moveItems = const_cast<std::decay_t<T0>*>(moveItems);
			for (auto it = _moveItems->begin(); it != _moveItems->end(); ++it) 
			{
				mPktWriter.WriteBinary((uint16)tvalsize, (uchar*)&(*it)); 
			}
			*mMoveItemsSize = (uint16) (tvalsize * moveItems->size());
		}
	}
#endif

#ifdef _SERVER 
	void send(IocpObjectSession* session, SendBufferRef sendBuffer, bool autoCloseSendBuffer)
	{
		if (session) 
			session->Send(sendBuffer, mPktWriter.GetPktSize(), autoCloseSendBuffer);
	}
#endif

#ifdef _SERVER 
	std::xwstring GetLogWString() const
	{
		auto readPacket = reinterpret_cast<PKT_CS_REQ_MOVE_INVENTORY_ITEM_TO_DEPOT_READ*>(mPktWriter.mBuf);
		return readPacket->GetLogWString();
	}
#endif

#ifndef _SERVER
#else
#endif
}; // PKT_CS_REQ_MOVE_INVENTORY_ITEM_TO_DEPOT_WRITE

