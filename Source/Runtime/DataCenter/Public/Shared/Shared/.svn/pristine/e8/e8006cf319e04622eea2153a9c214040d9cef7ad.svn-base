			func(data);
		}
	}
#endif


#ifdef _SERVER 
	std::xwstring GetLogWString() const
	{
		auto MaterialFairyIdAmountListListLogFunc = [this]() -> std::xwstring
		{
			std::xwstring result;
			result.append(L"\n");
			for (int offset = 0; offset < MaterialFairyIdAmountListSize(); offset += sizeof(struct FairyIdAmountPair))
			{
				const struct FairyIdAmountPair* data = reinterpret_cast<const struct FairyIdAmountPair*>(MaterialFairyIdAmountList() + offset);
				result.append(Log::format(L"{}", *data));
				result.append(L"\n");
			}
			return result;
		};

		std::wstringstream MaterialCountListStream; 
		MaterialCountListStream << std::endl;
		ForEachMaterialCountList(
			[&MaterialCountListStream](const uint8* Id) {
				MaterialCountListStream << "[" << static_cast<size_t>(*Id) << "]" << std::endl;
				}
			);


		return Log::format(
			L"[CS_REQ_FAIRY_COMPOSE] MaterialFairyIdAmountList: {}, MaterialCountList: {}"
			, MaterialFairyIdAmountListListLogFunc().c_str(), MaterialCountListStream.str().c_str()
		).c_str();
	}
