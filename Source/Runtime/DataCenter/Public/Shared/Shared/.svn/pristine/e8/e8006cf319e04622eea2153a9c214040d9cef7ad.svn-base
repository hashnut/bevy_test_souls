// type = CS
// related packet = PKT_SC_ACK_QUICK_SLOT_SET_WRITE
struct PKT_CS_REQ_QUICK_SLOT_SET_READ
{
	struct QuickSlotSetList
	{
	protected:
		uint16 mThisOffset;
		uint16 mNextOffset;
		QuickSlotId mQuickSlotId;
		ItemDBId mItemDBId;
		ItemId mItemId;

	public:
		QuickSlotId QuickSlotId() { return mQuickSlotId; }
		ItemDBId ItemDBId() { return mItemDBId; }
		ItemId ItemId() { return mItemId; }

		friend PktIterator<QuickSlotSetList>;
		friend PKT_CS_REQ_QUICK_SLOT_SET_READ;

		bool Validate(uint16 offset, uchar * pktStart, uint16 pktSize, uint16& dataSize)
		{
			if (static_cast<size_t>(pktSize) < static_cast<size_t>(offset) + sizeof(QuickSlotSetList))
				return false;

			QuickSlotSetList * node = (QuickSlotSetList*)(pktStart + offset);

			// ŔÚ±â ŔÚ˝ĹŔÇ Ć÷ŔÎĹÍ °ËÁő
			if (offset != node->mThisOffset)
				return false;

			// Value °ËÁő
			uchar* pktCurrentNodeStart = (uchar*)this - mThisOffset;
			uint16 pktCurrentNodeSize = *((uint16*)pktStart);
			dataSize += sizeof(QuickSlotSetList);	// skip
			if (false == ValidateValue(pktCurrentNodeStart, pktCurrentNodeSize, dataSize))
				return false;

			return true;
		}

		bool ValidateValue(const uchar* pktStart, uint16 pktSize, uint16& dataSize)
		{
			return (nullptr != pktStart && 0 < pktSize && 0 < dataSize) ? true : false;
		}

	}; // QuickSlotSetList

public:
	uint16 mPktSize;
	uint16 mPktId;
	uint16 mQuickSlotSetListCount;
	uint16 mFirstQuickSlotSetListOffset;

public:
#ifdef _SERVER 
	bool GetServerTaskIdRealTime(OUT [[maybe_unused]] int& serverTaskId) const { return false; }
	const wchar_t* GetPacketName() const { return L"CS_REQ_QUICK_SLOT_SET"; }
	const wchar_t* GetRelatedPacketName() const { return L"SC_ACK_QUICK_SLOT_SET"; }
#endif


	using QuickSlotSetListIterator = PktIterator<QuickSlotSetList>;
	const QuickSlotSetListIterator GetLastQuickSlotSetListIterator() const
	{
		return QuickSlotSetListIterator(0);
	}
	QuickSlotSetListIterator GetFirstQuickSlotSetListIterator() const
	{
		if (mFirstQuickSlotSetListOffset && mPktSize >= mFirstQuickSlotSetListOffset + sizeof(QuickSlotSetList))
		{
			QuickSlotSetList* quickSlotSetList = (QuickSlotSetList*)((uchar*)this + mFirstQuickSlotSetListOffset);
			if (mFirstQuickSlotSetListOffset == quickSlotSetList->mThisOffset)
				return QuickSlotSetListIterator(quickSlotSetList);
			else
				return QuickSlotSetListIterator(0);
		}
		else
			return QuickSlotSetListIterator(0);
	}
	const int GetQuickSlotSetListCount()
	{
		return mQuickSlotSetListCount;
	}
#ifdef _SERVER
	template<typename TFunc>
	void ForEachQuickSlotSetList(TFunc&& func)
	{
		for (auto it = GetFirstQuickSlotSetListIterator(); it != GetLastQuickSlotSetListIterator(); ++it)
			func(it);
	}
#endif


#ifdef _SERVER 
	std::xwstring FuncCreateQuickSlotSetListStr( [[maybe_unused]] QuickSlotSetListIterator& iter) const
	{
		return Log::format(
			L"QuickSlotId: {}, ItemDBId: {}, ItemId: {}", 
			iter->QuickSlotId(), iter->ItemDBId(), iter->ItemId()
		).c_str();
	}

	std::xwstring GetLogWString() const
	{
		std::xwstring str1;
		str1.append(L"\n");
		for (QuickSlotSetListIterator iter = this->GetFirstQuickSlotSetListIterator();
			iter != GetLastQuickSlotSetListIterator(); ++iter)
		{
			str1.append(L"[");
			str1.append(FuncCreateQuickSlotSetListStr(iter).c_str());

			str1.append(L"]\n");
		}

		return Log::format(
			L"[CS_REQ_QUICK_SLOT_SET] QuickSlotSetList : {}"
			, str1.c_str()
		).c_str();
	}
#endif

	bool Validate()
	{
		uchar* pktStart = (uchar*)this;
		uint16 pktSize = mPktSize;

		uint16 dataSize = sizeof(PKT_CS_REQ_QUICK_SLOT_SET_READ);
		if (dataSize > mPktSize)
			return false;

		if (false == ValidateValue(pktStart, pktSize, dataSize))
			return false;

		if (false == QuickSlotSetListValidateListNode(mFirstQuickSlotSetListOffset, pktStart, pktSize, dataSize))
			return false;

		if (dataSize != mPktSize)
			return false;

		return true;
	}

	bool QuickSlotSetListValidateListNode(uint16 offset, uchar * pktStart, uint16 pktSize, uint16& dataSize)
	{		for (QuickSlotSetListIterator iter = this->GetFirstQuickSlotSetListIterator();
			iter != GetLastQuickSlotSetListIterator(); ++iter)
		{
			if (false == (*iter).Validate(offset, pktStart, pktSize, dataSize))
			{
				return false;
			}
		}
		return true;
	}

	bool ValidateValue(const uchar* pktStart, uint16 pktSize, uint16& dataSize)
	{
		return (nullptr != pktStart && 0 < pktSize && 0 < dataSize) ? true : false;
	}

}; // PKT_CS_REQ_QUICK_SLOT_SET_READ

