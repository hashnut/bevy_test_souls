		mPktWriter << (*mMaterialCountListOffset);
		mMaterialCountListSize = (uint16*)mPktWriter.GetBuffer();
		*mMaterialCountListSize = 0;
		mPktWriter << (*mMaterialCountListSize);
		*mMaterialFairyIdAmountListOffset = (uint16)mPktWriter.GetPktSize();
		if (materialFairyIdAmountList && 0 < materialFairyIdAmountList->Num())
		{
