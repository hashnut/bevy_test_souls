	{
		uchar* pktStart = (uchar*)this;
		uint16 pktSize = *((uint16*)pktStart);
		if (mPurchase_bypass_infoOffset && pktSize > mPurchase_bypass_infoOffset)
			return (const uchar*)(pktStart + mPurchase_bypass_infoOffset);
