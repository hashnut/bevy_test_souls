// type = CS
// related packet = PKT_SC_ACK_SEAL_SLOT_LOCK_SAVE_WRITE
struct PKT_CS_REQ_SEAL_SLOT_LOCK_SAVE_READ
{
	struct SealSlotLockList
	{
	protected:
		uint16 mThisOffset;
		uint16 mNextOffset;
		SealSlotId mSealSlotId;
		bool mIsStatLock;
		bool mIsColorLock;

	public:
		const SealSlotId& ConstRefSealSlotId() { return mSealSlotId; }
		SealSlotId SealSlotId() { return mSealSlotId; }
		bool IsStatLock() { return mIsStatLock; }
		bool IsColorLock() { return mIsColorLock; }

		friend PktIterator<SealSlotLockList>;
		friend PKT_CS_REQ_SEAL_SLOT_LOCK_SAVE_READ;

		bool Validate(uint16 offset, uchar * pktStart, uint16 pktSize, uint16& dataSize)
		{
			if (static_cast<size_t>(pktSize) < static_cast<size_t>(offset) + sizeof(SealSlotLockList))
				return false;

			SealSlotLockList * node = (SealSlotLockList*)(pktStart + offset);

			// ŔÚ±â ŔÚ˝ĹŔÇ Ć÷ŔÎĹÍ °ËÁő
			if (offset != node->mThisOffset)
				return false;

			// Value °ËÁő
			uchar* pktCurrentNodeStart = (uchar*)this - mThisOffset;
			uint16 pktCurrentNodeSize = *((uint16*)pktStart);
			dataSize += sizeof(SealSlotLockList);	// skip
			if (false == ValidateValue(pktCurrentNodeStart, pktCurrentNodeSize, dataSize))
				return false;

			return true;
		}

		bool ValidateValue(const uchar* pktStart, uint16 pktSize, uint16& dataSize)
		{
			return (nullptr != pktStart && 0 < pktSize && 0 < dataSize) ? true : false;
		}

	}; // SealSlotLockList

public:
	uint16 mPktSize;
	uint16 mPktId;
	uint16 mSealSlotLockListCount;
	uint16 mFirstSealSlotLockListOffset;

public:
#ifdef _SERVER 
	bool GetServerTaskIdRealTime(OUT [[maybe_unused]] int& serverTaskId) const { return false; }
	const wchar_t* GetPacketName() const { return L"CS_REQ_SEAL_SLOT_LOCK_SAVE"; }
	const wchar_t* GetRelatedPacketName() const { return L"SC_ACK_SEAL_SLOT_LOCK_SAVE"; }
#endif


	using SealSlotLockListIterator = PktIterator<SealSlotLockList>;
	const SealSlotLockListIterator GetLastSealSlotLockListIterator() const
	{
		return SealSlotLockListIterator(0);
	}
	SealSlotLockListIterator GetFirstSealSlotLockListIterator() const
	{
		if (mFirstSealSlotLockListOffset && mPktSize >= mFirstSealSlotLockListOffset + sizeof(SealSlotLockList))
		{
			SealSlotLockList* sealSlotLockList = (SealSlotLockList*)((uchar*)this + mFirstSealSlotLockListOffset);
			if (mFirstSealSlotLockListOffset == sealSlotLockList->mThisOffset)
				return SealSlotLockListIterator(sealSlotLockList);
			else
				return SealSlotLockListIterator(0);
		}
		else
			return SealSlotLockListIterator(0);
	}
	const int GetSealSlotLockListCount()
	{
		return mSealSlotLockListCount;
	}
#ifdef _SERVER
	template<typename TFunc>
	void ForEachSealSlotLockList(TFunc&& func)
	{
		for (auto it = GetFirstSealSlotLockListIterator(); it != GetLastSealSlotLockListIterator(); ++it)
			func(it);
	}
#endif


#ifdef _SERVER 
	std::xwstring FuncCreateSealSlotLockListStr( [[maybe_unused]] SealSlotLockListIterator& iter) const
	{
		return Log::format(
			L"SealSlotId: {}, IsStatLock: {}, IsColorLock: {}", 
			iter->SealSlotId(), iter->IsStatLock(), iter->IsColorLock()
		).c_str();
	}

	std::xwstring GetLogWString() const
	{
		std::xwstring str1;
		str1.append(L"\n");
		for (SealSlotLockListIterator iter = this->GetFirstSealSlotLockListIterator();
			iter != GetLastSealSlotLockListIterator(); ++iter)
		{
			str1.append(L"[");
			str1.append(FuncCreateSealSlotLockListStr(iter).c_str());

			str1.append(L"]\n");
		}

		return Log::format(
			L"[CS_REQ_SEAL_SLOT_LOCK_SAVE] SealSlotLockList : {}"
			, str1.c_str()
		).c_str();
	}
#endif

	bool Validate()
	{
		uchar* pktStart = (uchar*)this;
		uint16 pktSize = mPktSize;

		uint16 dataSize = sizeof(PKT_CS_REQ_SEAL_SLOT_LOCK_SAVE_READ);
		if (dataSize > mPktSize)
			return false;

		if (false == ValidateValue(pktStart, pktSize, dataSize))
			return false;

		if (false == SealSlotLockListValidateListNode(mFirstSealSlotLockListOffset, pktStart, pktSize, dataSize))
			return false;

		if (dataSize != mPktSize)
			return false;

		return true;
	}

	bool SealSlotLockListValidateListNode(uint16 offset, uchar * pktStart, uint16 pktSize, uint16& dataSize)
	{		for (SealSlotLockListIterator iter = this->GetFirstSealSlotLockListIterator();
			iter != GetLastSealSlotLockListIterator(); ++iter)
		{
			if (false == (*iter).Validate(offset, pktStart, pktSize, dataSize))
			{
				return false;
			}
		}
		return true;
	}

	bool ValidateValue(const uchar* pktStart, uint16 pktSize, uint16& dataSize)
	{
		return (nullptr != pktStart && 0 < pktSize && 0 < dataSize) ? true : false;
	}

}; // PKT_CS_REQ_SEAL_SLOT_LOCK_SAVE_READ

