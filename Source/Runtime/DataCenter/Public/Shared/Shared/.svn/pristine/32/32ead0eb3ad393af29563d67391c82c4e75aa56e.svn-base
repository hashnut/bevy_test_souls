// type = GC
struct PKT_GC_PONG_READ
{
public:
	uint16 mPktSize;
	uint16 mPktId;
	uint32 mPingPongSeq;

public:
#ifdef _SERVER 
	bool GetServerTaskIdRealTime(OUT [[maybe_unused]] int& serverTaskId) const { return false; }
	const wchar_t* GetPacketName() const { return L"GC_PONG"; }
	const wchar_t* GetRelatedPacketName() const { return L"CG_PONG"; }
#endif

	uint32 PingPongSeq() { return mPingPongSeq; }


#ifdef _SERVER 
	std::xwstring GetLogWString() const
	{

		return Log::format(
			L"[GC_PONG] PingPongSeq: {}"
			, mPingPongSeq
		).c_str();
	}
#endif

	bool Validate()
	{
		uchar* pktStart = (uchar*)this;
		uint16 pktSize = mPktSize;

		uint16 dataSize = sizeof(PKT_GC_PONG_READ);
		if (dataSize > mPktSize)
			return false;

		if (false == ValidateValue(pktStart, pktSize, dataSize))
			return false;

		if (dataSize != mPktSize)
			return false;

		return true;
	}

	bool ValidateValue(const uchar* pktStart, uint16 pktSize, uint16& dataSize)
	{
		return (nullptr != pktStart && 0 < pktSize && 0 < dataSize) ? true : false;
	}

}; // PKT_GC_PONG_READ

// type = GC
#ifdef _SERVER
struct PKT_GC_PONG_WRITE : public Disposable
#else
struct PKT_GC_PONG_WRITE
#endif
{
	PktWriter mPktWriter;

#ifdef _SERVER 
	bool GetServerTaskIdRealTime(OUT int& serverTaskId) const { return reinterpret_cast<PKT_GC_PONG_READ*>(mPktWriter.mBuf)->GetServerTaskIdRealTime(serverTaskId); }
	const wchar_t* GetPacketName() const { return L"GC_PONG"; }
	const wchar_t* GetRelatedPacketName() const { return L"CG_PONG"; }
#endif

#ifndef _SERVER
	PKT_GC_PONG_WRITE(uchar* buf, int bufSize, uint32 pingPongSeq)
		:
		mPktWriter(buf, bufSize)

	{
		mPktWriter << static_cast<uint16>(PD::GC::GCPacketId::GC_PONG);
		mPktWriter << pingPongSeq;
	}

#endif // _SERVER
#ifdef _SERVER
	PKT_GC_PONG_WRITE(SendBufferHelper& sendBuffer, uint32 pingPongSeq)
		:
		mPktWriter(sendBuffer->GetCharBuffer(), (SEND_BUFFER_SIZE - 1))

	{
		mPktWriter << (uint16)GC_PONG;
		mPktWriter << pingPongSeq;
	}
#endif

#ifdef _SERVER 
	void send(IocpObjectSession* session, SendBufferRef sendBuffer, bool autoCloseSendBuffer)
	{
		if (session) 
			session->Send(sendBuffer, mPktWriter.GetPktSize(), autoCloseSendBuffer);
	}
#endif

#ifdef _SERVER 
	std::xwstring GetLogWString() const
	{
		auto readPacket = reinterpret_cast<PKT_GC_PONG_READ*>(mPktWriter.mBuf);
		return readPacket->GetLogWString();
	}
#endif

#ifndef _SERVER
#else
#endif
}; // PKT_GC_PONG_WRITE

