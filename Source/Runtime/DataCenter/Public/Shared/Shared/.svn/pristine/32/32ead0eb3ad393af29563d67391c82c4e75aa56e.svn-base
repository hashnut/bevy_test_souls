		uint16 nowWritten = (uint16)mPktWriter.GetPktSize();
		PartyMemberInfoList* newPartyMemberInfoList = new ((PartyMemberInfoList*)nowBuffer) PartyMemberInfoList(nowWritten, slotIndex, gameId, mapId, channelId, pos, weaponType, level, hp, hpShield, maxHp, mp, maxMp, isReady, memberWorldId, memberHomeWorldId);
		++(*mPartyMemberInfoListCount);
