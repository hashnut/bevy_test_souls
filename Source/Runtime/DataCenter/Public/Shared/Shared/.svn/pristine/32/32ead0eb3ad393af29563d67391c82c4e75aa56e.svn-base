// type = GC
// related packet = PKT_CG_REQ_GUILD_GROUP_CHAT_LIST_WRITE
struct PKT_GC_ACK_GUILD_GROUP_CHAT_LIST_READ
{
	struct GroupList
	{
	protected:
		uint16 mThisOffset;
		uint16 mNextOffset;
		uint16 mRoomNameOffset;
		GuildGroupChatRoomId mRoomId;
		int mGuildCount;
		uint8 mChatGrade;
		GuildDBId mLeaderGuildId;

	public:
		const GuildGroupChatRoomId& ConstRefRoomId() { return mRoomId; }
		GuildGroupChatRoomId RoomId() { return mRoomId; }
		int GuildCount() { return mGuildCount; }
		uint8 ChatGrade() { return mChatGrade; }
		GuildDBId LeaderGuildId() { return mLeaderGuildId; }

#ifdef _SERVER
		const wchar_t* RoomName()
		{
			uchar* pktStart = (uchar*)this - mThisOffset;
			uint16 pktSize = *((uint16*)pktStart);
			if (mRoomNameOffset && pktSize > mRoomNameOffset)
				return (const wchar_t*)(pktStart + mRoomNameOffset);
			else
				return L"";
		}
#else // _SERVER
		const FString RoomName()
		{
			const wchar_t* strWchar = L"";
			uchar* pktStart = (uchar*)this - mThisOffset;
			uint16 pktSize = *((uint16*)pktStart);
			if (mRoomNameOffset && pktSize > mRoomNameOffset)
				strWchar = (const wchar_t*)(pktStart + mRoomNameOffset);
			return PktWriter::ConvertToFString(strWchar);
		}
#endif // _SERVER
		friend PktIterator<GroupList>;
		friend PKT_GC_ACK_GUILD_GROUP_CHAT_LIST_READ;

		bool Validate(uint16 offset, uchar * pktStart, uint16 pktSize, uint16& dataSize)
		{
			if (static_cast<size_t>(pktSize) < static_cast<size_t>(offset) + sizeof(GroupList))
				return false;

			GroupList * node = (GroupList*)(pktStart + offset);

			// ŔÚ±â ŔÚ˝ĹŔÇ Ć÷ŔÎĹÍ °ËÁő
			if (offset != node->mThisOffset)
				return false;

			// Value °ËÁő
			uchar* pktCurrentNodeStart = (uchar*)this - mThisOffset;
			uint16 pktCurrentNodeSize = *((uint16*)pktStart);
			dataSize += sizeof(GroupList);	// skip
			if (false == ValidateValue(pktCurrentNodeStart, pktCurrentNodeSize, dataSize))
				return false;

			return true;
		}

		bool ValidateValue(const uchar* pktStart, uint16 pktSize, uint16& dataSize)
		{
			if (false == ValidateString(mRoomNameOffset, 0, pktStart, pktSize, dataSize))
				return false;

			return (nullptr != pktStart && 0 < pktSize && 0 < dataSize) ? true : false;
		}

	}; // GroupList

public:
	uint16 mPktSize;
	uint16 mPktId;
	uint16 mGroupListCount;
	uint16 mFirstGroupListOffset;

public:
#ifdef _SERVER 
	bool GetServerTaskIdRealTime(OUT [[maybe_unused]] int& serverTaskId) const { return false; }
	const wchar_t* GetPacketName() const { return L"GC_ACK_GUILD_GROUP_CHAT_LIST"; }
	const wchar_t* GetRelatedPacketName() const { return L"CG_REQ_GUILD_GROUP_CHAT_LIST"; }
#endif


	using GroupListIterator = PktIterator<GroupList>;
	const GroupListIterator GetLastGroupListIterator() const
	{
		return GroupListIterator(0);
	}
	GroupListIterator GetFirstGroupListIterator() const
	{
		if (mFirstGroupListOffset && mPktSize >= mFirstGroupListOffset + sizeof(GroupList))
		{
			GroupList* groupList = (GroupList*)((uchar*)this + mFirstGroupListOffset);
			if (mFirstGroupListOffset == groupList->mThisOffset)
				return GroupListIterator(groupList);
			else
				return GroupListIterator(0);
		}
		else
			return GroupListIterator(0);
	}
	const int GetGroupListCount()
	{
		return mGroupListCount;
	}
#ifdef _SERVER
	template<typename TFunc>
	void ForEachGroupList(TFunc&& func)
	{
		for (auto it = GetFirstGroupListIterator(); it != GetLastGroupListIterator(); ++it)
			func(it);
	}
#endif


#ifdef _SERVER 
	std::xwstring FuncCreateGroupListStr( [[maybe_unused]] GroupListIterator& iter) const
	{
		return Log::format(
			L"RoomId: {}, RoomName: {}, GuildCount: {}, ChatGrade: {}, LeaderGuildId: {}", 
			iter->RoomId(), iter->RoomName(), iter->GuildCount(), iter->ChatGrade(), iter->LeaderGuildId()
		).c_str();
	}

	std::xwstring GetLogWString() const
	{
		std::xwstring str1;
		str1.append(L"\n");
		for (GroupListIterator iter = this->GetFirstGroupListIterator();
			iter != GetLastGroupListIterator(); ++iter)
		{
			str1.append(L"[");
			str1.append(FuncCreateGroupListStr(iter).c_str());

			str1.append(L"]\n");
		}

		return Log::format(
			L"[GC_ACK_GUILD_GROUP_CHAT_LIST] GroupList : {}"
			, str1.c_str()
		).c_str();
	}
#endif

	bool Validate()
	{
		uchar* pktStart = (uchar*)this;
		uint16 pktSize = mPktSize;

		uint16 dataSize = sizeof(PKT_GC_ACK_GUILD_GROUP_CHAT_LIST_READ);
		if (dataSize > mPktSize)
			return false;

		if (false == ValidateValue(pktStart, pktSize, dataSize))
			return false;

		if (false == GroupListValidateListNode(mFirstGroupListOffset, pktStart, pktSize, dataSize))
			return false;

		if (dataSize != mPktSize)
			return false;

		return true;
	}

	bool GroupListValidateListNode(uint16 offset, uchar * pktStart, uint16 pktSize, uint16& dataSize)
	{		for (GroupListIterator iter = this->GetFirstGroupListIterator();
			iter != GetLastGroupListIterator(); ++iter)
		{
			if (false == (*iter).Validate(offset, pktStart, pktSize, dataSize))
			{
				return false;
			}
		}
		return true;
	}

	bool ValidateValue(const uchar* pktStart, uint16 pktSize, uint16& dataSize)
	{
		return (nullptr != pktStart && 0 < pktSize && 0 < dataSize) ? true : false;
	}

}; // PKT_GC_ACK_GUILD_GROUP_CHAT_LIST_READ

