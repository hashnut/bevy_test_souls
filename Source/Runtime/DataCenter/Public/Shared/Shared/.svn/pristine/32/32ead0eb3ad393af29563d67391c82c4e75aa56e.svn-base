	WorldId WorldId() { return mWorldId; }
	float MyPercentRank() { return mMyPercentRank; }
	uint64 MyParam1() { return mMyParam1; }
	uint64 MyParam2() { return mMyParam2; }

	using RankListIterator = PktIterator<RankList>;
	const RankListIterator GetLastRankListIterator() const
	{
		return RankListIterator(0);
	}
	RankListIterator GetFirstRankListIterator() const
	{
		if (mFirstRankListOffset && mPktSize >= mFirstRankListOffset + sizeof(RankList))
		{
			RankList* rankList = (RankList*)((uchar*)this + mFirstRankListOffset);
			if (mFirstRankListOffset == rankList->mThisOffset)
				return RankListIterator(rankList);
			else
				return RankListIterator(0);
		}
		else
			return RankListIterator(0);
	}
