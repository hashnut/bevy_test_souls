// type = GC
// related packet = PKT_CG_REQ_WDMARKET_SALES_ITEM_LIST_WRITE
struct PKT_GC_ACK_WDMARKET_SALES_ITEM_LIST_READ
{
	struct SalesItemList
	{
	protected:
		uint16 mThisOffset;
		uint16 mNextOffset;
		ItemId mItemId;
		MarketPrice mLowestPrice;
		uint16 mSalesCount;

	public:
		ItemId ItemId() { return mItemId; }
		MarketPrice LowestPrice() { return mLowestPrice; }
		uint16 SalesCount() { return mSalesCount; }

		friend PktIterator<SalesItemList>;
		friend PKT_GC_ACK_WDMARKET_SALES_ITEM_LIST_READ;

		bool Validate(uint16 offset, uchar * pktStart, uint16 pktSize, uint16& dataSize)
		{
			if (static_cast<size_t>(pktSize) < static_cast<size_t>(offset) + sizeof(SalesItemList))
				return false;

			SalesItemList * node = (SalesItemList*)(pktStart + offset);

			// ŔÚ±â ŔÚ˝ĹŔÇ Ć÷ŔÎĹÍ °ËÁő
			if (offset != node->mThisOffset)
				return false;

			// Value °ËÁő
			uchar* pktCurrentNodeStart = (uchar*)this - mThisOffset;
			uint16 pktCurrentNodeSize = *((uint16*)pktStart);
			dataSize += sizeof(SalesItemList);	// skip
			if (false == ValidateValue(pktCurrentNodeStart, pktCurrentNodeSize, dataSize))
				return false;

			return true;
		}

		bool ValidateValue(const uchar* pktStart, uint16 pktSize, uint16& dataSize)
		{
			return (nullptr != pktStart && 0 < pktSize && 0 < dataSize) ? true : false;
		}

	}; // SalesItemList

public:
	uint16 mPktSize;
	uint16 mPktId;
	uint16 mSalesItemListCount;
	uint16 mFirstSalesItemListOffset;
	int mResult;
	MarketCategory mMarketCategory;

public:
#ifdef _SERVER 
	bool GetServerTaskIdRealTime(OUT [[maybe_unused]] int& serverTaskId) const { return false; }
	const wchar_t* GetPacketName() const { return L"GC_ACK_WDMARKET_SALES_ITEM_LIST"; }
	const wchar_t* GetRelatedPacketName() const { return L"CG_REQ_WDMARKET_SALES_ITEM_LIST"; }
#endif

	int Result() { return mResult; }
	MarketCategory MarketCategory() { return mMarketCategory; }

	using SalesItemListIterator = PktIterator<SalesItemList>;
	const SalesItemListIterator GetLastSalesItemListIterator() const
	{
		return SalesItemListIterator(0);
	}
	SalesItemListIterator GetFirstSalesItemListIterator() const
	{
		if (mFirstSalesItemListOffset && mPktSize >= mFirstSalesItemListOffset + sizeof(SalesItemList))
		{
			SalesItemList* salesItemList = (SalesItemList*)((uchar*)this + mFirstSalesItemListOffset);
			if (mFirstSalesItemListOffset == salesItemList->mThisOffset)
				return SalesItemListIterator(salesItemList);
			else
				return SalesItemListIterator(0);
		}
		else
			return SalesItemListIterator(0);
	}
	const int GetSalesItemListCount()
	{
		return mSalesItemListCount;
	}
#ifdef _SERVER
	template<typename TFunc>
	void ForEachSalesItemList(TFunc&& func)
	{
		for (auto it = GetFirstSalesItemListIterator(); it != GetLastSalesItemListIterator(); ++it)
			func(it);
	}
#endif


#ifdef _SERVER 
	std::xwstring FuncCreateSalesItemListStr( [[maybe_unused]] SalesItemListIterator& iter) const
	{
		return Log::format(
			L"ItemId: {}, LowestPrice: {}, SalesCount: {}", 
			iter->ItemId(), iter->LowestPrice(), iter->SalesCount()
		).c_str();
	}

	std::xwstring GetLogWString() const
	{
		std::xwstring str1;
