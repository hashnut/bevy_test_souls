struct PKT_GC_ACK_GUILD_LIST_READ
{
	struct GuildList
	{
	protected:
		uint16 mThisOffset;
		uint16 mNextOffset;
		uint16 mGuildNameOffset;
		uint16 mCaptainNameOffset;
		uint16 mGuildDescOffset;
		GuildDBId mGuildDBId;
		GuildLevel mGuildLevel;
