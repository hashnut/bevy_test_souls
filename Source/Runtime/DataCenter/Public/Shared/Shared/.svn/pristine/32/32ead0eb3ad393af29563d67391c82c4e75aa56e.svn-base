	if (_wcsicmp(L"GC_ACK_CREATE_USER", str) == 0)	return GC_ACK_CREATE_USER;
	if (_wcsicmp(L"GC_ACK_DELETE_USER", str) == 0)	return GC_ACK_DELETE_USER;
	if (_wcsicmp(L"GC_ACK_DELETE_USER_CANCEL", str) == 0)	return GC_ACK_DELETE_USER_CANCEL;
