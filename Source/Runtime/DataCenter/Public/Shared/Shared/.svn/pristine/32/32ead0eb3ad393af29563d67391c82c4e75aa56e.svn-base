// type = GC
struct PKT_GC_CHAT_BLACKLIST_READ
{
	struct Chatblacklists
	{
	protected:
		uint16 mThisOffset;
		uint16 mNextOffset;
		uint16 mUserNameOffset;
		UserDBId mUserDBId;

	public:
		UserDBId UserDBId() { return mUserDBId; }

#ifdef _SERVER
		const wchar_t* UserName()
		{
			uchar* pktStart = (uchar*)this - mThisOffset;
			uint16 pktSize = *((uint16*)pktStart);
			if (mUserNameOffset && pktSize > mUserNameOffset)
				return (const wchar_t*)(pktStart + mUserNameOffset);
			else
				return L"";
		}
#else // _SERVER
		const FString UserName()
		{
			const wchar_t* strWchar = L"";
			uchar* pktStart = (uchar*)this - mThisOffset;
			uint16 pktSize = *((uint16*)pktStart);
			if (mUserNameOffset && pktSize > mUserNameOffset)
				strWchar = (const wchar_t*)(pktStart + mUserNameOffset);
			return PktWriter::ConvertToFString(strWchar);
		}
#endif // _SERVER
		friend PktIterator<Chatblacklists>;
		friend PKT_GC_CHAT_BLACKLIST_READ;

		bool Validate(uint16 offset, uchar * pktStart, uint16 pktSize, uint16& dataSize)
		{
			if (static_cast<size_t>(pktSize) < static_cast<size_t>(offset) + sizeof(Chatblacklists))
				return false;

			Chatblacklists * node = (Chatblacklists*)(pktStart + offset);

			// ŔÚ±â ŔÚ˝ĹŔÇ Ć÷ŔÎĹÍ °ËÁő
			if (offset != node->mThisOffset)
				return false;

			// Value °ËÁő
			uchar* pktCurrentNodeStart = (uchar*)this - mThisOffset;
			uint16 pktCurrentNodeSize = *((uint16*)pktStart);
			dataSize += sizeof(Chatblacklists);	// skip
			if (false == ValidateValue(pktCurrentNodeStart, pktCurrentNodeSize, dataSize))
				return false;

			return true;
		}

		bool ValidateValue(const uchar* pktStart, uint16 pktSize, uint16& dataSize)
		{
			if (false == ValidateString(mUserNameOffset, 0, pktStart, pktSize, dataSize))
				return false;

			return (nullptr != pktStart && 0 < pktSize && 0 < dataSize) ? true : false;
		}

	}; // Chatblacklists

public:
	uint16 mPktSize;
	uint16 mPktId;
	uint16 mChatblacklistsCount;
	uint16 mFirstChatblacklistsOffset;

public:
#ifdef _SERVER 
	bool GetServerTaskIdRealTime(OUT [[maybe_unused]] int& serverTaskId) const { return false; }
	const wchar_t* GetPacketName() const { return L"GC_CHAT_BLACKLIST"; }
	const wchar_t* GetRelatedPacketName() const { return L"CG_CHAT_BLACKLIST"; }
#endif


	using ChatblacklistsIterator = PktIterator<Chatblacklists>;
	const ChatblacklistsIterator GetLastChatblacklistsIterator() const
	{
		return ChatblacklistsIterator(0);
	}
	ChatblacklistsIterator GetFirstChatblacklistsIterator() const
	{
		if (mFirstChatblacklistsOffset && mPktSize >= mFirstChatblacklistsOffset + sizeof(Chatblacklists))
		{
			Chatblacklists* chatblacklists = (Chatblacklists*)((uchar*)this + mFirstChatblacklistsOffset);
			if (mFirstChatblacklistsOffset == chatblacklists->mThisOffset)
				return ChatblacklistsIterator(chatblacklists);
			else
				return ChatblacklistsIterator(0);
		}
		else
			return ChatblacklistsIterator(0);
	}
	const int GetChatblacklistsCount()
	{
		return mChatblacklistsCount;
	}
#ifdef _SERVER
	template<typename TFunc>
	void ForEachChatblacklists(TFunc&& func)
	{
		for (auto it = GetFirstChatblacklistsIterator(); it != GetLastChatblacklistsIterator(); ++it)
			func(it);
	}
#endif


#ifdef _SERVER 
	std::xwstring FuncCreateChatblacklistsStr( [[maybe_unused]] ChatblacklistsIterator& iter) const
	{
		return Log::format(
			L"UserDBId: {}, UserName: {}", 
			iter->UserDBId(), iter->UserName()
		).c_str();
	}

	std::xwstring GetLogWString() const
	{
		std::xwstring str1;
		str1.append(L"\n");
		for (ChatblacklistsIterator iter = this->GetFirstChatblacklistsIterator();
			iter != GetLastChatblacklistsIterator(); ++iter)
		{
			str1.append(L"[");
			str1.append(FuncCreateChatblacklistsStr(iter).c_str());

			str1.append(L"]\n");
		}

		return Log::format(
			L"[GC_CHAT_BLACKLIST] Chatblacklists : {}"
			, str1.c_str()
		).c_str();
	}
#endif

	bool Validate()
	{
		uchar* pktStart = (uchar*)this;
		uint16 pktSize = mPktSize;

		uint16 dataSize = sizeof(PKT_GC_CHAT_BLACKLIST_READ);
		if (dataSize > mPktSize)
			return false;

		if (false == ValidateValue(pktStart, pktSize, dataSize))
			return false;

		if (false == ChatblacklistsValidateListNode(mFirstChatblacklistsOffset, pktStart, pktSize, dataSize))
			return false;

		if (dataSize != mPktSize)
			return false;

		return true;
	}

	bool ChatblacklistsValidateListNode(uint16 offset, uchar * pktStart, uint16 pktSize, uint16& dataSize)
	{		for (ChatblacklistsIterator iter = this->GetFirstChatblacklistsIterator();
			iter != GetLastChatblacklistsIterator(); ++iter)
		{
			if (false == (*iter).Validate(offset, pktStart, pktSize, dataSize))
			{
				return false;
			}
		}
		return true;
	}

	bool ValidateValue(const uchar* pktStart, uint16 pktSize, uint16& dataSize)
	{
		return (nullptr != pktStart && 0 < pktSize && 0 < dataSize) ? true : false;
	}

}; // PKT_GC_CHAT_BLACKLIST_READ

