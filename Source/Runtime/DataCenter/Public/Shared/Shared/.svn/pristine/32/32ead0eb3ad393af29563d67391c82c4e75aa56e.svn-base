	uint64 mMyParam1;
	uint64 mMyParam2;

public:
#ifdef _SERVER 
	bool GetServerTaskIdRealTime(OUT [[maybe_unused]] int& serverTaskId) const { return false; }
	const wchar_t* GetPacketName() const { return L"GC_ACK_RANK"; }
	const wchar_t* GetRelatedPacketName() const { return L"CG_REQ_RANK"; }
