		if (mFirstAllyGuildRequestListOffset && mPktSize >= mFirstAllyGuildRequestListOffset + sizeof(AllyGuildRequestList))
		{
			AllyGuildRequestList* allyGuildRequestList = (AllyGuildRequestList*)((uchar*)this + mFirstAllyGuildRequestListOffset);
			if (mFirstAllyGuildRequestListOffset == allyGuildRequestList->mThisOffset)
				return AllyGuildRequestListIterator(allyGuildRequestList);
			else
