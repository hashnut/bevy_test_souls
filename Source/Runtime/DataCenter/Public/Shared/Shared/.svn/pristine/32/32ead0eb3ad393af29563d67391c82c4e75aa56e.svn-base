		{
			if (static_cast<size_t>(pktSize) < static_cast<size_t>(offset) + sizeof(GuildWarInfoList))
				return false;

			GuildWarInfoList * node = (GuildWarInfoList*)(pktStart + offset);

			// ŔÚ±â ŔÚ˝ĹŔÇ Ć÷ŔÎĹÍ °ËÁő
			if (offset != node->mThisOffset)
