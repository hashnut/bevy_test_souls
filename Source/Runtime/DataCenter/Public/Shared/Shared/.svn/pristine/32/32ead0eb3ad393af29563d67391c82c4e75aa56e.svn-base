			return false;

		if (false == SalesItemListValidateListNode(mFirstSalesItemListOffset, pktStart, pktSize, dataSize))
			return false;

		if (dataSize != mPktSize)
			return false;

		return true;
	}

	bool SalesItemListValidateListNode(uint16 offset, uchar * pktStart, uint16 pktSize, uint16& dataSize)
	{		for (SalesItemListIterator iter = this->GetFirstSalesItemListIterator();
			iter != GetLastSalesItemListIterator(); ++iter)
		{
			if (false == (*iter).Validate(offset, pktStart, pktSize, dataSize))
			{
				return false;
			}
		}
		return true;
	}

