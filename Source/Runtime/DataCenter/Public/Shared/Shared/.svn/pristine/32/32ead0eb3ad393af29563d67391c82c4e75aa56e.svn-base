		WhisperChatList* newWhisperChatList = new ((WhisperChatList*)nowBuffer) WhisperChatList(nowWritten, timeNow, accountGrade, userRank, worldId);
		++(*mWhisperChatListCount);
		if (mNowWhisperChatList == 0)
			*mFirstWhisperChatListOffset = nowWritten;
		else
			mNowWhisperChatList->mNextOffset = nowWritten;
		mNowWhisperChatList = newWhisperChatList;
		mPktWriter.Skip(sizeof(WhisperChatList));
		mNowWhisperChatList->SetSenderUserNameOffset((uint16)mPktWriter.GetPktSize());
		mPktWriter.WriteString(senderUserName);
		mNowWhisperChatList->SetReceiverUserNameOffset((uint16)mPktWriter.GetPktSize());
		mPktWriter.WriteString(receiverUserName);
		mNowWhisperChatList->SetMessageOffset((uint16)mPktWriter.GetPktSize());
