		mPktWriter << IsVisible;
		mPktWriter << userDBId;
		mPktWriter << userLevel;
		mPktWriter << userLookInfo;
		mPktWriter << customizingFaceData;
		mPktWriter << customizingBodyData;
		mPktWriter << mostKeywordId;
		mPktWriter << mostKeywordCount;
		mPktWriter << guildEmblemId;
		mPktWriter << memberGrade;
		mPktWriter << creatureGenderType;
		mPktWriter << accountGrade;
		mPktWriter << userRank;
		*mUserNameOffset = (uint16)mPktWriter.GetPktSize();
		mPktWriter.WriteString(userName);
		*mStatInfoListOffset = (uint16)mPktWriter.GetPktSize();
		if (statInfoList && !statInfoList->empty())
		{
			int tvalsize = (int)sizeof(*(statInfoList->begin())); 
			auto _statInfoList = const_cast<std::decay_t<T0>*>(statInfoList);
			for (auto it = _statInfoList->begin(); it != _statInfoList->end(); ++it) 
			{
				mPktWriter.WriteBinary((uint16)tvalsize, (uchar*)&(*it)); 
			}
			*mStatInfoListSize = (uint16) (tvalsize * statInfoList->size());
		}
		*mItemDataEquipListOffset = (uint16)mPktWriter.GetPktSize();
		if (itemDataEquipList && !itemDataEquipList->empty())
		{
			int tvalsize = (int)sizeof(*(itemDataEquipList->begin())); 
			auto _itemDataEquipList = const_cast<std::decay_t<T1>*>(itemDataEquipList);
			for (auto it = _itemDataEquipList->begin(); it != _itemDataEquipList->end(); ++it) 
			{
				mPktWriter.WriteBinary((uint16)tvalsize, (uchar*)&(*it)); 
			}
			*mItemDataEquipListSize = (uint16) (tvalsize * itemDataEquipList->size());
		}
		*mGuildNameOffset = (uint16)mPktWriter.GetPktSize();
		mPktWriter.WriteString(guildName);
		*mProfileIntroductionOffset = (uint16)mPktWriter.GetPktSize();
		mPktWriter.WriteString(profileIntroduction);
	}
