	template <typename T0, typename T1>
	PKT_GC_MY_GUILD_INFO_WRITE(uchar* buf, int bufSize, GuildDetail guildDetailInfo, const FString& guildName, const FString& captainName, const FString& guildDesc, const FString& guildNotice, GuildMemberGradeType memberGrade, GuildRightsLevel guildRights, bool checkAttendance, const T0* GuildBuildingData, time_t guildJoinedTime, const T1* allyGuildList, time_t lastItemAcquiredTime, time_t lastItemDistributedTime, time_t lastSanctumCheckTime, GuildRedDotDetail redDotDetail, time_t guildQuestBeginTime, GuildAcquisitionSettings acquisitionSettings)
