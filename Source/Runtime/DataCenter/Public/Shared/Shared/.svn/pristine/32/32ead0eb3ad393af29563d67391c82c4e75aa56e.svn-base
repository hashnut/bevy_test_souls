// type = GC
// related packet = PKT_CG_REQ_USER_LIST_WRITE
struct PKT_GC_ACK_USER_LIST_READ
{
	struct UserList
	{
	protected:
		uint16 mThisOffset;
		uint16 mNextOffset;
		uint16 mUserNameOffset;
		uint16 mGuildNameOffset;
		UserDBId mUserDBId;
		CreatureId mCreatureId;
		Level mUserLevel;
		time_t mLastLoginTime;
		UserLookInfo mLookInfo;
		CustomizeFaceData mCustomizingFaceData;
		CustomizeBodyData mCustomizingBodyData;
		MapId mMapId;
		time_t mExpiringTime;
		time_t mCreatedTime;
		bool mIsServerMigrateUserNameChanged;
		bool mIsServerMigrateGuildNameChanged;

	public:
		UserDBId UserDBId() { return mUserDBId; }
		CreatureId CreatureId() { return mCreatureId; }
		Level UserLevel() { return mUserLevel; }
		time_t LastLoginTime() { return mLastLoginTime; }
		const UserLookInfo& ConstRefLookInfo() { return mLookInfo; }
		UserLookInfo LookInfo() { return mLookInfo; }
		const CustomizeFaceData& ConstRefCustomizingFaceData() { return mCustomizingFaceData; }
		CustomizeFaceData CustomizingFaceData() { return mCustomizingFaceData; }
		const CustomizeBodyData& ConstRefCustomizingBodyData() { return mCustomizingBodyData; }
		CustomizeBodyData CustomizingBodyData() { return mCustomizingBodyData; }
		MapId MapId() { return mMapId; }
		time_t ExpiringTime() { return mExpiringTime; }
		time_t CreatedTime() { return mCreatedTime; }
		bool IsServerMigrateUserNameChanged() { return mIsServerMigrateUserNameChanged; }
		bool IsServerMigrateGuildNameChanged() { return mIsServerMigrateGuildNameChanged; }

#ifdef _SERVER
		const wchar_t* UserName()
		{
			uchar* pktStart = (uchar*)this - mThisOffset;
			uint16 pktSize = *((uint16*)pktStart);
			if (mUserNameOffset && pktSize > mUserNameOffset)
				return (const wchar_t*)(pktStart + mUserNameOffset);
			else
				return L"";
		}
#else // _SERVER
		const FString UserName()
		{
			const wchar_t* strWchar = L"";
			uchar* pktStart = (uchar*)this - mThisOffset;
			uint16 pktSize = *((uint16*)pktStart);
			if (mUserNameOffset && pktSize > mUserNameOffset)
				strWchar = (const wchar_t*)(pktStart + mUserNameOffset);
			return PktWriter::ConvertToFString(strWchar);
		}
#endif // _SERVER
#ifdef _SERVER
		const wchar_t* GuildName()
		{
			uchar* pktStart = (uchar*)this - mThisOffset;
			uint16 pktSize = *((uint16*)pktStart);
			if (mGuildNameOffset && pktSize > mGuildNameOffset)
				return (const wchar_t*)(pktStart + mGuildNameOffset);
			else
				return L"";
		}
#else // _SERVER
		const FString GuildName()
		{
			const wchar_t* strWchar = L"";
			uchar* pktStart = (uchar*)this - mThisOffset;
			uint16 pktSize = *((uint16*)pktStart);
			if (mGuildNameOffset && pktSize > mGuildNameOffset)
				strWchar = (const wchar_t*)(pktStart + mGuildNameOffset);
			return PktWriter::ConvertToFString(strWchar);
		}
#endif // _SERVER
		friend PktIterator<UserList>;
		friend PKT_GC_ACK_USER_LIST_READ;

		bool Validate(uint16 offset, uchar * pktStart, uint16 pktSize, uint16& dataSize)
		{
			if (static_cast<size_t>(pktSize) < static_cast<size_t>(offset) + sizeof(UserList))
				return false;

			UserList * node = (UserList*)(pktStart + offset);

			// ŔÚ±â ŔÚ˝ĹŔÇ Ć÷ŔÎĹÍ °ËÁő
			if (offset != node->mThisOffset)
				return false;

			// Value °ËÁő
			uchar* pktCurrentNodeStart = (uchar*)this - mThisOffset;
			uint16 pktCurrentNodeSize = *((uint16*)pktStart);
			dataSize += sizeof(UserList);	// skip
			if (false == ValidateValue(pktCurrentNodeStart, pktCurrentNodeSize, dataSize))
				return false;

			return true;
		}

		bool ValidateValue(const uchar* pktStart, uint16 pktSize, uint16& dataSize)
		{
			if (false == ValidateString(mUserNameOffset, 0, pktStart, pktSize, dataSize))
				return false;

			if (false == ValidateString(mGuildNameOffset, 0, pktStart, pktSize, dataSize))
				return false;

			return (nullptr != pktStart && 0 < pktSize && 0 < dataSize) ? true : false;
		}

	}; // UserList

public:
	uint16 mPktSize;
	uint16 mPktId;
	uint16 mUserListCount;
	uint16 mFirstUserListOffset;
	uint16 mAdvReservationUserNameOffset;
	int mPlayableEventCheckPoint;
	int mCharacterFreeSlotCount;
	int mCharacterPaidSlotCount;
	int mCustomizingTicketCount;

public:
#ifdef _SERVER 
	bool GetServerTaskIdRealTime(OUT [[maybe_unused]] int& serverTaskId) const { return false; }
	const wchar_t* GetPacketName() const { return L"GC_ACK_USER_LIST"; }
	const wchar_t* GetRelatedPacketName() const { return L"CG_REQ_USER_LIST"; }
#endif

	int PlayableEventCheckPoint() { return mPlayableEventCheckPoint; }
	int CharacterFreeSlotCount() { return mCharacterFreeSlotCount; }
	int CharacterPaidSlotCount() { return mCharacterPaidSlotCount; }
	int CustomizingTicketCount() { return mCustomizingTicketCount; }
#ifdef _SERVER
	const wchar_t* AdvReservationUserName() const
	{
		uchar* pktStart = (uchar*)this;
		uint16 pktSize = *((uint16*)pktStart);
		if (mAdvReservationUserNameOffset && pktSize > mAdvReservationUserNameOffset)
			return (const wchar_t*)(pktStart + mAdvReservationUserNameOffset);
		else
			return L"";
	}
#else // _SERVER
	const FString AdvReservationUserName()
	{
		const wchar_t* strWchar = L"";
		uchar* pktStart = (uchar*)this;
		uint16 pktSize = *((uint16*)pktStart);
		if (mAdvReservationUserNameOffset && pktSize > mAdvReservationUserNameOffset)
			strWchar = (const wchar_t*)(pktStart + mAdvReservationUserNameOffset);

		return PktWriter::ConvertToFString(strWchar);
	}
#endif // _SERVER

	using UserListIterator = PktIterator<UserList>;
	const UserListIterator GetLastUserListIterator() const
	{
		return UserListIterator(0);
	}
	UserListIterator GetFirstUserListIterator() const
	{
		if (mFirstUserListOffset && mPktSize >= mFirstUserListOffset + sizeof(UserList))
		{
			UserList* userList = (UserList*)((uchar*)this + mFirstUserListOffset);
			if (mFirstUserListOffset == userList->mThisOffset)
				return UserListIterator(userList);
			else
				return UserListIterator(0);
		}
		else
			return UserListIterator(0);
	}
	const int GetUserListCount()
	{
		return mUserListCount;
	}
#ifdef _SERVER
	template<typename TFunc>
	void ForEachUserList(TFunc&& func)
	{
		for (auto it = GetFirstUserListIterator(); it != GetLastUserListIterator(); ++it)
			func(it);
	}
#endif


#ifdef _SERVER 
	std::xwstring FuncCreateUserListStr( [[maybe_unused]] UserListIterator& iter) const
	{
		return Log::format(
			L"UserDBId: {}, UserName: {}, CreatureId: {}, UserLevel: {}, LastLoginTime: {}, LookInfo: {}, CustomizingFaceData: {}, CustomizingBodyData: {}, MapId: {}, ExpiringTime: {}, CreatedTime: {}, GuildName: {}, IsServerMigrateUserNameChanged: {}, IsServerMigrateGuildNameChanged: {}", 
			iter->UserDBId(), iter->UserName(), iter->CreatureId(), iter->UserLevel(), iter->LastLoginTime(), iter->LookInfo(), iter->CustomizingFaceData(), iter->CustomizingBodyData(), iter->MapId(), iter->ExpiringTime(), iter->CreatedTime(), iter->GuildName(), iter->IsServerMigrateUserNameChanged(), iter->IsServerMigrateGuildNameChanged()
		).c_str();
	}

	std::xwstring GetLogWString() const
	{
		std::xwstring str1;
		str1.append(L"\n");
		for (UserListIterator iter = this->GetFirstUserListIterator();
			iter != GetLastUserListIterator(); ++iter)
		{
			str1.append(L"[");
			str1.append(FuncCreateUserListStr(iter).c_str());

			str1.append(L"]\n");
		}

		return Log::format(
			L"[GC_ACK_USER_LIST] PlayableEventCheckPoint: {}, CharacterFreeSlotCount: {}, CharacterPaidSlotCount: {}, CustomizingTicketCount: {}, AdvReservationUserName: {}, UserList : {}"
			, mPlayableEventCheckPoint, mCharacterFreeSlotCount, mCharacterPaidSlotCount, mCustomizingTicketCount, AdvReservationUserName(), str1.c_str()
		).c_str();
	}
#endif

	bool Validate()
	{
		uchar* pktStart = (uchar*)this;
		uint16 pktSize = mPktSize;

		uint16 dataSize = sizeof(PKT_GC_ACK_USER_LIST_READ);
		if (dataSize > mPktSize)
			return false;

		if (false == ValidateValue(pktStart, pktSize, dataSize))
			return false;

		if (false == UserListValidateListNode(mFirstUserListOffset, pktStart, pktSize, dataSize))
			return false;

		if (dataSize != mPktSize)
			return false;

		return true;
	}

	bool UserListValidateListNode(uint16 offset, uchar * pktStart, uint16 pktSize, uint16& dataSize)
	{		for (UserListIterator iter = this->GetFirstUserListIterator();
			iter != GetLastUserListIterator(); ++iter)
		{
			if (false == (*iter).Validate(offset, pktStart, pktSize, dataSize))
			{
				return false;
			}
		}
		return true;
	}

	bool ValidateValue(const uchar* pktStart, uint16 pktSize, uint16& dataSize)
	{
		if (false == ValidateString(mAdvReservationUserNameOffset, 0, pktStart, pktSize, dataSize))
			return false;

		return (nullptr != pktStart && 0 < pktSize && 0 < dataSize) ? true : false;
	}

}; // PKT_GC_ACK_USER_LIST_READ

