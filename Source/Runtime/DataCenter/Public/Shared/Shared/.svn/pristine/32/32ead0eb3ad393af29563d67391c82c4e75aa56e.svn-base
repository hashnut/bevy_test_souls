	bool Validate()
	{
		uchar* pktStart = (uchar*)this;
		uint16 pktSize = mPktSize;

		uint16 dataSize = sizeof(PKT_GC_ACK_OPEN_GUILD_STORE_READ);
		if (dataSize > mPktSize)
			return false;

		if (false == ValidateValue(pktStart, pktSize, dataSize))
			return false;

		if (false == MemberListValidateListNode(mFirstMemberListOffset, pktStart, pktSize, dataSize))
			return false;

		if (false == DistributeListValidateListNode(mFirstDistributeListOffset, pktStart, pktSize, dataSize))
			return false;

		if (dataSize != mPktSize)
			return false;

		return true;
	}

