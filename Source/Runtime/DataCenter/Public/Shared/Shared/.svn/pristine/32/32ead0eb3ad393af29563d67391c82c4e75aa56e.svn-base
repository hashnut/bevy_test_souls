	std::xwstring GetLogWString() const
	{
		std::xwstring str1;
		str1.append(L"\n");
		for (AllyGuildRequestListIterator iter = this->GetFirstAllyGuildRequestListIterator();
			iter != GetLastAllyGuildRequestListIterator(); ++iter)
		{
			str1.append(L"[");
			str1.append(FuncCreateAllyGuildRequestListStr(iter).c_str());

			str1.append(L"]\n");
		}
		std::xwstring str2;
		str2.append(L"\n");
		for (HostileGuildListIterator iter = this->GetFirstHostileGuildListIterator();
			iter != GetLastHostileGuildListIterator(); ++iter)
		{
			str2.append(L"[");
			str2.append(FuncCreateHostileGuildListStr(iter).c_str());

			str2.append(L"]\n");
		}

		return Log::format(
			L"[GC_MY_GUILD_INFO] GuildDetailInfo: {}, GuildName: {}, CaptainName: {}, GuildDesc: {}, GuildNotice: {}, MemberGrade: {}, GuildRights: {}, CheckAttendance: {}, GuildJoinedTime: {}, LastItemAcquiredTime: {}, LastItemDistributedTime: {}, LastSanctumCheckTime: {}, RedDotDetail: {}, GuildQuestBeginTime: {}, AcquisitionSettings: {}, AllyGuildRequestList : {}, HostileGuildList : {}"
			, mGuildDetailInfo, GuildName(), CaptainName(), GuildDesc(), GuildNotice(), mMemberGrade, mGuildRights, mCheckAttendance, mGuildJoinedTime, mLastItemAcquiredTime, mLastItemDistributedTime, mLastSanctumCheckTime, mRedDotDetail, mGuildQuestBeginTime, mAcquisitionSettings, str1.c_str(), str2.c_str()
		).c_str();
	}
#endif

	bool Validate()
	{
		uchar* pktStart = (uchar*)this;
		uint16 pktSize = mPktSize;

		uint16 dataSize = sizeof(PKT_GC_MY_GUILD_INFO_READ);
		if (dataSize > mPktSize)
			return false;

		if (false == ValidateValue(pktStart, pktSize, dataSize))
			return false;

		if (false == AllyGuildRequestListValidateListNode(mFirstAllyGuildRequestListOffset, pktStart, pktSize, dataSize))
			return false;

		if (false == HostileGuildListValidateListNode(mFirstHostileGuildListOffset, pktStart, pktSize, dataSize))
			return false;

		if (dataSize != mPktSize)
			return false;

		return true;
	}

	bool AllyGuildRequestListValidateListNode(uint16 offset, uchar * pktStart, uint16 pktSize, uint16& dataSize)
	{		for (AllyGuildRequestListIterator iter = this->GetFirstAllyGuildRequestListIterator();
			iter != GetLastAllyGuildRequestListIterator(); ++iter)
		{
			if (false == (*iter).Validate(offset, pktStart, pktSize, dataSize))
			{
				return false;
			}
		}
		return true;
	}

	bool HostileGuildListValidateListNode(uint16 offset, uchar * pktStart, uint16 pktSize, uint16& dataSize)
	{		for (HostileGuildListIterator iter = this->GetFirstHostileGuildListIterator();
			iter != GetLastHostileGuildListIterator(); ++iter)
		{
			if (false == (*iter).Validate(offset, pktStart, pktSize, dataSize))
			{
				return false;
			}
		}
		return true;
	}

	bool ValidateValue(const uchar* pktStart, uint16 pktSize, uint16& dataSize)
	{
		if (false == ValidateString(mGuildNameOffset, 0, pktStart, pktSize, dataSize))
			return false;

		if (false == ValidateString(mCaptainNameOffset, 0, pktStart, pktSize, dataSize))
			return false;

		if (false == ValidateString(mGuildDescOffset, 0, pktStart, pktSize, dataSize))
			return false;

		if (false == ValidateString(mGuildNoticeOffset, 0, pktStart, pktSize, dataSize))
			return false;

		if (false == ValidateBinary(mGuildBuildingDataOffset, mGuildBuildingDataSize, 0, pktSize, dataSize))
			return false;

		if (false == ValidateBinary(mAllyGuildListOffset, mAllyGuildListSize, 0, pktSize, dataSize))
			return false;

		return (nullptr != pktStart && 0 < pktSize && 0 < dataSize) ? true : false;
	}

}; // PKT_GC_MY_GUILD_INFO_READ

