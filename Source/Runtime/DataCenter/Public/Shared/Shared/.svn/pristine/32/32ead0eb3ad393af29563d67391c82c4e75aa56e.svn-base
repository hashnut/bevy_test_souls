struct PKT_GC_ACK_COOP_PARTY_LIST_READ
{
	struct CoopPartyList
	{
	protected:
		uint16 mThisOffset;
		uint16 mNextOffset;
		uint16 mLeaderNameOffset;
		CoopPartyInfo mCoopPartyInfo;

	public:
		const CoopPartyInfo& ConstRefCoopPartyInfo() { return mCoopPartyInfo; }
