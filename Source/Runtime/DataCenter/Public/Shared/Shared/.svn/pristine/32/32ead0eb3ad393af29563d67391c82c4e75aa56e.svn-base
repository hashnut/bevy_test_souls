// type = GC
// related packet = PKT_CG_REQ_GUILD_MEMBER_LIST_WRITE
struct PKT_GC_ACK_GUILD_MEMBER_LIST_READ
{
	struct MemberList
	{
	protected:
		uint16 mThisOffset;
		uint16 mNextOffset;
		uint16 mUserNameOffset;
		UserDBId mUserDBId;
		Level mUserLevel;
		GuildMemberGradeType mMemberGrade;
		time_t mLastLoginTime;
		GuildContribution mContributionWeekend;
		GuildContribution mContributionAccuml;
		bool mCheckAttendance;
		time_t mGuildJoinedTime;

	public:
		UserDBId UserDBId() { return mUserDBId; }
		Level UserLevel() { return mUserLevel; }
		GuildMemberGradeType MemberGrade() { return mMemberGrade; }
		time_t LastLoginTime() { return mLastLoginTime; }
		GuildContribution ContributionWeekend() { return mContributionWeekend; }
		GuildContribution ContributionAccuml() { return mContributionAccuml; }
		bool CheckAttendance() { return mCheckAttendance; }
		time_t GuildJoinedTime() { return mGuildJoinedTime; }

#ifdef _SERVER
		const wchar_t* UserName()
		{
			uchar* pktStart = (uchar*)this - mThisOffset;
			uint16 pktSize = *((uint16*)pktStart);
			if (mUserNameOffset && pktSize > mUserNameOffset)
				return (const wchar_t*)(pktStart + mUserNameOffset);
			else
				return L"";
		}
#else // _SERVER
		const FString UserName()
		{
			const wchar_t* strWchar = L"";
			uchar* pktStart = (uchar*)this - mThisOffset;
			uint16 pktSize = *((uint16*)pktStart);
			if (mUserNameOffset && pktSize > mUserNameOffset)
				strWchar = (const wchar_t*)(pktStart + mUserNameOffset);
			return PktWriter::ConvertToFString(strWchar);
		}
#endif // _SERVER
		friend PktIterator<MemberList>;
		friend PKT_GC_ACK_GUILD_MEMBER_LIST_READ;

		bool Validate(uint16 offset, uchar * pktStart, uint16 pktSize, uint16& dataSize)
		{
			if (static_cast<size_t>(pktSize) < static_cast<size_t>(offset) + sizeof(MemberList))
				return false;

			MemberList * node = (MemberList*)(pktStart + offset);

			// ŔÚ±â ŔÚ˝ĹŔÇ Ć÷ŔÎĹÍ °ËÁő
			if (offset != node->mThisOffset)
				return false;

			// Value °ËÁő
			uchar* pktCurrentNodeStart = (uchar*)this - mThisOffset;
			uint16 pktCurrentNodeSize = *((uint16*)pktStart);
			dataSize += sizeof(MemberList);	// skip
			if (false == ValidateValue(pktCurrentNodeStart, pktCurrentNodeSize, dataSize))
				return false;

			return true;
		}

		bool ValidateValue(const uchar* pktStart, uint16 pktSize, uint16& dataSize)
		{
			if (false == ValidateString(mUserNameOffset, 0, pktStart, pktSize, dataSize))
				return false;

			return (nullptr != pktStart && 0 < pktSize && 0 < dataSize) ? true : false;
		}

	}; // MemberList

public:
	uint16 mPktSize;
	uint16 mPktId;
	uint16 mMemberListCount;
	uint16 mFirstMemberListOffset;

public:
#ifdef _SERVER 
	bool GetServerTaskIdRealTime(OUT [[maybe_unused]] int& serverTaskId) const { return false; }
	const wchar_t* GetPacketName() const { return L"GC_ACK_GUILD_MEMBER_LIST"; }
	const wchar_t* GetRelatedPacketName() const { return L"CG_REQ_GUILD_MEMBER_LIST"; }
#endif


	using MemberListIterator = PktIterator<MemberList>;
	const MemberListIterator GetLastMemberListIterator() const
	{
		return MemberListIterator(0);
	}
	MemberListIterator GetFirstMemberListIterator() const
	{
		if (mFirstMemberListOffset && mPktSize >= mFirstMemberListOffset + sizeof(MemberList))
		{
			MemberList* memberList = (MemberList*)((uchar*)this + mFirstMemberListOffset);
			if (mFirstMemberListOffset == memberList->mThisOffset)
				return MemberListIterator(memberList);
			else
				return MemberListIterator(0);
		}
		else
			return MemberListIterator(0);
	}
	const int GetMemberListCount()
	{
		return mMemberListCount;
	}
#ifdef _SERVER
	template<typename TFunc>
	void ForEachMemberList(TFunc&& func)
	{
		for (auto it = GetFirstMemberListIterator(); it != GetLastMemberListIterator(); ++it)
			func(it);
	}
#endif


#ifdef _SERVER 
	std::xwstring FuncCreateMemberListStr( [[maybe_unused]] MemberListIterator& iter) const
	{
		return Log::format(
			L"UserDBId: {}, UserName: {}, UserLevel: {}, MemberGrade: {}, LastLoginTime: {}, ContributionWeekend: {}, ContributionAccuml: {}, CheckAttendance: {}, GuildJoinedTime: {}", 
			iter->UserDBId(), iter->UserName(), iter->UserLevel(), iter->MemberGrade(), iter->LastLoginTime(), iter->ContributionWeekend(), iter->ContributionAccuml(), iter->CheckAttendance(), iter->GuildJoinedTime()
		).c_str();
	}

	std::xwstring GetLogWString() const
	{
		std::xwstring str1;
		str1.append(L"\n");
		for (MemberListIterator iter = this->GetFirstMemberListIterator();
			iter != GetLastMemberListIterator(); ++iter)
		{
			str1.append(L"[");
			str1.append(FuncCreateMemberListStr(iter).c_str());

			str1.append(L"]\n");
		}

		return Log::format(
			L"[GC_ACK_GUILD_MEMBER_LIST] MemberList : {}"
			, str1.c_str()
		).c_str();
	}
#endif

	bool Validate()
	{
		uchar* pktStart = (uchar*)this;
		uint16 pktSize = mPktSize;

		uint16 dataSize = sizeof(PKT_GC_ACK_GUILD_MEMBER_LIST_READ);
		if (dataSize > mPktSize)
			return false;

		if (false == ValidateValue(pktStart, pktSize, dataSize))
			return false;

		if (false == MemberListValidateListNode(mFirstMemberListOffset, pktStart, pktSize, dataSize))
			return false;

		if (dataSize != mPktSize)
			return false;

		return true;
	}

	bool MemberListValidateListNode(uint16 offset, uchar * pktStart, uint16 pktSize, uint16& dataSize)
	{		for (MemberListIterator iter = this->GetFirstMemberListIterator();
			iter != GetLastMemberListIterator(); ++iter)
		{
			if (false == (*iter).Validate(offset, pktStart, pktSize, dataSize))
			{
				return false;
			}
		}
		return true;
	}

	bool ValidateValue(const uchar* pktStart, uint16 pktSize, uint16& dataSize)
	{
		return (nullptr != pktStart && 0 < pktSize && 0 < dataSize) ? true : false;
	}

}; // PKT_GC_ACK_GUILD_MEMBER_LIST_READ

