		friend PKT_GC_ACK_AGIT_DUNGEON_RAID_READ;

		bool Validate(uint16 offset, uchar * pktStart, uint16 pktSize, uint16& dataSize)
		{
			if (static_cast<size_t>(pktSize) < static_cast<size_t>(offset) + sizeof(RaidList))
				return false;

			RaidList * node = (RaidList*)(pktStart + offset);

			// ŔÚ±â ŔÚ˝ĹŔÇ Ć÷ŔÎĹÍ °ËÁő
			if (offset != node->mThisOffset)
				return false;

			// Value °ËÁő
			uchar* pktCurrentNodeStart = (uchar*)this - mThisOffset;
			uint16 pktCurrentNodeSize = *((uint16*)pktStart);
			dataSize += sizeof(RaidList);	// skip
			if (false == ValidateValue(pktCurrentNodeStart, pktCurrentNodeSize, dataSize))
				return false;

			return true;
		}

		bool ValidateValue(const uchar* pktStart, uint16 pktSize, uint16& dataSize)
		{
			return (nullptr != pktStart && 0 < pktSize && 0 < dataSize) ? true : false;
		}

	}; // RaidList

public:
	uint16 mPktSize;
	uint16 mPktId;
	uint16 mRaidListCount;
	uint16 mFirstRaidListOffset;
	int mResult;
	uint32 mRaidClearCount;
	uint32 mTicketCount;
	time_t mResetDateTime;

public:
#ifdef _SERVER 
	bool GetServerTaskIdRealTime(OUT [[maybe_unused]] int& serverTaskId) const { return false; }
	const wchar_t* GetPacketName() const { return L"GC_ACK_AGIT_DUNGEON_RAID"; }
	const wchar_t* GetRelatedPacketName() const { return L"CG_REQ_AGIT_DUNGEON_RAID"; }
#endif

	int Result() { return mResult; }
	uint32 RaidClearCount() { return mRaidClearCount; }
	uint32 TicketCount() { return mTicketCount; }
	time_t ResetDateTime() { return mResetDateTime; }

	using RaidListIterator = PktIterator<RaidList>;
	const RaidListIterator GetLastRaidListIterator() const
	{
		return RaidListIterator(0);
	}
	RaidListIterator GetFirstRaidListIterator() const
	{
		if (mFirstRaidListOffset && mPktSize >= mFirstRaidListOffset + sizeof(RaidList))
		{
			RaidList* raidList = (RaidList*)((uchar*)this + mFirstRaidListOffset);
			if (mFirstRaidListOffset == raidList->mThisOffset)
				return RaidListIterator(raidList);
			else
				return RaidListIterator(0);
		}
		else
			return RaidListIterator(0);
	}
	const int GetRaidListCount()
	{
		return mRaidListCount;
	}
#ifdef _SERVER
	template<typename TFunc>
	void ForEachRaidList(TFunc&& func)
	{
		for (auto it = GetFirstRaidListIterator(); it != GetLastRaidListIterator(); ++it)
			func(it);
	}
#endif


#ifdef _SERVER 
	std::xwstring FuncCreateRaidListStr( [[maybe_unused]] RaidListIterator& iter) const
	{
		return Log::format(
			L"RaidId: {}, State: {}", 
			iter->RaidId(), iter->State()
		).c_str();
	}

	std::xwstring GetLogWString() const
	{
		std::xwstring str1;
		str1.append(L"\n");
		for (RaidListIterator iter = this->GetFirstRaidListIterator();
			iter != GetLastRaidListIterator(); ++iter)
		{
			str1.append(L"[");
			str1.append(FuncCreateRaidListStr(iter).c_str());

			str1.append(L"]\n");
		}

		return Log::format(
			L"[GC_ACK_AGIT_DUNGEON_RAID] Result: {}, RaidClearCount: {}, TicketCount: {}, ResetDateTime: {}, RaidList : {}"
			, mResult, mRaidClearCount, mTicketCount, mResetDateTime, str1.c_str()
		).c_str();
	}
#endif

	bool Validate()
	{
		uchar* pktStart = (uchar*)this;
		uint16 pktSize = mPktSize;

		uint16 dataSize = sizeof(PKT_GC_ACK_AGIT_DUNGEON_RAID_READ);
		if (dataSize > mPktSize)
			return false;

		if (false == ValidateValue(pktStart, pktSize, dataSize))
			return false;

		if (false == RaidListValidateListNode(mFirstRaidListOffset, pktStart, pktSize, dataSize))
			return false;

		if (dataSize != mPktSize)
			return false;

		return true;
	}

	bool RaidListValidateListNode(uint16 offset, uchar * pktStart, uint16 pktSize, uint16& dataSize)
	{		for (RaidListIterator iter = this->GetFirstRaidListIterator();
			iter != GetLastRaidListIterator(); ++iter)
		{
			if (false == (*iter).Validate(offset, pktStart, pktSize, dataSize))
			{
				return false;
			}
		}
		return true;
	}

	bool ValidateValue(const uchar* pktStart, uint16 pktSize, uint16& dataSize)
	{
		return (nullptr != pktStart && 0 < pktSize && 0 < dataSize) ? true : false;
	}

}; // PKT_GC_ACK_AGIT_DUNGEON_RAID_READ

