		mBookMarkListOffset = (uint16*)mPktWriter.GetBuffer();
		*mBookMarkListOffset = 0;
		mPktWriter << (*mBookMarkListOffset);
		mBookMarkListSize = (uint16*)mPktWriter.GetBuffer();
		*mBookMarkListSize = 0;
		mPktWriter << (*mBookMarkListSize);
