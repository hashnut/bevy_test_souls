		, mNowCalculatedList(0)
	{
		mPktWriter << static_cast<uint16>(PD::GC::GCPacketId::GC_ACK_MARKET_CALCULATED_LIST);
		mCalculatedListCount = (uint16*)mPktWriter.GetBuffer();
		*mCalculatedListCount = 0;
		mPktWriter << (*mCalculatedListCount);
		mFirstCalculatedListOffset = (uint16*)mPktWriter.GetBuffer();
		*mFirstCalculatedListOffset = 0;
		mPktWriter << (*mFirstCalculatedListOffset);
		mPktWriter << totalCalculatedCount;
