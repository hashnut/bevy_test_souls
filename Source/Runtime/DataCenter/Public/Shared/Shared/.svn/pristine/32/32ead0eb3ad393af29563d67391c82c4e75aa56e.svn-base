#else // _SERVER
		const FString ProcurerUserName()
		{
			const wchar_t* strWchar = L"";
			uchar* pktStart = (uchar*)this - mThisOffset;
			uint16 pktSize = *((uint16*)pktStart);
			if (mProcurerUserNameOffset && pktSize > mProcurerUserNameOffset)
				strWchar = (const wchar_t*)(pktStart + mProcurerUserNameOffset);
			return PktWriter::ConvertToFString(strWchar);
		}
#endif // _SERVER
#ifdef _SERVER
		const wchar_t* BidderUserName()
		{
			uchar* pktStart = (uchar*)this - mThisOffset;
			uint16 pktSize = *((uint16*)pktStart);
			if (mBidderUserNameOffset && pktSize > mBidderUserNameOffset)
				return (const wchar_t*)(pktStart + mBidderUserNameOffset);
			else
				return L"";
		}
#else // _SERVER
		const FString BidderUserName()
		{
			const wchar_t* strWchar = L"";
			uchar* pktStart = (uchar*)this - mThisOffset;
			uint16 pktSize = *((uint16*)pktStart);
			if (mBidderUserNameOffset && pktSize > mBidderUserNameOffset)
				strWchar = (const wchar_t*)(pktStart + mBidderUserNameOffset);
			return PktWriter::ConvertToFString(strWchar);
		}
#endif // _SERVER
		friend PktIterator<GuildStoreItemCapture>;
		friend PKT_GC_GUILD_STORE_ITEM_CAPTURE_INFO_LIST_READ;

		bool Validate(uint16 offset, uchar * pktStart, uint16 pktSize, uint16& dataSize)
		{
			if (static_cast<size_t>(pktSize) < static_cast<size_t>(offset) + sizeof(GuildStoreItemCapture))
				return false;

			GuildStoreItemCapture * node = (GuildStoreItemCapture*)(pktStart + offset);

			// ŔÚ±â ŔÚ˝ĹŔÇ Ć÷ŔÎĹÍ °ËÁő
			if (offset != node->mThisOffset)
				return false;

			// Value °ËÁő
			uchar* pktCurrentNodeStart = (uchar*)this - mThisOffset;
			uint16 pktCurrentNodeSize = *((uint16*)pktStart);
			dataSize += sizeof(GuildStoreItemCapture);	// skip
			if (false == ValidateValue(pktCurrentNodeStart, pktCurrentNodeSize, dataSize))
				return false;

			return true;
		}

		bool ValidateValue(const uchar* pktStart, uint16 pktSize, uint16& dataSize)
		{
			if (false == ValidateString(mProcurerUserNameOffset, 0, pktStart, pktSize, dataSize))
				return false;

			if (false == ValidateString(mBidderUserNameOffset, 0, pktStart, pktSize, dataSize))
				return false;

			return (nullptr != pktStart && 0 < pktSize && 0 < dataSize) ? true : false;
		}

	}; // GuildStoreItemCapture

public:
	uint16 mPktSize;
	uint16 mPktId;
	uint16 mGuildStoreItemCaptureCount;
	uint16 mFirstGuildStoreItemCaptureOffset;

public:
#ifdef _SERVER 
	bool GetServerTaskIdRealTime(OUT [[maybe_unused]] int& serverTaskId) const { return false; }
	const wchar_t* GetPacketName() const { return L"GC_GUILD_STORE_ITEM_CAPTURE_INFO_LIST"; }
	const wchar_t* GetRelatedPacketName() const { return L"CG_GUILD_STORE_ITEM_CAPTURE_INFO_LIST"; }
#endif


	using GuildStoreItemCaptureIterator = PktIterator<GuildStoreItemCapture>;
	const GuildStoreItemCaptureIterator GetLastGuildStoreItemCaptureIterator() const
	{
		return GuildStoreItemCaptureIterator(0);
	}
	GuildStoreItemCaptureIterator GetFirstGuildStoreItemCaptureIterator() const
	{
		if (mFirstGuildStoreItemCaptureOffset && mPktSize >= mFirstGuildStoreItemCaptureOffset + sizeof(GuildStoreItemCapture))
		{
			GuildStoreItemCapture* guildStoreItemCapture = (GuildStoreItemCapture*)((uchar*)this + mFirstGuildStoreItemCaptureOffset);
			if (mFirstGuildStoreItemCaptureOffset == guildStoreItemCapture->mThisOffset)
				return GuildStoreItemCaptureIterator(guildStoreItemCapture);
			else
				return GuildStoreItemCaptureIterator(0);
		}
		else
			return GuildStoreItemCaptureIterator(0);
	}
	const int GetGuildStoreItemCaptureCount()
	{
		return mGuildStoreItemCaptureCount;
	}
#ifdef _SERVER
	template<typename TFunc>
	void ForEachGuildStoreItemCapture(TFunc&& func)
	{
		for (auto it = GetFirstGuildStoreItemCaptureIterator(); it != GetLastGuildStoreItemCaptureIterator(); ++it)
			func(it);
	}
#endif


#ifdef _SERVER 
	std::xwstring FuncCreateGuildStoreItemCaptureStr( [[maybe_unused]] GuildStoreItemCaptureIterator& iter) const
	{
		return Log::format(
			L"ItemDBId: {}, ProcurerUserName: {}, ProcurerUserDBId: {}, BidderUserName: {}, BidderUserDBId: {}", 
			iter->ItemDBId(), iter->ProcurerUserName(), iter->ProcurerUserDBId(), iter->BidderUserName(), iter->BidderUserDBId()
		).c_str();
	}

	std::xwstring GetLogWString() const
	{
		std::xwstring str1;
		str1.append(L"\n");
		for (GuildStoreItemCaptureIterator iter = this->GetFirstGuildStoreItemCaptureIterator();
			iter != GetLastGuildStoreItemCaptureIterator(); ++iter)
		{
			str1.append(L"[");
			str1.append(FuncCreateGuildStoreItemCaptureStr(iter).c_str());

			str1.append(L"]\n");
		}

		return Log::format(
			L"[GC_GUILD_STORE_ITEM_CAPTURE_INFO_LIST] GuildStoreItemCapture : {}"
			, str1.c_str()
		).c_str();
	}
#endif

	bool Validate()
	{
		uchar* pktStart = (uchar*)this;
		uint16 pktSize = mPktSize;

		uint16 dataSize = sizeof(PKT_GC_GUILD_STORE_ITEM_CAPTURE_INFO_LIST_READ);
		if (dataSize > mPktSize)
			return false;

		if (false == ValidateValue(pktStart, pktSize, dataSize))
			return false;

		if (false == GuildStoreItemCaptureValidateListNode(mFirstGuildStoreItemCaptureOffset, pktStart, pktSize, dataSize))
			return false;

		if (dataSize != mPktSize)
			return false;

		return true;
	}

	bool GuildStoreItemCaptureValidateListNode(uint16 offset, uchar * pktStart, uint16 pktSize, uint16& dataSize)
	{		for (GuildStoreItemCaptureIterator iter = this->GetFirstGuildStoreItemCaptureIterator();
			iter != GetLastGuildStoreItemCaptureIterator(); ++iter)
		{
			if (false == (*iter).Validate(offset, pktStart, pktSize, dataSize))
			{
				return false;
			}
		}
		return true;
	}

	bool ValidateValue(const uchar* pktStart, uint16 pktSize, uint16& dataSize)
	{
		return (nullptr != pktStart && 0 < pktSize && 0 < dataSize) ? true : false;
	}

}; // PKT_GC_GUILD_STORE_ITEM_CAPTURE_INFO_LIST_READ

