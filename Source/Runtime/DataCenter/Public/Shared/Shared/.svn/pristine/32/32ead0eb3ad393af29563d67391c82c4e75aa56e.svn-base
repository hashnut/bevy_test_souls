// type = GC
struct PKT_GC_CONTENTS_EVENT_GROUP_ACTIVATED_LIST_READ
{
	struct ContentsEventList
	{
	protected:
		uint16 mThisOffset;
		uint16 mNextOffset;
		ContentsEventGroupId mGroupId;
		time_t mStartTime;
		time_t mEndTime;

	public:
		ContentsEventGroupId GroupId() { return mGroupId; }
		time_t StartTime() { return mStartTime; }
		time_t EndTime() { return mEndTime; }

		friend PktIterator<ContentsEventList>;
		friend PKT_GC_CONTENTS_EVENT_GROUP_ACTIVATED_LIST_READ;

		bool Validate(uint16 offset, uchar * pktStart, uint16 pktSize, uint16& dataSize)
		{
			if (static_cast<size_t>(pktSize) < static_cast<size_t>(offset) + sizeof(ContentsEventList))
				return false;

			ContentsEventList * node = (ContentsEventList*)(pktStart + offset);

			// ŔÚ±â ŔÚ˝ĹŔÇ Ć÷ŔÎĹÍ °ËÁő
			if (offset != node->mThisOffset)
				return false;

			// Value °ËÁő
			uchar* pktCurrentNodeStart = (uchar*)this - mThisOffset;
			uint16 pktCurrentNodeSize = *((uint16*)pktStart);
			dataSize += sizeof(ContentsEventList);	// skip
			if (false == ValidateValue(pktCurrentNodeStart, pktCurrentNodeSize, dataSize))
				return false;

			return true;
		}

		bool ValidateValue(const uchar* pktStart, uint16 pktSize, uint16& dataSize)
		{
			return (nullptr != pktStart && 0 < pktSize && 0 < dataSize) ? true : false;
		}

	}; // ContentsEventList

public:
	uint16 mPktSize;
	uint16 mPktId;
	uint16 mContentsEventListCount;
	uint16 mFirstContentsEventListOffset;

public:
#ifdef _SERVER 
	bool GetServerTaskIdRealTime(OUT [[maybe_unused]] int& serverTaskId) const { return false; }
	const wchar_t* GetPacketName() const { return L"GC_CONTENTS_EVENT_GROUP_ACTIVATED_LIST"; }
	const wchar_t* GetRelatedPacketName() const { return L"CG_CONTENTS_EVENT_GROUP_ACTIVATED_LIST"; }
#endif


	using ContentsEventListIterator = PktIterator<ContentsEventList>;
	const ContentsEventListIterator GetLastContentsEventListIterator() const
	{
		return ContentsEventListIterator(0);
	}
	ContentsEventListIterator GetFirstContentsEventListIterator() const
	{
		if (mFirstContentsEventListOffset && mPktSize >= mFirstContentsEventListOffset + sizeof(ContentsEventList))
		{
			ContentsEventList* contentsEventList = (ContentsEventList*)((uchar*)this + mFirstContentsEventListOffset);
			if (mFirstContentsEventListOffset == contentsEventList->mThisOffset)
				return ContentsEventListIterator(contentsEventList);
			else
				return ContentsEventListIterator(0);
		}
		else
			return ContentsEventListIterator(0);
	}
	const int GetContentsEventListCount()
	{
		return mContentsEventListCount;
	}
#ifdef _SERVER
	template<typename TFunc>
	void ForEachContentsEventList(TFunc&& func)
	{
		for (auto it = GetFirstContentsEventListIterator(); it != GetLastContentsEventListIterator(); ++it)
			func(it);
	}
#endif


#ifdef _SERVER 
	std::xwstring FuncCreateContentsEventListStr( [[maybe_unused]] ContentsEventListIterator& iter) const
	{
		return Log::format(
			L"GroupId: {}, StartTime: {}, EndTime: {}", 
			iter->GroupId(), iter->StartTime(), iter->EndTime()
		).c_str();
	}

	std::xwstring GetLogWString() const
	{
		std::xwstring str1;
		str1.append(L"\n");
		for (ContentsEventListIterator iter = this->GetFirstContentsEventListIterator();
			iter != GetLastContentsEventListIterator(); ++iter)
		{
			str1.append(L"[");
			str1.append(FuncCreateContentsEventListStr(iter).c_str());

			str1.append(L"]\n");
		}

		return Log::format(
			L"[GC_CONTENTS_EVENT_GROUP_ACTIVATED_LIST] ContentsEventList : {}"
			, str1.c_str()
		).c_str();
	}
#endif

	bool Validate()
	{
		uchar* pktStart = (uchar*)this;
		uint16 pktSize = mPktSize;

		uint16 dataSize = sizeof(PKT_GC_CONTENTS_EVENT_GROUP_ACTIVATED_LIST_READ);
		if (dataSize > mPktSize)
			return false;

		if (false == ValidateValue(pktStart, pktSize, dataSize))
			return false;

		if (false == ContentsEventListValidateListNode(mFirstContentsEventListOffset, pktStart, pktSize, dataSize))
			return false;

		if (dataSize != mPktSize)
			return false;

		return true;
	}

	bool ContentsEventListValidateListNode(uint16 offset, uchar * pktStart, uint16 pktSize, uint16& dataSize)
	{		for (ContentsEventListIterator iter = this->GetFirstContentsEventListIterator();
			iter != GetLastContentsEventListIterator(); ++iter)
		{
			if (false == (*iter).Validate(offset, pktStart, pktSize, dataSize))
			{
				return false;
			}
		}
		return true;
	}

	bool ValidateValue(const uchar* pktStart, uint16 pktSize, uint16& dataSize)
	{
		return (nullptr != pktStart && 0 < pktSize && 0 < dataSize) ? true : false;
	}

}; // PKT_GC_CONTENTS_EVENT_GROUP_ACTIVATED_LIST_READ

