		uint16 nowWritten = (uint16)mPktWriter.GetPktSize();
		CommentInfolist* newCommentInfolist = new ((CommentInfolist*)nowBuffer) CommentInfolist(nowWritten, userDBId, writeTime);
		++(*mCommentInfolistCount);
		if (mNowCommentInfolist == 0)
			*mFirstCommentInfolistOffset = nowWritten;
