struct PKT_GC_GUILD_AUCTION_BIDDER_INFO_LIST_READ
{
	struct AuctionBidderInfo
	{
	protected:
		uint16 mThisOffset;
		uint16 mNextOffset;
		uint16 mUserNameOffset;
		GuildAuctionId mGuildAuctionId;
		UserDBId mUserDBId;

	public:
		const GuildAuctionId& ConstRefGuildAuctionId() { return mGuildAuctionId; }
		GuildAuctionId GuildAuctionId() { return mGuildAuctionId; }
		UserDBId UserDBId() { return mUserDBId; }

#ifdef _SERVER
		const wchar_t* UserName()
		{
			uchar* pktStart = (uchar*)this - mThisOffset;
			uint16 pktSize = *((uint16*)pktStart);
			if (mUserNameOffset && pktSize > mUserNameOffset)
				return (const wchar_t*)(pktStart + mUserNameOffset);
			else
				return L"";
		}
#else // _SERVER
		const FString UserName()
		{
			const wchar_t* strWchar = L"";
			uchar* pktStart = (uchar*)this - mThisOffset;
			uint16 pktSize = *((uint16*)pktStart);
			if (mUserNameOffset && pktSize > mUserNameOffset)
				strWchar = (const wchar_t*)(pktStart + mUserNameOffset);
			return PktWriter::ConvertToFString(strWchar);
		}
#endif // _SERVER
		friend PktIterator<AuctionBidderInfo>;
		friend PKT_GC_GUILD_AUCTION_BIDDER_INFO_LIST_READ;

		bool Validate(uint16 offset, uchar * pktStart, uint16 pktSize, uint16& dataSize)
		{
			if (static_cast<size_t>(pktSize) < static_cast<size_t>(offset) + sizeof(AuctionBidderInfo))
				return false;

			AuctionBidderInfo * node = (AuctionBidderInfo*)(pktStart + offset);

			// ŔÚ±â ŔÚ˝ĹŔÇ Ć÷ŔÎĹÍ °ËÁő
			if (offset != node->mThisOffset)
				return false;

			// Value °ËÁő
			uchar* pktCurrentNodeStart = (uchar*)this - mThisOffset;
			uint16 pktCurrentNodeSize = *((uint16*)pktStart);
			dataSize += sizeof(AuctionBidderInfo);	// skip
			if (false == ValidateValue(pktCurrentNodeStart, pktCurrentNodeSize, dataSize))
				return false;

			return true;
		}

		bool ValidateValue(const uchar* pktStart, uint16 pktSize, uint16& dataSize)
		{
			if (false == ValidateString(mUserNameOffset, 0, pktStart, pktSize, dataSize))
				return false;

			return (nullptr != pktStart && 0 < pktSize && 0 < dataSize) ? true : false;
		}

	}; // AuctionBidderInfo

public:
	uint16 mPktSize;
	uint16 mPktId;
	uint16 mAuctionBidderInfoCount;
	uint16 mFirstAuctionBidderInfoOffset;

public:
#ifdef _SERVER 
	bool GetServerTaskIdRealTime(OUT [[maybe_unused]] int& serverTaskId) const { return false; }
	const wchar_t* GetPacketName() const { return L"GC_GUILD_AUCTION_BIDDER_INFO_LIST"; }
	const wchar_t* GetRelatedPacketName() const { return L"CG_GUILD_AUCTION_BIDDER_INFO_LIST"; }
#endif


	using AuctionBidderInfoIterator = PktIterator<AuctionBidderInfo>;
	const AuctionBidderInfoIterator GetLastAuctionBidderInfoIterator() const
	{
		return AuctionBidderInfoIterator(0);
	}
	AuctionBidderInfoIterator GetFirstAuctionBidderInfoIterator() const
	{
		if (mFirstAuctionBidderInfoOffset && mPktSize >= mFirstAuctionBidderInfoOffset + sizeof(AuctionBidderInfo))
		{
			AuctionBidderInfo* auctionBidderInfo = (AuctionBidderInfo*)((uchar*)this + mFirstAuctionBidderInfoOffset);
			if (mFirstAuctionBidderInfoOffset == auctionBidderInfo->mThisOffset)
				return AuctionBidderInfoIterator(auctionBidderInfo);
			else
				return AuctionBidderInfoIterator(0);
		}
		else
			return AuctionBidderInfoIterator(0);
	}
	const int GetAuctionBidderInfoCount()
	{
		return mAuctionBidderInfoCount;
	}
#ifdef _SERVER
	template<typename TFunc>
	void ForEachAuctionBidderInfo(TFunc&& func)
	{
		for (auto it = GetFirstAuctionBidderInfoIterator(); it != GetLastAuctionBidderInfoIterator(); ++it)
			func(it);
	}
#endif


#ifdef _SERVER 
	std::xwstring FuncCreateAuctionBidderInfoStr( [[maybe_unused]] AuctionBidderInfoIterator& iter) const
	{
		return Log::format(
			L"GuildAuctionId: {}, UserName: {}, UserDBId: {}", 
			iter->GuildAuctionId(), iter->UserName(), iter->UserDBId()
		).c_str();
	}

	std::xwstring GetLogWString() const
	{
		std::xwstring str1;
		str1.append(L"\n");
		for (AuctionBidderInfoIterator iter = this->GetFirstAuctionBidderInfoIterator();
			iter != GetLastAuctionBidderInfoIterator(); ++iter)
		{
			str1.append(L"[");
			str1.append(FuncCreateAuctionBidderInfoStr(iter).c_str());

			str1.append(L"]\n");
		}

		return Log::format(
			L"[GC_GUILD_AUCTION_BIDDER_INFO_LIST] AuctionBidderInfo : {}"
			, str1.c_str()
		).c_str();
	}
#endif

	bool Validate()
	{
		uchar* pktStart = (uchar*)this;
		uint16 pktSize = mPktSize;

		uint16 dataSize = sizeof(PKT_GC_GUILD_AUCTION_BIDDER_INFO_LIST_READ);
		if (dataSize > mPktSize)
			return false;

		if (false == ValidateValue(pktStart, pktSize, dataSize))
			return false;

		if (false == AuctionBidderInfoValidateListNode(mFirstAuctionBidderInfoOffset, pktStart, pktSize, dataSize))
			return false;

		if (dataSize != mPktSize)
			return false;

		return true;
	}

	bool AuctionBidderInfoValidateListNode(uint16 offset, uchar * pktStart, uint16 pktSize, uint16& dataSize)
	{		for (AuctionBidderInfoIterator iter = this->GetFirstAuctionBidderInfoIterator();
			iter != GetLastAuctionBidderInfoIterator(); ++iter)
		{
			if (false == (*iter).Validate(offset, pktStart, pktSize, dataSize))
			{
				return false;
			}
		}
		return true;
	}

	bool ValidateValue(const uchar* pktStart, uint16 pktSize, uint16& dataSize)
	{
		return (nullptr != pktStart && 0 < pktSize && 0 < dataSize) ? true : false;
	}

