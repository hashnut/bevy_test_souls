	{
	protected:
		uint16 mThisOffset;
		uint16 mNextOffset;
		AgitDungeonRaidId mRaidId;
		AgitDungeonRaidState mState;

	public:
		const AgitDungeonRaidId& ConstRefRaidId() { return mRaidId; }
		AgitDungeonRaidId RaidId() { return mRaidId; }
		const AgitDungeonRaidState& ConstRefState() { return mState; }
		AgitDungeonRaidState State() { return mState; }

