		bool Validate(uint16 offset, uchar * pktStart, uint16 pktSize, uint16& dataSize)
		{
			if (static_cast<size_t>(pktSize) < static_cast<size_t>(offset) + sizeof(EntrymemberList))
				return false;

			EntrymemberList * node = (EntrymemberList*)(pktStart + offset);

			// ŔÚ±â ŔÚ˝ĹŔÇ Ć÷ŔÎĹÍ °ËÁő
			if (offset != node->mThisOffset)
				return false;

			// Value °ËÁő
			uchar* pktCurrentNodeStart = (uchar*)this - mThisOffset;
			uint16 pktCurrentNodeSize = *((uint16*)pktStart);
			dataSize += sizeof(EntrymemberList);	// skip
			if (false == ValidateValue(pktCurrentNodeStart, pktCurrentNodeSize, dataSize))
				return false;

			return true;
		}

		bool ValidateValue(const uchar* pktStart, uint16 pktSize, uint16& dataSize)
		{
			return (nullptr != pktStart && 0 < pktSize && 0 < dataSize) ? true : false;
		}

	}; // EntrymemberList

public:
	uint16 mPktSize;
	uint16 mPktId;
	uint16 mEntrymemberListCount;
	uint16 mFirstEntrymemberListOffset;
	GuildWarState mState;
	MapId mMapId;
	time_t mStateEndTime;
	uint8 mMaxUserCnt;

public:
#ifdef _SERVER 
	bool GetServerTaskIdRealTime(OUT [[maybe_unused]] int& serverTaskId) const { return false; }
	const wchar_t* GetPacketName() const { return L"GC_GUILDWAR_INFO"; }
	const wchar_t* GetRelatedPacketName() const { return L"CG_GUILDWAR_INFO"; }
#endif

	const GuildWarState& ConstRefState() { return mState; }
	GuildWarState State() { return mState; }
	MapId MapId() { return mMapId; }
	time_t StateEndTime() { return mStateEndTime; }
	uint8 MaxUserCnt() { return mMaxUserCnt; }

	using EntrymemberListIterator = PktIterator<EntrymemberList>;
	const EntrymemberListIterator GetLastEntrymemberListIterator() const
	{
		return EntrymemberListIterator(0);
	}
	EntrymemberListIterator GetFirstEntrymemberListIterator() const
	{
		if (mFirstEntrymemberListOffset && mPktSize >= mFirstEntrymemberListOffset + sizeof(EntrymemberList))
		{
			EntrymemberList* entrymemberList = (EntrymemberList*)((uchar*)this + mFirstEntrymemberListOffset);
			if (mFirstEntrymemberListOffset == entrymemberList->mThisOffset)
				return EntrymemberListIterator(entrymemberList);
			else
				return EntrymemberListIterator(0);
		}
		else
			return EntrymemberListIterator(0);
	}
	const int GetEntrymemberListCount()
	{
		return mEntrymemberListCount;
	}
#ifdef _SERVER
	template<typename TFunc>
	void ForEachEntrymemberList(TFunc&& func)
	{
		for (auto it = GetFirstEntrymemberListIterator(); it != GetLastEntrymemberListIterator(); ++it)
			func(it);
	}
#endif


#ifdef _SERVER 
	std::xwstring FuncCreateEntrymemberListStr( [[maybe_unused]] EntrymemberListIterator& iter) const
	{
		return Log::format(
			L"Member: {}", 
			iter->Member()
		).c_str();
	}

	std::xwstring GetLogWString() const
	{
		std::xwstring str1;
		str1.append(L"\n");
		for (EntrymemberListIterator iter = this->GetFirstEntrymemberListIterator();
			iter != GetLastEntrymemberListIterator(); ++iter)
		{
			str1.append(L"[");
			str1.append(FuncCreateEntrymemberListStr(iter).c_str());

			str1.append(L"]\n");
		}

		return Log::format(
			L"[GC_GUILDWAR_INFO] State: {}, MapId: {}, StateEndTime: {}, MaxUserCnt: {}, EntrymemberList : {}"
			, mState, mMapId, mStateEndTime, mMaxUserCnt, str1.c_str()
		).c_str();
	}
#endif

