// type = GC
// related packet = PKT_CG_REQ_WDMARKET_CALCULATED_LIST_WRITE
struct PKT_GC_ACK_WDMARKET_CALCULATED_LIST_READ
{
	struct CalculatedList
	{
	protected:
		uint16 mThisOffset;
		uint16 mNextOffset;
		MarketTransactionId mMarketTransactionId;
		ItemId mItemId;
		Level mLevel;
		ItemAmount mAmount;
		MarketPrice mPrice;
		MarketPrice mCalculatedPrice;
		time_t mTimeSalesComplete;

	public:
		MarketTransactionId MarketTransactionId() { return mMarketTransactionId; }
		ItemId ItemId() { return mItemId; }
		Level Level() { return mLevel; }
		ItemAmount Amount() { return mAmount; }
		MarketPrice Price() { return mPrice; }
		MarketPrice CalculatedPrice() { return mCalculatedPrice; }
		time_t TimeSalesComplete() { return mTimeSalesComplete; }

		friend PktIterator<CalculatedList>;
		friend PKT_GC_ACK_WDMARKET_CALCULATED_LIST_READ;

		bool Validate(uint16 offset, uchar * pktStart, uint16 pktSize, uint16& dataSize)
		{
			if (static_cast<size_t>(pktSize) < static_cast<size_t>(offset) + sizeof(CalculatedList))
				return false;

			CalculatedList * node = (CalculatedList*)(pktStart + offset);

			// ŔÚ±â ŔÚ˝ĹŔÇ Ć÷ŔÎĹÍ °ËÁő
			if (offset != node->mThisOffset)
				return false;

			// Value °ËÁő
			uchar* pktCurrentNodeStart = (uchar*)this - mThisOffset;
			uint16 pktCurrentNodeSize = *((uint16*)pktStart);
			dataSize += sizeof(CalculatedList);	// skip
			if (false == ValidateValue(pktCurrentNodeStart, pktCurrentNodeSize, dataSize))
				return false;

			return true;
		}

		bool ValidateValue(const uchar* pktStart, uint16 pktSize, uint16& dataSize)
		{
			return (nullptr != pktStart && 0 < pktSize && 0 < dataSize) ? true : false;
		}

	}; // CalculatedList

public:
	uint16 mPktSize;
	uint16 mPktId;
	uint16 mCalculatedListCount;
	uint16 mFirstCalculatedListOffset;
	uint16 mTotalCalculatedCount;
	MarketPrice mTotalCalculatedPrice;

public:
#ifdef _SERVER 
	bool GetServerTaskIdRealTime(OUT [[maybe_unused]] int& serverTaskId) const { return false; }
	const wchar_t* GetPacketName() const { return L"GC_ACK_WDMARKET_CALCULATED_LIST"; }
	const wchar_t* GetRelatedPacketName() const { return L"CG_REQ_WDMARKET_CALCULATED_LIST"; }
#endif

	uint16 TotalCalculatedCount() { return mTotalCalculatedCount; }
	MarketPrice TotalCalculatedPrice() { return mTotalCalculatedPrice; }

	using CalculatedListIterator = PktIterator<CalculatedList>;
	const CalculatedListIterator GetLastCalculatedListIterator() const
	{
		return CalculatedListIterator(0);
	}
	CalculatedListIterator GetFirstCalculatedListIterator() const
	{
		if (mFirstCalculatedListOffset && mPktSize >= mFirstCalculatedListOffset + sizeof(CalculatedList))
		{
			CalculatedList* calculatedList = (CalculatedList*)((uchar*)this + mFirstCalculatedListOffset);
			if (mFirstCalculatedListOffset == calculatedList->mThisOffset)
				return CalculatedListIterator(calculatedList);
			else
				return CalculatedListIterator(0);
		}
		else
			return CalculatedListIterator(0);
	}
	const int GetCalculatedListCount()
	{
		return mCalculatedListCount;
	}
#ifdef _SERVER
	template<typename TFunc>
	void ForEachCalculatedList(TFunc&& func)
	{
		for (auto it = GetFirstCalculatedListIterator(); it != GetLastCalculatedListIterator(); ++it)
			func(it);
	}
#endif


#ifdef _SERVER 
	std::xwstring FuncCreateCalculatedListStr( [[maybe_unused]] CalculatedListIterator& iter) const
	{
		return Log::format(
			L"MarketTransactionId: {}, ItemId: {}, Level: {}, Amount: {}, Price: {}, CalculatedPrice: {}, TimeSalesComplete: {}", 
			iter->MarketTransactionId(), iter->ItemId(), iter->Level(), iter->Amount(), iter->Price(), iter->CalculatedPrice(), iter->TimeSalesComplete()
		).c_str();
	}

	std::xwstring GetLogWString() const
	{
		std::xwstring str1;
		str1.append(L"\n");
		for (CalculatedListIterator iter = this->GetFirstCalculatedListIterator();
			iter != GetLastCalculatedListIterator(); ++iter)
		{
			str1.append(L"[");
			str1.append(FuncCreateCalculatedListStr(iter).c_str());

			str1.append(L"]\n");
		}

		return Log::format(
			L"[GC_ACK_WDMARKET_CALCULATED_LIST] TotalCalculatedCount: {}, TotalCalculatedPrice: {}, CalculatedList : {}"
			, mTotalCalculatedCount, mTotalCalculatedPrice, str1.c_str()
		).c_str();
	}
#endif

	bool Validate()
	{
		uchar* pktStart = (uchar*)this;
		uint16 pktSize = mPktSize;

		uint16 dataSize = sizeof(PKT_GC_ACK_WDMARKET_CALCULATED_LIST_READ);
		if (dataSize > mPktSize)
			return false;

		if (false == ValidateValue(pktStart, pktSize, dataSize))
			return false;

		if (false == CalculatedListValidateListNode(mFirstCalculatedListOffset, pktStart, pktSize, dataSize))
			return false;

		if (dataSize != mPktSize)
			return false;

		return true;
	}

	bool CalculatedListValidateListNode(uint16 offset, uchar * pktStart, uint16 pktSize, uint16& dataSize)
	{		for (CalculatedListIterator iter = this->GetFirstCalculatedListIterator();
			iter != GetLastCalculatedListIterator(); ++iter)
		{
			if (false == (*iter).Validate(offset, pktStart, pktSize, dataSize))
			{
				return false;
			}
		}
		return true;
	}

	bool ValidateValue(const uchar* pktStart, uint16 pktSize, uint16& dataSize)
	{
		return (nullptr != pktStart && 0 < pktSize && 0 < dataSize) ? true : false;
	}

}; // PKT_GC_ACK_WDMARKET_CALCULATED_LIST_READ

