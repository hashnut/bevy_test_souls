// type = GC
// related packet = PKT_CG_REQ_CONTINENT_TAX_WRITE
struct PKT_GC_ACK_CONTINENT_TAX_READ
{
	struct ContinentList
	{
	protected:
		uint16 mThisOffset;
		uint16 mNextOffset;
		ContinentId mContinentId;
		GuildDBId mGuildDBId;
		Currency mAccumul_Gold;
		Currency mAccumul_Dia;
		time_t mStartAccumlateTime;
		time_t mEndAccumlateTime;

	public:
		ContinentId ContinentId() { return mContinentId; }
		GuildDBId GuildDBId() { return mGuildDBId; }
		Currency Accumul_Gold() { return mAccumul_Gold; }
		Currency Accumul_Dia() { return mAccumul_Dia; }
		time_t StartAccumlateTime() { return mStartAccumlateTime; }
		time_t EndAccumlateTime() { return mEndAccumlateTime; }

		friend PktIterator<ContinentList>;
		friend PKT_GC_ACK_CONTINENT_TAX_READ;

		bool Validate(uint16 offset, uchar * pktStart, uint16 pktSize, uint16& dataSize)
		{
			if (static_cast<size_t>(pktSize) < static_cast<size_t>(offset) + sizeof(ContinentList))
				return false;

			ContinentList * node = (ContinentList*)(pktStart + offset);

			// ŔÚ±â ŔÚ˝ĹŔÇ Ć÷ŔÎĹÍ °ËÁő
			if (offset != node->mThisOffset)
				return false;

			// Value °ËÁő
			uchar* pktCurrentNodeStart = (uchar*)this - mThisOffset;
			uint16 pktCurrentNodeSize = *((uint16*)pktStart);
			dataSize += sizeof(ContinentList);	// skip
			if (false == ValidateValue(pktCurrentNodeStart, pktCurrentNodeSize, dataSize))
				return false;

			return true;
		}

		bool ValidateValue(const uchar* pktStart, uint16 pktSize, uint16& dataSize)
		{
			return (nullptr != pktStart && 0 < pktSize && 0 < dataSize) ? true : false;
		}

	}; // ContinentList

public:
	uint16 mPktSize;
	uint16 mPktId;
	uint16 mContinentListCount;
	uint16 mFirstContinentListOffset;

public:
#ifdef _SERVER 
	bool GetServerTaskIdRealTime(OUT [[maybe_unused]] int& serverTaskId) const { return false; }
	const wchar_t* GetPacketName() const { return L"GC_ACK_CONTINENT_TAX"; }
	const wchar_t* GetRelatedPacketName() const { return L"CG_REQ_CONTINENT_TAX"; }
#endif


	using ContinentListIterator = PktIterator<ContinentList>;
	const ContinentListIterator GetLastContinentListIterator() const
	{
		return ContinentListIterator(0);
	}
	ContinentListIterator GetFirstContinentListIterator() const
	{
		if (mFirstContinentListOffset && mPktSize >= mFirstContinentListOffset + sizeof(ContinentList))
		{
			ContinentList* continentList = (ContinentList*)((uchar*)this + mFirstContinentListOffset);
			if (mFirstContinentListOffset == continentList->mThisOffset)
				return ContinentListIterator(continentList);
			else
				return ContinentListIterator(0);
		}
		else
			return ContinentListIterator(0);
	}
	const int GetContinentListCount()
	{
		return mContinentListCount;
	}
#ifdef _SERVER
	template<typename TFunc>
	void ForEachContinentList(TFunc&& func)
	{
		for (auto it = GetFirstContinentListIterator(); it != GetLastContinentListIterator(); ++it)
			func(it);
	}
#endif


#ifdef _SERVER 
	std::xwstring FuncCreateContinentListStr( [[maybe_unused]] ContinentListIterator& iter) const
	{
		return Log::format(
			L"ContinentId: {}, GuildDBId: {}, Accumul_Gold: {}, Accumul_Dia: {}, StartAccumlateTime: {}, EndAccumlateTime: {}", 
			iter->ContinentId(), iter->GuildDBId(), iter->Accumul_Gold(), iter->Accumul_Dia(), iter->StartAccumlateTime(), iter->EndAccumlateTime()
		).c_str();
	}

	std::xwstring GetLogWString() const
	{
		std::xwstring str1;
		str1.append(L"\n");
		for (ContinentListIterator iter = this->GetFirstContinentListIterator();
			iter != GetLastContinentListIterator(); ++iter)
		{
			str1.append(L"[");
			str1.append(FuncCreateContinentListStr(iter).c_str());

			str1.append(L"]\n");
		}

		return Log::format(
			L"[GC_ACK_CONTINENT_TAX] ContinentList : {}"
			, str1.c_str()
		).c_str();
	}
#endif

	bool Validate()
	{
		uchar* pktStart = (uchar*)this;
		uint16 pktSize = mPktSize;

		uint16 dataSize = sizeof(PKT_GC_ACK_CONTINENT_TAX_READ);
		if (dataSize > mPktSize)
			return false;

		if (false == ValidateValue(pktStart, pktSize, dataSize))
			return false;

		if (false == ContinentListValidateListNode(mFirstContinentListOffset, pktStart, pktSize, dataSize))
			return false;

		if (dataSize != mPktSize)
			return false;

		return true;
	}

	bool ContinentListValidateListNode(uint16 offset, uchar * pktStart, uint16 pktSize, uint16& dataSize)
	{		for (ContinentListIterator iter = this->GetFirstContinentListIterator();
			iter != GetLastContinentListIterator(); ++iter)
		{
			if (false == (*iter).Validate(offset, pktStart, pktSize, dataSize))
			{
				return false;
			}
		}
		return true;
	}

	bool ValidateValue(const uchar* pktStart, uint16 pktSize, uint16& dataSize)
	{
		return (nullptr != pktStart && 0 < pktSize && 0 < dataSize) ? true : false;
	}

}; // PKT_GC_ACK_CONTINENT_TAX_READ

