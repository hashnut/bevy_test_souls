	using ListIterator = PktIterator<List>;
	const ListIterator GetLastListIterator() const
	{
		return ListIterator(0);
	}
	ListIterator GetFirstListIterator() const
	{
		if (mFirstListOffset && mPktSize >= mFirstListOffset + sizeof(List))
		{
			List* list = (List*)((uchar*)this + mFirstListOffset);
			if (mFirstListOffset == list->mThisOffset)
				return ListIterator(list);
			else
