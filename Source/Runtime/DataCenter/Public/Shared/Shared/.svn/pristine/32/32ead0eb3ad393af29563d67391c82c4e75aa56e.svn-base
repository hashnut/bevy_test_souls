struct PKT_GC_CHAT_WHISPER_LIST_OFF_LINE_READ
{
	struct WhisperChatList
	{
	protected:
		uint16 mThisOffset;
		uint16 mNextOffset;
		uint16 mSenderUserNameOffset;
		uint16 mReceiverUserNameOffset;
		uint16 mMessageOffset;
		time_t mTimeNow;
		AccountGrade mAccountGrade;
		Rank mUserRank;

	public:
		time_t TimeNow() { return mTimeNow; }
		AccountGrade AccountGrade() { return mAccountGrade; }
		Rank UserRank() { return mUserRank; }

#ifdef _SERVER
		const wchar_t* SenderUserName()
		{
			uchar* pktStart = (uchar*)this - mThisOffset;
			uint16 pktSize = *((uint16*)pktStart);
			if (mSenderUserNameOffset && pktSize > mSenderUserNameOffset)
				return (const wchar_t*)(pktStart + mSenderUserNameOffset);
			else
				return L"";
		}
#else // _SERVER
		const FString SenderUserName()
		{
			const wchar_t* strWchar = L"";
			uchar* pktStart = (uchar*)this - mThisOffset;
			uint16 pktSize = *((uint16*)pktStart);
			if (mSenderUserNameOffset && pktSize > mSenderUserNameOffset)
				strWchar = (const wchar_t*)(pktStart + mSenderUserNameOffset);
			return PktWriter::ConvertToFString(strWchar);
		}
#endif // _SERVER
#ifdef _SERVER
		const wchar_t* ReceiverUserName()
		{
			uchar* pktStart = (uchar*)this - mThisOffset;
			uint16 pktSize = *((uint16*)pktStart);
			if (mReceiverUserNameOffset && pktSize > mReceiverUserNameOffset)
				return (const wchar_t*)(pktStart + mReceiverUserNameOffset);
			else
				return L"";
		}
#else // _SERVER
		const FString ReceiverUserName()
		{
			const wchar_t* strWchar = L"";
			uchar* pktStart = (uchar*)this - mThisOffset;
			uint16 pktSize = *((uint16*)pktStart);
			if (mReceiverUserNameOffset && pktSize > mReceiverUserNameOffset)
				strWchar = (const wchar_t*)(pktStart + mReceiverUserNameOffset);
			return PktWriter::ConvertToFString(strWchar);
		}
#endif // _SERVER
#ifdef _SERVER
		const wchar_t* Message()
		{
			uchar* pktStart = (uchar*)this - mThisOffset;
			uint16 pktSize = *((uint16*)pktStart);
			if (mMessageOffset && pktSize > mMessageOffset)
				return (const wchar_t*)(pktStart + mMessageOffset);
			else
				return L"";
		}
#else // _SERVER
		const FString Message()
		{
			const wchar_t* strWchar = L"";
			uchar* pktStart = (uchar*)this - mThisOffset;
			uint16 pktSize = *((uint16*)pktStart);
			if (mMessageOffset && pktSize > mMessageOffset)
				strWchar = (const wchar_t*)(pktStart + mMessageOffset);
			return PktWriter::ConvertToFString(strWchar);
		}
#endif // _SERVER
		friend PktIterator<WhisperChatList>;
		friend PKT_GC_CHAT_WHISPER_LIST_OFF_LINE_READ;

		bool Validate(uint16 offset, uchar * pktStart, uint16 pktSize, uint16& dataSize)
		{
			if (static_cast<size_t>(pktSize) < static_cast<size_t>(offset) + sizeof(WhisperChatList))
				return false;

			WhisperChatList * node = (WhisperChatList*)(pktStart + offset);

			// ŔÚ±â ŔÚ˝ĹŔÇ Ć÷ŔÎĹÍ °ËÁő
			if (offset != node->mThisOffset)
				return false;

			// Value °ËÁő
			uchar* pktCurrentNodeStart = (uchar*)this - mThisOffset;
			uint16 pktCurrentNodeSize = *((uint16*)pktStart);
			dataSize += sizeof(WhisperChatList);	// skip
			if (false == ValidateValue(pktCurrentNodeStart, pktCurrentNodeSize, dataSize))
				return false;

			return true;
		}

		bool ValidateValue(const uchar* pktStart, uint16 pktSize, uint16& dataSize)
		{
			if (false == ValidateString(mSenderUserNameOffset, 0, pktStart, pktSize, dataSize))
				return false;

			if (false == ValidateString(mReceiverUserNameOffset, 0, pktStart, pktSize, dataSize))
				return false;

			if (false == ValidateString(mMessageOffset, 0, pktStart, pktSize, dataSize))
				return false;

			return (nullptr != pktStart && 0 < pktSize && 0 < dataSize) ? true : false;
		}

	}; // WhisperChatList

public:
	uint16 mPktSize;
	uint16 mPktId;
	uint16 mWhisperChatListCount;
	uint16 mFirstWhisperChatListOffset;

public:
#ifdef _SERVER 
	bool GetServerTaskIdRealTime(OUT [[maybe_unused]] int& serverTaskId) const { return false; }
	const wchar_t* GetPacketName() const { return L"GC_CHAT_WHISPER_LIST_OFF_LINE"; }
	const wchar_t* GetRelatedPacketName() const { return L"CG_CHAT_WHISPER_LIST_OFF_LINE"; }
#endif


	using WhisperChatListIterator = PktIterator<WhisperChatList>;
	const WhisperChatListIterator GetLastWhisperChatListIterator() const
	{
		return WhisperChatListIterator(0);
	}
	WhisperChatListIterator GetFirstWhisperChatListIterator() const
	{
		if (mFirstWhisperChatListOffset && mPktSize >= mFirstWhisperChatListOffset + sizeof(WhisperChatList))
		{
			WhisperChatList* whisperChatList = (WhisperChatList*)((uchar*)this + mFirstWhisperChatListOffset);
			if (mFirstWhisperChatListOffset == whisperChatList->mThisOffset)
				return WhisperChatListIterator(whisperChatList);
			else
				return WhisperChatListIterator(0);
		}
		else
			return WhisperChatListIterator(0);
	}
	const int GetWhisperChatListCount()
	{
		return mWhisperChatListCount;
	}
#ifdef _SERVER
	template<typename TFunc>
	void ForEachWhisperChatList(TFunc&& func)
	{
		for (auto it = GetFirstWhisperChatListIterator(); it != GetLastWhisperChatListIterator(); ++it)
			func(it);
	}
#endif


#ifdef _SERVER 
	std::xwstring FuncCreateWhisperChatListStr( [[maybe_unused]] WhisperChatListIterator& iter) const
	{
		return Log::format(
			L"SenderUserName: {}, ReceiverUserName: {}, Message: {}, TimeNow: {}, AccountGrade: {}, UserRank: {}", 
			iter->SenderUserName(), iter->ReceiverUserName(), iter->Message(), iter->TimeNow(), iter->AccountGrade(), iter->UserRank()
		).c_str();
	}

	std::xwstring GetLogWString() const
	{
		std::xwstring str1;
		str1.append(L"\n");
		for (WhisperChatListIterator iter = this->GetFirstWhisperChatListIterator();
			iter != GetLastWhisperChatListIterator(); ++iter)
		{
			str1.append(L"[");
			str1.append(FuncCreateWhisperChatListStr(iter).c_str());

			str1.append(L"]\n");
		}

		return Log::format(
			L"[GC_CHAT_WHISPER_LIST_OFF_LINE] WhisperChatList : {}"
			, str1.c_str()
		).c_str();
	}
#endif

	bool Validate()
	{
		uchar* pktStart = (uchar*)this;
		uint16 pktSize = mPktSize;

		uint16 dataSize = sizeof(PKT_GC_CHAT_WHISPER_LIST_OFF_LINE_READ);
		if (dataSize > mPktSize)
			return false;

		if (false == ValidateValue(pktStart, pktSize, dataSize))
			return false;

		if (false == WhisperChatListValidateListNode(mFirstWhisperChatListOffset, pktStart, pktSize, dataSize))
			return false;

		if (dataSize != mPktSize)
			return false;

		return true;
	}

	bool WhisperChatListValidateListNode(uint16 offset, uchar * pktStart, uint16 pktSize, uint16& dataSize)
	{		for (WhisperChatListIterator iter = this->GetFirstWhisperChatListIterator();
			iter != GetLastWhisperChatListIterator(); ++iter)
		{
			if (false == (*iter).Validate(offset, pktStart, pktSize, dataSize))
			{
				return false;
			}
		}
		return true;
	}

	bool ValidateValue(const uchar* pktStart, uint16 pktSize, uint16& dataSize)
	{
		return (nullptr != pktStart && 0 < pktSize && 0 < dataSize) ? true : false;
	}

}; // PKT_GC_CHAT_WHISPER_LIST_OFF_LINE_READ

