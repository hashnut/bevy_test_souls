// type = GC
// related packet = PKT_CG_REQ_KEYBOARD_MAPPING_LOAD_WRITE
struct PKT_GC_ACK_KEYBOARD_MAPPING_LOAD_READ
{
	struct KeyList
	{
	protected:
		uint16 mThisOffset;
		uint16 mNextOffset;
		uint8 mMulti;
		uint32 mKey0;
		uint32 mKey1;
		uint8 mAction;
		float mScaling;

	public:
		uint8 Multi() { return mMulti; }
		uint32 Key0() { return mKey0; }
		uint32 Key1() { return mKey1; }
		uint8 Action() { return mAction; }
		float Scaling() { return mScaling; }

		friend PktIterator<KeyList>;
		friend PKT_GC_ACK_KEYBOARD_MAPPING_LOAD_READ;

		bool Validate(uint16 offset, uchar * pktStart, uint16 pktSize, uint16& dataSize)
		{
			if (static_cast<size_t>(pktSize) < static_cast<size_t>(offset) + sizeof(KeyList))
				return false;

			KeyList * node = (KeyList*)(pktStart + offset);

			// ŔÚ±â ŔÚ˝ĹŔÇ Ć÷ŔÎĹÍ °ËÁő
			if (offset != node->mThisOffset)
				return false;

			// Value °ËÁő
			uchar* pktCurrentNodeStart = (uchar*)this - mThisOffset;
			uint16 pktCurrentNodeSize = *((uint16*)pktStart);
			dataSize += sizeof(KeyList);	// skip
			if (false == ValidateValue(pktCurrentNodeStart, pktCurrentNodeSize, dataSize))
				return false;

			return true;
		}

		bool ValidateValue(const uchar* pktStart, uint16 pktSize, uint16& dataSize)
		{
			return (nullptr != pktStart && 0 < pktSize && 0 < dataSize) ? true : false;
		}

	}; // KeyList

public:
	uint16 mPktSize;
	uint16 mPktId;
	uint16 mKeyListCount;
	uint16 mFirstKeyListOffset;
	int mResult;

public:
#ifdef _SERVER 
	bool GetServerTaskIdRealTime(OUT [[maybe_unused]] int& serverTaskId) const { return false; }
	const wchar_t* GetPacketName() const { return L"GC_ACK_KEYBOARD_MAPPING_LOAD"; }
	const wchar_t* GetRelatedPacketName() const { return L"CG_REQ_KEYBOARD_MAPPING_LOAD"; }
#endif

	int Result() { return mResult; }

	using KeyListIterator = PktIterator<KeyList>;
	const KeyListIterator GetLastKeyListIterator() const
	{
		return KeyListIterator(0);
	}
	KeyListIterator GetFirstKeyListIterator() const
	{
		if (mFirstKeyListOffset && mPktSize >= mFirstKeyListOffset + sizeof(KeyList))
		{
			KeyList* keyList = (KeyList*)((uchar*)this + mFirstKeyListOffset);
			if (mFirstKeyListOffset == keyList->mThisOffset)
				return KeyListIterator(keyList);
			else
				return KeyListIterator(0);
		}
		else
			return KeyListIterator(0);
	}
	const int GetKeyListCount()
	{
		return mKeyListCount;
	}
#ifdef _SERVER
	template<typename TFunc>
	void ForEachKeyList(TFunc&& func)
	{
		for (auto it = GetFirstKeyListIterator(); it != GetLastKeyListIterator(); ++it)
			func(it);
	}
#endif


#ifdef _SERVER 
	std::xwstring FuncCreateKeyListStr( [[maybe_unused]] KeyListIterator& iter) const
	{
		return Log::format(
			L"Multi: {}, Key0: {}, Key1: {}, Action: {}, Scaling: {}", 
			iter->Multi(), iter->Key0(), iter->Key1(), iter->Action(), iter->Scaling()
		).c_str();
	}

	std::xwstring GetLogWString() const
	{
		std::xwstring str1;
		str1.append(L"\n");
		for (KeyListIterator iter = this->GetFirstKeyListIterator();
			iter != GetLastKeyListIterator(); ++iter)
		{
			str1.append(L"[");
			str1.append(FuncCreateKeyListStr(iter).c_str());

			str1.append(L"]\n");
		}

		return Log::format(
			L"[GC_ACK_KEYBOARD_MAPPING_LOAD] Result: {}, KeyList : {}"
			, mResult, str1.c_str()
		).c_str();
	}
#endif

	bool Validate()
	{
		uchar* pktStart = (uchar*)this;
		uint16 pktSize = mPktSize;

		uint16 dataSize = sizeof(PKT_GC_ACK_KEYBOARD_MAPPING_LOAD_READ);
		if (dataSize > mPktSize)
			return false;

		if (false == ValidateValue(pktStart, pktSize, dataSize))
			return false;

		if (false == KeyListValidateListNode(mFirstKeyListOffset, pktStart, pktSize, dataSize))
			return false;

		if (dataSize != mPktSize)
			return false;

		return true;
	}

	bool KeyListValidateListNode(uint16 offset, uchar * pktStart, uint16 pktSize, uint16& dataSize)
	{		for (KeyListIterator iter = this->GetFirstKeyListIterator();
			iter != GetLastKeyListIterator(); ++iter)
		{
			if (false == (*iter).Validate(offset, pktStart, pktSize, dataSize))
			{
				return false;
			}
		}
		return true;
	}

	bool ValidateValue(const uchar* pktStart, uint16 pktSize, uint16& dataSize)
	{
		return (nullptr != pktStart && 0 < pktSize && 0 < dataSize) ? true : false;
	}

}; // PKT_GC_ACK_KEYBOARD_MAPPING_LOAD_READ

