// type = GC
struct PKT_GC_ACK_BUDDY_SEND_FRIENDSHIP_READ
{
public:
	uint16 mPktSize;
	uint16 mPktId;
	uint16 mResultAccountIdListOffset;
	uint16 mResultAccountIdListSize;

public:
#ifdef _SERVER 
	using _T0 = AccountDBId;
	bool GetServerTaskIdRealTime(OUT [[maybe_unused]] int& serverTaskId) const { return false; }
	const wchar_t* GetPacketName() const { return L"GC_ACK_BUDDY_SEND_FRIENDSHIP"; }
	const wchar_t* GetRelatedPacketName() const { return L"CG_REQ_BUDDY_SEND_FRIENDSHIP"; }
#endif

	const uchar* ResultAccountIdList() const
	{
		uchar* pktStart = (uchar*)this;
		uint16 pktSize = *((uint16*)pktStart);
		if (mResultAccountIdListOffset && pktSize > mResultAccountIdListOffset)
			return (const uchar*)(pktStart + mResultAccountIdListOffset);
		else
			return 0;
	}
	int ResultAccountIdListSize() const
	{
		return mResultAccountIdListSize;
	}
#ifdef _SERVER
	template <typename Container>
	void MakeResultAccountIdListVector(Container & container)
	{
		//emplace() ČŁĂâÇŇ¶§¸¶´Ů ¸Ţ¸đ¸®¸¦ »ýĽş ÇĎ´Â şńżëŔĚ ąß»ýÇŃ´Ů şńżëŔ»ÁŮŔĚŔ§°ł reserve()»çżë
		container.reserve(mResultAccountIdListSize/sizeof(_T0));
		for (int offset = 0; offset < mResultAccountIdListSize; offset += sizeof(_T0))
		{
			const _T0* data = reinterpret_cast<const _T0*>(ResultAccountIdList() + offset);
			container.emplace_back(*data);
		}
	}
#else // _SERVER
	template <typename Container, typename Data>
	void MakeResultAccountIdListVector(Container & container)
	{
		for (int offset = 0; offset < mResultAccountIdListSize; offset += sizeof(Data))
		{
			const Data* data = reinterpret_cast<const Data*>(ResultAccountIdList() + offset);
			container.Add(*data);
		}
	}
#endif // _SERVER
#ifdef _SERVER
	template <typename TFunc>
	void ForEachResultAccountIdList(TFunc&& func) const
	{
		for (int offset = 0; offset < ResultAccountIdListSize(); offset += sizeof(_T0))
		{
			const _T0* data = reinterpret_cast<const _T0*>(ResultAccountIdList() + offset);
			func(data);
		}
	}
#endif


#ifdef _SERVER 
	std::xwstring GetLogWString() const
	{
		std::wstringstream ResultAccountIdListStream; 
		ResultAccountIdListStream << std::endl;
		ForEachResultAccountIdList(
			[&ResultAccountIdListStream](const AccountDBId* Id) {
				ResultAccountIdListStream << "[" << static_cast<size_t>(*Id) << "]" << std::endl;
				}
			);


		return Log::format(
			L"[GC_ACK_BUDDY_SEND_FRIENDSHIP] ResultAccountIdList: {}"
			, ResultAccountIdListStream.str().c_str()
		).c_str();
	}
#endif

	bool Validate()
	{
		uchar* pktStart = (uchar*)this;
		uint16 pktSize = mPktSize;

		uint16 dataSize = sizeof(PKT_GC_ACK_BUDDY_SEND_FRIENDSHIP_READ);
		if (dataSize > mPktSize)
			return false;

		if (false == ValidateValue(pktStart, pktSize, dataSize))
			return false;

		if (dataSize != mPktSize)
			return false;

		return true;
	}

	bool ValidateValue(const uchar* pktStart, uint16 pktSize, uint16& dataSize)
	{
		if (false == ValidateBinary(mResultAccountIdListOffset, mResultAccountIdListSize, 0, pktSize, dataSize))
			return false;

