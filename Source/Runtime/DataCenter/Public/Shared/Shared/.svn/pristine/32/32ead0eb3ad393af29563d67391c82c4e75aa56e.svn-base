	struct HostileGuildList
	{
	protected:
		uint16 mThisOffset;
		uint16 mNextOffset;
		GuildDBId mGuildId;

	public:
		GuildDBId GuildId() { return mGuildId; }

		friend PktIterator<HostileGuildList>;
		friend PKT_GC_MY_GUILD_INFO_READ;

		bool Validate(uint16 offset, uchar * pktStart, uint16 pktSize, uint16& dataSize)
		{
			if (static_cast<size_t>(pktSize) < static_cast<size_t>(offset) + sizeof(HostileGuildList))
				return false;

			HostileGuildList * node = (HostileGuildList*)(pktStart + offset);

			// ŔÚ±â ŔÚ˝ĹŔÇ Ć÷ŔÎĹÍ °ËÁő
			if (offset != node->mThisOffset)
				return false;

			// Value °ËÁő
			uchar* pktCurrentNodeStart = (uchar*)this - mThisOffset;
			uint16 pktCurrentNodeSize = *((uint16*)pktStart);
			dataSize += sizeof(HostileGuildList);	// skip
			if (false == ValidateValue(pktCurrentNodeStart, pktCurrentNodeSize, dataSize))
				return false;

			return true;
		}

		bool ValidateValue(const uchar* pktStart, uint16 pktSize, uint16& dataSize)
		{
			return (nullptr != pktStart && 0 < pktSize && 0 < dataSize) ? true : false;
		}

	}; // HostileGuildList

