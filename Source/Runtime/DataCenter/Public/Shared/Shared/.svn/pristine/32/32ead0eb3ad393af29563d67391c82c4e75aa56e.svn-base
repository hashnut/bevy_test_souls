		{
			const wchar_t* strWchar = L"";
			uchar* pktStart = (uchar*)this - mThisOffset;
			uint16 pktSize = *((uint16*)pktStart);
			if (mGuildNameOffset && pktSize > mGuildNameOffset)
				strWchar = (const wchar_t*)(pktStart + mGuildNameOffset);
			return PktWriter::ConvertToFString(strWchar);
		}
#endif // _SERVER
#ifdef _SERVER
		const wchar_t* UserName()
		{
			uchar* pktStart = (uchar*)this - mThisOffset;
			uint16 pktSize = *((uint16*)pktStart);
			if (mUserNameOffset && pktSize > mUserNameOffset)
				return (const wchar_t*)(pktStart + mUserNameOffset);
			else
				return L"";
		}
#else // _SERVER
		const FString UserName()
		{
			const wchar_t* strWchar = L"";
			uchar* pktStart = (uchar*)this - mThisOffset;
			uint16 pktSize = *((uint16*)pktStart);
			if (mUserNameOffset && pktSize > mUserNameOffset)
				strWchar = (const wchar_t*)(pktStart + mUserNameOffset);
			return PktWriter::ConvertToFString(strWchar);
		}
#endif // _SERVER
#ifdef _SERVER
		const wchar_t* Message()
		{
			uchar* pktStart = (uchar*)this - mThisOffset;
			uint16 pktSize = *((uint16*)pktStart);
			if (mMessageOffset && pktSize > mMessageOffset)
				return (const wchar_t*)(pktStart + mMessageOffset);
			else
				return L"";
		}
#else // _SERVER
		const FString Message()
		{
			const wchar_t* strWchar = L"";
			uchar* pktStart = (uchar*)this - mThisOffset;
			uint16 pktSize = *((uint16*)pktStart);
			if (mMessageOffset && pktSize > mMessageOffset)
				strWchar = (const wchar_t*)(pktStart + mMessageOffset);
			return PktWriter::ConvertToFString(strWchar);
		}
#endif // _SERVER
#ifdef _SERVER
		const wchar_t* HomeWorldPrefix()
		{
			uchar* pktStart = (uchar*)this - mThisOffset;
			uint16 pktSize = *((uint16*)pktStart);
			if (mHomeWorldPrefixOffset && pktSize > mHomeWorldPrefixOffset)
				return (const wchar_t*)(pktStart + mHomeWorldPrefixOffset);
			else
				return L"";
		}
#else // _SERVER
		const FString HomeWorldPrefix()
		{
			const wchar_t* strWchar = L"";
			uchar* pktStart = (uchar*)this - mThisOffset;
			uint16 pktSize = *((uint16*)pktStart);
			if (mHomeWorldPrefixOffset && pktSize > mHomeWorldPrefixOffset)
				strWchar = (const wchar_t*)(pktStart + mHomeWorldPrefixOffset);
			return PktWriter::ConvertToFString(strWchar);
		}
#endif // _SERVER
		friend PktIterator<GuildChatList>;
		friend PKT_GC_GUILD_ALLY_CHAT_LIST_RECENT_READ;

		bool Validate(uint16 offset, uchar * pktStart, uint16 pktSize, uint16& dataSize)
		{
			if (static_cast<size_t>(pktSize) < static_cast<size_t>(offset) + sizeof(GuildChatList))
				return false;

			GuildChatList * node = (GuildChatList*)(pktStart + offset);

			// ŔÚ±â ŔÚ˝ĹŔÇ Ć÷ŔÎĹÍ °ËÁő
			if (offset != node->mThisOffset)
				return false;

			// Value °ËÁő
			uchar* pktCurrentNodeStart = (uchar*)this - mThisOffset;
			uint16 pktCurrentNodeSize = *((uint16*)pktStart);
			dataSize += sizeof(GuildChatList);	// skip
			if (false == ValidateValue(pktCurrentNodeStart, pktCurrentNodeSize, dataSize))
				return false;

			return true;
		}

		bool ValidateValue(const uchar* pktStart, uint16 pktSize, uint16& dataSize)
		{
			if (false == ValidateString(mGuildNameOffset, 0, pktStart, pktSize, dataSize))
				return false;

			if (false == ValidateString(mUserNameOffset, 0, pktStart, pktSize, dataSize))
				return false;

			if (false == ValidateString(mMessageOffset, 0, pktStart, pktSize, dataSize))
				return false;

			if (false == ValidateString(mHomeWorldPrefixOffset, 0, pktStart, pktSize, dataSize))
				return false;

			return (nullptr != pktStart && 0 < pktSize && 0 < dataSize) ? true : false;
		}

	}; // GuildChatList

public:
	uint16 mPktSize;
	uint16 mPktId;
	uint16 mGuildChatListCount;
	uint16 mFirstGuildChatListOffset;

public:
#ifdef _SERVER 
	bool GetServerTaskIdRealTime(OUT [[maybe_unused]] int& serverTaskId) const { return false; }
	const wchar_t* GetPacketName() const { return L"GC_GUILD_ALLY_CHAT_LIST_RECENT"; }
	const wchar_t* GetRelatedPacketName() const { return L"CG_GUILD_ALLY_CHAT_LIST_RECENT"; }
#endif


	using GuildChatListIterator = PktIterator<GuildChatList>;
	const GuildChatListIterator GetLastGuildChatListIterator() const
	{
		return GuildChatListIterator(0);
	}
	GuildChatListIterator GetFirstGuildChatListIterator() const
	{
		if (mFirstGuildChatListOffset && mPktSize >= mFirstGuildChatListOffset + sizeof(GuildChatList))
		{
			GuildChatList* guildChatList = (GuildChatList*)((uchar*)this + mFirstGuildChatListOffset);
			if (mFirstGuildChatListOffset == guildChatList->mThisOffset)
				return GuildChatListIterator(guildChatList);
			else
				return GuildChatListIterator(0);
		}
		else
			return GuildChatListIterator(0);
	}
	const int GetGuildChatListCount()
	{
		return mGuildChatListCount;
	}
#ifdef _SERVER
	template<typename TFunc>
	void ForEachGuildChatList(TFunc&& func)
	{
		for (auto it = GetFirstGuildChatListIterator(); it != GetLastGuildChatListIterator(); ++it)
			func(it);
	}
#endif


#ifdef _SERVER 
	std::xwstring FuncCreateGuildChatListStr( [[maybe_unused]] GuildChatListIterator& iter) const
	{
		return Log::format(
			L"GuildName: {}, GuildId: {}, GuildChatDBId: {}, GuildEmblemId: {}, UserName: {}, Message: {}, MessageTime: {}, HomeWorldId: {}, HomeWorldPrefix: {}, AccountGrade: {}", 
			iter->GuildName(), iter->GuildId(), iter->GuildChatDBId(), iter->GuildEmblemId(), iter->UserName(), iter->Message(), iter->MessageTime(), iter->HomeWorldId(), iter->HomeWorldPrefix(), iter->AccountGrade()
		).c_str();
	}

	std::xwstring GetLogWString() const
	{
		std::xwstring str1;
		str1.append(L"\n");
		for (GuildChatListIterator iter = this->GetFirstGuildChatListIterator();
			iter != GetLastGuildChatListIterator(); ++iter)
		{
			str1.append(L"[");
			str1.append(FuncCreateGuildChatListStr(iter).c_str());

			str1.append(L"]\n");
		}

		return Log::format(
			L"[GC_GUILD_ALLY_CHAT_LIST_RECENT] GuildChatList : {}"
			, str1.c_str()
		).c_str();
	}
#endif

	bool Validate()
	{
		uchar* pktStart = (uchar*)this;
		uint16 pktSize = mPktSize;

		uint16 dataSize = sizeof(PKT_GC_GUILD_ALLY_CHAT_LIST_RECENT_READ);
		if (dataSize > mPktSize)
			return false;

		if (false == ValidateValue(pktStart, pktSize, dataSize))
			return false;

		if (false == GuildChatListValidateListNode(mFirstGuildChatListOffset, pktStart, pktSize, dataSize))
			return false;

		if (dataSize != mPktSize)
			return false;

		return true;
	}

	bool GuildChatListValidateListNode(uint16 offset, uchar * pktStart, uint16 pktSize, uint16& dataSize)
	{		for (GuildChatListIterator iter = this->GetFirstGuildChatListIterator();
			iter != GetLastGuildChatListIterator(); ++iter)
		{
			if (false == (*iter).Validate(offset, pktStart, pktSize, dataSize))
			{
				return false;
			}
		}
		return true;
	}

	bool ValidateValue(const uchar* pktStart, uint16 pktSize, uint16& dataSize)
	{
		return (nullptr != pktStart && 0 < pktSize && 0 < dataSize) ? true : false;
	}

}; // PKT_GC_GUILD_ALLY_CHAT_LIST_RECENT_READ

