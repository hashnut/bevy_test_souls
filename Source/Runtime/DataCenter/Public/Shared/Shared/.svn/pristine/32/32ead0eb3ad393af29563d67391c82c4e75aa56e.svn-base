#ifdef _SERVER 
	std::xwstring FuncCreateEnterUserListStr( [[maybe_unused]] EnterUserListIterator& iter) const
	{
		return Log::format(
			L"Level: {}, UserName: {}", 
			iter->Level(), iter->UserName()
		).c_str();
	}

	std::xwstring FuncCreateRankingUserListStr( [[maybe_unused]] RankingUserListIterator& iter) const
	{
		return Log::format(
			L"UserName: {}, ContributePoint: {}", 
			iter->UserName(), iter->ContributePoint()
		).c_str();
	}

	std::xwstring GetLogWString() const
	{
		std::xwstring str1;
		str1.append(L"\n");
		for (EnterUserListIterator iter = this->GetFirstEnterUserListIterator();
			iter != GetLastEnterUserListIterator(); ++iter)
		{
			str1.append(L"[");
			str1.append(FuncCreateEnterUserListStr(iter).c_str());

			str1.append(L"]\n");
		}
		std::xwstring str2;
		str2.append(L"\n");
		for (RankingUserListIterator iter = this->GetFirstRankingUserListIterator();
			iter != GetLastRankingUserListIterator(); ++iter)
		{
			str2.append(L"[");
			str2.append(FuncCreateRankingUserListStr(iter).c_str());

			str2.append(L"]\n");
		}

		return Log::format(
			L"[GC_ACK_OPEN_GUILD_DUNGEON_INFO] Level: {}, TicketCount: {}, BossHpRate: {}, ResetDateTime: {}, Allclear: {}, EnterUserList : {}, RankingUserList : {}"
			, mLevel, mTicketCount, mBossHpRate, mResetDateTime, mAllclear, str1.c_str(), str2.c_str()
		).c_str();
	}
#endif

	bool Validate()
	{
		uchar* pktStart = (uchar*)this;
		uint16 pktSize = mPktSize;

		uint16 dataSize = sizeof(PKT_GC_ACK_OPEN_GUILD_DUNGEON_INFO_READ);
		if (dataSize > mPktSize)
			return false;

		if (false == ValidateValue(pktStart, pktSize, dataSize))
			return false;

		if (false == EnterUserListValidateListNode(mFirstEnterUserListOffset, pktStart, pktSize, dataSize))
			return false;

		if (false == RankingUserListValidateListNode(mFirstRankingUserListOffset, pktStart, pktSize, dataSize))
			return false;

		if (dataSize != mPktSize)
			return false;

		return true;
	}

	bool EnterUserListValidateListNode(uint16 offset, uchar * pktStart, uint16 pktSize, uint16& dataSize)
	{		for (EnterUserListIterator iter = this->GetFirstEnterUserListIterator();
			iter != GetLastEnterUserListIterator(); ++iter)
		{
			if (false == (*iter).Validate(offset, pktStart, pktSize, dataSize))
			{
				return false;
			}
		}
		return true;
	}

	bool RankingUserListValidateListNode(uint16 offset, uchar * pktStart, uint16 pktSize, uint16& dataSize)
	{		for (RankingUserListIterator iter = this->GetFirstRankingUserListIterator();
			iter != GetLastRankingUserListIterator(); ++iter)
		{
			if (false == (*iter).Validate(offset, pktStart, pktSize, dataSize))
			{
				return false;
			}
		}
		return true;
	}

	bool ValidateValue(const uchar* pktStart, uint16 pktSize, uint16& dataSize)
	{
		return (nullptr != pktStart && 0 < pktSize && 0 < dataSize) ? true : false;
	}

}; // PKT_GC_ACK_OPEN_GUILD_DUNGEON_INFO_READ

