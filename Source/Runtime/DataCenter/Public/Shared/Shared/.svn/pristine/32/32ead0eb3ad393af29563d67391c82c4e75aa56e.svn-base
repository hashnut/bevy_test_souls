		return readPacket->GetLogWString();
	}
#endif

#ifndef _SERVER
	CalculatedListHandle CreateCalculatedList(MarketTransactionId marketTransactionId, ItemId itemId, Level level, ItemAmount amount, MarketPrice price, MarketPrice calculatedPrice, time_t timeSalesComplete)
	{
		uchar* nowBuffer = mPktWriter.GetBuffer();
		uint16 nowWritten = (uint16)mPktWriter.GetPktSize();
		CalculatedList* newCalculatedList = new ((CalculatedList*)nowBuffer) CalculatedList(nowWritten, marketTransactionId, itemId, level, amount, price, calculatedPrice, timeSalesComplete);
		++(*mCalculatedListCount);
		if (mNowCalculatedList == 0)
			*mFirstCalculatedListOffset = nowWritten;
		else
			mNowCalculatedList->mNextOffset = nowWritten;
		mNowCalculatedList = newCalculatedList;
		mPktWriter.Skip(sizeof(CalculatedList));
		return CalculatedListHandle(mPktWriter, newCalculatedList);
	}

#else
	CalculatedListHandle CreateCalculatedList(MarketTransactionId marketTransactionId, ItemId itemId, Level level, ItemAmount amount, MarketPrice price, MarketPrice calculatedPrice, time_t timeSalesComplete)
