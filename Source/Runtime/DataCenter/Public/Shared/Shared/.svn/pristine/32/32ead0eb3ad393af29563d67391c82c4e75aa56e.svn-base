#ifndef _SERVER
	PKT_GC_ACK_GUILD_MEMBER_LIST_WRITE(uchar* buf, int bufSize)
		:
		mPktWriter(buf, bufSize)
		, mNowMemberList(0)
	{
		mPktWriter << static_cast<uint16>(PD::GC::GCPacketId::GC_ACK_GUILD_MEMBER_LIST);
		mMemberListCount = (uint16*)mPktWriter.GetBuffer();
		*mMemberListCount = 0;
		mPktWriter << (*mMemberListCount);
		mFirstMemberListOffset = (uint16*)mPktWriter.GetBuffer();
		*mFirstMemberListOffset = 0;
		mPktWriter << (*mFirstMemberListOffset);
	}

#endif // _SERVER
#ifdef _SERVER
	PKT_GC_ACK_GUILD_MEMBER_LIST_WRITE(SendBufferHelper& sendBuffer)
		:
		mPktWriter(sendBuffer->GetCharBuffer(), (SEND_BUFFER_SIZE - 1))
		, mNowMemberList(0)
	{
		mPktWriter << (uint16)GC_ACK_GUILD_MEMBER_LIST;
		mMemberListCount = (uint16*)mPktWriter.GetBuffer();
		*mMemberListCount = 0;
		mPktWriter << (*mMemberListCount);
		mFirstMemberListOffset = (uint16*)mPktWriter.GetBuffer();
		*mFirstMemberListOffset = 0;
		mPktWriter << (*mFirstMemberListOffset);
	}
#endif

#ifdef _SERVER 
	void send(IocpObjectSession* session, SendBufferRef sendBuffer, bool autoCloseSendBuffer)
	{
		if (session) 
			session->Send(sendBuffer, mPktWriter.GetPktSize(), autoCloseSendBuffer);
	}
#endif

#ifdef _SERVER 
	std::xwstring GetLogWString() const
	{
		auto readPacket = reinterpret_cast<PKT_GC_ACK_GUILD_MEMBER_LIST_READ*>(mPktWriter.mBuf);
		return readPacket->GetLogWString();
	}
#endif

#ifndef _SERVER
	MemberListHandle CreateMemberList(UserDBId userDBId, const FString& userName, Level userLevel, GuildMemberGradeType memberGrade, time_t lastLoginTime, GuildContribution contributionWeekend, GuildContribution contributionAccuml, bool checkAttendance, time_t guildJoinedTime)
	{
		uchar* nowBuffer = mPktWriter.GetBuffer();
		uint16 nowWritten = (uint16)mPktWriter.GetPktSize();
		MemberList* newMemberList = new ((MemberList*)nowBuffer) MemberList(nowWritten, userDBId, userLevel, memberGrade, lastLoginTime, contributionWeekend, contributionAccuml, checkAttendance, guildJoinedTime);
		++(*mMemberListCount);
		if (mNowMemberList == 0)
			*mFirstMemberListOffset = nowWritten;
		else
			mNowMemberList->mNextOffset = nowWritten;
		mNowMemberList = newMemberList;
		mPktWriter.Skip(sizeof(MemberList));
		mNowMemberList->SetUserNameOffset((uint16)mPktWriter.GetPktSize());
