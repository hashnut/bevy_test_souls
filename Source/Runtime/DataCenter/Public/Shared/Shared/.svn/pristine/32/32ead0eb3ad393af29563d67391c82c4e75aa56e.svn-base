	{
		std::xwstring str1;
		str1.append(L"\n");
		for (PurchasedLimitListIterator iter = this->GetFirstPurchasedLimitListIterator();
			iter != GetLastPurchasedLimitListIterator(); ++iter)
		{
			str1.append(L"[");
			str1.append(FuncCreatePurchasedLimitListStr(iter).c_str());

			str1.append(L"]\n");
		}
		std::xwstring str2;
		str2.append(L"\n");
		for (BlockListIterator iter = this->GetFirstBlockListIterator();
			iter != GetLastBlockListIterator(); ++iter)
		{
			str2.append(L"[");
			str2.append(FuncCreateBlockListStr(iter).c_str());

