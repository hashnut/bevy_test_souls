	const wchar_t* GetRelatedPacketName() const { return L"CG_REQ_MARKET_ITEM_SEARCH"; }
#endif


	using SalesItemListIterator = PktIterator<SalesItemList>;
	const SalesItemListIterator GetLastSalesItemListIterator() const
	{
		return SalesItemListIterator(0);
	}
	SalesItemListIterator GetFirstSalesItemListIterator() const
	{
		if (mFirstSalesItemListOffset && mPktSize >= mFirstSalesItemListOffset + sizeof(SalesItemList))
		{
			SalesItemList* salesItemList = (SalesItemList*)((uchar*)this + mFirstSalesItemListOffset);
			if (mFirstSalesItemListOffset == salesItemList->mThisOffset)
				return SalesItemListIterator(salesItemList);
