			// Value °ËÁő
			uchar* pktCurrentNodeStart = (uchar*)this - mThisOffset;
			uint16 pktCurrentNodeSize = *((uint16*)pktStart);
			dataSize += sizeof(GuildWarInfoList);	// skip
			if (false == ValidateValue(pktCurrentNodeStart, pktCurrentNodeSize, dataSize))
				return false;

			if (false == GuildWarInfoList::EntrymemberListValidateListNode(mFirstEntrymemberListOffset, pktStart, pktSize, dataSize))
				return false;

