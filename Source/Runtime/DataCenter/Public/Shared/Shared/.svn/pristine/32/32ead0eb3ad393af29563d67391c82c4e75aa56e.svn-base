#ifdef _SERVER 
	bool GetServerTaskIdRealTime(OUT int& serverTaskId) const { return reinterpret_cast<PKT_GC_ACK_GUILD_MEMBER_LIST_READ*>(mPktWriter.mBuf)->GetServerTaskIdRealTime(serverTaskId); }
	const wchar_t* GetPacketName() const { return L"GC_ACK_GUILD_MEMBER_LIST"; }
	const wchar_t* GetRelatedPacketName() const { return L"CG_REQ_GUILD_MEMBER_LIST"; }
