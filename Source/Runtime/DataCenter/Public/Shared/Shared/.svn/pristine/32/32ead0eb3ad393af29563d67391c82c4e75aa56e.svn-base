// type = GC
// related packet = PKT_CG_REQ_USER_PROFILE_COMMENT_LIST_WRITE
struct PKT_GC_ACK_USER_PROFILE_COMMENT_LIST_READ
{
	struct CommentInfolist
	{
	protected:
		uint16 mThisOffset;
		uint16 mNextOffset;
		uint16 mUserNameOffset;
		uint16 mCommentTextOffset;
		UserDBId mUserDBId;
		time_t mWriteTime;

	public:
		UserDBId UserDBId() { return mUserDBId; }
		time_t WriteTime() { return mWriteTime; }

#ifdef _SERVER
		const wchar_t* UserName()
		{
			uchar* pktStart = (uchar*)this - mThisOffset;
			uint16 pktSize = *((uint16*)pktStart);
			if (mUserNameOffset && pktSize > mUserNameOffset)
				return (const wchar_t*)(pktStart + mUserNameOffset);
			else
				return L"";
		}
#else // _SERVER
		const FString UserName()
		{
			const wchar_t* strWchar = L"";
			uchar* pktStart = (uchar*)this - mThisOffset;
			uint16 pktSize = *((uint16*)pktStart);
			if (mUserNameOffset && pktSize > mUserNameOffset)
				strWchar = (const wchar_t*)(pktStart + mUserNameOffset);
			return PktWriter::ConvertToFString(strWchar);
		}
#endif // _SERVER
#ifdef _SERVER
		const wchar_t* CommentText()
		{
			uchar* pktStart = (uchar*)this - mThisOffset;
			uint16 pktSize = *((uint16*)pktStart);
			if (mCommentTextOffset && pktSize > mCommentTextOffset)
				return (const wchar_t*)(pktStart + mCommentTextOffset);
			else
				return L"";
		}
#else // _SERVER
		const FString CommentText()
		{
			const wchar_t* strWchar = L"";
			uchar* pktStart = (uchar*)this - mThisOffset;
			uint16 pktSize = *((uint16*)pktStart);
			if (mCommentTextOffset && pktSize > mCommentTextOffset)
				strWchar = (const wchar_t*)(pktStart + mCommentTextOffset);
			return PktWriter::ConvertToFString(strWchar);
		}
#endif // _SERVER
		friend PktIterator<CommentInfolist>;
		friend PKT_GC_ACK_USER_PROFILE_COMMENT_LIST_READ;

		bool Validate(uint16 offset, uchar * pktStart, uint16 pktSize, uint16& dataSize)
		{
			if (static_cast<size_t>(pktSize) < static_cast<size_t>(offset) + sizeof(CommentInfolist))
				return false;

			CommentInfolist * node = (CommentInfolist*)(pktStart + offset);

			// ŔÚ±â ŔÚ˝ĹŔÇ Ć÷ŔÎĹÍ °ËÁő
			if (offset != node->mThisOffset)
				return false;

			// Value °ËÁő
			uchar* pktCurrentNodeStart = (uchar*)this - mThisOffset;
			uint16 pktCurrentNodeSize = *((uint16*)pktStart);
			dataSize += sizeof(CommentInfolist);	// skip
			if (false == ValidateValue(pktCurrentNodeStart, pktCurrentNodeSize, dataSize))
				return false;

			return true;
		}

		bool ValidateValue(const uchar* pktStart, uint16 pktSize, uint16& dataSize)
		{
			if (false == ValidateString(mUserNameOffset, 0, pktStart, pktSize, dataSize))
				return false;

			if (false == ValidateString(mCommentTextOffset, 0, pktStart, pktSize, dataSize))
				return false;

			return (nullptr != pktStart && 0 < pktSize && 0 < dataSize) ? true : false;
		}

	}; // CommentInfolist

public:
	uint16 mPktSize;
	uint16 mPktId;
	uint16 mCommentInfolistCount;
	uint16 mFirstCommentInfolistOffset;
	UserDBId mProfileUserDBId;

public:
#ifdef _SERVER 
	bool GetServerTaskIdRealTime(OUT [[maybe_unused]] int& serverTaskId) const { return false; }
	const wchar_t* GetPacketName() const { return L"GC_ACK_USER_PROFILE_COMMENT_LIST"; }
	const wchar_t* GetRelatedPacketName() const { return L"CG_REQ_USER_PROFILE_COMMENT_LIST"; }
#endif

	UserDBId ProfileUserDBId() { return mProfileUserDBId; }

	using CommentInfolistIterator = PktIterator<CommentInfolist>;
	const CommentInfolistIterator GetLastCommentInfolistIterator() const
	{
		return CommentInfolistIterator(0);
	}
	CommentInfolistIterator GetFirstCommentInfolistIterator() const
	{
		if (mFirstCommentInfolistOffset && mPktSize >= mFirstCommentInfolistOffset + sizeof(CommentInfolist))
		{
			CommentInfolist* commentInfolist = (CommentInfolist*)((uchar*)this + mFirstCommentInfolistOffset);
			if (mFirstCommentInfolistOffset == commentInfolist->mThisOffset)
				return CommentInfolistIterator(commentInfolist);
			else
				return CommentInfolistIterator(0);
		}
		else
			return CommentInfolistIterator(0);
	}
	const int GetCommentInfolistCount()
	{
		return mCommentInfolistCount;
	}
#ifdef _SERVER
	template<typename TFunc>
	void ForEachCommentInfolist(TFunc&& func)
	{
		for (auto it = GetFirstCommentInfolistIterator(); it != GetLastCommentInfolistIterator(); ++it)
			func(it);
	}
#endif


#ifdef _SERVER 
	std::xwstring FuncCreateCommentInfolistStr( [[maybe_unused]] CommentInfolistIterator& iter) const
	{
		return Log::format(
			L"UserDBId: {}, UserName: {}, CommentText: {}, WriteTime: {}", 
			iter->UserDBId(), iter->UserName(), iter->CommentText(), iter->WriteTime()
		).c_str();
	}

	std::xwstring GetLogWString() const
	{
		std::xwstring str1;
		str1.append(L"\n");
		for (CommentInfolistIterator iter = this->GetFirstCommentInfolistIterator();
			iter != GetLastCommentInfolistIterator(); ++iter)
		{
			str1.append(L"[");
			str1.append(FuncCreateCommentInfolistStr(iter).c_str());

			str1.append(L"]\n");
		}

		return Log::format(
			L"[GC_ACK_USER_PROFILE_COMMENT_LIST] ProfileUserDBId: {}, CommentInfolist : {}"
			, mProfileUserDBId, str1.c_str()
		).c_str();
	}
#endif

	bool Validate()
	{
		uchar* pktStart = (uchar*)this;
		uint16 pktSize = mPktSize;

		uint16 dataSize = sizeof(PKT_GC_ACK_USER_PROFILE_COMMENT_LIST_READ);
		if (dataSize > mPktSize)
			return false;

		if (false == ValidateValue(pktStart, pktSize, dataSize))
			return false;

		if (false == CommentInfolistValidateListNode(mFirstCommentInfolistOffset, pktStart, pktSize, dataSize))
			return false;

		if (dataSize != mPktSize)
			return false;

		return true;
	}

	bool CommentInfolistValidateListNode(uint16 offset, uchar * pktStart, uint16 pktSize, uint16& dataSize)
	{		for (CommentInfolistIterator iter = this->GetFirstCommentInfolistIterator();
			iter != GetLastCommentInfolistIterator(); ++iter)
		{
			if (false == (*iter).Validate(offset, pktStart, pktSize, dataSize))
			{
				return false;
			}
		}
		return true;
	}

	bool ValidateValue(const uchar* pktStart, uint16 pktSize, uint16& dataSize)
	{
		return (nullptr != pktStart && 0 < pktSize && 0 < dataSize) ? true : false;
	}

}; // PKT_GC_ACK_USER_PROFILE_COMMENT_LIST_READ

