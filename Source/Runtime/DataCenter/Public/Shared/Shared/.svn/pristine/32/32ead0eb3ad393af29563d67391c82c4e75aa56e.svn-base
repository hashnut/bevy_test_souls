		uint8 CurUserCnt() { return mCurUserCnt; }
		Level LimitedUserLevel() { return mLimitedUserLevel; }
		GuildJoinType GuildJoinType() { return mGuildJoinType; }
		GuildEmblemId GuildEmblemId() { return mGuildEmblemId; }
		const PlanetWorldId& ConstRefCurrentHomePlanetWorldId() { return mCurrentHomePlanetWorldId; }
		PlanetWorldId CurrentHomePlanetWorldId() { return mCurrentHomePlanetWorldId; }

#ifdef _SERVER
		const wchar_t* GuildName()
		{
			uchar* pktStart = (uchar*)this - mThisOffset;
			uint16 pktSize = *((uint16*)pktStart);
			if (mGuildNameOffset && pktSize > mGuildNameOffset)
				return (const wchar_t*)(pktStart + mGuildNameOffset);
			else
				return L"";
		}
#else // _SERVER
		const FString GuildName()
		{
			const wchar_t* strWchar = L"";
			uchar* pktStart = (uchar*)this - mThisOffset;
			uint16 pktSize = *((uint16*)pktStart);
			if (mGuildNameOffset && pktSize > mGuildNameOffset)
				strWchar = (const wchar_t*)(pktStart + mGuildNameOffset);
			return PktWriter::ConvertToFString(strWchar);
		}
#endif // _SERVER
#ifdef _SERVER
		const wchar_t* CaptainName()
		{
			uchar* pktStart = (uchar*)this - mThisOffset;
			uint16 pktSize = *((uint16*)pktStart);
			if (mCaptainNameOffset && pktSize > mCaptainNameOffset)
				return (const wchar_t*)(pktStart + mCaptainNameOffset);
			else
				return L"";
		}
#else // _SERVER
		const FString CaptainName()
		{
			const wchar_t* strWchar = L"";
			uchar* pktStart = (uchar*)this - mThisOffset;
			uint16 pktSize = *((uint16*)pktStart);
			if (mCaptainNameOffset && pktSize > mCaptainNameOffset)
				strWchar = (const wchar_t*)(pktStart + mCaptainNameOffset);
			return PktWriter::ConvertToFString(strWchar);
		}
#endif // _SERVER
#ifdef _SERVER
		const wchar_t* GuildDesc()
		{
			uchar* pktStart = (uchar*)this - mThisOffset;
			uint16 pktSize = *((uint16*)pktStart);
			if (mGuildDescOffset && pktSize > mGuildDescOffset)
				return (const wchar_t*)(pktStart + mGuildDescOffset);
			else
				return L"";
		}
#else // _SERVER
		const FString GuildDesc()
		{
			const wchar_t* strWchar = L"";
			uchar* pktStart = (uchar*)this - mThisOffset;
			uint16 pktSize = *((uint16*)pktStart);
			if (mGuildDescOffset && pktSize > mGuildDescOffset)
				strWchar = (const wchar_t*)(pktStart + mGuildDescOffset);
			return PktWriter::ConvertToFString(strWchar);
		}
#endif // _SERVER
		friend PktIterator<GuildList>;
		friend PKT_GC_ACK_GUILD_LIST_READ;

		bool Validate(uint16 offset, uchar * pktStart, uint16 pktSize, uint16& dataSize)
		{
			if (static_cast<size_t>(pktSize) < static_cast<size_t>(offset) + sizeof(GuildList))
				return false;

			GuildList * node = (GuildList*)(pktStart + offset);

			// ŔÚ±â ŔÚ˝ĹŔÇ Ć÷ŔÎĹÍ °ËÁő
			if (offset != node->mThisOffset)
				return false;

			// Value °ËÁő
			uchar* pktCurrentNodeStart = (uchar*)this - mThisOffset;
			uint16 pktCurrentNodeSize = *((uint16*)pktStart);
			dataSize += sizeof(GuildList);	// skip
			if (false == ValidateValue(pktCurrentNodeStart, pktCurrentNodeSize, dataSize))
				return false;

			return true;
		}

		bool ValidateValue(const uchar* pktStart, uint16 pktSize, uint16& dataSize)
		{
			if (false == ValidateString(mGuildNameOffset, 0, pktStart, pktSize, dataSize))
				return false;

			if (false == ValidateString(mCaptainNameOffset, 0, pktStart, pktSize, dataSize))
				return false;

			if (false == ValidateString(mGuildDescOffset, 0, pktStart, pktSize, dataSize))
				return false;

			return (nullptr != pktStart && 0 < pktSize && 0 < dataSize) ? true : false;
		}

	}; // GuildList

public:
	uint16 mPktSize;
	uint16 mPktId;
	uint16 mGuildListCount;
	uint16 mFirstGuildListOffset;
	time_t mReJoinCoolDownTime;
	int mResult;
	bool mIsOnlyInMyWorld;

public:
#ifdef _SERVER 
	bool GetServerTaskIdRealTime(OUT [[maybe_unused]] int& serverTaskId) const { return false; }
	const wchar_t* GetPacketName() const { return L"GC_ACK_GUILD_LIST"; }
	const wchar_t* GetRelatedPacketName() const { return L"CG_REQ_GUILD_LIST"; }
#endif

	time_t ReJoinCoolDownTime() { return mReJoinCoolDownTime; }
	int Result() { return mResult; }
	bool IsOnlyInMyWorld() { return mIsOnlyInMyWorld; }

	using GuildListIterator = PktIterator<GuildList>;
	const GuildListIterator GetLastGuildListIterator() const
	{
		return GuildListIterator(0);
	}
	GuildListIterator GetFirstGuildListIterator() const
	{
		if (mFirstGuildListOffset && mPktSize >= mFirstGuildListOffset + sizeof(GuildList))
		{
			GuildList* guildList = (GuildList*)((uchar*)this + mFirstGuildListOffset);
			if (mFirstGuildListOffset == guildList->mThisOffset)
				return GuildListIterator(guildList);
			else
				return GuildListIterator(0);
		}
		else
			return GuildListIterator(0);
	}
	const int GetGuildListCount()
	{
		return mGuildListCount;
	}
#ifdef _SERVER
	template<typename TFunc>
	void ForEachGuildList(TFunc&& func)
	{
		for (auto it = GetFirstGuildListIterator(); it != GetLastGuildListIterator(); ++it)
			func(it);
	}
#endif


#ifdef _SERVER 
	std::xwstring FuncCreateGuildListStr( [[maybe_unused]] GuildListIterator& iter) const
	{
		return Log::format(
