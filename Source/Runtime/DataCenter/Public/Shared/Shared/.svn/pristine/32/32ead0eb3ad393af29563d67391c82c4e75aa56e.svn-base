		mNowCommentInfolist->SetUserNameOffset((uint16)mPktWriter.GetPktSize());
		mPktWriter.WriteString(userName);
		mNowCommentInfolist->SetCommentTextOffset((uint16)mPktWriter.GetPktSize());
