	{
		for (auto it = GetFirstRankListIterator(); it != GetLastRankListIterator(); ++it)
			func(it);
	}
#endif


#ifdef _SERVER 
	std::xwstring FuncCreateRankListStr( [[maybe_unused]] RankListIterator& iter) const
	{
		return Log::format(
			L"Rank: {}, PrevRank: {}, UserName: {}, GuildEmblemId: {}, GuildName: {}, Param1: {}, Param2: {}, ServerName: {}, PlanetWorldId: {}", 
			iter->Rank(), iter->PrevRank(), iter->UserName(), iter->GuildEmblemId(), iter->GuildName(), iter->Param1(), iter->Param2(), iter->ServerName(), iter->PlanetWorldId()
		).c_str();
	}

	std::xwstring GetLogWString() const
	{
		std::xwstring str1;
		str1.append(L"\n");
		for (RankListIterator iter = this->GetFirstRankListIterator();
			iter != GetLastRankListIterator(); ++iter)
		{
			str1.append(L"[");
			str1.append(FuncCreateRankListStr(iter).c_str());

			str1.append(L"]\n");
		}

		return Log::format(
			L"[GC_ACK_RANK] RankType: {}, WorldId: {}, MyPercentRank: {}, MyParam1: {}, MyParam2: {}, RankList : {}"
			, mRankType, mWorldId, mMyPercentRank, mMyParam1, mMyParam2, str1.c_str()
		).c_str();
	}
#endif

	bool Validate()
	{
		uchar* pktStart = (uchar*)this;
		uint16 pktSize = mPktSize;

		uint16 dataSize = sizeof(PKT_GC_ACK_RANK_READ);
		if (dataSize > mPktSize)
			return false;

		if (false == ValidateValue(pktStart, pktSize, dataSize))
			return false;

		if (false == RankListValidateListNode(mFirstRankListOffset, pktStart, pktSize, dataSize))
			return false;

		if (dataSize != mPktSize)
			return false;

		return true;
	}

	bool RankListValidateListNode(uint16 offset, uchar * pktStart, uint16 pktSize, uint16& dataSize)
	{		for (RankListIterator iter = this->GetFirstRankListIterator();
			iter != GetLastRankListIterator(); ++iter)
		{
			if (false == (*iter).Validate(offset, pktStart, pktSize, dataSize))
			{
				return false;
			}
		}
		return true;
	}

	bool ValidateValue(const uchar* pktStart, uint16 pktSize, uint16& dataSize)
	{
		return (nullptr != pktStart && 0 < pktSize && 0 < dataSize) ? true : false;
	}

