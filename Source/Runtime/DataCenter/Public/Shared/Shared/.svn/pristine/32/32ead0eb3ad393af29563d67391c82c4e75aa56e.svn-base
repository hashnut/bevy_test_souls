		int MaxRank() { return mMaxRank; }

		friend PktIterator<TierMaxRankList>;
		friend PKT_GC_ACK_GUILDWAR_MY_RANK_INFO_READ;

		bool Validate(uint16 offset, uchar * pktStart, uint16 pktSize, uint16& dataSize)
		{
			if (static_cast<size_t>(pktSize) < static_cast<size_t>(offset) + sizeof(TierMaxRankList))
				return false;

			TierMaxRankList * node = (TierMaxRankList*)(pktStart + offset);

			// ŔÚ±â ŔÚ˝ĹŔÇ Ć÷ŔÎĹÍ °ËÁő
			if (offset != node->mThisOffset)
				return false;

			// Value °ËÁő
			uchar* pktCurrentNodeStart = (uchar*)this - mThisOffset;
			uint16 pktCurrentNodeSize = *((uint16*)pktStart);
			dataSize += sizeof(TierMaxRankList);	// skip
			if (false == ValidateValue(pktCurrentNodeStart, pktCurrentNodeSize, dataSize))
				return false;

			return true;
		}

		bool ValidateValue(const uchar* pktStart, uint16 pktSize, uint16& dataSize)
		{
			return (nullptr != pktStart && 0 < pktSize && 0 < dataSize) ? true : false;
		}

	}; // TierMaxRankList

public:
	uint16 mPktSize;
	uint16 mPktId;
	uint16 mTierMaxRankListCount;
	uint16 mFirstTierMaxRankListOffset;
	int mPlayCount;
	time_t mNextUpdateTime;
	int mIndex;
	Rank mPrevRank;
	Rank mNowRank;
	int mScore;
	int mWinCount;
	int mLoseCount;
	int mTieCount;

public:
#ifdef _SERVER 
	bool GetServerTaskIdRealTime(OUT [[maybe_unused]] int& serverTaskId) const { return false; }
	const wchar_t* GetPacketName() const { return L"GC_ACK_GUILDWAR_MY_RANK_INFO"; }
	const wchar_t* GetRelatedPacketName() const { return L"CG_REQ_GUILDWAR_MY_RANK_INFO"; }
#endif

	int PlayCount() { return mPlayCount; }
	time_t NextUpdateTime() { return mNextUpdateTime; }
	int Index() { return mIndex; }
	Rank PrevRank() { return mPrevRank; }
	Rank NowRank() { return mNowRank; }
	int Score() { return mScore; }
	int WinCount() { return mWinCount; }
	int LoseCount() { return mLoseCount; }
	int TieCount() { return mTieCount; }

	using TierMaxRankListIterator = PktIterator<TierMaxRankList>;
	const TierMaxRankListIterator GetLastTierMaxRankListIterator() const
	{
		return TierMaxRankListIterator(0);
	}
	TierMaxRankListIterator GetFirstTierMaxRankListIterator() const
	{
		if (mFirstTierMaxRankListOffset && mPktSize >= mFirstTierMaxRankListOffset + sizeof(TierMaxRankList))
		{
			TierMaxRankList* tierMaxRankList = (TierMaxRankList*)((uchar*)this + mFirstTierMaxRankListOffset);
			if (mFirstTierMaxRankListOffset == tierMaxRankList->mThisOffset)
				return TierMaxRankListIterator(tierMaxRankList);
			else
				return TierMaxRankListIterator(0);
		}
		else
			return TierMaxRankListIterator(0);
	}
	const int GetTierMaxRankListCount()
	{
		return mTierMaxRankListCount;
	}
#ifdef _SERVER
	template<typename TFunc>
	void ForEachTierMaxRankList(TFunc&& func)
	{
		for (auto it = GetFirstTierMaxRankListIterator(); it != GetLastTierMaxRankListIterator(); ++it)
			func(it);
	}
#endif


#ifdef _SERVER 
	std::xwstring FuncCreateTierMaxRankListStr( [[maybe_unused]] TierMaxRankListIterator& iter) const
	{
		return Log::format(
			L"TierId: {}, MaxRank: {}", 
			iter->TierId(), iter->MaxRank()
		).c_str();
	}

	std::xwstring GetLogWString() const
	{
		std::xwstring str1;
		str1.append(L"\n");
		for (TierMaxRankListIterator iter = this->GetFirstTierMaxRankListIterator();
			iter != GetLastTierMaxRankListIterator(); ++iter)
		{
			str1.append(L"[");
			str1.append(FuncCreateTierMaxRankListStr(iter).c_str());

			str1.append(L"]\n");
		}

		return Log::format(
			L"[GC_ACK_GUILDWAR_MY_RANK_INFO] PlayCount: {}, NextUpdateTime: {}, Index: {}, PrevRank: {}, NowRank: {}, Score: {}, WinCount: {}, LoseCount: {}, TieCount: {}, TierMaxRankList : {}"
			, mPlayCount, mNextUpdateTime, mIndex, mPrevRank, mNowRank, mScore, mWinCount, mLoseCount, mTieCount, str1.c_str()
		).c_str();
	}
#endif

	bool Validate()
	{
		uchar* pktStart = (uchar*)this;
		uint16 pktSize = mPktSize;

		uint16 dataSize = sizeof(PKT_GC_ACK_GUILDWAR_MY_RANK_INFO_READ);
		if (dataSize > mPktSize)
			return false;

		if (false == ValidateValue(pktStart, pktSize, dataSize))
			return false;

		if (false == TierMaxRankListValidateListNode(mFirstTierMaxRankListOffset, pktStart, pktSize, dataSize))
			return false;

		if (dataSize != mPktSize)
			return false;

		return true;
	}

	bool TierMaxRankListValidateListNode(uint16 offset, uchar * pktStart, uint16 pktSize, uint16& dataSize)
	{		for (TierMaxRankListIterator iter = this->GetFirstTierMaxRankListIterator();
			iter != GetLastTierMaxRankListIterator(); ++iter)
		{
			if (false == (*iter).Validate(offset, pktStart, pktSize, dataSize))
			{
				return false;
			}
		}
		return true;
	}

	bool ValidateValue(const uchar* pktStart, uint16 pktSize, uint16& dataSize)
	{
		return (nullptr != pktStart && 0 < pktSize && 0 < dataSize) ? true : false;
	}

}; // PKT_GC_ACK_GUILDWAR_MY_RANK_INFO_READ

