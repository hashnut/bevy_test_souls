	}; // GuildChatList

	struct GuildChatListHandle
	{
		GuildChatListHandle(PktWriter& pktWriter, GuildChatList* guildChatList)
			:
			mPktWriter(pktWriter)
			, mGuildChatList(guildChatList)
		{
		}

		PktWriter& mPktWriter;
		GuildChatList* mGuildChatList;

	}; // GuildChatListHandle

	PktWriter mPktWriter;
	uint16* mGuildChatListCount;
	uint16* mFirstGuildChatListOffset;
	GuildChatList* mNowGuildChatList;

#ifdef _SERVER 
	bool GetServerTaskIdRealTime(OUT int& serverTaskId) const { return reinterpret_cast<PKT_GC_GUILD_ALLY_CHAT_LIST_RECENT_READ*>(mPktWriter.mBuf)->GetServerTaskIdRealTime(serverTaskId); }
	const wchar_t* GetPacketName() const { return L"GC_GUILD_ALLY_CHAT_LIST_RECENT"; }
	const wchar_t* GetRelatedPacketName() const { return L"CG_GUILD_ALLY_CHAT_LIST_RECENT"; }
#endif

#ifndef _SERVER
	PKT_GC_GUILD_ALLY_CHAT_LIST_RECENT_WRITE(uchar* buf, int bufSize)
		:
		mPktWriter(buf, bufSize)
		, mNowGuildChatList(0)
	{
		mPktWriter << static_cast<uint16>(PD::GC::GCPacketId::GC_GUILD_ALLY_CHAT_LIST_RECENT);
		mGuildChatListCount = (uint16*)mPktWriter.GetBuffer();
		*mGuildChatListCount = 0;
		mPktWriter << (*mGuildChatListCount);
		mFirstGuildChatListOffset = (uint16*)mPktWriter.GetBuffer();
		*mFirstGuildChatListOffset = 0;
		mPktWriter << (*mFirstGuildChatListOffset);
	}

#endif // _SERVER
#ifdef _SERVER
	PKT_GC_GUILD_ALLY_CHAT_LIST_RECENT_WRITE(SendBufferHelper& sendBuffer)
		:
		mPktWriter(sendBuffer->GetCharBuffer(), (SEND_BUFFER_SIZE - 1))
		, mNowGuildChatList(0)
	{
		mPktWriter << (uint16)GC_GUILD_ALLY_CHAT_LIST_RECENT;
		mGuildChatListCount = (uint16*)mPktWriter.GetBuffer();
		*mGuildChatListCount = 0;
		mPktWriter << (*mGuildChatListCount);
		mFirstGuildChatListOffset = (uint16*)mPktWriter.GetBuffer();
		*mFirstGuildChatListOffset = 0;
		mPktWriter << (*mFirstGuildChatListOffset);
	}
#endif

#ifdef _SERVER 
	void send(IocpObjectSession* session, SendBufferRef sendBuffer, bool autoCloseSendBuffer)
	{
		if (session) 
			session->Send(sendBuffer, mPktWriter.GetPktSize(), autoCloseSendBuffer);
	}
#endif

#ifdef _SERVER 
	std::xwstring GetLogWString() const
	{
		auto readPacket = reinterpret_cast<PKT_GC_GUILD_ALLY_CHAT_LIST_RECENT_READ*>(mPktWriter.mBuf);
		return readPacket->GetLogWString();
	}
#endif

#ifndef _SERVER
	GuildChatListHandle CreateGuildChatList(const FString& guildName, GuildDBId guildId, GuildChatDBId guildChatDBId, GuildEmblemId guildEmblemId, const FString& userName, const FString& message, time_t messageTime, WorldId homeWorldId, const FString& homeWorldPrefix, AccountGrade accountGrade)
	{
		uchar* nowBuffer = mPktWriter.GetBuffer();
		uint16 nowWritten = (uint16)mPktWriter.GetPktSize();
		GuildChatList* newGuildChatList = new ((GuildChatList*)nowBuffer) GuildChatList(nowWritten, guildId, guildChatDBId, guildEmblemId, messageTime, homeWorldId, accountGrade);
		++(*mGuildChatListCount);
		if (mNowGuildChatList == 0)
			*mFirstGuildChatListOffset = nowWritten;
		else
			mNowGuildChatList->mNextOffset = nowWritten;
		mNowGuildChatList = newGuildChatList;
		mPktWriter.Skip(sizeof(GuildChatList));
		mNowGuildChatList->SetGuildNameOffset((uint16)mPktWriter.GetPktSize());
		mPktWriter.WriteString(guildName);
		mNowGuildChatList->SetUserNameOffset((uint16)mPktWriter.GetPktSize());
		mPktWriter.WriteString(userName);
		mNowGuildChatList->SetMessageOffset((uint16)mPktWriter.GetPktSize());
		mPktWriter.WriteString(message);
		mNowGuildChatList->SetHomeWorldPrefixOffset((uint16)mPktWriter.GetPktSize());
		mPktWriter.WriteString(homeWorldPrefix);
		return GuildChatListHandle(mPktWriter, newGuildChatList);
	}

#else
	GuildChatListHandle CreateGuildChatList(const wchar* guildName, GuildDBId guildId, GuildChatDBId guildChatDBId, GuildEmblemId guildEmblemId, const wchar* userName, const wchar* message, time_t messageTime, WorldId homeWorldId, const wchar* homeWorldPrefix, AccountGrade accountGrade)
