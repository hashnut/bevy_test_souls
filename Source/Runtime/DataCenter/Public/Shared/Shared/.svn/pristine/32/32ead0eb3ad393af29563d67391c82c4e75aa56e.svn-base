	bool Allclear() { return mAllclear; }

	using EnterUserListIterator = PktIterator<EnterUserList>;
	const EnterUserListIterator GetLastEnterUserListIterator() const
	{
		return EnterUserListIterator(0);
	}
	EnterUserListIterator GetFirstEnterUserListIterator() const
	{
		if (mFirstEnterUserListOffset && mPktSize >= mFirstEnterUserListOffset + sizeof(EnterUserList))
		{
			EnterUserList* enterUserList = (EnterUserList*)((uchar*)this + mFirstEnterUserListOffset);
			if (mFirstEnterUserListOffset == enterUserList->mThisOffset)
				return EnterUserListIterator(enterUserList);
			else
				return EnterUserListIterator(0);
		}
		else
			return EnterUserListIterator(0);
	}
	const int GetEnterUserListCount()
	{
		return mEnterUserListCount;
	}
#ifdef _SERVER
	template<typename TFunc>
	void ForEachEnterUserList(TFunc&& func)
	{
		for (auto it = GetFirstEnterUserListIterator(); it != GetLastEnterUserListIterator(); ++it)
			func(it);
	}
#endif

	using RankingUserListIterator = PktIterator<RankingUserList>;
	const RankingUserListIterator GetLastRankingUserListIterator() const
	{
