		++(*mCoopPartyListCount);
		if (mNowCoopPartyList == 0)
			*mFirstCoopPartyListOffset = nowWritten;
		else
			mNowCoopPartyList->mNextOffset = nowWritten;
		mNowCoopPartyList = newCoopPartyList;
		mPktWriter.Skip(sizeof(CoopPartyList));
		mNowCoopPartyList->SetLeaderNameOffset((uint16)mPktWriter.GetPktSize());
		mPktWriter.WriteString(leaderName);
		return CoopPartyListHandle(mPktWriter, newCoopPartyList);
	}

#endif
}; // PKT_GC_ACK_COOP_PARTY_LIST_WRITE

