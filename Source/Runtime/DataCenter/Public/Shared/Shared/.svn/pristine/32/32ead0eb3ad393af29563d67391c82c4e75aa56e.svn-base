#ifdef _SERVER
		const wchar_t* LeaderName()
		{
			uchar* pktStart = (uchar*)this - mThisOffset;
			uint16 pktSize = *((uint16*)pktStart);
			if (mLeaderNameOffset && pktSize > mLeaderNameOffset)
				return (const wchar_t*)(pktStart + mLeaderNameOffset);
			else
				return L"";
		}
#else // _SERVER
		const FString LeaderName()
		{
			const wchar_t* strWchar = L"";
			uchar* pktStart = (uchar*)this - mThisOffset;
			uint16 pktSize = *((uint16*)pktStart);
			if (mLeaderNameOffset && pktSize > mLeaderNameOffset)
				strWchar = (const wchar_t*)(pktStart + mLeaderNameOffset);
			return PktWriter::ConvertToFString(strWchar);
		}
#endif // _SERVER
		friend PktIterator<CoopPartyList>;
		friend PKT_GC_ACK_COOP_PARTY_LIST_READ;

		bool Validate(uint16 offset, uchar * pktStart, uint16 pktSize, uint16& dataSize)
		{
			if (static_cast<size_t>(pktSize) < static_cast<size_t>(offset) + sizeof(CoopPartyList))
				return false;

			CoopPartyList * node = (CoopPartyList*)(pktStart + offset);

			// ŔÚ±â ŔÚ˝ĹŔÇ Ć÷ŔÎĹÍ °ËÁő
			if (offset != node->mThisOffset)
				return false;

			// Value °ËÁő
			uchar* pktCurrentNodeStart = (uchar*)this - mThisOffset;
			uint16 pktCurrentNodeSize = *((uint16*)pktStart);
			dataSize += sizeof(CoopPartyList);	// skip
			if (false == ValidateValue(pktCurrentNodeStart, pktCurrentNodeSize, dataSize))
				return false;

			return true;
		}

		bool ValidateValue(const uchar* pktStart, uint16 pktSize, uint16& dataSize)
		{
			if (false == ValidateString(mLeaderNameOffset, 0, pktStart, pktSize, dataSize))
				return false;

			return (nullptr != pktStart && 0 < pktSize && 0 < dataSize) ? true : false;
		}

	}; // CoopPartyList

public:
	uint16 mPktSize;
	uint16 mPktId;
	uint16 mCoopPartyListCount;
	uint16 mFirstCoopPartyListOffset;

public:
#ifdef _SERVER 
	bool GetServerTaskIdRealTime(OUT [[maybe_unused]] int& serverTaskId) const { return false; }
	const wchar_t* GetPacketName() const { return L"GC_ACK_COOP_PARTY_LIST"; }
	const wchar_t* GetRelatedPacketName() const { return L"CG_REQ_COOP_PARTY_LIST"; }
#endif


	using CoopPartyListIterator = PktIterator<CoopPartyList>;
	const CoopPartyListIterator GetLastCoopPartyListIterator() const
	{
		return CoopPartyListIterator(0);
	}
	CoopPartyListIterator GetFirstCoopPartyListIterator() const
	{
		if (mFirstCoopPartyListOffset && mPktSize >= mFirstCoopPartyListOffset + sizeof(CoopPartyList))
		{
			CoopPartyList* coopPartyList = (CoopPartyList*)((uchar*)this + mFirstCoopPartyListOffset);
			if (mFirstCoopPartyListOffset == coopPartyList->mThisOffset)
				return CoopPartyListIterator(coopPartyList);
			else
				return CoopPartyListIterator(0);
		}
		else
			return CoopPartyListIterator(0);
	}
	const int GetCoopPartyListCount()
	{
		return mCoopPartyListCount;
	}
#ifdef _SERVER
	template<typename TFunc>
	void ForEachCoopPartyList(TFunc&& func)
	{
		for (auto it = GetFirstCoopPartyListIterator(); it != GetLastCoopPartyListIterator(); ++it)
			func(it);
	}
#endif


#ifdef _SERVER 
	std::xwstring FuncCreateCoopPartyListStr( [[maybe_unused]] CoopPartyListIterator& iter) const
	{
		return Log::format(
			L"CoopPartyInfo: {}, LeaderName: {}", 
			iter->CoopPartyInfo(), iter->LeaderName()
		).c_str();
	}

	std::xwstring GetLogWString() const
	{
		std::xwstring str1;
		str1.append(L"\n");
		for (CoopPartyListIterator iter = this->GetFirstCoopPartyListIterator();
			iter != GetLastCoopPartyListIterator(); ++iter)
		{
			str1.append(L"[");
			str1.append(FuncCreateCoopPartyListStr(iter).c_str());

			str1.append(L"]\n");
		}

		return Log::format(
			L"[GC_ACK_COOP_PARTY_LIST] CoopPartyList : {}"
			, str1.c_str()
		).c_str();
	}
#endif

	bool Validate()
	{
		uchar* pktStart = (uchar*)this;
		uint16 pktSize = mPktSize;

		uint16 dataSize = sizeof(PKT_GC_ACK_COOP_PARTY_LIST_READ);
		if (dataSize > mPktSize)
			return false;

		if (false == ValidateValue(pktStart, pktSize, dataSize))
			return false;

		if (false == CoopPartyListValidateListNode(mFirstCoopPartyListOffset, pktStart, pktSize, dataSize))
			return false;

		if (dataSize != mPktSize)
			return false;

		return true;
	}

	bool CoopPartyListValidateListNode(uint16 offset, uchar * pktStart, uint16 pktSize, uint16& dataSize)
	{		for (CoopPartyListIterator iter = this->GetFirstCoopPartyListIterator();
			iter != GetLastCoopPartyListIterator(); ++iter)
		{
			if (false == (*iter).Validate(offset, pktStart, pktSize, dataSize))
			{
				return false;
			}
		}
		return true;
	}

	bool ValidateValue(const uchar* pktStart, uint16 pktSize, uint16& dataSize)
	{
		return (nullptr != pktStart && 0 < pktSize && 0 < dataSize) ? true : false;
	}

}; // PKT_GC_ACK_COOP_PARTY_LIST_READ

