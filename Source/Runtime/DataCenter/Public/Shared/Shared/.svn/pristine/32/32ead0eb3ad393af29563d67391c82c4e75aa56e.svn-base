	{
		uchar* nowBuffer = mPktWriter.GetBuffer();
		uint16 nowWritten = (uint16)mPktWriter.GetPktSize();
		KeyList* newKeyList = new ((KeyList*)nowBuffer) KeyList(nowWritten, multi, key0, key1, action, scaling);
		++(*mKeyListCount);
		if (mNowKeyList == 0)
			*mFirstKeyListOffset = nowWritten;
		else
			mNowKeyList->mNextOffset = nowWritten;
		mNowKeyList = newKeyList;
		mPktWriter.Skip(sizeof(KeyList));
		return KeyListHandle(mPktWriter, newKeyList);
	}

