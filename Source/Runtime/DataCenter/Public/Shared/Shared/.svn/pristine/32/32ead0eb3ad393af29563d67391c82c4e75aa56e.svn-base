	{
	protected:
		uint16 mThisOffset;
		uint16 mNextOffset;
		MarketTransactionId mMarketTransactionId;
		ItemId mItemId;
		Level mLevel;
		ItemAmount mAmount;
		MarketPrice mPrice;
		bool mIsWdMarket;

	public:
		MarketTransactionId MarketTransactionId() { return mMarketTransactionId; }
		ItemId ItemId() { return mItemId; }
		Level Level() { return mLevel; }
		ItemAmount Amount() { return mAmount; }
		MarketPrice Price() { return mPrice; }
