	{
		for (auto it = GetFirstListIterator(); it != GetLastListIterator(); ++it)
			func(it);
	}
#endif


#ifdef _SERVER 
	std::xwstring FuncCreateListStr( [[maybe_unused]] ListIterator& iter) const
	{
		return Log::format(
			L"CurrentHomePlanetWorldId: {}, GuildId: {}, GuildEmblemId: {}, GuildName: {}, GuildCaptianName: {}, Type: {}, ExpirationDateTm: {}", 
			iter->CurrentHomePlanetWorldId(), iter->GuildId(), iter->GuildEmblemId(), iter->GuildName(), iter->GuildCaptianName(), iter->Type(), iter->ExpirationDateTm()
		).c_str();
	}

	std::xwstring GetLogWString() const
	{
		std::xwstring str1;
		str1.append(L"\n");
		for (ListIterator iter = this->GetFirstListIterator();
			iter != GetLastListIterator(); ++iter)
		{
			str1.append(L"[");
			str1.append(FuncCreateListStr(iter).c_str());

			str1.append(L"]\n");
		}

		return Log::format(
			L"[GC_ACK_GUILD_ALLY_REQUEST_LIST] List : {}"
			, str1.c_str()
		).c_str();
	}
#endif

	bool Validate()
	{
		uchar* pktStart = (uchar*)this;
		uint16 pktSize = mPktSize;

		uint16 dataSize = sizeof(PKT_GC_ACK_GUILD_ALLY_REQUEST_LIST_READ);
		if (dataSize > mPktSize)
			return false;

		if (false == ValidateValue(pktStart, pktSize, dataSize))
			return false;

		if (false == ListValidateListNode(mFirstListOffset, pktStart, pktSize, dataSize))
			return false;

		if (dataSize != mPktSize)
			return false;

		return true;
	}

	bool ListValidateListNode(uint16 offset, uchar * pktStart, uint16 pktSize, uint16& dataSize)
	{		for (ListIterator iter = this->GetFirstListIterator();
			iter != GetLastListIterator(); ++iter)
		{
			if (false == (*iter).Validate(offset, pktStart, pktSize, dataSize))
			{
				return false;
			}
		}
		return true;
	}

	bool ValidateValue(const uchar* pktStart, uint16 pktSize, uint16& dataSize)
	{
		return (nullptr != pktStart && 0 < pktSize && 0 < dataSize) ? true : false;
	}

}; // PKT_GC_ACK_GUILD_ALLY_REQUEST_LIST_READ

