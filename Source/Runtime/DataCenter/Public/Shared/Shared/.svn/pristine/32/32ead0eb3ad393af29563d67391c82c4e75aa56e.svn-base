		Chatblacklists* newChatblacklists = new ((Chatblacklists*)nowBuffer) Chatblacklists(nowWritten, userDBId);
		++(*mChatblacklistsCount);
		if (mNowChatblacklists == 0)
			*mFirstChatblacklistsOffset = nowWritten;
		else
			mNowChatblacklists->mNextOffset = nowWritten;
		mNowChatblacklists = newChatblacklists;
		mPktWriter.Skip(sizeof(Chatblacklists));
		mNowChatblacklists->SetUserNameOffset((uint16)mPktWriter.GetPktSize());
		mPktWriter.WriteString(userName);
		return ChatblacklistsHandle(mPktWriter, newChatblacklists);
