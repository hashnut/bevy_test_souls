// type = GC
struct PKT_GC_GUILD_GROUP_CHAT_DELEGATE_READ
{
public:
	uint16 mPktSize;
	uint16 mPktId;
	uint16 mGuildNameOffset;
	GuildGroupChatRoomId mRoomId;
	GuildDBId mGuildDBId;

public:
#ifdef _SERVER 
	bool GetServerTaskIdRealTime(OUT [[maybe_unused]] int& serverTaskId) const { return false; }
	const wchar_t* GetPacketName() const { return L"GC_GUILD_GROUP_CHAT_DELEGATE"; }
	const wchar_t* GetRelatedPacketName() const { return L"CG_GUILD_GROUP_CHAT_DELEGATE"; }
#endif

	const GuildGroupChatRoomId& ConstRefRoomId() { return mRoomId; }
	GuildGroupChatRoomId RoomId() { return mRoomId; }
	GuildDBId GuildDBId() { return mGuildDBId; }
#ifdef _SERVER
	const wchar_t* GuildName() const
	{
		uchar* pktStart = (uchar*)this;
		uint16 pktSize = *((uint16*)pktStart);
		if (mGuildNameOffset && pktSize > mGuildNameOffset)
			return (const wchar_t*)(pktStart + mGuildNameOffset);
		else
			return L"";
	}
#else // _SERVER
	const FString GuildName()
	{
		const wchar_t* strWchar = L"";
		uchar* pktStart = (uchar*)this;
		uint16 pktSize = *((uint16*)pktStart);
		if (mGuildNameOffset && pktSize > mGuildNameOffset)
			strWchar = (const wchar_t*)(pktStart + mGuildNameOffset);

		return PktWriter::ConvertToFString(strWchar);
	}
#endif // _SERVER


#ifdef _SERVER 
	std::xwstring GetLogWString() const
	{

		return Log::format(
			L"[GC_GUILD_GROUP_CHAT_DELEGATE] RoomId: {}, GuildDBId: {}, GuildName: {}"
			, mRoomId, mGuildDBId, GuildName()
		).c_str();
	}
#endif

	bool Validate()
	{
		uchar* pktStart = (uchar*)this;
		uint16 pktSize = mPktSize;

		uint16 dataSize = sizeof(PKT_GC_GUILD_GROUP_CHAT_DELEGATE_READ);
		if (dataSize > mPktSize)
			return false;

		if (false == ValidateValue(pktStart, pktSize, dataSize))
			return false;

		if (dataSize != mPktSize)
			return false;

		return true;
	}

	bool ValidateValue(const uchar* pktStart, uint16 pktSize, uint16& dataSize)
	{
		if (false == ValidateString(mGuildNameOffset, 0, pktStart, pktSize, dataSize))
			return false;

		return (nullptr != pktStart && 0 < pktSize && 0 < dataSize) ? true : false;
	}

}; // PKT_GC_GUILD_GROUP_CHAT_DELEGATE_READ

// type = GC
#ifdef _SERVER
struct PKT_GC_GUILD_GROUP_CHAT_DELEGATE_WRITE : public Disposable
#else
struct PKT_GC_GUILD_GROUP_CHAT_DELEGATE_WRITE
#endif
{
	PktWriter mPktWriter;
	uint16* mGuildNameOffset;

#ifdef _SERVER 
	bool GetServerTaskIdRealTime(OUT int& serverTaskId) const { return reinterpret_cast<PKT_GC_GUILD_GROUP_CHAT_DELEGATE_READ*>(mPktWriter.mBuf)->GetServerTaskIdRealTime(serverTaskId); }
	const wchar_t* GetPacketName() const { return L"GC_GUILD_GROUP_CHAT_DELEGATE"; }
	const wchar_t* GetRelatedPacketName() const { return L"CG_GUILD_GROUP_CHAT_DELEGATE"; }
#endif

#ifndef _SERVER
	PKT_GC_GUILD_GROUP_CHAT_DELEGATE_WRITE(uchar* buf, int bufSize, GuildGroupChatRoomId roomId, GuildDBId guildDBId, const FString& guildName)
		:
		mPktWriter(buf, bufSize)

	{
		mPktWriter << static_cast<uint16>(PD::GC::GCPacketId::GC_GUILD_GROUP_CHAT_DELEGATE);
		mGuildNameOffset = (uint16*)mPktWriter.GetBuffer();
		*mGuildNameOffset = 0;
		mPktWriter << (*mGuildNameOffset);
		mPktWriter << roomId;
		mPktWriter << guildDBId;
		*mGuildNameOffset = (uint16)mPktWriter.GetPktSize();
		mPktWriter.WriteString(guildName);
	}

#endif // _SERVER
#ifdef _SERVER
	PKT_GC_GUILD_GROUP_CHAT_DELEGATE_WRITE(SendBufferHelper& sendBuffer, const GuildGroupChatRoomId& roomId, GuildDBId guildDBId, const wchar* guildName)
		:
		mPktWriter(sendBuffer->GetCharBuffer(), (SEND_BUFFER_SIZE - 1))

	{
		mPktWriter << (uint16)GC_GUILD_GROUP_CHAT_DELEGATE;
		mGuildNameOffset = (uint16*)mPktWriter.GetBuffer();
		*mGuildNameOffset = 0;
		mPktWriter << (*mGuildNameOffset);
		mPktWriter << roomId;
		mPktWriter << guildDBId;
		*mGuildNameOffset = (uint16)mPktWriter.GetPktSize();
		mPktWriter.WriteString(guildName);
	}
#endif

#ifdef _SERVER 
	void send(IocpObjectSession* session, SendBufferRef sendBuffer, bool autoCloseSendBuffer)
	{
		if (session) 
			session->Send(sendBuffer, mPktWriter.GetPktSize(), autoCloseSendBuffer);
	}
#endif

#ifdef _SERVER 
	std::xwstring GetLogWString() const
	{
		auto readPacket = reinterpret_cast<PKT_GC_GUILD_GROUP_CHAT_DELEGATE_READ*>(mPktWriter.mBuf);
		return readPacket->GetLogWString();
	}
#endif

#ifndef _SERVER
#else
#endif
}; // PKT_GC_GUILD_GROUP_CHAT_DELEGATE_WRITE

