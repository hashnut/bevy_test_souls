// type = GC
struct PKT_GC_CONTENTS_EVENT_ACTIVATED_LIST_READ
{
	struct ActivatedList
	{
	protected:
		uint16 mThisOffset;
		uint16 mNextOffset;
		ContentsEventType mContentsEventType;
		ContentsEventId mContentsEventId;

	public:
		ContentsEventType ContentsEventType() { return mContentsEventType; }
		ContentsEventId ContentsEventId() { return mContentsEventId; }

		friend PktIterator<ActivatedList>;
		friend PKT_GC_CONTENTS_EVENT_ACTIVATED_LIST_READ;

		bool Validate(uint16 offset, uchar * pktStart, uint16 pktSize, uint16& dataSize)
		{
			if (static_cast<size_t>(pktSize) < static_cast<size_t>(offset) + sizeof(ActivatedList))
				return false;

			ActivatedList * node = (ActivatedList*)(pktStart + offset);

			// ŔÚ±â ŔÚ˝ĹŔÇ Ć÷ŔÎĹÍ °ËÁő
			if (offset != node->mThisOffset)
				return false;

			// Value °ËÁő
			uchar* pktCurrentNodeStart = (uchar*)this - mThisOffset;
			uint16 pktCurrentNodeSize = *((uint16*)pktStart);
			dataSize += sizeof(ActivatedList);	// skip
			if (false == ValidateValue(pktCurrentNodeStart, pktCurrentNodeSize, dataSize))
				return false;

			return true;
		}

		bool ValidateValue(const uchar* pktStart, uint16 pktSize, uint16& dataSize)
		{
			return (nullptr != pktStart && 0 < pktSize && 0 < dataSize) ? true : false;
		}

	}; // ActivatedList

public:
	uint16 mPktSize;
	uint16 mPktId;
	uint16 mActivatedListCount;
	uint16 mFirstActivatedListOffset;

public:
#ifdef _SERVER 
	bool GetServerTaskIdRealTime(OUT [[maybe_unused]] int& serverTaskId) const { return false; }
	const wchar_t* GetPacketName() const { return L"GC_CONTENTS_EVENT_ACTIVATED_LIST"; }
	const wchar_t* GetRelatedPacketName() const { return L"CG_CONTENTS_EVENT_ACTIVATED_LIST"; }
#endif


	using ActivatedListIterator = PktIterator<ActivatedList>;
	const ActivatedListIterator GetLastActivatedListIterator() const
	{
		return ActivatedListIterator(0);
	}
	ActivatedListIterator GetFirstActivatedListIterator() const
	{
		if (mFirstActivatedListOffset && mPktSize >= mFirstActivatedListOffset + sizeof(ActivatedList))
		{
			ActivatedList* activatedList = (ActivatedList*)((uchar*)this + mFirstActivatedListOffset);
			if (mFirstActivatedListOffset == activatedList->mThisOffset)
				return ActivatedListIterator(activatedList);
			else
				return ActivatedListIterator(0);
		}
		else
			return ActivatedListIterator(0);
	}
	const int GetActivatedListCount()
	{
		return mActivatedListCount;
	}
#ifdef _SERVER
	template<typename TFunc>
	void ForEachActivatedList(TFunc&& func)
	{
		for (auto it = GetFirstActivatedListIterator(); it != GetLastActivatedListIterator(); ++it)
			func(it);
	}
#endif


#ifdef _SERVER 
	std::xwstring FuncCreateActivatedListStr( [[maybe_unused]] ActivatedListIterator& iter) const
	{
		return Log::format(
			L"ContentsEventType: {}, ContentsEventId: {}", 
			iter->ContentsEventType(), iter->ContentsEventId()
		).c_str();
	}

	std::xwstring GetLogWString() const
	{
		std::xwstring str1;
		str1.append(L"\n");
		for (ActivatedListIterator iter = this->GetFirstActivatedListIterator();
			iter != GetLastActivatedListIterator(); ++iter)
		{
			str1.append(L"[");
			str1.append(FuncCreateActivatedListStr(iter).c_str());

			str1.append(L"]\n");
		}

		return Log::format(
			L"[GC_CONTENTS_EVENT_ACTIVATED_LIST] ActivatedList : {}"
			, str1.c_str()
		).c_str();
	}
#endif

	bool Validate()
	{
		uchar* pktStart = (uchar*)this;
		uint16 pktSize = mPktSize;

		uint16 dataSize = sizeof(PKT_GC_CONTENTS_EVENT_ACTIVATED_LIST_READ);
		if (dataSize > mPktSize)
			return false;

		if (false == ValidateValue(pktStart, pktSize, dataSize))
			return false;

		if (false == ActivatedListValidateListNode(mFirstActivatedListOffset, pktStart, pktSize, dataSize))
			return false;

		if (dataSize != mPktSize)
			return false;

		return true;
	}

	bool ActivatedListValidateListNode(uint16 offset, uchar * pktStart, uint16 pktSize, uint16& dataSize)
	{		for (ActivatedListIterator iter = this->GetFirstActivatedListIterator();
			iter != GetLastActivatedListIterator(); ++iter)
		{
			if (false == (*iter).Validate(offset, pktStart, pktSize, dataSize))
			{
				return false;
			}
		}
		return true;
	}

	bool ValidateValue(const uchar* pktStart, uint16 pktSize, uint16& dataSize)
	{
		return (nullptr != pktStart && 0 < pktSize && 0 < dataSize) ? true : false;
	}

}; // PKT_GC_CONTENTS_EVENT_ACTIVATED_LIST_READ

