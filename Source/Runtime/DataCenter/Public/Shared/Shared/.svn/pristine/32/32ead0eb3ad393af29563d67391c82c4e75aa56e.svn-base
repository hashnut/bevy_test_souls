		mNowGuildChatList = newGuildChatList;
		mPktWriter.Skip(sizeof(GuildChatList));
		mNowGuildChatList->SetGuildNameOffset((uint16)mPktWriter.GetPktSize());
		mPktWriter.WriteString(guildName);
		mNowGuildChatList->SetUserNameOffset((uint16)mPktWriter.GetPktSize());
		mPktWriter.WriteString(userName);
		mNowGuildChatList->SetMessageOffset((uint16)mPktWriter.GetPktSize());
		mPktWriter.WriteString(message);
		mNowGuildChatList->SetHomeWorldPrefixOffset((uint16)mPktWriter.GetPktSize());
		mPktWriter.WriteString(homeWorldPrefix);
		return GuildChatListHandle(mPktWriter, newGuildChatList);
	}

