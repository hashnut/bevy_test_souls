////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
// String -> Enum
////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////

inline uint16 GCPacketIdStringToEnum(const wchar_t* str) noexcept
{
	if (_wcsicmp(L"GC_PONG", str) == 0)	return GC_PONG;
	if (_wcsicmp(L"GC_SERVER_PING", str) == 0)	return GC_SERVER_PING;
	if (_wcsicmp(L"GC_ACK_LOGIN", str) == 0)	return GC_ACK_LOGIN;
	if (_wcsicmp(L"GC_ACK_RECONNECT", str) == 0)	return GC_ACK_RECONNECT;
