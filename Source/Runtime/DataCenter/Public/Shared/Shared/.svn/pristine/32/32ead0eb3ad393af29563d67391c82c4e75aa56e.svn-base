// type = GC
// related packet = PKT_CG_REQ_BUDDY_LIST_WRITE
struct PKT_GC_ACK_BUDDY_LIST_READ
{
	struct BuddyList
	{
	protected:
		uint16 mThisOffset;
		uint16 mNextOffset;
		uint16 mUserNameOffset;
		UserDBId mUserDBId;
		time_t mLastLoginTime;

	public:
		UserDBId UserDBId() { return mUserDBId; }
		time_t LastLoginTime() { return mLastLoginTime; }

#ifdef _SERVER
		const wchar_t* UserName()
		{
			uchar* pktStart = (uchar*)this - mThisOffset;
			uint16 pktSize = *((uint16*)pktStart);
			if (mUserNameOffset && pktSize > mUserNameOffset)
				return (const wchar_t*)(pktStart + mUserNameOffset);
			else
				return L"";
		}
#else // _SERVER
		const FString UserName()
		{
			const wchar_t* strWchar = L"";
			uchar* pktStart = (uchar*)this - mThisOffset;
			uint16 pktSize = *((uint16*)pktStart);
			if (mUserNameOffset && pktSize > mUserNameOffset)
				strWchar = (const wchar_t*)(pktStart + mUserNameOffset);
			return PktWriter::ConvertToFString(strWchar);
		}
#endif // _SERVER
		friend PktIterator<BuddyList>;
		friend PKT_GC_ACK_BUDDY_LIST_READ;

		bool Validate(uint16 offset, uchar * pktStart, uint16 pktSize, uint16& dataSize)
		{
			if (static_cast<size_t>(pktSize) < static_cast<size_t>(offset) + sizeof(BuddyList))
				return false;

			BuddyList * node = (BuddyList*)(pktStart + offset);

			// ŔÚ±â ŔÚ˝ĹŔÇ Ć÷ŔÎĹÍ °ËÁő
			if (offset != node->mThisOffset)
				return false;

			// Value °ËÁő
			uchar* pktCurrentNodeStart = (uchar*)this - mThisOffset;
			uint16 pktCurrentNodeSize = *((uint16*)pktStart);
			dataSize += sizeof(BuddyList);	// skip
			if (false == ValidateValue(pktCurrentNodeStart, pktCurrentNodeSize, dataSize))
				return false;

			return true;
		}

		bool ValidateValue(const uchar* pktStart, uint16 pktSize, uint16& dataSize)
		{
			if (false == ValidateString(mUserNameOffset, 0, pktStart, pktSize, dataSize))
				return false;

			return (nullptr != pktStart && 0 < pktSize && 0 < dataSize) ? true : false;
		}

	}; // BuddyList

public:
	uint16 mPktSize;
	uint16 mPktId;
	uint16 mBuddyListCount;
	uint16 mFirstBuddyListOffset;
	bool mIsRedDot;

public:
#ifdef _SERVER 
	bool GetServerTaskIdRealTime(OUT [[maybe_unused]] int& serverTaskId) const { return false; }
	const wchar_t* GetPacketName() const { return L"GC_ACK_BUDDY_LIST"; }
	const wchar_t* GetRelatedPacketName() const { return L"CG_REQ_BUDDY_LIST"; }
#endif

	bool IsRedDot() { return mIsRedDot; }

	using BuddyListIterator = PktIterator<BuddyList>;
	const BuddyListIterator GetLastBuddyListIterator() const
	{
		return BuddyListIterator(0);
	}
	BuddyListIterator GetFirstBuddyListIterator() const
	{
		if (mFirstBuddyListOffset && mPktSize >= mFirstBuddyListOffset + sizeof(BuddyList))
		{
			BuddyList* buddyList = (BuddyList*)((uchar*)this + mFirstBuddyListOffset);
			if (mFirstBuddyListOffset == buddyList->mThisOffset)
				return BuddyListIterator(buddyList);
			else
				return BuddyListIterator(0);
		}
		else
			return BuddyListIterator(0);
	}
	const int GetBuddyListCount()
	{
		return mBuddyListCount;
	}
#ifdef _SERVER
	template<typename TFunc>
	void ForEachBuddyList(TFunc&& func)
	{
		for (auto it = GetFirstBuddyListIterator(); it != GetLastBuddyListIterator(); ++it)
			func(it);
	}
#endif


#ifdef _SERVER 
	std::xwstring FuncCreateBuddyListStr( [[maybe_unused]] BuddyListIterator& iter) const
	{
		return Log::format(
			L"UserDBId: {}, UserName: {}, LastLoginTime: {}", 
			iter->UserDBId(), iter->UserName(), iter->LastLoginTime()
		).c_str();
	}

	std::xwstring GetLogWString() const
	{
		std::xwstring str1;
		str1.append(L"\n");
		for (BuddyListIterator iter = this->GetFirstBuddyListIterator();
			iter != GetLastBuddyListIterator(); ++iter)
		{
			str1.append(L"[");
			str1.append(FuncCreateBuddyListStr(iter).c_str());

			str1.append(L"]\n");
		}

		return Log::format(
			L"[GC_ACK_BUDDY_LIST] IsRedDot: {}, BuddyList : {}"
			, mIsRedDot, str1.c_str()
		).c_str();
	}
#endif

	bool Validate()
	{
		uchar* pktStart = (uchar*)this;
		uint16 pktSize = mPktSize;

		uint16 dataSize = sizeof(PKT_GC_ACK_BUDDY_LIST_READ);
		if (dataSize > mPktSize)
			return false;

		if (false == ValidateValue(pktStart, pktSize, dataSize))
			return false;

		if (false == BuddyListValidateListNode(mFirstBuddyListOffset, pktStart, pktSize, dataSize))
			return false;

		if (dataSize != mPktSize)
			return false;

		return true;
	}

	bool BuddyListValidateListNode(uint16 offset, uchar * pktStart, uint16 pktSize, uint16& dataSize)
	{		for (BuddyListIterator iter = this->GetFirstBuddyListIterator();
			iter != GetLastBuddyListIterator(); ++iter)
		{
			if (false == (*iter).Validate(offset, pktStart, pktSize, dataSize))
			{
				return false;
			}
		}
		return true;
	}

	bool ValidateValue(const uchar* pktStart, uint16 pktSize, uint16& dataSize)
	{
		return (nullptr != pktStart && 0 < pktSize && 0 < dataSize) ? true : false;
	}

}; // PKT_GC_ACK_BUDDY_LIST_READ

