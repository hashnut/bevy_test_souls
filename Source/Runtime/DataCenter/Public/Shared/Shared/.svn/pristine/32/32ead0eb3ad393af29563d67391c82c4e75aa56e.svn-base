		if (bookMarkList && 0 < bookMarkList->Num())
		{
			int tvalsize = (int)sizeof(*(bookMarkList->begin())); 
			auto _bookMarkList = (T0*)bookMarkList;
			for (auto it = _bookMarkList->begin(); it != _bookMarkList->end(); ++it) 
			{
				mPktWriter.WriteBinary((uint16)tvalsize, (uchar*)&(*it)); 
			}
			*mBookMarkListSize = (uint16)(tvalsize* bookMarkList->Num());
		}
