	PartyMemberInfoListHandle CreatePartyMemberInfoList(int slotIndex, int64 gameId, const FString& name, MapId mapId, ChannelId channelId, const FVector& pos, CreatureWeaponType weaponType, Level level, StatValue hp, StatValue hpShield, StatValue maxHp, StatValue mp, StatValue maxMp, bool isReady, WorldId memberWorldId, WorldId memberHomeWorldId)
	{
