#ifndef _SERVER
	RecentChatListHandle CreateRecentChatList(const GuildGroupChatRoomId& roomId, const GuildGroupChatDBId& groupChatDBId, GuildDBId guildId, GuildEmblemId guildEmblemId, const FString& roomName, const FString& userName, const FString& message, time_t messageTime)
	{
		uchar* nowBuffer = mPktWriter.GetBuffer();
		uint16 nowWritten = (uint16)mPktWriter.GetPktSize();
		RecentChatList* newRecentChatList = new ((RecentChatList*)nowBuffer) RecentChatList(nowWritten, roomId, groupChatDBId, guildId, guildEmblemId, messageTime);
		++(*mRecentChatListCount);
		if (mNowRecentChatList == 0)
			*mFirstRecentChatListOffset = nowWritten;
		else
			mNowRecentChatList->mNextOffset = nowWritten;
		mNowRecentChatList = newRecentChatList;
		mPktWriter.Skip(sizeof(RecentChatList));
		mNowRecentChatList->SetRoomNameOffset((uint16)mPktWriter.GetPktSize());
		mPktWriter.WriteString(roomName);
		mNowRecentChatList->SetUserNameOffset((uint16)mPktWriter.GetPktSize());
		mPktWriter.WriteString(userName);
		mNowRecentChatList->SetMessageOffset((uint16)mPktWriter.GetPktSize());
		mPktWriter.WriteString(message);
		return RecentChatListHandle(mPktWriter, newRecentChatList);
	}

#else
