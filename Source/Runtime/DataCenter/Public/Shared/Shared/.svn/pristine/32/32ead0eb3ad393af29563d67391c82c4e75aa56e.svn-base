struct PKT_GC_ACK_BUDDY_RECV_INVITATION_LIST_READ
{
	struct RecvInvitationList
	{
	protected:
		uint16 mThisOffset;
		uint16 mNextOffset;
		uint16 mUserNameOffset;
		UserDBId mUserDBId;

	public:
		UserDBId UserDBId() { return mUserDBId; }

#ifdef _SERVER
		const wchar_t* UserName()
		{
			uchar* pktStart = (uchar*)this - mThisOffset;
			uint16 pktSize = *((uint16*)pktStart);
			if (mUserNameOffset && pktSize > mUserNameOffset)
				return (const wchar_t*)(pktStart + mUserNameOffset);
			else
				return L"";
		}
#else // _SERVER
		const FString UserName()
		{
			const wchar_t* strWchar = L"";
			uchar* pktStart = (uchar*)this - mThisOffset;
			uint16 pktSize = *((uint16*)pktStart);
			if (mUserNameOffset && pktSize > mUserNameOffset)
				strWchar = (const wchar_t*)(pktStart + mUserNameOffset);
			return PktWriter::ConvertToFString(strWchar);
		}
#endif // _SERVER
		friend PktIterator<RecvInvitationList>;
		friend PKT_GC_ACK_BUDDY_RECV_INVITATION_LIST_READ;

		bool Validate(uint16 offset, uchar * pktStart, uint16 pktSize, uint16& dataSize)
		{
			if (static_cast<size_t>(pktSize) < static_cast<size_t>(offset) + sizeof(RecvInvitationList))
				return false;

			RecvInvitationList * node = (RecvInvitationList*)(pktStart + offset);

			// ŔÚ±â ŔÚ˝ĹŔÇ Ć÷ŔÎĹÍ °ËÁő
			if (offset != node->mThisOffset)
				return false;

			// Value °ËÁő
			uchar* pktCurrentNodeStart = (uchar*)this - mThisOffset;
			uint16 pktCurrentNodeSize = *((uint16*)pktStart);
			dataSize += sizeof(RecvInvitationList);	// skip
			if (false == ValidateValue(pktCurrentNodeStart, pktCurrentNodeSize, dataSize))
				return false;

			return true;
		}

		bool ValidateValue(const uchar* pktStart, uint16 pktSize, uint16& dataSize)
		{
			if (false == ValidateString(mUserNameOffset, 0, pktStart, pktSize, dataSize))
				return false;

			return (nullptr != pktStart && 0 < pktSize && 0 < dataSize) ? true : false;
		}

	}; // RecvInvitationList

public:
	uint16 mPktSize;
	uint16 mPktId;
	uint16 mRecvInvitationListCount;
	uint16 mFirstRecvInvitationListOffset;
	bool mIsRedDot;

public:
#ifdef _SERVER 
	bool GetServerTaskIdRealTime(OUT [[maybe_unused]] int& serverTaskId) const { return false; }
	const wchar_t* GetPacketName() const { return L"GC_ACK_BUDDY_RECV_INVITATION_LIST"; }
	const wchar_t* GetRelatedPacketName() const { return L"CG_REQ_BUDDY_RECV_INVITATION_LIST"; }
#endif

	bool IsRedDot() { return mIsRedDot; }

	using RecvInvitationListIterator = PktIterator<RecvInvitationList>;
	const RecvInvitationListIterator GetLastRecvInvitationListIterator() const
	{
		return RecvInvitationListIterator(0);
	}
	RecvInvitationListIterator GetFirstRecvInvitationListIterator() const
	{
		if (mFirstRecvInvitationListOffset && mPktSize >= mFirstRecvInvitationListOffset + sizeof(RecvInvitationList))
		{
			RecvInvitationList* recvInvitationList = (RecvInvitationList*)((uchar*)this + mFirstRecvInvitationListOffset);
			if (mFirstRecvInvitationListOffset == recvInvitationList->mThisOffset)
				return RecvInvitationListIterator(recvInvitationList);
			else
				return RecvInvitationListIterator(0);
		}
		else
			return RecvInvitationListIterator(0);
	}
	const int GetRecvInvitationListCount()
	{
		return mRecvInvitationListCount;
	}
#ifdef _SERVER
	template<typename TFunc>
	void ForEachRecvInvitationList(TFunc&& func)
	{
		for (auto it = GetFirstRecvInvitationListIterator(); it != GetLastRecvInvitationListIterator(); ++it)
			func(it);
	}
#endif


#ifdef _SERVER 
	std::xwstring FuncCreateRecvInvitationListStr( [[maybe_unused]] RecvInvitationListIterator& iter) const
	{
		return Log::format(
			L"UserDBId: {}, UserName: {}", 
			iter->UserDBId(), iter->UserName()
		).c_str();
	}

	std::xwstring GetLogWString() const
	{
		std::xwstring str1;
		str1.append(L"\n");
		for (RecvInvitationListIterator iter = this->GetFirstRecvInvitationListIterator();
			iter != GetLastRecvInvitationListIterator(); ++iter)
		{
			str1.append(L"[");
			str1.append(FuncCreateRecvInvitationListStr(iter).c_str());

			str1.append(L"]\n");
		}

		return Log::format(
			L"[GC_ACK_BUDDY_RECV_INVITATION_LIST] IsRedDot: {}, RecvInvitationList : {}"
			, mIsRedDot, str1.c_str()
		).c_str();
	}
#endif

	bool Validate()
	{
		uchar* pktStart = (uchar*)this;
		uint16 pktSize = mPktSize;

		uint16 dataSize = sizeof(PKT_GC_ACK_BUDDY_RECV_INVITATION_LIST_READ);
		if (dataSize > mPktSize)
			return false;

		if (false == ValidateValue(pktStart, pktSize, dataSize))
			return false;

		if (false == RecvInvitationListValidateListNode(mFirstRecvInvitationListOffset, pktStart, pktSize, dataSize))
			return false;

		if (dataSize != mPktSize)
			return false;

		return true;
	}

	bool RecvInvitationListValidateListNode(uint16 offset, uchar * pktStart, uint16 pktSize, uint16& dataSize)
	{		for (RecvInvitationListIterator iter = this->GetFirstRecvInvitationListIterator();
			iter != GetLastRecvInvitationListIterator(); ++iter)
		{
			if (false == (*iter).Validate(offset, pktStart, pktSize, dataSize))
			{
				return false;
			}
		}
		return true;
	}

	bool ValidateValue(const uchar* pktStart, uint16 pktSize, uint16& dataSize)
	{
		return (nullptr != pktStart && 0 < pktSize && 0 < dataSize) ? true : false;
	}

}; // PKT_GC_ACK_BUDDY_RECV_INVITATION_LIST_READ

