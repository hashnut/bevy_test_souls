#ifndef _SERVER
	PKT_GC_GUILD_GROUP_CHAT_LIST_RECENT_WRITE(uchar* buf, int bufSize)
		:
		mPktWriter(buf, bufSize)
		, mNowRecentChatList(0)
	{
		mPktWriter << static_cast<uint16>(PD::GC::GCPacketId::GC_GUILD_GROUP_CHAT_LIST_RECENT);
		mRecentChatListCount = (uint16*)mPktWriter.GetBuffer();
		*mRecentChatListCount = 0;
		mPktWriter << (*mRecentChatListCount);
		mFirstRecentChatListOffset = (uint16*)mPktWriter.GetBuffer();
		*mFirstRecentChatListOffset = 0;
		mPktWriter << (*mFirstRecentChatListOffset);
	}

#endif // _SERVER
#ifdef _SERVER
	PKT_GC_GUILD_GROUP_CHAT_LIST_RECENT_WRITE(SendBufferHelper& sendBuffer)
		:
		mPktWriter(sendBuffer->GetCharBuffer(), (SEND_BUFFER_SIZE - 1))
		, mNowRecentChatList(0)
	{
		mPktWriter << (uint16)GC_GUILD_GROUP_CHAT_LIST_RECENT;
		mRecentChatListCount = (uint16*)mPktWriter.GetBuffer();
		*mRecentChatListCount = 0;
		mPktWriter << (*mRecentChatListCount);
		mFirstRecentChatListOffset = (uint16*)mPktWriter.GetBuffer();
		*mFirstRecentChatListOffset = 0;
		mPktWriter << (*mFirstRecentChatListOffset);
	}
