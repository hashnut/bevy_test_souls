	bool MemberListValidateListNode(uint16 offset, uchar * pktStart, uint16 pktSize, uint16& dataSize)
	{		for (MemberListIterator iter = this->GetFirstMemberListIterator();
			iter != GetLastMemberListIterator(); ++iter)
